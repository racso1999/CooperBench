+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very loose threshold should be satisfied with far fewer colors
+    # than the requested maximum.
+    loose = image.quantize(colors=256, error_threshold=1000)
+    assert_image(loose, "P", loose.size)
+    assert len(loose.getcolors()) < 256
+
+    # A very strict threshold cannot be met, so the requested maximum
+    # number of colors should be used instead.
+    strict = image.quantize(colors=32, error_threshold=0.0001)
+    assert_image(strict, "P", strict.size)
+    assert len(strict.getcolors()) == 32
+
+    # Without error_threshold, behavior should be unaffected.
+    default = image.quantize(colors=32)
+    assert_image(default, "P", default.size)
+    assert len(default.getcolors()) == 32
+
