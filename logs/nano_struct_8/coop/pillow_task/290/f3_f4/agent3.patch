@@ -85,3 +85,59 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="bogus")
+
+
+@pytest.mark.parametrize("sort_palette", ("luminance", "rgb"))
+def test_sort_palette(sort_palette):
+    image = hopper()
+    unsorted = image.quantize(100, Image.FASTOCTREE)
+    sorted_im = image.quantize(100, Image.FASTOCTREE, sort_palette=sort_palette)
+
+    assert_image(sorted_im, "P", sorted_im.size)
+    # Sorting the palette shouldn't change the decoded image.
+    assert_image_similar(sorted_im.convert("RGB"), unsorted.convert("RGB"), 0)
+    assert len(sorted_im.getcolors()) == len(unsorted.getcolors())
+
+    used = [color for count, color in sorted_im.getcolors()]
+    palette = sorted_im.getpalette()
+    used_colors = [
+        tuple(palette[i * 3 : i * 3 + 3]) for count, i in sorted_im.getcolors()
+    ]
+    if sort_palette == "luminance":
+        keys = [r * 299 + g * 587 + b * 114 for r, g, b in used_colors]
+    else:
+        keys = used_colors
+    assert keys == sorted(keys)
+
+
+def test_sort_palette_with_reference_palette():
+    image = hopper()
+    palette_im = image.quantize(32, Image.FASTOCTREE)
+
+    converted = image.quantize(palette=palette_im, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(
+        converted.convert("RGB"),
+        image.quantize(palette=palette_im).convert("RGB"),
+        0,
+    )
+
+
+def test_sort_palette_rgba():
+    im = Image.new("RGBA", (2, 2))
+    px = im.load()
+    px[0, 0] = (255, 0, 0, 255)
+    px[1, 0] = (0, 255, 0, 128)
+    px[0, 1] = (0, 0, 255, 0)
+    px[1, 1] = (10, 10, 10, 64)
+
+    converted = im.quantize(sort_palette="luminance")
+    assert_image_similar(
+        converted.convert("RGBA"), im.quantize().convert("RGBA"), 0
+    )
