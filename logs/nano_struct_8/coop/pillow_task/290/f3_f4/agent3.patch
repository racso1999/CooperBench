+
+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping pixel indexes so that the
+        displayed colors are unchanged.
+
+        :param sort_palette: ``"luminance"`` to sort colors from darkest to
+           lightest, or ``"rgb"`` to sort colors by their (red, green, blue)
+           values.
+        :returns: A new :py:class:`~PIL.Image.Image` object.
+        """
+        if sort_palette not in ("luminance", "rgb"):
+            raise ValueError("sort_palette must be 'luminance' or 'rgb'")
+
+        self.load()
+
+        mode = self.im.getpalettemode()
+        mode_len = len(mode)
+        palette = self.im.getpalette(mode, mode)
+        num_colors = len(palette) // mode_len
+        colors = [
+            tuple(palette[i * mode_len : (i + 1) * mode_len])
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "luminance":
+
+            def sort_key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        else:
+
+            def sort_key(color):
+                return color[:3]
+
+        # Only the palette entries actually used by a pixel are meaningful;
+        # the rest are unused filler left over from quantization. Sort the
+        # used entries and leave the filler ones in their original order,
+        # appended at the end, so that used colors are grouped predictably
+        # at the start of the palette.
+        histogram = self.histogram()[:num_colors]
+        used = [i for i in range(num_colors) if histogram[i]]
+        unused = [i for i in range(num_colors) if not histogram[i]]
+        order = sorted(used, key=lambda i: sort_key(colors[i])) + unused
+
+        new_positions = [0] * num_colors
+        new_palette = bytearray()
+        new_alpha = bytearray() if "A" in mode else None
+        for new_index, old_index in enumerate(order):
+            new_positions[old_index] = new_index
+            color = colors[old_index]
+            new_palette += bytes(color[:3])
+            if new_alpha is not None:
+                new_alpha.append(color[3])
+
+        lut = list(range(256))
+        for old_index in range(num_colors):
+            lut[old_index] = new_positions[old_index]
+
+        im = self.point(lut)
+        im.im.putpalette("RGB", bytes(new_palette))
+        if new_alpha is not None:
+            im.im.putpalettealphas(bytes(new_alpha))
+
+        from . import ImagePalette
+
+        new_mode = im.im.getpalettemode()
+        im.palette = ImagePalette.ImagePalette(
+            new_mode, im.im.getpalette(new_mode, new_mode)
+        )
+
         return im
 
     def copy(self):
