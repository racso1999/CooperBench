+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Compute this option's value from its dynamic ``default``
+        mapping, based on the current values of the option(s) it
+        depends on.
+
+        Returns ``None`` if no mapping matches the current values.
+        """
