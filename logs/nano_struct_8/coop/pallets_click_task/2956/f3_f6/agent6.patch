+            source_param = None
+
+            for param in ctx.command.get_params(ctx):
+                if opt_name in param.opts or opt_name in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+            key = str(source_value)
+
+            if key in mapping:
+                result = mapping[key]
+
+        return result
+
