+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or base64-encoded image bytes.
+
+    Detects whether ``image`` is already base64-encoded to avoid double
+    encoding it, and returns a tuple ``(encoded_image, decoded_for_guessing)``
+    where ``encoded_image`` is the base64-encoded representation to store and
+    ``decoded_for_guessing`` is the raw bytes suitable for MIME type guessing.
+    """
+    try:
+        decoded = base64.b64decode(image, validate=True)
+        if base64.b64encode(decoded) == image:
+            return image, decoded
+    except Exception:
+        pass
+
+    return base64.b64encode(image), image
+
