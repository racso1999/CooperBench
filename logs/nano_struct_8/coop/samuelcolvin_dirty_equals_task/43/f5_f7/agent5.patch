+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally checking country-specific formatting.
+    """
+
+    _clean_re = re.compile(r'[\s\-.()]')
+
+    # national and international patterns for countries with dedicated support
+    _country_patterns = {
+        'US': {
+            'national': re.compile(r'^\d{10}$'),
+            'international': re.compile(r'^\+1\d{10}$'),
+        },
+        'GB': {
+            'national': re.compile(r'^0\d{9,10}$'),
+            'international': re.compile(r'^\+44\d{9,10}$'),
+        },
+    }
+
+    # generic patterns used when no country is given, or a country outside `_country_patterns` is given
+    _generic_international = re.compile(r'^\+\d{7,15}$')
+    _generic_national = re.compile(r'^\d{7,15}$')
+
+    def __init__(self, country_code: Optional[str] = None):
+        """
+        Args:
+            country_code: optional ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) used to apply
+                country-specific formatting rules. If omitted, generic phone number validation is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+        assert 123 != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+
+        assert '+33 1 23 45 67 89' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country_code = country_code
+        super().__init__(country_code if country_code is not None else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._clean_re.sub('', other)
+        if not cleaned:
+            return False
+
+        if self.country_code is None:
+            return bool(self._generic_international.fullmatch(cleaned) or self._generic_national.fullmatch(cleaned))
+
+        patterns = self._country_patterns.get(self.country_code.upper())
+        if patterns is not None:
+            return bool(
+                patterns['national'].fullmatch(cleaned) or patterns['international'].fullmatch(cleaned)
+            )
+        else:
+            return bool(self._generic_international.fullmatch(cleaned))
