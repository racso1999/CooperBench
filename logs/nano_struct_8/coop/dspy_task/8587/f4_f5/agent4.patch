+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has stalled and, if so, force it to a terminal state.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` is set and that many
+        seconds have elapsed since the last chunk was received while the stream had started but not yet ended,
+        this emits a final `StreamResponse` with an empty `chunk` to signal termination. The listener state is
+        then reset unconditionally, regardless of `allow_reuse`, so it's never left stuck in a started state.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
