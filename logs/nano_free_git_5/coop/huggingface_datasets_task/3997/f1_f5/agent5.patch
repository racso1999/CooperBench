+def _deep_merge_dicts(current: dict, new: dict) -> None:
+    """Recursively merge ``new`` into ``current`` in place.
+
+    For keys present in both, if both values are dictionaries (or ``Sequence`` objects
+    wrapping a dictionary feature), they are merged recursively instead of being overwritten.
+    """
+    for key, value in new.items():
+        if key in current:
+            current_value = current[key]
+            current_dict = current_value.feature if isinstance(current_value, Sequence) else current_value
+            new_dict = value.feature if isinstance(value, Sequence) else value
+            if isinstance(current_dict, dict) and isinstance(new_dict, dict):
+                _deep_merge_dicts(current_dict, new_dict)
+                continue
+        current[key] = value
+
+
+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the `Features` class synced with the
+    main dictionary.
+
+    A decorator is used instead of a `UserDict` subclass to avoid a performance penalty on `Features` instantiation
+    and to avoid breaking `isinstance(features, dict)` checks elsewhere in the code base.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        if args:
+            self: "Features" = args[0]
+            args = args[1:]
+        else:
+            self: "Features" = kwargs.pop("self")
+        out = func(self, *args, **kwargs)
+        assert hasattr(self, "_column_requires_decoding")
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper.__name__ = func.__name__
+    return wrapper
+
