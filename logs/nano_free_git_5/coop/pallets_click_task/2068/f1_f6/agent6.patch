+# Mapping of the public priority names to Unix "nice" increments. Lower
+# nice values mean higher scheduling priority.
+_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+# Mapping of the public priority names to Windows priority classes. The
+# numeric values match the ``*_PRIORITY_CLASS`` constants from the Win32
+# API so they can be used even on non-Windows platforms without importing
+# the ``subprocess`` module's Windows-only attributes.
+_WIN_PRIORITY_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
