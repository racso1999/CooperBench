+def _resolve_dynamic_defaults(
+    ctx: Context, params: cabc.Iterable[Parameter]
+) -> None:
+    """Second-pass resolution for options whose default is a dynamic
+    mapping keyed by other options' values. This runs after every
+    parameter has been parsed, so it has access to the final value of
+    any option it depends on regardless of declaration order.
+    """
+    params = list(params)
+
+    for param in params:
+        dynamic_default = getattr(param, "_dynamic_default", None)
+
+        if dynamic_default is None:
+            continue
+
+        if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+            continue
+
+        resolved = None
+
+        for opt, mapping in dynamic_default.items():
+            source_param = _find_param_by_opt(params, opt)
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        if resolved is None:
+            continue
+
+        value = param.type_cast_value(ctx, resolved)
+
+        if param.callback is not None:
+            value = param.callback(ctx, param, value)
+
+        if param.expose_value:
+            ctx.params[param.name] = value  # type: ignore[assignment]
+
