+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+
+        # No existing file, so no backup should be created
+        im.save(out, backup=True)
+        assert not (tmp_path / "temp.png.bak").exists()
+
+        modified = hopper().rotate(45)
+        modified.save(out, backup=True)
+        assert (tmp_path / "temp.png.bak").exists()
+        with Image.open(out) as reloaded:
+            assert_image_equal(modified, reloaded)
+        with Image.open(tmp_path / "temp.png.bak") as backup:
+            assert_image_equal(im, backup)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        modified = hopper().rotate(45)
+        modified.save(out, backup=True, backup_suffix=".backup")
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_no_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        modified = hopper().rotate(45)
+        modified.save(out)
+        assert not (tmp_path / "temp.png.bak").exists()
+
