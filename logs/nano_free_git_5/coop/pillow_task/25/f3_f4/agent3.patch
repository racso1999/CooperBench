+
+    def test_dry_run_fp(self) -> None:
+        fp = io.BytesIO()
+        im = hopper()
+        im.save(fp, "PNG", dry_run=True)
+        assert fp.tell() == 0
+
+    def test_dry_run_raises(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.jpg"
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(out, dry_run=True)
+        assert not out.exists()
+
