+    def _sort_palette_colors(self, sort_palette):
+        """
+        Reorders the palette indexes that are actually used by this image,
+        e.g. to improve compression, or to give consistent results between
+        similarly quantized images.
+
+        :param sort_palette: ``"brightness"``, to sort colors by perceived
+           brightness, or ``"rgb"``, to sort colors by their raw RGB value.
+        :returns: A new image, with palette indexes reassigned in sorted
+           order.
+        """
+        if sort_palette not in ("brightness", "rgb"):
+            msg = "sort_palette must be 'brightness' or 'rgb'"
+            raise ValueError(msg)
+
+        channels = len(self.palette.mode)
+        palette = self.palette.palette
+
+        def color(i):
+            return tuple(palette[i * channels : i * channels + channels])
+
+        if sort_palette == "brightness":
+
+            def key(i):
+                r, g, b = color(i)[:3]
+                return r * 299 + g * 587 + b * 114
+
+        else:
+            key = color
+
+        used_palette_colors = [i for i, count in enumerate(self.histogram()) if count]
+        used_palette_colors.sort(key=key)
+
+        return self.remap_palette(used_palette_colors)
+
+    def _quantize_mse(self, quantized_im):
+        """
+        Computes the mean square error, averaged across bands, between this
+        image and a quantized version of it, used by ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(self.convert("RGB"), quantized_im.convert("RGB"))
+        stat = ImageStat.Stat(diff)
+        return sum(rms ** 2 for rms in stat.rms) / len(stat.rms)
+
+    def _find_quantize_colors_for_error_threshold(
+        self, colors, method, kmeans, error_threshold
+    ):
+        """
+        Finds the fewest number of colors, up to ``colors``, needed to
+        quantize this image with a mean square error at or below
+        ``error_threshold``. Falls back to ``colors`` if the threshold
+        cannot be met.
+        """
+
+        def error_at(n):
+            im = self._new(self.im.quantize(n, method, kmeans))
+            return self._quantize_mse(im)
+
+        if error_at(colors) > error_threshold:
+            return colors
+
+        lo, hi = 1, colors
+        while lo < hi:
+            mid = (lo + hi) // 2
+            if error_at(mid) <= error_threshold:
+                hi = mid
+            else:
+                lo = mid + 1
+        return lo
+
