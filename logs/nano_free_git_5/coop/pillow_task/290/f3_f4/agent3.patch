+def test_error_threshold_high_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=10000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_low_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=32, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 32
+
+
+def test_error_threshold_meets_quality():
+    image = hopper()
+    error_threshold = 500
+    converted = image.quantize(colors=256, error_threshold=error_threshold)
+    assert converted._quantize_mse(converted) == 0
+
+    mse = image._quantize_mse(converted)
+    assert mse <= error_threshold or len(converted.getcolors()) == 256
+
+
+def test_error_threshold_negative():
+    image = hopper()
+    with pytest.raises(ValueError):
