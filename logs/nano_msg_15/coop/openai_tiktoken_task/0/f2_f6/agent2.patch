+    def _encode_with_positions_inner(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        if allowed_special:
+            special_pattern = _special_token_regex(frozenset(allowed_special))
+            last_end = 0
