+def _strip_all_metadata(image: Image.Image) -> None:
+    exif = image.getexif()
+    for tag in list(exif.keys()):
+        del exif[tag]
+    for key in (
+        "exif",
+        "Raw profile type exif",
+        "icc_profile",
+        "xmp",
+        "XML:com.adobe.xmp",
+        "comment",
+    ):
+        if key in image.info:
+            del image.info[key]
