+
+    def _mean_squared_error(self, other):
+        from . import ImageChops, ImageStat
+
+        reference = self.convert("RGB")
+        comparison = other.convert("RGB")
+        diff = ImageChops.difference(reference, comparison)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        # Start from the maximum allowed number of colors. If even that
+        # doesn't satisfy the threshold, it is the best we can do.
+        best_im = self._quantize_to_colors(colors, method, kmeans)
+        if self._mean_squared_error(best_im) > error_threshold:
+            return best_im
+
+        # Binary search for the smallest number of colors whose error is
+        # still within the given threshold, assuming that using more colors
+        # monotonically decreases (or at least does not increase) the error.
+        low, high = 2, colors
+        while low < high:
+            mid = (low + high) // 2
+            candidate = self._quantize_to_colors(mid, method, kmeans)
+            if self._mean_squared_error(candidate) <= error_threshold:
+                best_im = candidate
+                high = mid
+            else:
+                low = mid + 1
+
+        return best_im
+
