--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,34 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should allow fewer colors than the maximum.
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    mse = image._mean_squared_error(converted.convert("RGB"))
+    assert mse <= 100 or len(converted.getcolors()) == 256
+
+
+def test_quantize_error_threshold_unreachable():
+    image = hopper()
+
+    # An impossibly strict threshold should fall back to using
+    # the maximum number of colors requested.
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_lenient():
+    image = hopper()
+
+    # A very lenient threshold should be satisfied with very few colors.
+    converted = image.quantize(colors=256, error_threshold=100000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
