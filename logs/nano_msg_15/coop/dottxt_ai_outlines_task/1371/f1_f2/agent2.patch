@@ -11,6 +11,39 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to make it globally available in prompt templates.
+
+    Once registered, the filter is automatically available in every prompt
+    template rendered with `Prompt`, without needing to be passed explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be accessible in templates
+        (e.g. `{{ text | name }}`).
+    func
+        The callable implementing the filter.
+
+    """
+    FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove. Does nothing if no filter is
+        registered under that name.
+
+    """
+    FILTERS.pop(name, None)
+
 
