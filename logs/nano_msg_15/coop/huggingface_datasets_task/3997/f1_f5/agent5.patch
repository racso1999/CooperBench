@@ -1245,15 +1245,33 @@ class Features(dict):
         super().__delitem__(column_name)
         del self._column_requires_decoding[column_name]
 
+    def _update_key(self, key, value):
+        """Set ``self[key]`` to ``value``, deep-merging with the existing value if both are dict-like.
+
+        A value is considered dict-like if it's a :obj:`dict` (which includes :class:`Features`) or a
+        :class:`Sequence` whose ``feature`` is itself a :obj:`dict`.
+        """
+        if key in self:
+            current_value = self[key]
+            current_dict = (
+                current_value if isinstance(current_value, dict) else getattr(current_value, "feature", None)
+            )
+            new_dict = value if isinstance(value, dict) else getattr(value, "feature", None)
+            if isinstance(current_dict, dict) and isinstance(new_dict, dict):
+                current_dict.update(new_dict)
+                self[key] = current_value
+                return
+        self[key] = value
+
     def update(self, iterable, **kwds):
         if hasattr(iterable, "keys"):
             for key in iterable.keys():
-                self[key] = iterable[key]
+                self._update_key(key, iterable[key])
         else:
             for key, value in iterable:
-                self[key] = value
-        for key in kwds:
-            self[key] = kwds[key]
+                self._update_key(key, value)
+        for key, value in kwds.items():
+            self._update_key(key, value)
 
     def __reduce__(self):
         return Features, (dict(self),)
