+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and, if so, end it.
+
+        This should be called periodically (e.g. by the streaming system on a timer) so that an upstream
+        stall doesn't leave the consumer waiting forever. If `idle_timeout_s` is set and has elapsed since
+        the last chunk was received, and the stream has started but hasn't ended yet, this emits a final
+        `StreamResponse` with an empty `chunk` and resets the listener state so it's no longer marked as
+        started, regardless of `allow_reuse`.
+
+        Args:
+            now_ts: The current timestamp to compare against. Defaults to `time.time()`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset state unconditionally (even if `allow_reuse` is False) so the listener isn't left stuck
+        # in a started state after a timeout.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
