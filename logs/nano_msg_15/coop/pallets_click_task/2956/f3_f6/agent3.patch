+def _batch(
+    values: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Split ``values`` into consecutive tuples of at most ``batch_size``
+    items each. The final tuple may be shorter if the number of values
+    isn't evenly divisible by ``batch_size``.
+    """
+    it = iter(values)
+
+    while batch := tuple(itertools.islice(it, batch_size)):
+        yield batch
+
