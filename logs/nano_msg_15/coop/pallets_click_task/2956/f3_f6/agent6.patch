+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve this option's dynamic default (a mapping of other
+        option names to value lookup tables) using the already-resolved
+        values of the referenced options on ``ctx``.
+
+        Returns ``None`` if no mapping matches the current values of the
+        referenced options. If more than one referenced option matches,
+        later entries in the mapping take precedence.
+        """
+        assert self._dynamic_default is not None
+        value = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source = next(
+                (
+                    param
+                    for param in ctx.command.get_params(ctx)
+                    if opt_name in param.opts or opt_name in param.secondary_opts
+                ),
+                None,
+            )
+
+            if source is None or source.name is None:
+                continue
+
+            key = str(ctx.params.get(source.name))
+
+            if key in mapping:
+                value = mapping[key]
+
+        return value
+
