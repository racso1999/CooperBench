+    def get_image_mimetype(self) -> str | None:
+        """Lazily resolve and cache the image mimetype.
+
+        If the mimetype hasn't been set yet, guess it from the raw image
+        bytes using the filetype library and cache the result on
+        `image_mimetype` so subsequent calls avoid redundant guessing.
