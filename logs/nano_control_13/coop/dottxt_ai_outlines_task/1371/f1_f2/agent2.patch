+#: Registry of globally available Jinja2 filters. Filters registered here
+#: via :func:`register_filter` are automatically made available to every
+#: prompt template.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is automatically available in every prompt
+    template without needing to be passed explicitly, e.g. after calling
+    ``register_filter("capitalize", str.upper)`` templates can use
+    ``{{ text | capitalize }}``.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered global filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
