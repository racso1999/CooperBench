+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and terminate it if so.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` has elapsed since
+        the last chunk was received for a field that has started but not yet ended, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination, and resets the listener state so it
+        doesn't get stuck in a started state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = time.monotonic() if now_ts is None else now_ts
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the state unconditionally, regardless of `allow_reuse`, so the listener doesn't get stuck
+        # in a started state after a timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
