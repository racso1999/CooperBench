     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_loose_uses_fewer_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+    assert image._quantize_mse(converted.convert("RGB")) <= 1000
+
+
+def test_quantize_error_threshold_strict_uses_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=32, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 32
+
+
+def test_quantize_error_threshold_unreachable_matches_default():
+    image = hopper()
+
+    # An error threshold of 0 can't be met by a lossy palette, so this
+    # should fall back to using the full number of requested colors,
+    # matching the behavior without an error threshold.
+    with_threshold = image.quantize(colors=64, error_threshold=0)
+    without_threshold = image.quantize(colors=64)
+    assert with_threshold.tobytes() == without_threshold.tobytes()
