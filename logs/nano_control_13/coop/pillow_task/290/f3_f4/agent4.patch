+    def _quantize_mse(self, quantized):
+        # Mean squared error between this image and a quantized version of it.
+        from . import ImageChops, ImageStat
+
+        comparable_mode = self.mode if self.mode in ("RGB", "L") else "RGB"
+        original = self.convert(comparable_mode)
+        candidate = quantized.convert(comparable_mode)
+
+        diff = ImageChops.difference(original, candidate)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        def quantize_with(n):
+            return self._new(self.im.quantize(n, method, kmeans))
+
+        if colors < 2:
+            return quantize_with(colors)
+
+        # If even the maximum allowed number of colors doesn't reach the
+        # error threshold, fall back to using that maximum.
+        best = quantize_with(colors)
+        if self._quantize_mse(best) > error_threshold:
+            return best
+
+        # Binary search for the smallest number of colors, no more than
+        # ``colors``, that still satisfies the error threshold. This assumes
+        # that error decreases as the number of colors increases.
+        low, high = 2, colors
+        low_im = quantize_with(low)
+        if self._quantize_mse(low_im) <= error_threshold:
+            return low_im
+
+        while low + 1 < high:
+            mid = (low + high) // 2
+            mid_im = quantize_with(mid)
+            if self._quantize_mse(mid_im) <= error_threshold:
+                high = mid
+                best = mid_im
+            else:
+                low = mid
+
+        return best
+
