+    def _sort_palette(self, sort_palette):
+        # Reorders a "P" or "PA" image's palette, remapping pixel data to match.
+        if sort_palette == "luminance":
+
+            def sort_key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color[:3]
+
+        else:
+            raise ValueError("sort_palette must be 'luminance', 'rgb' or None")
+
+        mode_len = len(self.palette.mode)
+        palette_bytes = self.palette.palette
+        colors = [
+            tuple(palette_bytes[i : i + mode_len])
+            for i in range(0, len(palette_bytes), mode_len)
+        ]
+
+        order = sorted(range(len(colors)), key=lambda i: sort_key(colors[i]))
+        mapping = [0] * 256
+        for new_index, old_index in enumerate(order):
+            mapping[old_index] = new_index
+
+        new_palette_bytes = bytearray()
+        for old_index in order:
+            new_palette_bytes.extend(colors[old_index])
+
+        im = self.point(mapping)
