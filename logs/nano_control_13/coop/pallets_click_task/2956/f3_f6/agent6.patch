+def _find_dynamic_default_sample(default: dict[t.Any, t.Any]) -> t.Any | None:
+    """Find a value out of a dynamic default's mapping to use as a
+    sample for guessing the option's type. The mapping is expected to
+    be a mapping of a source option's name to a mapping of that
+    option's value to a default value.
+    """
+    for mapping in default.values():
+        if not isinstance(mapping, dict):
+            continue
+
+        for value in mapping.values():
+            return value
+
+    return None
+
