+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dynamic default (a mapping of a source option's
+        name to a mapping of that option's value to the default value
+        to use) using the already-resolved values of the other
+        parameters on ``ctx``.
+
+        Returns ``None`` if none of the mappings match the current
+        values of the source options.
+
+        .. versionadded:: 8.3
+        """
+        if not isinstance(self.default, dict):
+            return None
+
+        resolved: t.Any | None = None
+
+        for source_opt, mapping in self.default.items():
+            source_param = None
+
+            for param in ctx.command.get_params(ctx):
+                if source_opt in param.opts or source_opt in getattr(
+                    param, "secondary_opts", ()
+                ):
+                    source_param = param
+                    break
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
+
