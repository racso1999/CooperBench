+# Global registry of custom filters that are made available to every
+# prompt template in addition to the filters defined locally.
+FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to be used in all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered custom filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    FILTERS.pop(name, None)
+
 
