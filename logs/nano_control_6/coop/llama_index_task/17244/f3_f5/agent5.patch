+    def get_image_mimetype(self) -> str | None:
+        """Lazily resolve and cache the image's mimetype.
+
+        Returns the cached mimetype if it was already resolved. Otherwise,
+        guesses it from the raw image bytes using the filetype library and
+        caches the result on the instance for future accesses.
+        """
+        if self.image_mimetype:
+            return self.image_mimetype
+
+        if self.image:
