+def test_quantize_error_threshold():
+    image = hopper()
+
+    full = image.quantize(256)
+    reduced = image.quantize(256, error_threshold=50)
+
+    assert len(reduced.getcolors(256)) < len(full.getcolors(256))
+    assert image._quantize_mse(reduced) <= 50
+
+
+def test_quantize_error_threshold_unattainable():
+    image = hopper()
+
+    # An unreasonably strict threshold cannot be met,
+    # so the requested number of colors should be used
+    converted = image.quantize(100, error_threshold=0.0001)
+
+    assert len(converted.getcolors(256)) == 100
+
