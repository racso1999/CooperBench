+    def _quantize_mse(self, quantized_im):
+        """
+        Returns the mean square error between this image and a quantized
+        version of it, used to evaluate ``error_threshold`` in
+        :py:meth:`~PIL.Image.Image.quantize`.
+        """
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(self, quantized_im.convert(self.mode))
+        stat = ImageStat.Stat(diff)
+        return sum(stat.sum2) / sum(stat.count)
+
+    def _find_quantize_colors(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the fewest number of colors, up to ``colors``, that
+        quantizing this image can use while keeping the mean square error
+        at or below ``error_threshold``. Returns ``colors`` if no such
+        number of colors exists.
+        """
+        best = colors
+        lo, hi = 1, colors
+        while lo <= hi:
+            mid = (lo + hi) // 2
+            quantized_im = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantize_mse(quantized_im) <= error_threshold:
+                best = mid
+                hi = mid - 1
+            else:
+                lo = mid + 1
+        return best
+
