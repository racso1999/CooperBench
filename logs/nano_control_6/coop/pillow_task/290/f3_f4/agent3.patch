diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..3babb2574 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,54 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _quantize_test_image():
+    im = Image.new("RGB", (10, 10))
+    px = im.load()
+    colors = ((255, 0, 0), (0, 255, 0), (0, 0, 255), (255, 255, 255), (0, 0, 0))
+    for x in range(10):
+        for y in range(10):
+            px[x, y] = colors[(x + y) % len(colors)]
+    return im
+
+
+def test_quantize_sort_palette_luminance():
+    im = _quantize_test_image()
+
+    converted = im.quantize(colors=5, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), im, 1)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 5 * 3, 3)]
+    luminance = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    assert luminance == sorted(luminance)
+
+
+def test_quantize_sort_palette_rgb():
+    im = _quantize_test_image()
+
+    converted = im.quantize(colors=5, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), im, 1)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 5 * 3, 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_pixels_unchanged():
+    im = _quantize_test_image()
+
+    unsorted = im.quantize(colors=5)
+    sorted_by_rgb = im.quantize(colors=5, sort_palette="rgb")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_by_rgb.convert("RGB").tobytes()
+
+
+def test_quantize_sort_palette_invalid():
+    im = _quantize_test_image()
+
+    with pytest.raises(ValueError):
+        im.quantize(colors=5, sort_palette="bogus")
