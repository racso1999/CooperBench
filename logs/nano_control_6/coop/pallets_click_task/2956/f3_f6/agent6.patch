+def _validate_dynamic_default(value: dict[str, t.Any]) -> None:
+    """Validate the structure of a dynamic default mapping used by
+    :class:`Option`. Raises ``TypeError`` if the mapping is malformed.
+    """
+    for key, mapping in value.items():
+        if not isinstance(key, str):
+            raise TypeError("Dynamic default keys must be strings")
+
+        if not isinstance(mapping, dict):
+            raise TypeError("Dynamic default values must be dictionaries")
+
+
+def _dynamic_default_sample_value(value: dict[str, t.Any]) -> t.Any | None:
+    """Return a representative value from a dynamic default mapping, used
+    to guess the option's type when one isn't explicitly given.
+    """
+    for mapping in value.values():
+        for sample in mapping.values():
+            return sample
+
+    return None
+
