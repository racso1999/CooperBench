+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        dynamic mapping of other option declarations to value-based
+        defaults (see :class:`Option`). Runs after every parameter has
+        consumed its value from the command line, environment, and
+        default map, so dependent options can be resolved from their
+        final values.
+        """
+        params = self.get_params(ctx)
+        opt_lookup: dict[str, Parameter] = {}
+
+        for candidate in params:
+            for opt in candidate.opts:
+                opt_lookup.setdefault(opt, candidate)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_decl, value_map in dynamic_default.items():
+                source_param = opt_lookup.get(source_decl)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+                key = str(source_value)
+
+                if key in value_map:
+                    resolved = value_map[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                try:
+                    value = param.process_value(ctx, resolved)
+                except Exception:
+                    if not ctx.resilient_parsing:
+                        raise
+
+                    value = None
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
