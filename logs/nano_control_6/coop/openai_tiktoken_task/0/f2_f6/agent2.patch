+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes text into tokens, tracking the starting character position of each token.
+
+        Special tokens are matched as whole units (position = start of the special token text);
+        ordinary text is split using `pat_str` and BPE-encoded piece by piece, with each
+        resulting token's position derived from its byte offset within the piece.
+        """
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        if allowed_special:
+            special_regex = _special_token_regex(frozenset(allowed_special))
+            search_start = 0
+            for match in special_regex.finditer(text):
+                self._encode_ordinary_with_positions(
+                    text, search_start, match.start(), tokens, positions
+                )
+                tokens.append(self._special_tokens[match.group()])
+                positions.append(match.start())
+                search_start = match.end()
+            self._encode_ordinary_with_positions(text, search_start, len(text), tokens, positions)
+        else:
+            self._encode_ordinary_with_positions(text, 0, len(text), tokens, positions)
+
+        return tokens, positions
+
+    def _encode_ordinary_with_positions(
+        self, text: str, start: int, end: int, tokens: list[int], positions: list[int]
+    ) -> None:
+        if start >= end:
+            return
+
+        pat = regex.compile(self._pat_str)
+        for match in pat.finditer(text[start:end]):
+            piece = match.group()
+            piece_tokens = self._core_bpe.encode_single_piece(piece.encode("utf-8"))
+            if not piece_tokens:
+                continue
+
+            piece_start = start + match.start()
+            token_bytes = [self._core_bpe.decode_single_token_bytes(t) for t in piece_tokens]
+
+            piece_len = 0
+            for token, tb in zip(piece_tokens, token_bytes):
+                offset = max(0, piece_len - (0x80 <= tb[0] < 0xC0))
+                tokens.append(token)
+                positions.append(piece_start + offset)
+                piece_len += sum(1 for c in tb if not 0x80 <= c < 0xC0)
+
     def _encode_only_native_bpe(self, text: str) -> list[int]:
