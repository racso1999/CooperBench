+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has been idle for longer than `idle_timeout_s` and, if so, terminate it.
+
+        This should be called periodically by the streaming system while a stream is in flight. If the stream
+        has started but not ended, and no chunk has been received within `idle_timeout_s` seconds, this emits a
+        final `StreamResponse` with an empty `chunk` to signal termination and resets the listener's state so it
+        no longer appears "started". The state is reset unconditionally, regardless of `allow_reuse`, so the
+        listener isn't left stuck mid-stream.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()` if not provided.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response_kwargs = {
+            "predict_name": self.predict_name,
+            "signature_field_name": self.signature_field_name,
+            "chunk": "",
+        }
+        if "is_last_chunk" in {f.name for f in fields(StreamResponse)}:
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(**response_kwargs)
+
+        # Reset state unconditionally, regardless of `allow_reuse`, so the listener doesn't remain "started".
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        on_chunk = getattr(self, "on_chunk", None)
+        if callable(on_chunk):
+            on_chunk(response)
+
+        return response
+
