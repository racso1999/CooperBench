+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        original = hopper()
+        original.save(out)
+
+        # No existing file, so no backup should be created even if requested
+        backup_file = out + ".bak"
+        assert not os.path.exists(backup_file)
+
+        modified = hopper().rotate(90)
+        modified.save(out, backup=True)
+        assert os.path.exists(backup_file)
+        with Image.open(backup_file) as reloaded:
+            assert_image_equal(original, reloaded)
+        with Image.open(out) as reloaded:
+            assert_image_equal(modified, reloaded)
+
+        # Without backup=True, no backup should be made
+        os.remove(backup_file)
+        modified.save(out)
+        assert not os.path.exists(backup_file)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        original = hopper()
+        original.save(out)
+
+        modified = hopper().rotate(90)
+        modified.save(out, backup=True, backup_suffix=".backup")
+        backup_file = out + ".backup"
+        assert os.path.exists(backup_file)
+        with Image.open(backup_file) as reloaded:
+            assert_image_equal(original, reloaded)
+
     def test_pathlib(self, tmp_path: Path) -> None:
