+# Registry of filters that have been registered globally and are made
+# available to every prompt template automatically.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is made available to every prompt template
+    without having to pass it explicitly, e.g. ``{{ text | my_filter }}``.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTERS.pop(name, None)
+
 
