+    def _popen_kwargs(self) -> dict[str, t.Any]:
+        """Build extra keyword arguments for ``subprocess.Popen`` that
+        apply the configured process priority, if any. Falls back to no
+        special handling if the priority is unset or not supported on
+        this platform.
+        """
+        if self.process_priority is None or not WIN:
+            return {}
+
+        import subprocess
+
+        win_priority_classes = {
+            "low": subprocess.IDLE_PRIORITY_CLASS,
+            "below_normal": subprocess.BELOW_NORMAL_PRIORITY_CLASS,
+            "normal": subprocess.NORMAL_PRIORITY_CLASS,
+            "above_normal": subprocess.ABOVE_NORMAL_PRIORITY_CLASS,
+            "high": subprocess.HIGH_PRIORITY_CLASS,
+        }
+        return {"creationflags": win_priority_classes[self.process_priority]}
+
+    def _set_unix_priority(self, pid: int) -> None:
+        """Best-effort adjustment of the editor process niceness on
+        Unix-like systems. Any failure (e.g. insufficient permissions to
+        raise priority) is silently ignored so the edit operation still
+        succeeds.
+        """
+        if WIN or self.process_priority is None:
+            return
+
+        try:
+            os.setpriority(
+                os.PRIO_PROCESS, pid, _UNIX_PRIORITY_NICE_VALUES[self.process_priority]
+            )
+        except (AttributeError, OSError, PermissionError):
