+def _batched(iterable: cabc.Iterable[V], n: int) -> cabc.Iterator[tuple[V, ...]]:
+    """Batch ``iterable`` into tuples of length ``n``. The last batch may
+    be shorter than ``n`` if the number of items is not a multiple of it.
+    """
+    it = iter(iterable)
+    while chunk := tuple(islice(it, n)):
+        yield chunk
