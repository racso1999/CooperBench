         ctx._opt_prefixes.update(parser._opt_prefixes)
         return args
 
+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose ``default`` is a dynamic mapping keyed
+        by other options' values.
+
+        This runs as a second pass after command line arguments,
+        environment variables, and configuration files have all been
+        processed, so any option referenced by a dynamic default
+        mapping already holds its final value.
+        """
+        for param in self.get_params(ctx):
+            if not isinstance(param, Option) or param.dynamic_default is None:
+                continue
+
+            if param.name is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in param.dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in self.get_params(ctx)
+                        if opt_name in p.opts or opt_name in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)
+
     def invoke(self, ctx: Context) -> t.Any:
         """Given a context, this invokes the attached callback (if it exists)
         in the right way.
@@ -1360,6 +1403,7 @@ class Command:
