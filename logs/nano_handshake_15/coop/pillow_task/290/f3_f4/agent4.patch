+    def _quantize_mse(self, quantized_im):
+        """
+        Returns the mean square error (MSE) between this image and a
+        quantized version of it, averaged across bands.
+        """
+        from . import ImageChops, ImageStat
+
+        comparison_im = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparison_im)
+        stat = ImageStat.Stat(diff)
+        return sum(rms ** 2 for rms in stat.rms) / len(stat.rms)
+
+    def quantize(
