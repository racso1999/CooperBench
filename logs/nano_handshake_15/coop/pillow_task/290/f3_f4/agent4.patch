@@ -85,3 +85,30 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_reduces_colors():
+    im = Image.new("RGB", (10, 10), (255, 0, 0))
+    im.paste(Image.new("RGB", (5, 5), (0, 255, 0)), (0, 0))
+
+    converted = im.quantize(colors=256, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_quantize_error_threshold_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 4
+
+
+def test_quantize_error_threshold_met():
+    image = hopper()
+    threshold = 200
+    converted = image.quantize(colors=256, error_threshold=threshold)
+    assert_image(converted, "P", converted.size)
+
+    mse = image._quantize_mse(converted)
+    assert mse <= threshold
+    assert len(converted.getcolors()) < 256
