diff --git a/Tests/test_imageops.py b/Tests/test_imageops.py
index 3621aa50f..e0b8ee8b2 100644
--- a/Tests/test_imageops.py
+++ b/Tests/test_imageops.py
@@ -470,6 +470,45 @@ def test_exif_transpose_in_place() -> None:
         assert_image_equal(im, expected)
 
 
+def test_exif_transpose_strip_metadata() -> None:
+    with Image.open("Tests/images/hopper_orientation_5.jpg") as im:
+        assert im.getexif()[0x0112] == 5
+        assert "exif" in im.info
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert not transposed_im.getexif()
+        assert not transposed_im.info
+
+    # No orientation transposition needed, but metadata should still be stripped
+    with Image.open("Tests/images/flower.jpg") as im:
+        assert im.getexif()[0x0112] == 1
+        assert "exif" in im.info
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert not transposed_im.getexif()
+        assert not transposed_im.info
+
+
+def test_exif_transpose_strip_metadata_in_place() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.getexif()[0x0112] == 8
+        assert "exif" in im.info
+
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert not im.getexif()
+        assert not im.info
+
+    # No orientation transposition needed, but metadata should still be
+    # stripped in-place
+    with Image.open("Tests/images/flower.jpg") as im:
+        assert im.getexif()[0x0112] == 1
+        assert "exif" in im.info
+
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert not im.getexif()
+        assert not im.info
+
+
