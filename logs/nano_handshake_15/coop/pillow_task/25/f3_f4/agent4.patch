@@ -1129,6 +1129,57 @@ class TestImage:
         with pytest.warns(DeprecationWarning):
             assert not Image.isImageType(None)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        f = str(tmp_path / "temp.png")
+
+        im = hopper()
+        im.save(f)
+        with open(f, "rb") as fp:
+            original_data = fp.read()
+
+        im2 = Image.new("RGB", (2, 2), "#f00")
+        im2.save(f, backup=True)
+
+        backup_f = f + ".bak"
+        assert os.path.exists(backup_f)
+        with open(backup_f, "rb") as fp:
+            assert fp.read() == original_data
+
+        with Image.open(f) as reloaded:
+            assert reloaded.size == (2, 2)
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        f = str(tmp_path / "temp.png")
+
+        im = hopper()
+        im.save(f, backup=True)
+
+        assert not os.path.exists(f + ".bak")
+        assert os.path.exists(f)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        f = str(tmp_path / "temp.png")
+
+        im = hopper()
+        im.save(f)
+
+        im2 = Image.new("RGB", (2, 2), "#f00")
+        im2.save(f, backup=True, backup_suffix=".backup")
+
+        assert os.path.exists(f + ".backup")
+        assert not os.path.exists(f + ".bak")
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        f = str(tmp_path / "temp.png")
+
+        im = hopper()
+        im.save(f)
+
+        im2 = Image.new("RGB", (2, 2), "#f00")
+        im2.save(f)
+
+        assert not os.path.exists(f + ".bak")
+
 
