+
+
+# Registry of custom filters made available to every prompt template,
+# without having to pass them explicitly to each one.
+GLOBAL_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to make it available to all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    GLOBAL_FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered custom filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove. Does nothing if no filter was
+        registered under this name.
+
+    """
+    GLOBAL_FILTERS.pop(name, None)
