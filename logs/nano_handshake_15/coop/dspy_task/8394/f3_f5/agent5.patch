+# 4-byte magic string identifying a DSPy cache blob, followed by a 1-byte codec selector.
+# Entries written before this feature existed (or values diskcache stores directly, e.g.
+# primitives) won't start with this magic string and are read back unchanged, which is what
+# keeps this format backward compatible with pre-existing cache directories.
+_DISK_BLOB_MAGIC = b"DSPC"
+_CODEC_NONE = 0x00
+_CODEC_GZIP = 0x01
+_CODEC_ZLIB = 0x02
+_VALID_COMPRESS_CODECS = (None, "gzip", "zlib")
+_COMPRESSORS = {
+    "gzip": (_CODEC_GZIP, gzip.compress, gzip.decompress),
+    "zlib": (_CODEC_ZLIB, zlib.compress, zlib.decompress),
+}
+
+
+def _validate_compress(compress: Optional[str]) -> None:
+    if compress not in _VALID_COMPRESS_CODECS:
+        raise ValueError(f"`compress` must be one of {_VALID_COMPRESS_CODECS}, got {compress!r}.")
+
+
+def _encode_disk_value(value: Any, compress: Optional[str]) -> bytes:
+    """Pickle `value` and prepend a magic header encoding the compression codec, if any."""
+    payload = cloudpickle.dumps(value)
+    if compress is None:
+        return _DISK_BLOB_MAGIC + bytes([_CODEC_NONE]) + payload
+    codec_byte, compress_fn, _ = _COMPRESSORS[compress]
+    return _DISK_BLOB_MAGIC + bytes([codec_byte]) + compress_fn(payload)
+
+
+def _decode_disk_value(raw: Any) -> Any:
+    """Reverse `_encode_disk_value`, falling back to returning `raw` unchanged when it wasn't
+    produced by it (e.g. a legacy cache entry written before compression support, or a
+    primitive value diskcache deserialized on its own)."""
+    if not isinstance(raw, (bytes, bytearray)) or raw[:4] != _DISK_BLOB_MAGIC:
+        return raw
+
+    codec_byte = raw[4]
+    payload = bytes(raw[5:])
+    if codec_byte == _CODEC_NONE:
+        pass
+    elif codec_byte == _CODEC_GZIP:
+        payload = gzip.decompress(payload)
+    elif codec_byte == _CODEC_ZLIB:
+        payload = zlib.decompress(payload)
+    else:
+        raise ValueError(f"Unknown DSPy cache compression codec byte: {codec_byte!r}")
+    return cloudpickle.loads(payload)
+
 
