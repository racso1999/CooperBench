+    def _select_tip_with_weights(self) -> str:
+        """Select a tip key from TIPS using self.tip_weights to bias the draw.
+
+        Nonpositive or missing weights are treated as 0 (missing keys default to 1.0
+        before that clamp). If every weight ends up 0, falls back to a uniform draw.
+        """
+        keys = list(TIPS.keys())
+        weights = [max(0.0, self.tip_weights.get(key, 1.0)) for key in keys]
+        total_weight = sum(weights)
+
+        if total_weight <= 0:
+            return self.rng.choice(keys)
+
+        probabilities = [weight / total_weight for weight in weights]
+        threshold = self.rng.random()
+        cumulative = 0.0
+        for key, probability in zip(keys, probabilities):
+            cumulative += probability
+            if threshold < cumulative:
+                return key
+        return keys[-1]
+
