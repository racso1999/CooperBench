+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a specific algorithm/type, using regex.
+    """
+
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The algorithm to use to check the hash, must be one of `md5`, `sha1`, `sha224`, `sha256`,
+                `sha384`, `sha512`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'hello').hexdigest() == IsHash('md5')
+        assert hashlib.sha1(b'hello').hexdigest() == IsHash('sha1')
+        assert hashlib.sha256(b'hello').hexdigest() == IsHash('sha256')
+        assert 'not_a_hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.hash_length = self.hash_lengths[algorithm.lower()]
+        except KeyError as e:
+            raise ValueError(f'Unknown hash algorithm: {algorithm!r}') from e
+        self.hash_regex = re.compile(f'^[0-9a-fA-F]{{{self.hash_length}}}$')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return bool(self.hash_regex.match(other))
