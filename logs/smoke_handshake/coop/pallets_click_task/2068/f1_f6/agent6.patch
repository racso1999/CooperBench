+_PRIORITY_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+
+def _priority_popen_kwargs(process_priority: str | None) -> dict[str, t.Any]:
+    """Build extra :class:`subprocess.Popen` kwargs to apply the given
+    process priority, if possible. Returns an empty dict for unknown or
+    unsupported priority values so callers can always merge it in safely.
+    """
+    if process_priority not in _PRIORITY_NICE_VALUES:
+        return {}
+
+    import subprocess
+
+    if WIN:
+        priority_classes = {
+            "low": getattr(subprocess, "IDLE_PRIORITY_CLASS", None),
+            "below_normal": getattr(subprocess, "BELOW_NORMAL_PRIORITY_CLASS", None),
+            "normal": getattr(subprocess, "NORMAL_PRIORITY_CLASS", None),
+            "above_normal": getattr(subprocess, "ABOVE_NORMAL_PRIORITY_CLASS", None),
+            "high": getattr(subprocess, "HIGH_PRIORITY_CLASS", None),
+        }
+        creation_flag = priority_classes[process_priority]
+
+        if creation_flag is None:
+            return {}
+
+        return {"creationflags": creation_flag}
+
+    nice_value = _PRIORITY_NICE_VALUES[process_priority]
+
+    def _set_priority() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            pass
+
+    return {"preexec_fn": _set_priority}
+
+
