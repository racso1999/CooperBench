+    def _reorder_palette(self, sort_palette):
+        """
+        Returns a copy of this "P" mode image with its palette colors
+        reordered according to ``sort_palette``, remapping pixel indices to
+        match. See :py:meth:`~PIL.Image.Image.quantize` for the accepted
+        values of ``sort_palette``.
+        """
+        mode = self.palette.mode
+        channels = len(mode)
+        palette = self.palette.palette
+        colors = [
+            tuple(palette[i : i + channels]) for i in range(0, len(palette), channels)
+        ]
+
+        if callable(sort_palette):
+            key = sort_palette
+        elif sort_palette == "luminance":
+
+            def key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color[:3]
+
+        else:
+            raise ValueError(f"Unknown sort_palette method: {sort_palette!r}")
+
+        order = sorted(range(len(colors)), key=lambda i: key(colors[i]))
+
+        mapping = list(range(256))
+        for new_index, old_index in enumerate(order):
+            mapping[old_index] = new_index
+
+        im = self.point(mapping)
+
+        new_palette = bytearray()
+        for old_index in order:
+            new_palette.extend(colors[old_index])
+        im.putpalette(bytes(new_palette), mode)
+
         return im
 
     def copy(self):
