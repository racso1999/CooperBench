diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..22d347b1b 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,58 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    luminance = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), 3)
+    ]
+    assert luminance == sorted(luminance)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def sort_key(color):
+        r, g, b = color[:3]
+        return -(r + g + b)
+
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=sort_key)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    sums = [sum(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert sums == sorted(sums, reverse=True)
+
+
+def test_quantize_sort_palette_unknown():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, Image.FASTOCTREE, sort_palette="unknown")
+
+
+def test_quantize_sort_palette_pixels_unchanged():
+    image = hopper()
+    unsorted = image.quantize(100, Image.FASTOCTREE)
+    sorted_ = image.quantize(100, Image.FASTOCTREE, sort_palette="luminance")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_.convert("RGB").tobytes()
