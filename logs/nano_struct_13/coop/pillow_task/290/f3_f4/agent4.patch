+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A loose threshold should allow fewer colors than requested.
+    loose = image.quantize(colors=256, error_threshold=1000)
+    assert len(loose.getcolors()) < 256
+
+    # A very tight threshold should max out at the requested color count.
+    tight = image.quantize(colors=8, error_threshold=0.0001)
+    assert len(tight.getcolors()) == 8
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=10)
+
+
