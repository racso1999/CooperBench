+    def _find_colors_for_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Returns the smallest number of colors, at most ``colors``, whose
+        quantized result has a mean square error at or below
+        ``error_threshold``. If no such number of colors exists,
+        ``colors`` is returned.
+        """
+        from . import ImageChops, ImageStat
+
+        def mse(num_colors):
+            quantized = self._new(self.im.quantize(num_colors, method, kmeans))
+            reference = self.convert("RGB")
+            difference = ImageChops.difference(quantized.convert("RGB"), reference)
+            rms = ImageStat.Stat(difference).rms
+            return sum(band_rms**2 for band_rms in rms) / len(rms)
+
+        low, high = 1, colors
+        if mse(high) > error_threshold:
+            return colors
+
+        while low < high:
+            mid = (low + high) // 2
+            if mse(mid) <= error_threshold:
+                high = mid
+            else:
+                low = mid + 1
+
+        return low
+
