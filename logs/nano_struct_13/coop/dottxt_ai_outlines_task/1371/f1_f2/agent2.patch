+#: Global registry of custom Jinja2 filters, made available to every prompt
+#: template so users don't have to pass the same filters to each template.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, filter_func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter becomes available in every prompt template,
+    without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    filter_func
+        The callable implementing the filter.
+
+    """
+    _FILTER_REGISTRY[name] = filter_func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered Jinja2 filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+
 
