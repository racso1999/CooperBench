+# Nice deltas applied on POSIX systems, relative to the priority the
+# parent process is already running at.
+_PRIORITY_NICE_VALUES: dict[str, int] = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+# Windows process priority classes, keyed the same way as
+# ``_PRIORITY_NICE_VALUES`` above.
+_PRIORITY_WIN_CLASSES: dict[str, int] = {}
+
+if WIN:
+    import subprocess as _subprocess
+
+    _PRIORITY_WIN_CLASSES = {
+        "low": _subprocess.IDLE_PRIORITY_CLASS,
+        "below_normal": _subprocess.BELOW_NORMAL_PRIORITY_CLASS,
+        "normal": _subprocess.NORMAL_PRIORITY_CLASS,
+        "above_normal": _subprocess.ABOVE_NORMAL_PRIORITY_CLASS,
+        "high": _subprocess.HIGH_PRIORITY_CLASS,
+    }
+
+
+def _posix_priority_preexec_fn(priority: str) -> t.Callable[[], None]:
+    """Return a ``preexec_fn`` that lowers/raises the child's niceness.
+
+    Any failure (e.g. lacking permission to raise priority) is
+    swallowed so that the editor still launches with default priority.
+    """
+
+    def _set_priority() -> None:
+        try:
+            os.nice(_PRIORITY_NICE_VALUES[priority])
+        except (OSError, AttributeError):
+            pass
+
+    return _set_priority
+
+
