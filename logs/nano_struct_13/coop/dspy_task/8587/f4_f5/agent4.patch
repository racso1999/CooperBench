+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system (independent of `receive()`) so
+        that a stalled upstream doesn't leave a consumer waiting forever. If the timeout has elapsed
+        while a stream is in progress, this emits a terminal `StreamResponse` with an empty `chunk` and
+        resets the listener's state so it isn't left stuck in a started state.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk. Defaults to `time.time()`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = time.time() if now_ts is None else now_ts
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            # `is_last_chunk` may not exist on `StreamResponse` yet; if it's added later, mark this
+            # chunk as the last one since the timeout is terminating the stream.
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally (regardless of `allow_reuse`) so it doesn't remain
+        # stuck in a started state; when `allow_reuse` is True this also allows the listener to be used
+        # for the next stream.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        on_chunk = getattr(self, "on_chunk", None)
+        if callable(on_chunk):
+            on_chunk(response)
+
+        return response
+
