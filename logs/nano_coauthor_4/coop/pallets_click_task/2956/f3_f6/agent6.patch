+    def resolve_dynamic_default(self, ctx: Context) -> t.Any:
+        """Resolve a dynamic default: a mapping of other option
+        declarations (e.g. ``"--protocol"``) to a mapping of that
+        option's stringified value to the default that should be used
+        for this option.
+
+        Only called for options whose ``default`` is a ``dict``. If
+        multiple source options are given, later entries take
+        precedence over earlier ones. Returns ``None`` if nothing
+        matches.
+        """
+        resolved = None
+
+        for source_decl, mapping in self.default.items():
+            source_param = None
+
+            for param in ctx.command.params:
+                if source_decl in param.opts or source_decl in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
 
