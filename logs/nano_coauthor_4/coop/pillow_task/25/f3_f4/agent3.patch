+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        im = hopper()
+        im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_existing_file_not_modified(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        im = hopper()
+        im.save(temp_file)
+        mtime = os.path.getmtime(temp_file)
+
+        im.save(temp_file, dry_run=True)
+        assert os.path.getmtime(temp_file) == mtime
+
+    def test_dry_run_raises_errors(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+        im = hopper("RGBA")
+        with pytest.raises(OSError):
+            im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
     def test_internals(self) -> None:
