+    def _sort_palette(self, sort_by):
+        """
+        Sorts the colors that are actually used in a "P" mode image's
+        palette, remapping pixel values so that the image's appearance is
+        unchanged. Unused palette entries keep their original position.
+
+        :param sort_by: ``"brightness"`` to sort by perceived brightness,
+           or ``"rgb"`` to sort by RGB value.
+        :returns: The image, with its palette sorted.
+        """
+        mode_len = len(self.palette.mode)
+        palette_bytes = self.palette.tobytes()
+
+        def color_at(index):
+            start = index * mode_len
+            return tuple(palette_bytes[start : start + mode_len])
+
+        if sort_by == "brightness":
+
+            def sort_key(index):
+                r, g, b = color_at(index)[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_by == "rgb":
+
+            def sort_key(index):
+                return color_at(index)[:3]
+
+        else:
+            msg = f"Unknown sort_palette method: {sort_by}"
+            raise ValueError(msg)
+
+        used_indexes = sorted(index for _, index in self.getcolors(maxcolors=256))
+        order = sorted(used_indexes, key=sort_key)
+
+        new_palette = bytearray(palette_bytes)
+        lut = list(range(256))
+        for new_index, old_index in zip(used_indexes, order):
+            start = new_index * mode_len
+            new_palette[start : start + mode_len] = color_at(old_index)
+            lut[old_index] = new_index
+
+        self.im = self.im.point(lut, self.mode)
+        self.putpalette(bytes(new_palette), self.palette.mode)
+
+        return self
+
