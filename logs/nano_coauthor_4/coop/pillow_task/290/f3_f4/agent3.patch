+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=8, sort_palette="unknown")
+
+
+@pytest.mark.parametrize("sort_by", ("brightness", "rgb"))
+def test_sort_palette(sort_by):
+    image = hopper()
+
+    unsorted = image.quantize(colors=8)
+    sorted_im = image.quantize(colors=8, sort_palette=sort_by)
+
+    assert_image(sorted_im, "P", sorted_im.size)
+
+    # Sorting the palette should not change how the image looks.
+    assert_image_similar(sorted_im.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    palette = sorted_im.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    num_colors = len(sorted_im.getcolors())
+    colors = colors[:num_colors]
+
+    if sort_by == "brightness":
+        keys = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    else:
+        keys = colors
+
+    assert keys == sorted(keys)
