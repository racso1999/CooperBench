+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible, up to
+        ``colors``, such that the mean square error against the original
+        image does not exceed ``error_threshold``. If no color count up to
+        ``colors`` satisfies the threshold, ``colors`` colors are used.
+
+        :param colors: The maximum number of colors, <= 256
+        :param method: The quantization method to use
+        :param kmeans: Integer
+        :param error_threshold: The maximum allowed mean square error (MSE)
+        :returns: A new, quantized image
+        """
+        rgb_self = self.convert("RGB") if self.mode != "RGB" else self
+
+        low, high = 1, colors
+        best_im = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            mse = rgb_self._quantize_mse(candidate)
+            if mse <= error_threshold:
+                best_im = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_im is not None:
+            return best_im
+        return self._new(self.im.quantize(colors, method, kmeans))
+
+    def _quantize_mse(self, quantized_im):
+        """
+        Computes the mean square error between this image (which must be
+        in RGB mode) and a quantized version of it.
+        """
+        from . import ImageChops
+
+        diff = ImageChops.difference(self, quantized_im.convert("RGB"))
+        histogram = diff.histogram()
+
+        channels = len(histogram) // 256
+        squared_error = 0
+        for channel in range(channels):
+            offset = channel * 256
+            for value in range(256):
+                squared_error += (value * value) * histogram[offset + value]
+
+        pixel_count = self.size[0] * self.size[1] * channels
+        return squared_error / pixel_count if pixel_count else 0
+
