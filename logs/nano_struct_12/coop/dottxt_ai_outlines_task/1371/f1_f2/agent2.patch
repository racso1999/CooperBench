+#: Registry of filters that should be made available to every prompt
+#: template, without having to pass them explicitly. Populate it with
+#: `register_filter` and remove entries with `unregister_filter`.
+filters: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter so it becomes available to all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates,
+        e.g. ``{{ text | name }}``.
+    func
+        The callable that implements the filter.
+
+    """
+    filters[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Does nothing if no filter was registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter to remove was registered.
+
+    """
+    filters.pop(name, None)
+
 
