           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
+    case-insensitive by default. The ``key`` for each group will use the
+    case of the first item encountered for that value. For example, if a
+    list of users has cities ``["CA", "NY", "ca"]``, the "CA" and "ca"
+    values will be grouped together.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items in users|groupby("city", case_sensitive=true) %}
+          <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``case_sensitive`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1226,19 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    sort_key = make_attrgetter(
+        environment,
+        attribute,
+        postprocess=None if case_sensitive else ignore_case,
+        default=default,
+    )
+    out = []
+
+    for _, values in groupby(sorted(value, key=sort_key), key=sort_key):
+        values = list(values)
+        out.append(_GroupTuple(expr(values[0]), values))
+
+    return out
 
 
