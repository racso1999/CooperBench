+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very loose threshold should allow much fewer colors than requested.
+    loose = image.quantize(256, error_threshold=10000)
+    assert len(loose.getcolors(256)) < 256
+
+    # A very tight threshold should require the full number of colors.
+    tight = image.quantize(256, error_threshold=0.001)
+    assert len(tight.getcolors(256)) == 256
+
+    # Without a threshold, the requested number of colors is used.
+    default = image.quantize(256)
+    assert len(default.getcolors(256)) == 256
+
+
+def test_quantize_error_threshold_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
