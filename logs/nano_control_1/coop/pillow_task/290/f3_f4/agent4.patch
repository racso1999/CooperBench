+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the smallest number of colors (up to ``colors``) for which
+        quantizing this image keeps the mean square error at or below
+        ``error_threshold``, and returns the resulting core image object.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        def mse(n):
+            core = self.im.quantize(n, method, kmeans)
+            quantized = self._new(core)
+            palette_mode = core.getpalettemode()
+            quantized.palette = ImagePalette.ImagePalette(
+                palette_mode, core.getpalette(palette_mode, palette_mode)
+            )
+            diff = ImageChops.difference(self, quantized.convert(self.mode))
+            stat = ImageStat.Stat(diff)
+            count = sum(stat.count)
+            return core, (sum(stat.sum2) / count if count else 0)
+
+        max_core, max_error = mse(colors)
+        if colors <= 2 or max_error > error_threshold:
+            return max_core
+
+        lo, hi = 2, colors
+        while lo < hi:
+            mid = (lo + hi) // 2
+            mid_core, mid_error = mse(mid)
+            if mid_error <= error_threshold:
+                hi = mid
+                best_core = mid_core
+            else:
+                lo = mid + 1
+        return best_core if hi < colors else max_core
+
