+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm/type.
+    """
+
+    hash_lengths: Dict[str, int] = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: str):
+        """
+        Args:
+            algorithm: The name of the algorithm the hash is expected to be generated with, this is used to
+                validate the length and character set of the value. Must be one of `'md5'`, `'sha1'`,
+                `'sha224'`, `'sha256'`, `'sha384'` or `'sha512'` (case-insensitive).
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'hello').hexdigest() == IsHash('md5')
+        assert hashlib.sha256(b'hello').hexdigest() == IsHash('sha256')
+        assert 'not_a_valid_hash' != IsHash('md5')
+        ```
+        """
+        try:
+            self.length = self.hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm: {algorithm!r}')
+        self.algorithm = algorithm
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return len(other) == self.length and all(c in '0123456789abcdefABCDEF' for c in other)
