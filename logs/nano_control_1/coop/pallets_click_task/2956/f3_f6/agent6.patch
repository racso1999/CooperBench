+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve mapping-based dynamic defaults on :class:`Option`
+        parameters now that command line arguments, environment
+        variables, and configuration files have all been processed.
+
+        A dynamic default only replaces a value whose source is still
+        :attr:`ParameterSource.DEFAULT`, so any value explicitly
+        provided elsewhere is left untouched.
+        """
+        for param in self.params:
+            if not isinstance(param, Option) or not param._dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved: t.Any | None = None
+
+            for source_opt, mapping in param._dynamic_default.items():
+                source_value = None
+
+                for other in self.params:
+                    if source_opt in other.opts or source_opt in other.secondary_opts:
+                        source_value = ctx.params.get(other.name)  # type: ignore[arg-type]
+                        break
+
+                if source_value is None:
+                    continue
+
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore[index]
+
     def invoke(self, ctx: Context) -> t.Any:
