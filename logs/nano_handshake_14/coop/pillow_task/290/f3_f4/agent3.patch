diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..697a6a5a8 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,44 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(im, num_colors):
+    palette = im.im.getpalette("RGB")
+    return [tuple(palette[i * 3 : i * 3 + 3]) for i in range(num_colors)]
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    def brightness(color):
+        r, g, b = color
+        return r * 299 + g * 587 + b * 114
+
+    colors = _palette_colors(converted, 32)
+    assert [brightness(c) for c in colors] == sorted(brightness(c) for c in colors)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted, 32)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_preserves_image():
+    image = hopper()
+    unsorted = image.quantize(colors=32)
+    sorted_by_rgb = image.quantize(colors=32, sort_palette="rgb")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_by_rgb.convert("RGB").tobytes()
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not-a-real-option")
