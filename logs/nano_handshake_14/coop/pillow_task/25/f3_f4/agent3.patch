+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not os.path.exists(out)
+
+    def test_save_dry_run_existing_file_not_overwritten(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+        im.save(out)
+        with open(out, "rb") as f:
+            original_contents = f.read()
+
+        im.rotate(45).save(out, dry_run=True)
+        with open(out, "rb") as f:
+            assert f.read() == original_contents
+
+    def test_save_dry_run_raises_for_unsupported_mode(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.jpg")
+        im = Image.new("RGBA", (1, 1))
+        with pytest.raises(OSError):
+            im.save(out, dry_run=True)
+        assert not os.path.exists(out)
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
             assert im.mode == "P"
