+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter for use in all prompt templates.
+
+    Once registered, the filter becomes available under `name` in every
+    template rendered via `Prompt`, without needing to be passed explicitly.
+    Filters passed directly to a given template take precedence over a
+    globally registered filter of the same name.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered custom filter, if present.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTERS.pop(name, None)
+
