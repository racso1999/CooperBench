+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, checking the length and characters used depending on the
+    hash algorithm.
+    """
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The name of the hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`,
+                `'sha256'`, `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' != IsHash('sha1')
+        assert 'aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d' == IsHash('sha1')
+        assert '2c26b46b68ffc68ff99b453c1d30413413422d706483bfa0f98a5e886266e7ae' == IsHash('sha256')
+        ```
+        """
+        self._algorithm_lengths = {
+            'md5': 32,
+            'sha1': 40,
+            'sha224': 56,
+            'sha256': 64,
+            'sha384': 96,
+            'sha512': 128,
+        }
+        if algorithm.lower() not in self._algorithm_lengths:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        self.algorithm = algorithm
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        expected_length = self._algorithm_lengths[self.algorithm.lower()]
+        if len(other) != expected_length:
+            return False
+
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+
+        return True
+
