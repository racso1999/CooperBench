+    def _get_win_priority_creationflags(self) -> int:
+        import subprocess
+
+        class_name = _WIN_PRIORITY_CLASSES.get(self.process_priority or "")
+        return getattr(subprocess, class_name, 0) if class_name else 0
+
+    def _apply_unix_priority(self, pid: int) -> None:
+        nice_value = _NICE_VALUES.get(self.process_priority or "")
+        if nice_value is None:
+            return
+        try:
+            os.setpriority(os.PRIO_PROCESS, pid, nice_value)
+        except (AttributeError, OSError, PermissionError):
+            # Priority adjustment is best-effort; if the platform doesn't
+            # support it or permission is denied, keep the default priority.
+            pass
+
