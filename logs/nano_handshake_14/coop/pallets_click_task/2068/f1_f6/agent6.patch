+# Maps the public ``process_priority`` values to a Unix ``nice`` delta.
+# Positive nice values lower a process's scheduling priority, negative
+# values raise it (raising it typically requires elevated privileges).
+_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+# Maps the public ``process_priority`` values to the ``subprocess``
+# module's Windows priority class constants (only defined on Windows).
+_WIN_PRIORITY_CLASSES = {
+    "low": "IDLE_PRIORITY_CLASS",
+    "below_normal": "BELOW_NORMAL_PRIORITY_CLASS",
+    "normal": "NORMAL_PRIORITY_CLASS",
+    "above_normal": "ABOVE_NORMAL_PRIORITY_CLASS",
+    "high": "HIGH_PRIORITY_CLASS",
+}
