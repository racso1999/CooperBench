+
+
+def _group_by(
+    value: "t.Iterable[V]",
+    expr: "t.Callable[[t.Any], t.Any]",
+    case_sensitive: bool,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    if case_sensitive:
+        key_func = expr
+    else:
+
+        def key_func(item: t.Any) -> t.Any:
+            return ignore_case(expr(item))
+
+    groups = [
+        (key, list(values))
+        for key, values in groupby(sorted(value, key=key_func), key_func)
     ]
 
+    if case_sensitive:
+        return groups
+
+    # Preserve the original case of the first matching item's value
+    # rather than exposing the normalized key used to sort and group.
+    return [(expr(values[0]), values) for key, values in groups]
+
 
