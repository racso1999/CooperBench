+    def _quantize_mean_square_error(self, reference, colors, method, kmeans):
+        from . import ImageChops, ImagePalette, ImageStat
+
+        candidate = self._new(self.im.quantize(colors, method, kmeans))
+        mode = candidate.im.getpalettemode()
+        candidate.palette = ImagePalette.ImagePalette(
+            mode, candidate.im.getpalette(mode, mode)
+        )
+
+        diff = ImageChops.difference(reference, candidate.convert(reference.mode))
+        stat = ImageStat.Stat(diff)
+        return sum(rms ** 2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_colors_for_error_threshold(
+        self, method, kmeans, max_colors, error_threshold
+    ):
+        reference = self.convert("RGB") if self.mode != "RGB" else self
+
+        low, high = 2, max(max_colors, 2)
+        if (
+            self._quantize_mean_square_error(reference, high, method, kmeans)
+            > error_threshold
+        ):
+            # Even the maximum allowed number of colors doesn't meet the
+            # threshold, so use as many colors as are allowed.
+            return high
+
+        while low < high:
+            mid = (low + high) // 2
+            error = self._quantize_mean_square_error(reference, mid, method, kmeans)
+            if error <= error_threshold:
+                high = mid
+            else:
+                low = mid + 1
+        return low
