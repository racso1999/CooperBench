+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes `text`, additionally tracking the starting character position of each token.
+
+        `allowed_special` is expected to have already been resolved (i.e. it is a concrete set of
+        special token strings, not the literal "all").
+        """
+        special_regex = _special_token_regex(frozenset(allowed_special)) if allowed_special else None
+        pat = regex.compile(self._pat_str)
+
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        pos = 0
+        text_len = len(text)
+        while pos < text_len:
+            match = special_regex.search(text, pos) if special_regex else None
+            end = match.start() if match else text_len
+
+            segment = text[pos:end]
+            for piece_match in pat.finditer(segment):
+                piece = piece_match.group()
+                piece_start = pos + piece_match.start()
+                piece_tokens = self._core_bpe.encode_single_piece(piece.encode("utf-8"))
+                token_pos = piece_start
+                for token in piece_tokens:
+                    tokens.append(token)
+                    positions.append(token_pos)
+                    token_bytes = self._core_bpe.decode_single_token_bytes(token)
+                    token_pos += sum(1 for b in token_bytes if not 0x80 <= b < 0xC0)
+
+            if match:
+                tokens.append(self._special_tokens[match.group()])
+                positions.append(match.start())
+                pos = match.end()
+            else:
+                pos = text_len
+
+        return tokens, positions
