+    def _emit_event(self, event_type: str, pid: int, editor_command: str) -> None:
+        import warnings
+
+        assert self.monitor_process is not None
+
+        try:
+            self.monitor_process(event_type, pid, editor_command, time.time())
+        except Exception as e:
+            warnings.warn(
+                f"monitor_process callback raised an exception while "
+                f"handling {event_type!r} event: {e}",
+                UserWarning,
+                stacklevel=3,
+            )
+
+    @staticmethod
+    def _get_process_state(pid: int) -> str | None:
+        """Return the state code of a process from ``/proc``, or ``None``
+        if that information isn't available on this platform.
+        """
+        try:
+            with open(f"/proc/{pid}/stat") as f:
+                content = f.read()
+            # The second field is "(comm)" and may itself contain spaces
+            # or parentheses, so split off everything after the last ')'.
+            after_comm = content.rsplit(")", 1)[-1].split()
+            return after_comm[0]
+        except (OSError, IndexError):
+            return None
+
+    def _monitor_worker(self, process: t.Any, editor_command: str) -> None:
+        self._emit_event("start", process.pid, editor_command)
+
+        last_state: str | None = None
+
+        while process.poll() is None:
+            if not WIN:
+                state = self._get_process_state(process.pid)
+                if state == "T" and last_state != "T":
+                    self._emit_event("suspend", process.pid, editor_command)
+                elif last_state == "T" and state is not None and state != "T":
+                    self._emit_event("resume", process.pid, editor_command)
+                last_state = state
+
+            time.sleep(0.1)
+
+        self._emit_event("terminate", process.pid, editor_command)
+
+    def _start_monitor_thread(
+        self, process: t.Any, editor_command: str
+    ) -> threading.Thread:
+        thread = threading.Thread(
+            target=self._monitor_worker,
+            args=(process, editor_command),
+            daemon=True,
+        )
+        thread.start()
+        return thread
+
