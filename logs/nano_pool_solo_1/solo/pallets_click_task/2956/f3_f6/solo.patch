+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for :class:`Option`\\s that declare a
+        dynamic ``default`` (a mapping of other option names to
+        value-based default mappings). Runs after every parameter has
+        been parsed so that the values it depends on are final.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+        opt_lookup: dict[str, Parameter] = {}
+
+        for param in params:
+            for opt in param.opts:
+                opt_lookup[opt] = param
+
+        for param in params:
+            if (
+                not isinstance(param, Option)
+                or param._dynamic_default is None
+                or ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT
+            ):
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param._dynamic_default.items():
+                source_param = opt_lookup.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+
+                if str(source_value) in mapping:
+                    resolved = mapping[str(source_value)]
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved
+
