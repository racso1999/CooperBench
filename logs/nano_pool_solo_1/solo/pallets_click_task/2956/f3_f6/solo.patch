+def _batched(
+    iterable: cabc.Iterable[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Yield successive tuples of at most ``batch_size`` items from
+    ``iterable``. Used to implement :attr:`Option.batch_size`.
+    """
+    it = iter(iterable)
+
+    while chunk := tuple(islice(it, batch_size)):
+        yield chunk
