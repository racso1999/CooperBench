-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+
+    if case_sensitive:
+        key_func = expr
+    else:
+        key_func = make_attrgetter(
+            environment, attribute, default=default, postprocess=ignore_case
+        )
+
+    if not include_empty:
+        value = [item for item in value if expr(item)]
+
+    out = []
+
+    for _, group in groupby(sorted(value, key=key_func), key_func):
+        group_items = list(group)
+        out.append(_GroupTuple(expr(group_items[0]), group_items))
+
+    return out
 
 
