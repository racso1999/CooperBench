+    out = [
         _GroupTuple(key, list(values))
         for key, values in groupby(sorted(value, key=expr), expr)
     ]
 
+    if key_transform is not None:
+        out = [_GroupTuple(key_transform(key), values) for key, values in out]
+
+    return out
+
 
