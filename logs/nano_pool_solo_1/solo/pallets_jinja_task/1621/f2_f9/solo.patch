+    def _on_template_changed(self, file_paths: t.List[str]) -> None:
+        """Invalidate cached templates whose backing file is one of
+        ``file_paths``.  ``file_paths`` is a list of absolute paths to
+        files that have been created, modified, or deleted.
+
+        This is primarily intended for tests and for callers that
+        have their own file system monitoring set up; it is called
+        automatically by nothing in this module.
+        """
+        for file_path in file_paths:
+            template_name = self._get_template_name(file_path)
+            if template_name is None:
+                continue
+
+            cache_key = (weakref.ref(self), template_name)
+            for environment in self._environments:
+                if environment.cache is not None:
+                    try:
+                        del environment.cache[cache_key]
+                    except KeyError:
+                        pass
+
+    def _get_template_name(self, file_path: str) -> t.Optional[str]:
+        file_path = os.path.abspath(file_path)
+
+        for searchpath in self.searchpath:
+            searchpath = os.path.abspath(searchpath)
+            prefix = searchpath + os.path.sep
+
+            if file_path.startswith(prefix):
+                return file_path[len(prefix) :].replace(os.path.sep, "/")
+
+        return None
+
 
