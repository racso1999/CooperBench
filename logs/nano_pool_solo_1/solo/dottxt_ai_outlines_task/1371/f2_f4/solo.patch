+def _register_filters(
+    env: jinja2.Environment, builtin_filters: Dict[str, Callable]
+) -> None:
+    """Populate a Jinja2 environment's filters.
+
+    Filters are applied in increasing order of precedence: globally
+    registered filters first, then the requested built-in filter
+    categories, and finally the prompt module's own built-in filters
+    (`name`, `description`, `source`, `signature`, `schema`, `args`),
+    which are never overridden.
+
+    """
+    env.filters.update(_FILTER_REGISTRY)
+    env.filters.update(builtin_filters)
+
+    env.filters["name"] = get_fn_name
+    env.filters["description"] = get_fn_description
+    env.filters["source"] = get_fn_source
+    env.filters["signature"] = get_fn_signature
+    env.filters["schema"] = get_schema
+    env.filters["args"] = get_fn_args
+
