+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain matches.
+    """
+
+    _email_regex = re.compile(r'^[^@\s]+@([^@\s]+)$')
+
+    def __init__(self, *, domain: Optional[str] = None):
+        """
+        Args:
+            domain: Domain of the email address, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'sample@example.com' == IsEmail
+        assert 'sample@example.com' == IsEmail(domain='example.com')
+        assert 'sample@example.com' != IsEmail(domain='example.org')
+        assert 'not-a-valid-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(domain or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        m = self._email_regex.match(other)
+        if not m:
+            return False
+
+        if self.domain is not None and m.group(1) != self.domain:
+            return False
+
+        return True
+
+
+HashAlgorithm = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+_hash_lengths = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm.
+    """
+
+    def __init__(self, algorithm: HashAlgorithm):
+        """
+        Args:
+            algorithm: The algorithm to use for the hash, must be one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'hello').hexdigest() == IsHash('md5')
+        assert hashlib.sha256(b'hello').hexdigest() == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('sha256')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self._length = _hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self._length:
+            return False
+
+        return re.fullmatch('[0-9a-fA-F]+', other) is not None
