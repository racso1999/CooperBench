+_mac_format_regexes = {
+    'colon': re.compile(r'^([0-9a-f]{2}:){5}[0-9a-f]{2}$', re.IGNORECASE),
+    'hyphen': re.compile(r'^([0-9a-f]{2}-){5}[0-9a-f]{2}$', re.IGNORECASE),
+    'dot': re.compile(r'^([0-9a-f]{4}\.){2}[0-9a-f]{4}$', re.IGNORECASE),
+    'compact': re.compile(r'^[0-9a-f]{12}$', re.IGNORECASE),
+}
+
+
+class IsMac(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid MAC address, optionally checking its format.
+    """
+
+    def __init__(self, format: Literal[None, 'colon', 'hyphen', 'dot', 'compact'] = None):
+        """
+        Args:
+            format: The format of the MAC address to check, if omitted, all formats are accepted.
+
+        ```py title="IsMac"
+        from dirty_equals import IsMac
+
+        assert '00:1B:44:11:3A:B7' == IsMac
+        assert '00:1b:44:11:3a:b7' == IsMac
+        assert '00-1B-44-11-3A-B7' == IsMac('hyphen')
+        assert '001B.4411.3AB7' == IsMac('dot')
+        assert '001b44113ab7' == IsMac('compact')
+        assert '00:1B:44:11:3A:B7' != IsMac('hyphen')
+        ```
+        """
+        self.format = format
+        super().__init__(format or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if self.format is not None:
+            regex = _mac_format_regexes[self.format]
+            return bool(regex.match(other))
+        else:
+            return any(regex.match(other) for regex in _mac_format_regexes.values())
+
+
+_email_regex = re.compile(r'^[^@\s]+@([^@\s]+\.[^@\s]+)$')
+
+
+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking its domain.
+    """
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: The domain the email address must belong to, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'foobar@example.com' == IsEmail
+        assert 'foobar@example.com' == IsEmail(domain='example.com')
+        assert 'foobar@example.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(domain or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        m = _email_regex.match(other)
+        if not m:
+            return False
+
+        if self.domain is not None:
+            return m.group(1) == self.domain
+        else:
+            return True
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
