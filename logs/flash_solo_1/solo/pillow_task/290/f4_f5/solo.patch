+    def _quantize_mse(self, quantized):
+        """
+        Returns the mean square error, in RGB space, between this image and
+        a quantized version of it.
+        """
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(self.convert("RGB"), quantized.convert("RGB"))
+        stat = ImageStat.Stat(diff)
+        return sum(stat.sum2) / sum(stat.count)
+
+    @staticmethod
+    def _adjust_palette_lightness(im, lightness_factor):
+        """
+        Scales the channel values of an image's palette by ``lightness_factor``,
+        leaving any alpha channel untouched. Modifies ``im`` in place.
+        """
+        mode = im.palette.mode
+        channels = len(mode)
+        alpha_index = mode.find("A")
+
+        palette_bytes = im.palette.palette
+        adjusted = bytearray(len(palette_bytes))
+        for i in range(0, len(palette_bytes), channels):
+            for c in range(channels):
+                value = palette_bytes[i + c]
+                if c == alpha_index:
+                    adjusted[i + c] = value
+                else:
+                    adjusted[i + c] = min(255, max(0, round(value * lightness_factor)))
+        im.putpalette(bytes(adjusted), mode)
+
