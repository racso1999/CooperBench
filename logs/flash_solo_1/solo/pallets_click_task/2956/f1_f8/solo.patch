+    def get_option_history(self, name: str) -> list[dict[str, t.Any]] | None:
+        """Get the recorded history of how an option's value was set.
+
+        Returns ``None`` if history tracking is disabled for this
+        context (see the ``track_changes`` parameter of
+        :class:`Command`). Returns an empty list if tracking is
+        enabled but no history exists for the given name, including
+        when the name does not match any known parameter.
+
+        :param name: The parameter name (e.g. ``"count"``) or one of
+            its option flags (e.g. ``"--count"``, ``"-c"``).
+
+        .. versionadded:: 8.3
+        """
+        if not self._track_changes:
+            return None
+
+        param_name = name
+
+        if name.startswith("-"):
+            for param in self.command.params:
+                if name in param.opts or name in param.secondary_opts:
+                    param_name = param.name  # type: ignore[assignment]
+                    break
+
+        return list(self._option_history.get(param_name, []))
+
 
