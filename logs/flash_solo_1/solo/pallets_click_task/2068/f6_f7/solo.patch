+                    "BELOW_NORMAL_PRIORITY_CLASS": 0x00004000,
+                    "NORMAL_PRIORITY_CLASS": 0x00000020,
+                    "ABOVE_NORMAL_PRIORITY_CLASS": 0x00008000,
+                    "HIGH_PRIORITY_CLASS": 0x00000080,
