+/// A named character class used to search for a matching grapheme cluster in
+/// [`first`]($str.first) and [`last`]($str.last).
+#[derive(Debug, Copy, Clone, Eq, PartialEq, Hash, Cast)]
+pub enum CharPattern {
+    /// Matches alphabetic characters.
+    Alpha,
+    /// Matches numeric characters.
+    Numeric,
+    /// Matches alphabetic or numeric characters.
+    Alphanumeric,
+    /// Matches uppercase letters.
+    Uppercase,
+    /// Matches lowercase letters.
+    Lowercase,
+    /// Matches whitespace.
+    Whitespace,
+}
+
+impl CharPattern {
+    /// Whether the given character belongs to this class.
+    fn matches(self, c: char) -> bool {
+        match self {
+            Self::Alpha => c.is_alphabetic(),
+            Self::Numeric => c.is_numeric(),
+            Self::Alphanumeric => c.is_alphanumeric(),
+            Self::Uppercase => c.is_uppercase(),
+            Self::Lowercase => c.is_lowercase(),
+            Self::Whitespace => c.is_whitespace(),
+        }
+    }
+
+    /// The name of this pattern, as it is written in Typst code.
+    fn name(self) -> &'static str {
+        match self {
+            Self::Alpha => "alpha",
+            Self::Numeric => "numeric",
+            Self::Alphanumeric => "alphanumeric",
+            Self::Uppercase => "uppercase",
+            Self::Lowercase => "lowercase",
+            Self::Whitespace => "whitespace",
+        }
+    }
+}
+
+/// A letter case to convert a grapheme cluster to, used by
+/// [`first`]($str.first) and [`last`]($str.last).
+#[derive(Debug, Copy, Clone, Eq, PartialEq, Hash, Cast)]
+pub enum StrCase {
+    /// Converts to uppercase.
+    Upper,
+    /// Converts to lowercase.
+    Lower,
+    /// Converts to title case: The first scalar value is uppercased, the
+    /// rest are lowercased.
+    Title,
+}
+
+/// Applies the given case, if any, to a single grapheme cluster.
+fn apply_case(case: Option<StrCase>, grapheme: &str) -> Str {
+    match case {
+        None => grapheme.into(),
+        Some(StrCase::Upper) => grapheme.to_uppercase().into(),
+        Some(StrCase::Lower) => grapheme.to_lowercase().into(),
+        Some(StrCase::Title) => {
+            let mut chars = grapheme.chars();
+            let mut result = EcoString::new();
+            if let Some(first) = chars.next() {
+                result.extend(first.to_uppercase());
+            }
+            result.extend(chars.flat_map(char::to_lowercase));
+            result.into()
+        }
+    }
+}
+
