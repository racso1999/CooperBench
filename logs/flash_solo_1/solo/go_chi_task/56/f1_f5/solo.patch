+// reverseMethodMap is the inverse of methodMap, used to convert a
+// methodTyp back into its string representation, e.g. when building the
+// Allow header for 405 responses.
+var reverseMethodMap = map[methodTyp]string{
+	mCONNECT: http.MethodConnect,
+	mDELETE:  http.MethodDelete,
+	mGET:     http.MethodGet,
+	mHEAD:    http.MethodHead,
+	mOPTIONS: http.MethodOptions,
+	mPATCH:   http.MethodPatch,
+	mPOST:    http.MethodPost,
+	mPUT:     http.MethodPut,
+	mTRACE:   http.MethodTrace,
+}
+
+// methodNames is an alias of reverseMethodMap used to convert method
+// types back to their string names, e.g. for CORS headers.
+var methodNames = reverseMethodMap
+
+// GetMethodName returns the string representation of a methodTyp, or ""
+// if it isn't a known method.
+func GetMethodName(method methodTyp) string {
+	return methodNames[method]
+}
