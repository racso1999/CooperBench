+// EnableCORS turns on Cross-Origin Resource Sharing support for the router
+// using DefaultCORSOptions. See EnableCORSWithOptions for details.
+func (mx *Mux) EnableCORS() {
+	mx.EnableCORSWithOptions(DefaultCORSOptions())
+}
+
+// EnableCORSWithOptions turns on Cross-Origin Resource Sharing support for
+// the router using the given options. It installs the CORS middleware to
+// annotate every response, and configures the method-not-allowed handler
+// so that preflight OPTIONS requests are answered automatically with a 204
+// and the Access-Control-Allow-Methods detected for the requested route.
+func (mx *Mux) EnableCORSWithOptions(options CORSOptions) {
+	mx.Use(CORS(options))
+	mx.MethodNotAllowed(corsMethodNotAllowedHandler(options))
+}
+
+// WithCORS returns an inline router group with Cross-Origin Resource
+// Sharing enabled using DefaultCORSOptions.
+func (mx *Mux) WithCORS() Router {
+	im := mx.With(CORS(DefaultCORSOptions()))
+	if m, ok := im.(*Mux); ok {
+		m.MethodNotAllowed(corsMethodNotAllowedHandler(DefaultCORSOptions()))
+	}
+	return im
+}
