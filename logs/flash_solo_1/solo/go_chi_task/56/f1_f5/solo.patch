 }
 
+// appendAllowedMethods appends the methods with registered handlers in eps
+// to methods, skipping duplicates and the internal mSTUB/mALL markers.
+// It's used to collect the set of methods to report via the Allow header
+// on 405 responses.
+func appendAllowedMethods(methods []methodTyp, eps endpoints) []methodTyp {
+	for mt, ep := range eps {
+		if mt == mALL || mt == mSTUB || ep == nil || ep.handler == nil {
+			continue
+		}
+
+		found := false
+		for _, m := range methods {
+			if m == mt {
+				found = true
+				break
+			}
+		}
+		if !found {
+			methods = append(methods, mt)
+		}
+	}
+	return methods
+}
+
+// sortedMethodNames returns the string names of methods in a stable,
+// deterministic order suitable for use in an Allow header.
+func sortedMethodNames(methods []methodTyp) []string {
+	sorted := make([]methodTyp, len(methods))
+	copy(sorted, methods)
+	sort.Slice(sorted, func(i, j int) bool { return sorted[i] < sorted[j] })
+
+	names := make([]string, 0, len(sorted))
+	for _, mt := range sorted {
+		if name := reverseMethodMap[mt]; name != "" {
+			names = append(names, name)
+		}
+	}
+	return names
+}
