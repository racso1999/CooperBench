+    def add_alias(self, alias: str, target: str) -> None:
+        """Register ``alias`` as another name that resolves to the
+        ``target`` template. The alias is resolved once, before the
+        normal template lookup happens, so aliases do not chain.
+
+        Calling this again with the same ``alias`` overwrites the
+        previous target.
+
+        .. versionadded:: 3.1
+        """
+        self._aliases[alias] = target
+
+    def remove_alias(self, alias: str) -> None:
+        """Remove a previously registered alias. Safe to call with a
+        name that was never aliased.
+
+        .. versionadded:: 3.1
+        """
+        self._aliases.pop(alias, None)
+
+    def resolve_alias(self, template: str) -> str:
+        """Return the target template name for ``template`` if it is a
+        registered alias, otherwise return it unchanged.
+        """
+        return self._aliases.get(template, template)
