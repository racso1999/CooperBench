diff --git a/src/datasets/features/features.py b/src/datasets/features/features.py
index 6a0da6401..1dca2da64 100644
--- a/src/datasets/features/features.py
+++ b/src/datasets/features/features.py
@@ -1248,12 +1248,26 @@ class Features(dict):
     def update(self, iterable, **kwds):
         if hasattr(iterable, "keys"):
             for key in iterable.keys():
-                self[key] = iterable[key]
+                self._update_column(key, iterable[key])
         else:
             for key, value in iterable:
-                self[key] = value
+                self._update_column(key, value)
         for key in kwds:
-            self[key] = kwds[key]
+            self._update_column(key, kwds[key])
+
+    def _update_column(self, key: str, value: FeatureType):
+        # If both the current and the new value for this column are dictionaries (either plain
+        # dicts or `Sequence`/`Features` objects backed by one), merge them instead of letting the
+        # new value overwrite the existing one.
+        if key in self:
+            current_value = self[key]
+            current_dict = current_value.feature if isinstance(current_value, Sequence) else current_value
+            new_dict = value.feature if isinstance(value, Sequence) else value
+            if isinstance(current_dict, dict) and isinstance(new_dict, dict):
+                current_dict.update(new_dict)
+                self[key] = current_value
+                return
+        self[key] = value
 
     def __reduce__(self):
         return Features, (dict(self),)
