+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes a string into tokens, also returning the starting character position of
+        each token in `text`.
+
+        Splits `text` around any allowed special tokens, then, for the ordinary text segments,
+        splits into regex pieces (same as the Rust encoder) and encodes each piece on its own so
+        that piece/token boundaries can be mapped back to character offsets.
+        """
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        if allowed_special:
+            special_pattern = _special_token_regex(frozenset(allowed_special))
+            segments = []
+            last_end = 0
+            for m in special_pattern.finditer(text):
+                if m.start() > last_end:
+                    segments.append((text[last_end : m.start()], last_end, False))
+                segments.append((m.group(), m.start(), True))
+                last_end = m.end()
+            if last_end < len(text):
+                segments.append((text[last_end:], last_end, False))
+        else:
+            segments = [(text, 0, False)]
+
+        pat = regex.compile(self._pat_str)
+        for segment_text, offset, is_special in segments:
+            if is_special:
+                tokens.append(self._special_tokens[segment_text])
+                positions.append(offset)
+                continue
+
+            for piece_match in regex.finditer(pat, segment_text):
+                piece = piece_match.group()
+                piece_offset = offset + piece_match.start()
+                piece_tokens = self._core_bpe.encode_single_piece(piece.encode("utf-8"))
+
+                # Map each token back to a character offset within the piece using the same
+                # continuation-byte technique as decode_with_offsets, since BPE merges operate
+                # on bytes rather than characters.
+                char_len = 0
+                for token in piece_tokens:
+                    token_bytes = self._core_bpe.decode_single_token_bytes(token)
+                    token_start = max(0, char_len - (0x80 <= token_bytes[0] < 0xC0))
+                    tokens.append(token)
+                    positions.append(piece_offset + token_start)
+                    char_len += sum(1 for c in token_bytes if not 0x80 <= c < 0xC0)
+
+        return tokens, positions
+
