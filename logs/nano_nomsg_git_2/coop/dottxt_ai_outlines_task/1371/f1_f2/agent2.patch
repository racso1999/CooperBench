+# Registry of filters that are made available to every prompt template.
+# Filters registered here can be used in any template without having to
+# be passed explicitly. See `register_filter` and `unregister_filter`.
+FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter that will be available to all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered global filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    FILTERS.pop(name, None)
+
 
