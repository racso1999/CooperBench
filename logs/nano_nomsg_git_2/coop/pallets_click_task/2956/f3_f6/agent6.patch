+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dictionary-based dynamic defaults now that every
+        parameter has a final value.
+
+        A dynamic default maps another option's declaration (e.g.
+        ``"--protocol"``) to a ``{value: default}`` mapping. It's only
+        applied to options whose value still comes from their static
+        default, i.e. nothing was given on the command line, through an
+        environment variable, or a default map.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved_value = None
+
+            for source_decl, mapping in param.default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if source_decl in p.opts
+                        or source_decl in getattr(p, "secondary_opts", ())
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                match = mapping.get(str(source_value))
+
+                if match is not None:
+                    resolved_value = match
+
+            if resolved_value is not None:
+                ctx.params[param.name] = param.type_cast_value(  # type: ignore[arg-type]
+                    ctx, resolved_value
+                )
+
