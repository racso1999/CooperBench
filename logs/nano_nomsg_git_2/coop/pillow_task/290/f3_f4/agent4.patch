+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A lenient threshold should be satisfied with fewer colors than the max
+    lenient = image.quantize(colors=256, error_threshold=50)
+    assert len(lenient.getcolors()) < 256
+
+    # An unreachable threshold should fall back to the requested color count
+    strict = image.quantize(colors=32, error_threshold=0.001)
+    assert len(strict.getcolors()) == 32
+
