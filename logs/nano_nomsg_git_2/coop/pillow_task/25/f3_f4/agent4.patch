+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "red")
+        im.save(temp_file)
+
+        # No backup should be created if the file does not already exist
+        new_file = tmp_path / "new.png"
+        im.save(new_file, backup=True)
+        assert not os.path.exists(str(new_file) + ".bak")
+
+        im2 = Image.new("RGB", (1, 1), "blue")
+        im2.save(temp_file, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        with Image.open(backup_file) as backup_im:
+            assert backup_im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as reloaded:
+            assert reloaded.getpixel((0, 0)) == (0, 0, 255)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "red")
+        im.save(temp_file)
+
+        im2 = Image.new("RGB", (1, 1), "blue")
+        im2.save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
