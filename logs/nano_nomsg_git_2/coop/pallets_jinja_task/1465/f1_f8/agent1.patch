+    return _group_tuples(await auto_to_list(value), expr, case_sensitive)
+
+
+def _group_tuples(
+    value: "t.Iterable[V]",
+    expr: t.Callable[[t.Any], t.Any],
+    case_sensitive: bool,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    if case_sensitive:
+        key_func = expr
+    else:
+
+        def key_func(item: t.Any) -> t.Any:
+            return ignore_case(expr(item))
+
+    sorted_value = sorted(value, key=key_func)
+    out = [
+        _GroupTuple(key, list(values))
+        for key, values in groupby(sorted_value, key_func)
     ]
 
+    if not case_sensitive:
+        # Use the real key, rather than the lower-cased key, from the
+        # first item in each group.
+        out = [_GroupTuple(expr(values[0]), values) for _, values in out]
+
+    return out
+
 
