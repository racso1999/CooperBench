+def set_ttl(seconds: Optional[int] = None) -> None:
+    """Set the time-to-live (in seconds) for entries added to the active DSPy cache.
+
+    Args:
+        seconds: The number of seconds after which new cache entries expire. Pass None to disable expiration.
+    """
+    import dspy
+
+    cache = dspy.cache
+    cache.ttl = seconds
+
+    if cache.enable_memory_cache:
+        maxsize = getattr(cache.memory_cache, "maxsize", None) or 1000000
+        if seconds is not None:
+            cache.memory_cache = TTLCache(maxsize=maxsize, ttl=seconds)
+        else:
+            cache.memory_cache = LRUCache(maxsize=maxsize)
+
