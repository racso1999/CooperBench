+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and end it if so.
+
+        This method should be called periodically by the streaming system, e.g. on a timer, so that a stalled
+        upstream (no chunks arriving) doesn't leave the consumer waiting indefinitely. If a timeout is detected,
+        a `StreamResponse` with an empty `chunk` is returned to signal the end of the stream, and the listener's
+        state is reset so it can pick up a new stream (or be reused, if `allow_reuse` is set).
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has been exceeded, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response_kwargs = {
+            "predict_name": self.predict_name,
+            "signature_field_name": self.signature_field_name,
+            "chunk": "",
+        }
+        if "is_last_chunk" in {f.name for f in fields(StreamResponse)}:
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(**response_kwargs)
+
+        # Reset state unconditionally so the listener isn't left stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
