+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a given country.
+    """
+
+    _generic_pattern: Pattern[str] = re.compile(r'^\+\d{7,15}$|^\d{7,15}$')
+
+    _country_patterns: Dict[str, Tuple[Pattern[str], ...]] = {
+        'US': (
+            re.compile(r'^\+1\d{10}$'),
+            re.compile(r'^\d{10}$'),
+        ),
+        'GB': (
+            re.compile(r'^\+44\d{9,10}$'),
+            re.compile(r'^0\d{9,10}$'),
+        ),
+    }
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to restrict validation to that country's phone
+                number format. If omitted, a generic international/national format is accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        ```
+        """
+        self.country: Optional[str] = country.upper() if country else None
+        super().__init__(plain_repr('*') if self.country is None else self.country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = re.sub(r'[\s\-.()]', '', other)
+        if not normalized:
+            return False
+
+        if self.country is None:
+            return bool(self._generic_pattern.match(normalized))
+
+        patterns: Optional[Tuple[Pattern[str], ...]] = self._country_patterns.get(self.country)
+        if patterns is None:
+            # unknown/unsupported country, fall back to generic international validation
+            return bool(re.match(r'^\+\d{7,15}$', normalized))
+
+        return any(pattern.match(normalized) is not None for pattern in patterns)
+
