+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, e.g. on a timer, so that a stalled
+        upstream that stops sending chunks doesn't leave the consumer waiting forever. If the idle timeout
+        has elapsed since the last chunk was received, this emits a `StreamResponse` with an empty `chunk`
+        to signal termination and resets the listener state, regardless of `allow_reuse`, so the listener
+        isn't left stuck in a started state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        extra_kwargs = {}
+        if "is_last_chunk" in StreamResponse.__dataclass_fields__:
+            extra_kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **extra_kwargs)
+
+        # Reset the listener state unconditionally, even if `allow_reuse` is False, so that a timed-out
+        # listener doesn't remain stuck mid-stream.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = current_ts
+
+        return response
