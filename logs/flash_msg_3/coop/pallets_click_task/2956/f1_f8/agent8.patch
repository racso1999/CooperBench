+    def get_option_history(self, name: str) -> list[dict[str, t.Any]] | None:
+        """Get the recorded history of values assigned to an option or
+        argument. Each entry is a dict with the keys ``value``,
+        ``source`` (a :class:`ParameterSource` member), and
+        ``timestamp``.
+
+        History is only recorded when the command was created with
+        ``track_changes=True``.
+
+        :param name: The parameter name (e.g. ``"count"``) or one of
+            its option flags (e.g. ``"--count"`` or ``"-c"``).
+        :return: ``None`` if history tracking is disabled for this
+            context. Otherwise a list of history entries, which is
+            empty if the parameter has no recorded history or does
+            not exist.
+
+        .. versionadded:: 8.3
+        """
+        if not self._track_changes:
+            return None
+
+        if name not in self._option_history:
+            for param in self.command.params:
+                if name in getattr(param, "opts", ()) or name in getattr(
+                    param, "secondary_opts", ()
+                ):
+                    name = param.name  # type: ignore[assignment]
+                    break
+
+        return self._option_history.get(name, [])
+
 
