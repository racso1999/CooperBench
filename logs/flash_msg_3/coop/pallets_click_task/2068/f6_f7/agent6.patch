+    def _set_process_priority(self, pid: int) -> None:
+        """Best-effort attempt to set the CPU priority of the given
+        process. Any failure (unsupported platform, missing
+        permissions, missing dependency, etc.) is silently ignored so
+        that editing is never blocked by this.
+        """
+        if self.process_priority is None:
+            return
+
+        try:
+            if WIN:
+                import ctypes
+
+                priority_class = _WIN_PRIORITY_CLASSES[self.process_priority]
+                handle = ctypes.windll.kernel32.OpenProcess(  # type: ignore[attr-defined]
+                    0x0200 | 0x0400, False, pid
+                )
+                if handle:
+                    try:
+                        ctypes.windll.kernel32.SetPriorityClass(  # type: ignore[attr-defined]
+                            handle, priority_class
+                        )
+                    finally:
+                        ctypes.windll.kernel32.CloseHandle(handle)  # type: ignore[attr-defined]
+            else:
+                nice_value = _UNIX_NICE_VALUES[self.process_priority]
+                current = os.getpriority(os.PRIO_PROCESS, pid)
+                os.setpriority(os.PRIO_PROCESS, pid, current + nice_value)
+        except Exception:
+            pass
