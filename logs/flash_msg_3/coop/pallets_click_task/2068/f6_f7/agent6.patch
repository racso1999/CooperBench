+_PROCESS_PRIORITIES = ("low", "below_normal", "normal", "above_normal", "high")
+
+# Maps priority name to a Windows priority class, for use with
+# ``psutil.Process.nice`` or ``subprocess.CREATE_*`` flags.
+_WIN_PRIORITY_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+# Maps priority name to a Unix ``nice`` value. Range is -20 (highest
+# priority) to 19 (lowest priority); only unprivileged users can't raise
+# priority above 0, so setting "above_normal"/"high" may silently have no
+# effect without elevated permissions.
+_UNIX_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
