+_PROCESS_PRIORITIES = ("low", "below_normal", "normal", "above_normal", "high")
+
+# Unix ``nice`` values corresponding to each priority level. Lower values
+# mean higher scheduling priority; negative values typically require
+# elevated privileges and are ignored if they cannot be applied.
+_UNIX_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+
+def _nice_preexec_fn(nice_value: int) -> t.Callable[[], None]:
+    def _preexec() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            pass
+
+    return _preexec
+
