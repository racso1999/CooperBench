+    def _get_lock_filename(self, filename: str) -> str:
+        directory = os.path.dirname(filename)
+        basename = os.path.basename(filename)
+        return os.path.join(directory, f".{basename}.lock")
+
+    def _create_lock_file(self, filename: str) -> str:
+        import datetime
+
+        lock_filename = self._get_lock_filename(filename)
+
+        try:
+            # O_CREAT | O_EXCL is atomic: the open fails if the file
+            # already exists, so two processes can't both "win" the
+            # race to create the lock.
+            fd = os.open(lock_filename, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
+        except FileExistsError:
+            raise ClickException(
+                _(
+                    "Could not acquire lock for {filename!r}: lock file"
+                    " {lock_filename!r} already exists. Another edit"
+                    " session may be in progress."
+                ).format(filename=filename, lock_filename=lock_filename)
+            ) from None
+
+        try:
+            content = (
+                f"PID: {os.getpid()}\nTime: {datetime.datetime.now().isoformat()}\n"
+            )
+            os.write(fd, content.encode("utf-8"))
+        finally:
+            os.close(fd)
+
+        return lock_filename
+
+    def _remove_lock_file(self, lock_filename: str) -> None:
+        with contextlib.suppress(OSError):
+            os.remove(lock_filename)
+
+    @contextlib.contextmanager
+    def _lock_context(self, filename: str) -> cabc.Iterator[None]:
+        lock_filename = self._create_lock_file(filename) if self.lock_files else None
+
+        try:
+            yield
+        finally:
+            if lock_filename is not None:
+                self._remove_lock_file(lock_filename)
+
