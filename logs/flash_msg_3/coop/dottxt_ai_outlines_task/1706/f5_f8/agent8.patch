         self.xgrammar_logits_processor = None
+        self.track_memory_usage = track_memory_usage
+        self._init_memory_stats()
         super().__init__("torch")
 
+    def _init_memory_stats(self):
+        """Initialize the memory statistics tracking data structures."""
+        self._memory_stats = {
+            "peak_memory_mb": 0.0,
+            "total_calls": 0,
+            "memory_history": [],
+        }
+
+    def _get_memory_usage(self) -> float:
+        """Return the current process memory usage in MB.
+
+        Returns 0.0 if the memory usage cannot be determined.
+
+        """
+        try:
+            import psutil
+
+            process = psutil.Process()
+            return process.memory_info().rss / (1024 * 1024)
+        except Exception:
+            return 0.0
+
+    def _update_memory_stats(self, memory_mb: float):
+        """Update the running memory statistics with a new sample."""
+        self._memory_stats["total_calls"] += 1
+        self._memory_stats["memory_history"].append(memory_mb)
+        if memory_mb > self._memory_stats["peak_memory_mb"]:
+            self._memory_stats["peak_memory_mb"] = memory_mb
+
+        if self._memory_stats["total_calls"] % 10 == 0:
+            logger.info(
+                "XGrammarLogitsProcessor memory usage: %.2f MB "
+                "(peak: %.2f MB, calls: %d)",
+                memory_mb,
+                self._memory_stats["peak_memory_mb"],
+                self._memory_stats["total_calls"],
+            )
+
+    def get_memory_stats(self) -> dict:
+        """Return the collected memory usage statistics.
+
+        Returns
+        -------
+        dict
+            A dictionary containing `peak_memory_mb`, `total_calls`,
+            `avg_memory_per_call_mb` and `memory_history`.
+
+        """
+        history = self._memory_stats["memory_history"]
+        avg_memory = sum(history) / len(history) if history else 0.0
+        return {
+            "peak_memory_mb": self._memory_stats["peak_memory_mb"],
+            "total_calls": self._memory_stats["total_calls"],
+            "avg_memory_per_call_mb": avg_memory,
+            "memory_history": list(history),
+        }
+
     def reset(self):
         """Reset the logits processor for a new generation."""
         self.xgrammar_logits_processor = None
+        if self.track_memory_usage:
+            self._init_memory_stats()
 
     def process_logits(self, input_ids: TensorType, logits: TensorType) -> TensorType:
         """Bias the logits."""
