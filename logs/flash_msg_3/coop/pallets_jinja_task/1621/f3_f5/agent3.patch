+def validate_template_path(template: str) -> None:
+    """Check a template path for dangerous or malformed sequences before
+    it is used to load a template.  Raises :exc:`TemplateNotFound` if the
+    path is empty, contains a null byte or other disallowed control
+    characters, is an absolute path, or starts with a Windows drive
+    letter.
+    """
+    if not template:
+        raise TemplateNotFound(template)
+
+    if "\x00" in template:
+        raise TemplateNotFound(template)
+
+    if template.startswith("/") or template.startswith("\\"):
+        raise TemplateNotFound(template)
+
+    if _drive_letter_re.match(template):
+        raise TemplateNotFound(template)
+
+    for char in template:
+        if ord(char) < 32 and char not in _allowed_control_chars:
+            raise TemplateNotFound(template)
+
