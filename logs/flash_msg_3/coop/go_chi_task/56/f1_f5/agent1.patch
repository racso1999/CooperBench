+// method not allowed. If methodsAllowed is non-empty, the response includes
+// an Allow header listing the registered methods for the matched route,
+// per RFC 9110.
+func methodNotAllowedHandler(methodsAllowed ...methodTyp) http.HandlerFunc {
+	return func(w http.ResponseWriter, r *http.Request) {
+		if allowed := allowedMethods(methodsAllowed); len(allowed) > 0 {
