+// allowedMethods returns the sorted, deduplicated list of method names for
+// the given methodTyp values, in a stable order suitable for the Allow
+// header on 405 responses.
+func allowedMethods(methods []methodTyp) []string {
+	if len(methods) == 0 {
+		return nil
+	}
+	set := make(map[methodTyp]bool, len(methods))
+	for _, m := range methods {
+		set[m] = true
+	}
+	list := make([]string, 0, len(methods))
+	for _, m := range methodOrder {
+		if set[m] {
+			if name, ok := reverseMethodMap[m]; ok {
+				list = append(list, name)
+			}
+		}
+	}
+	return list
+}
