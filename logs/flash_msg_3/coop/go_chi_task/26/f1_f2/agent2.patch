+// recordHit builds a RouteMetric for the just-served request and reports
+// it to the configured MetricsCollector.
+func (mx *Mux) recordHit(rctx *Context, r *http.Request, duration time.Duration) {
+	params := make(map[string]string, len(rctx.URLParams.Keys))
+	for i, key := range rctx.URLParams.Keys {
+		if key == "*" {
+			continue
+		}
+		params[key] = rctx.URLParams.Values[i]
+	}
+
+	mx.metricsCollector.RecordHit(r.Context(), r, RouteMetric{
+		Pattern:   rctx.RoutePattern(),
+		Method:    r.Method,
+		Path:      r.URL.Path,
+		Duration:  duration,
+		URLParams: params,
+	})
+}
