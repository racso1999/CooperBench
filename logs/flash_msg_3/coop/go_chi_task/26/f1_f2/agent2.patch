new file mode 100644
index 0000000..d7d53bc
--- /dev/null
+++ b/metrics.go
@@ -0,0 +1,53 @@
+package chi
+
+import (
+	"context"
+	"net/http"
+	"time"
+)
+
+// MetricsCollector is the interface used by Mux to report route hit
+// metrics. Implementations can aggregate hit counts, response times,
+// or forward the data to an external monitoring system.
+type MetricsCollector interface {
+	// RecordHit is called after a matched route handler has finished
+	// serving a request, with the full route pattern and how long the
+	// handler took to execute.
+	RecordHit(ctx context.Context, r *http.Request, m RouteMetric)
+}
+
+// RouteMetric carries the data collected for a single request served by
+// a matched route.
+type RouteMetric struct {
+	// Pattern is the full routing pattern that matched the request,
+	// e.g. "/users/{id}".
+	Pattern string
+
+	// Method is the HTTP method of the request, e.g. "GET".
+	Method string
+
+	// Path is the actual request path that was routed.
+	Path string
+
+	// Duration is how long the matched handler took to serve the request.
+	Duration time.Duration
+
+	// URLParams are the URL parameters captured while matching the route.
+	URLParams map[string]string
+}
+
+// SimpleMetricsCollector is a MetricsCollector implementation that invokes
+// a user-supplied callback function for every recorded hit. It's a
+// lightweight way to hook route metrics into an existing monitoring system
+// without implementing the full MetricsCollector interface.
+type SimpleMetricsCollector struct {
+	// Fn is called for every route hit recorded.
+	Fn func(m RouteMetric)
+}
+
+// RecordHit implements the MetricsCollector interface.
+func (c *SimpleMetricsCollector) RecordHit(ctx context.Context, r *http.Request, m RouteMetric) {
+	if c.Fn != nil {
+		c.Fn(m)
+	}
+}
diff --git a/metrics_test.go b/metrics_test.go
new file mode 100644
index 0000000..ec9c0fc
--- /dev/null
+++ b/metrics_test.go
@@ -0,0 +1,82 @@
+package chi
+
+import (
+	"net/http"
+	"net/http/httptest"
+	"sync"
+	"testing"
+	"time"
+)
+
+func TestMuxMetricsCollector(t *testing.T) {
+	var mu sync.Mutex
+	var hits []RouteMetric
+
+	collector := &SimpleMetricsCollector{
+		Fn: func(m RouteMetric) {
+			mu.Lock()
+			defer mu.Unlock()
+			hits = append(hits, m)
+		},
+	}
+
+	r := NewRouter()
+	r.SetMetricsCollector(collector)
+	r.Get("/users/{id}", func(w http.ResponseWriter, r *http.Request) {
+		time.Sleep(1 * time.Millisecond)
+		w.WriteHeader(http.StatusOK)
+	})
+
+	ts := httptest.NewServer(r)
+	defer ts.Close()
+
+	resp, err := http.Get(ts.URL + "/users/42")
+	if err != nil {
+		t.Fatal(err)
+	}
+	resp.Body.Close()
+
+	mu.Lock()
+	defer mu.Unlock()
+
+	if len(hits) != 1 {
+		t.Fatalf("expected 1 recorded hit, got %d", len(hits))
+	}
+
+	m := hits[0]
+	if m.Pattern != "/users/{id}" {
+		t.Errorf("expected pattern /users/{id}, got %q", m.Pattern)
+	}
+	if m.Method != "GET" {
+		t.Errorf("expected method GET, got %q", m.Method)
+	}
+	if m.Path != "/users/42" {
+		t.Errorf("expected path /users/42, got %q", m.Path)
+	}
+	if m.Duration <= 0 {
+		t.Errorf("expected positive duration, got %v", m.Duration)
+	}
+	if m.URLParams["id"] != "42" {
+		t.Errorf("expected url param id=42, got %q", m.URLParams["id"])
+	}
+}
+
+func TestMuxMetricsCollectorNotConfigured(t *testing.T) {
+	r := NewRouter()
+	r.Get("/ping", func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	})
+
+	ts := httptest.NewServer(r)
+	defer ts.Close()
+
+	resp, err := http.Get(ts.URL + "/ping")
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer resp.Body.Close()
+
+	if resp.StatusCode != http.StatusOK {
+		t.Fatalf("expected status 200, got %d", resp.StatusCode)
+	}
+}
