+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain matches.
+    """
+
+    _email_regex = re.compile(r'^[^@\s]+@([^@\s]+)$')
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: domain to check the email address against, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'sam@example.com' == IsEmail
+        assert 'sam@example.com' == IsEmail(domain='example.com')
+        assert 'sam@example.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(plain_repr('*') if domain is None else domain)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        match = self._email_regex.match(other)
+        if not match:
+            return False
+
+        if self.domain is not None and match.group(1) != self.domain:
+            return False
+
+        return True
