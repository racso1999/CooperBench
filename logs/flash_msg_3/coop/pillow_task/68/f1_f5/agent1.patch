+def test_exif_transpose_xmp_tuple() -> None:
+    with Image.open("Tests/images/xmp_tags_orientation.png") as im:
+        assert im.getexif()[0x0112] == 3
+
+        # XMP data may be stored as a tuple, e.g. when written by some macOS tools
+        im.info["xmp"] = (im.info["xmp"],)
+
+        transposed_im = ImageOps.exif_transpose(im)
+        assert 0x0112 not in transposed_im.getexif()
+
+        assert isinstance(transposed_im.info["xmp"], tuple)
+        assert b"tiff:Orientation" not in transposed_im.info["xmp"][0]
+
+
 def test_exif_transpose_xml_without_xmp() -> None:
     with Image.open("Tests/images/xmp_tags_orientation.png") as im:
         assert im.getexif()[0x0112] == 3
