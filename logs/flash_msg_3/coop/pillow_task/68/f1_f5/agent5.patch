+def test_exif_transpose_logger_callable() -> None:
+    messages = []
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im, logger=messages.append)
+    assert transposed_im is not None
+    assert messages
+    assert any("orientation" in message for message in messages)
+    assert any("Orientation" in message for message in messages)
+
+
+def test_exif_transpose_logger_standard_logger(caplog: pytest.LogCaptureFixture) -> None:
+    test_logger = logging.getLogger("PIL.test_exif_transpose")
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        with caplog.at_level(logging.INFO, logger=test_logger.name):
+            ImageOps.exif_transpose(im, logger=test_logger)
+    assert any(
+        "orientation" in record.message for record in caplog.records
+    )
+
+
+def test_exif_transpose_no_logger() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im)
+    assert transposed_im is not None
+
