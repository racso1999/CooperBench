diff --git a/Tests/test_image.py b/Tests/test_image.py
index c2e850c36..cb4419594 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,16 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_mark_corners(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10))
+        im.save(temp_file, mark_corners=True)
+
+        with Image.open(temp_file) as reloaded:
+            assert reloaded.getpixel((0, 0)) == (255, 0, 0)
+            assert reloaded.getpixel((9, 9)) == (255, 0, 0)
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
