+    def test_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+        im.save(out)
+        assert out.exists()
+
+    def test_dry_run_raises_error(self) -> None:
+        im = Image.new("RGBA", (1, 1))
+        with pytest.raises(OSError):
+            im.save(io.BytesIO(), format="JPEG", dry_run=True)
+
