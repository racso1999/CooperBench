 _fromarray_typemap[((1, 1), _ENDIAN + "f4")] = ("F", "F")
 
 
+def _adjust_palette_lightness(palette, lightness_factor):
+    from . import ImagePalette
+
+    mode = palette.mode
+    channels = len(mode)
+    # don't adjust the alpha channel, if present
+    color_channels = min(channels, 3)
+
+    data = bytearray(palette.tobytes())
+    for i in range(0, len(data), channels):
+        for c in range(color_channels):
+            value = round(data[i + c] * lightness_factor)
+            data[i + c] = max(0, min(255, value))
+
+    return ImagePalette.ImagePalette(mode, bytes(data))
+
+
