diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..6a12662aa 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,41 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_lightness_factor_no_change():
+    image = Image.new("RGB", (10, 10), (100, 150, 200))
+    converted = image.quantize(colors=4)
+    unchanged = image.quantize(colors=4, lightness_factor=1.0)
+    assert converted.getpalette() == unchanged.getpalette()
+
+
+def test_quantize_lightness_factor_brighter():
+    image = Image.new("RGB", (10, 10), (100, 150, 200))
+    converted = image.quantize(colors=4, lightness_factor=1.2)
+    assert converted.getpalette()[:3] == [120, 180, 240]
+
+
+def test_quantize_lightness_factor_darker():
+    image = Image.new("RGB", (10, 10), (100, 150, 200))
+    converted = image.quantize(colors=4, lightness_factor=0.5)
+    assert converted.getpalette()[:3] == [50, 75, 100]
+
+
+def test_quantize_lightness_factor_clamped():
+    image = Image.new("RGB", (10, 10), (200, 220, 240))
+    converted = image.quantize(colors=4, lightness_factor=2.0)
+    assert converted.getpalette()[:3] == [255, 255, 255]
+
+    darkened = image.quantize(colors=4, lightness_factor=-1.0)
+    assert darkened.getpalette()[:3] == [0, 0, 0]
+
+
+def test_quantize_lightness_factor_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette, lightness_factor=1.5)
+    unchanged = image.quantize(palette=palette)
+    assert converted.getpalette() != unchanged.getpalette()
