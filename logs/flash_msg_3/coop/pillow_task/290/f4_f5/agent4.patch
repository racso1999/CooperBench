+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes to the smallest palette size (up to ``colors``) whose mean
+        square error against the original image is at or below
+        ``error_threshold``, falling back to ``colors`` if none qualifies.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        original = self.convert("RGB")
+
+        def quantize_to(num_colors):
+            quantized_im = self._new(self.im.quantize(num_colors, method, kmeans))
+            mode = quantized_im.im.getpalettemode()
+            quantized_im.palette = ImagePalette.ImagePalette(
+                mode, quantized_im.im.getpalette(mode, mode)
+            )
+            return quantized_im
+
+        def mean_square_error(im):
+            stat = ImageStat.Stat(ImageChops.difference(original, im.convert("RGB")))
+            return sum(stat.sum2) / sum(stat.count)
+
+        if colors < 2:
+            return quantize_to(colors)
+
+        candidate = None
+        for num_colors in range(2, colors + 1):
+            candidate = quantize_to(num_colors)
+            if mean_square_error(candidate) <= error_threshold:
+                break
+
+        return candidate
+
