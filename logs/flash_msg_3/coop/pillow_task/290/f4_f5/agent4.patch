--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,41 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_quantize_error_threshold_meets_threshold():
+    image = hopper()
+    error_threshold = 500
+    converted = image.quantize(colors=256, error_threshold=error_threshold)
+
+    from PIL import ImageChops, ImageStat
+
+    stat = ImageStat.Stat(
+        ImageChops.difference(image.convert("RGB"), converted.convert("RGB"))
+    )
+    mse = sum(stat.sum2) / sum(stat.count)
+    assert mse <= error_threshold
+
+
+def test_quantize_error_threshold_falls_back_to_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_ignored_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette, error_threshold=0)
+    without_threshold = image.quantize(palette=palette)
+    assert converted.tobytes() == without_threshold.tobytes()
