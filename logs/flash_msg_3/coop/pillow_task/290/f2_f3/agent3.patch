+    def _sort_palette(self, sort_palette):
+        mode = self.palette.mode
+        mode_len = len(mode)
+        palette = self.palette.palette
+        entries = [
+            tuple(palette[i : i + mode_len]) for i in range(0, len(palette), mode_len)
+        ]
+
+        if sort_palette == "brightness":
+
+            def key(color):
+                rgb = color[:3]
+                return (
+                    0.299 * rgb[0] + 0.587 * rgb[1] + 0.114 * rgb[2],
+                ) + color
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            raise ValueError("sort_palette must be one of 'brightness', 'rgb' or None")
+
+        order = sorted(range(len(entries)), key=lambda i: key(entries[i]))
+        remap = [0] * len(order)
+        for new_index, old_index in enumerate(order):
+            remap[old_index] = new_index
+
+        new_palette = bytearray()
+        for old_index in order:
+            new_palette.extend(entries[old_index])
+
+        im = self.point(remap)
+        im.putpalette(bytes(new_palette), mode)
         return im
 
