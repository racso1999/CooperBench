+def test_max_colors_quantize():
+    image = hopper()
+
+    # max_colors below colors should limit the resulting palette size
+    converted = image.quantize(colors=100, max_colors=32, method=Image.FASTOCTREE)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 32
+
+    # max_colors above colors should have no effect
+    converted = image.quantize(colors=32, max_colors=100, method=Image.FASTOCTREE)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 32
+
+    # not specifying max_colors preserves previous behavior
+    converted = image.quantize(colors=100, method=Image.FASTOCTREE)
+    assert len(converted.getcolors()) == 100
+
+    with pytest.raises(ValueError):
+        image.quantize(max_colors=0)
+
+    with pytest.raises(ValueError):
+        image.quantize(max_colors=257)
+
+
