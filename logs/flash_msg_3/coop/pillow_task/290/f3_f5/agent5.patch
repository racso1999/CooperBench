@@ -85,3 +85,51 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_lightness_factor_default_no_change():
+    image = hopper()
+    converted = image.quantize()
+    converted_brighter = image.quantize(lightness_factor=1.0)
+    assert converted.palette.palette == converted_brighter.palette.palette
+
+
+def test_quantize_lightness_factor_brighten():
+    image = hopper()
+    converted = image.quantize()
+    brighter = image.quantize(lightness_factor=1.5)
+
+    original_palette = converted.palette.palette
+    brighter_palette = brighter.palette.palette
+    assert len(original_palette) == len(brighter_palette)
+    assert sum(brighter_palette) >= sum(original_palette)
+
+
+def test_quantize_lightness_factor_darken():
+    image = hopper()
+    converted = image.quantize()
+    darker = image.quantize(lightness_factor=0.5)
+
+    original_palette = converted.palette.palette
+    darker_palette = darker.palette.palette
+    assert len(original_palette) == len(darker_palette)
+    assert sum(darker_palette) <= sum(original_palette)
+
+
+def test_quantize_lightness_factor_clamped():
+    image = hopper()
+    converted = image.quantize(lightness_factor=100.0)
+    for value in converted.palette.palette:
+        assert 0 <= value <= 255
+
+
+def test_quantize_lightness_factor_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette)
+    brighter = image.quantize(palette=palette, lightness_factor=1.5)
+
+    assert len(converted.palette.palette) == len(brighter.palette.palette)
+    assert sum(brighter.palette.palette) >= sum(converted.palette.palette)
