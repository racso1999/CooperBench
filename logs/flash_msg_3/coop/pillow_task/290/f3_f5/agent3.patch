@@ -85,3 +85,42 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(8, sort_palette="unknown")
+
+
+@pytest.mark.parametrize("sort_palette", ("rgb", "luminance"))
+def test_sort_palette(sort_palette):
+    image = hopper()
+    unsorted_im = image.quantize(8)
+    sorted_im = image.quantize(8, sort_palette=sort_palette)
+
+    assert_image(sorted_im, "P", sorted_im.size)
+
+    # Pixel colors are unaffected by sorting the palette
+    assert_image_similar(sorted_im.convert("RGB"), unsorted_im.convert("RGB"), 1)
+
+    palette = sorted_im.im.getpalette("RGB")
+    used_indices = [index for _, index in sorted_im.getcolors()]
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in sorted(used_indices)]
+
+    def luminance(rgb):
+        return rgb[0] * 299 + rgb[1] * 587 + rgb[2] * 114
+
+    if sort_palette == "rgb":
+        expected = sorted(colors)
+    else:
+        expected = sorted(colors, key=luminance)
+    assert colors == expected
+
+
+def test_sort_palette_rgba():
+    image = hopper("RGBA")
+    unsorted_im = image.quantize(8, Image.FASTOCTREE)
+    sorted_im = image.quantize(8, Image.FASTOCTREE, sort_palette="luminance")
+
+    assert sorted_im.convert("RGBA").tobytes() == unsorted_im.convert("RGBA").tobytes()
