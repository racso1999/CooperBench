+# Global registry of custom filters that are made available to every
+# prompt template in addition to the filters defined locally.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter in the global filter registry.
+
+    Once registered, the filter is automatically available in all prompt
+    templates under the given name, without having to pass it explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Does nothing if no filter is registered under the given name.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove from the registry.
+
+    """
+    _FILTERS.pop(name, None)
+
 
