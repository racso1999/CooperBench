+def _format_debug_preview(text: str, max_len: int = DEBUG_PREVIEW_MAX_LEN) -> str:
+    """Truncate and escape a string for safe, single-line debug log previews."""
+    truncated = len(text) > max_len
+    preview = text[:max_len]
+    preview = preview.replace("\\", "\\\\").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
+    if truncated:
+        preview += "..."
+    return preview
+
+
+_LEADING_VALUE_QUOTE = re.compile(r'^\s*"')
+
+
+def _buffer_preview(raw_buffer: str) -> str:
+    """Build a debug preview of the raw post-identifier buffer.
+
+    Strips a leading value-opening quote (e.g. JSONAdapter's `"key": "value`) so the preview reflects the
+    field's content, while leaving other whitespace untouched so boundary/whitespace issues stay visible.
+    """
+    return _format_debug_preview(_LEADING_VALUE_QUOTE.sub("", raw_buffer, count=1))
+
 
