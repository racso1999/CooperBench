+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This method should be called periodically by the streaming system. If the field's stream has started but
+        not yet ended, and no chunk has been received for at least `idle_timeout_s` seconds, this emits a final
+        `StreamResponse` with an empty `chunk` to signal that the stream should be terminated, then resets the
+        listener's state so it doesn't remain stuck in a "started" state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+        if now_ts - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Unconditionally reset the state so the listener isn't left stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
