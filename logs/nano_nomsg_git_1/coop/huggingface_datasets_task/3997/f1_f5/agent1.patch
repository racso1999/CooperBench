+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the :class:`Features` object
+    in sync with the main dictionary.
+
+    A :obj:`Features` object is a subclass of ``dict`` (rather than ``collections.UserDict``, for performance
+    reasons), so any dictionary method that can mutate the instance in place (``__setitem__``, ``__delitem__``,
+    ``update``, etc.) has to be wrapped with this decorator to make sure ``_column_requires_decoding`` doesn't
+    get out of sync with the main dictionary.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        self: "Features" = args[0]
+        out = func(*args, **kwargs)
+        assert hasattr(self, "_column_requires_decoding")
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper._decorator_name_ = "_keep_dicts_synced"
+    return wrapper
+
+
