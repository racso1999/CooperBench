+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash for the given algorithm.
+
+    Checks length and character set, but not that the value is the hash of any particular data.
+    """
+
+    hash_lengths: Dict[str, int] = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The algorithm used to generate the hash, this is used to check the length
+                of the hash, either `md5`, `sha1`, `sha224`, `sha256`, `sha384` or `sha512`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert 'not_a_hash' != IsHash('md5')
+
+        assert 'aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d' == IsHash('sha1')
+
+        assert '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' == IsHash('sha256')
+        assert 'not_a_valid_sha256_hash' != IsHash('sha256')
+        ```
+        """
+        algorithm_lower = algorithm.lower()
+        try:
+            self.hash_length = self.hash_lengths[algorithm_lower]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}, must be one of {sorted(self.hash_lengths)}')
+        self.algorithm = algorithm
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return len(other) == self.hash_length and re.fullmatch('[0-9a-fA-F]+', other) is not None
