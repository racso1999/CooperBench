+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette using the given sort method, remapping
+        pixel values to match. Used by :py:meth:`~PIL.Image.Image.quantize`.
+
+        :param sort_palette: Either ``"luminance"`` or ``"rgb"``.
+        :returns: A new image
+        """
+        mode = self.palette.mode
+        channels = len(mode)
+        palette = self.im.getpalette(mode, mode)
+        num_colors = self.im.getextrema()[1] + 1
+
+        def luminance(i):
+            r, g, b = palette[i * channels : i * channels + 3]
+            return r * 299 + g * 587 + b * 114
+
+        def rgb(i):
+            return tuple(palette[i * channels : i * channels + channels])
+
+        if sort_palette == "luminance":
+            key = luminance
+        elif sort_palette == "rgb":
+            key = rgb
+        else:
+            raise ValueError("sort_palette must be 'luminance', 'rgb' or None")
+
+        new_order = sorted(range(num_colors), key=key)
+
+        lut = list(range(256))
+        for new_index, old_index in enumerate(new_order):
+            lut[old_index] = new_index
+        im = self.point(lut)
+
+        new_palette = bytearray()
+        for old_index in new_order:
+            new_palette += palette[old_index * channels : (old_index + 1) * channels]
+        new_palette += palette[num_colors * channels :]
+
+        im.putpalette(new_palette, mode)
         return im
 
