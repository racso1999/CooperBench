+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        dynamic mapping (``{"--source-option": {value: default}}``).
+
+        This runs after every parameter has been parsed so that a
+        dynamic default can depend on the final value of another
+        option. It only applies to options whose value still comes
+        from :attr:`ParameterSource.DEFAULT`, i.e. no explicit value
+        was given via the command line, an environment variable, or
+        ``default_map``.
+        """
+        opts_to_param: dict[str, Parameter] = {}
+
+        for param in ctx.command.params:
+            for opt in (*param.opts, *param.secondary_opts):
+                opts_to_param[opt] = param
+
+        for param in ctx.command.params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None or not param.expose_value:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = opts_to_param.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore[arg-type]
+
