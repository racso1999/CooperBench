diff --git a/src/click/types.py b/src/click/types.py
index 684cb3b..d3eebcd 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -2,6 +2,7 @@ from __future__ import annotations
 
 import collections.abc as cabc
 import enum
+import itertools
 import os
 import stat
 import sys
@@ -1125,6 +1126,19 @@ def convert_type(ty: t.Any | None, default: t.Any | None = None) -> ParamType:
     return FuncParamType(ty)
 
 
+def _batched(
+    iterable: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Group items from *iterable* into tuples of up to *batch_size* items
+    each. The final batch may be shorter. Items are pulled from *iterable*
+    lazily, one batch at a time.
+    """
+    it = iter(iterable)
+
+    while batch := tuple(itertools.islice(it, batch_size)):
+        yield batch
+
