+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the listener has been idle for too long and, if so, terminate the stream.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` is set and no chunk has
+        been received within that window since the stream started, a final `StreamResponse` with an empty `chunk`
+        is emitted and the listener state is reset so it doesn't remain stuck in a started state.
+
+        Args:
+            now_ts: The current timestamp to compare against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` signaling timeout, or `None` if no timeout has occurred.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally so it isn't left stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
