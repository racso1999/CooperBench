@@ -580,3 +580,64 @@ def test_autocontrast_preserve_one_color(color: tuple[int, int, int]) -> None:
         img, cutoff=10, preserve_tone=True
     )  # single color 10 cutoff
     assert_image_equal(img, out)
+
+
+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        assert base_im.getexif()[0x0112] == 8
+
+        # A callback overrides the default orientation-to-method mapping
+        def callback(orientation: int) -> Image.Transpose:
+            assert orientation == 8
+            return Image.Transpose.FLIP_LEFT_RIGHT
+
+        transposed_im = ImageOps.exif_transpose(base_im, transform_callback=callback)
+        assert 0x0112 not in transposed_im.getexif()
+        assert_image_equal(
+            transposed_im, base_im.transpose(Image.Transpose.FLIP_LEFT_RIGHT)
+        )
+
+        # A callback can return a sequence of methods, applied in order
+        def sequence_callback(orientation: int) -> list[Image.Transpose]:
+            return [Image.Transpose.ROTATE_90, Image.Transpose.FLIP_TOP_BOTTOM]
+
+        transposed_im = ImageOps.exif_transpose(
+            base_im, transform_callback=sequence_callback
+        )
+        assert 0x0112 not in transposed_im.getexif()
+        expected = base_im.transpose(Image.Transpose.ROTATE_90).transpose(
+            Image.Transpose.FLIP_TOP_BOTTOM
+        )
+        assert_image_equal(transposed_im, expected)
+
+        # A callback can return None, meaning no transposition is applied
+        def none_callback(orientation: int) -> None:
+            return None
+
+        transposed_im = ImageOps.exif_transpose(
+            base_im, transform_callback=none_callback
+        )
+        assert_image_equal(transposed_im, base_im.copy())
+
+        # If no callback is provided, original behavior is preserved
+        transposed_im = ImageOps.exif_transpose(base_im)
+        assert_image_equal(
+            transposed_im,
+            ImageOps.exif_transpose(base_im, transform_callback=None),
+        )
+
+
+def test_exif_transpose_transform_callback_in_place() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+        expected = im.rotate(90, expand=True)
+
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_90,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
