+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the smallest number of colors (at most ``colors``) whose
+        quantized result has a mean squared error at or below
+        ``error_threshold``, using a binary search over the color count.
+        Falls back to ``colors`` if the threshold cannot be reached.
+        """
+        from . import ImageChops
+
+        original_rgb = self.convert("RGB")
+
+        def mse(candidate_core):
+            candidate_rgb = self._new(candidate_core).convert("RGB")
+            diff = ImageChops.difference(original_rgb, candidate_rgb)
+            histogram = diff.histogram()
+            num_bands = len(diff.getbands())
+            num_values = original_rgb.size[0] * original_rgb.size[1] * num_bands
+            if num_values == 0:
+                return 0
+            squared_error_sum = sum(
+                count * (value % 256) ** 2 for value, count in enumerate(histogram)
+            )
+            return squared_error_sum / num_values
+
+        low, high = 2, colors
+        best_core = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate_core = self.im.quantize(mid, method, kmeans)
+            if mse(candidate_core) <= error_threshold:
+                best_core = candidate_core
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_core is None:
+            best_core = self.im.quantize(colors, method, kmeans)
+        return best_core
+
