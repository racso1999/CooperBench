+def test_error_threshold_reduces_colors():
+    image = hopper()
+
+    loose = image.quantize(colors=256, error_threshold=200)
+    default = image.quantize(colors=256)
+
+    assert len(loose.getcolors(256)) < len(default.getcolors(256))
+
+
+def test_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=32, error_threshold=0)
+
+    assert len(converted.getcolors(32)) == 32
+
+
+def test_error_threshold_with_palette_raises():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=10)
