-        im.palette = ImagePalette.ImagePalette(mode, im.im.getpalette(mode, mode))
+        palette = im.im.getpalette(mode, mode)
+
+        if sort_palette:
+            if mode != "RGB":
+                raise ValueError(
+                    "sort_palette is only supported when quantizing to an RGB "
+                    "palette"
+                )
+            channels = len(mode)
+            # only the first "colors" entries are actually used by the
+            # quantized image; the rest of the fixed-size palette buffer is
+            # unused padding and is left untouched.
+            num_colors = min(colors, len(palette) // channels)
+            palette_colors = [
+                tuple(palette[i * channels : i * channels + channels])
+                for i in range(num_colors)
+            ]
+
+            if sort_palette == "rgb":
+                sort_key = palette_colors.__getitem__
+            elif sort_palette == "brightness":
+
+                def sort_key(i, _colors=palette_colors):
+                    r, g, b = _colors[i][:3]
+                    return r * 299 + g * 587 + b * 114
+
+            else:
+                raise ValueError("sort_palette must be 'rgb', 'brightness' or None")
+
+            order = sorted(range(num_colors), key=sort_key)
+
+            new_positions = list(range(256))
+            new_palette = bytearray(palette)
+            for new_index, old_index in enumerate(order):
+                new_positions[old_index] = new_index
+                start = new_index * channels
+                new_palette[start : start + channels] = palette_colors[old_index]
+
+            im = im.point(new_positions)
+            palette = bytes(new_palette)
+            im.im.putpalette(mode, palette)
+
+        im.palette = ImagePalette.ImagePalette(mode, palette)
 
         return im
 
