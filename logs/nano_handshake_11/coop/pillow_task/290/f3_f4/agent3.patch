diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..87cc47705 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,57 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(im, count):
+    palette = im.getpalette()
+    return [tuple(palette[i * 3 : i * 3 + 3]) for i in range(count)]
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted, 32)
+    assert colors == sorted(colors)
+
+    # the actual pixel colors should be unaffected by reordering the palette
+    unsorted = image.quantize(32)
+    assert list(converted.convert("RGB").getdata()) == list(
+        unsorted.convert("RGB").getdata()
+    )
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted, 32)
+    brightness = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    assert brightness == sorted(brightness)
+
+    unsorted = image.quantize(32)
+    assert list(converted.convert("RGB").getdata()) == list(
+        unsorted.convert("RGB").getdata()
+    )
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_rgba_unsupported():
+    image = hopper("RGBA")
+    with pytest.raises(ValueError):
+        image.quantize(32, method=Image.FASTOCTREE, sort_palette="rgb")
+
+
+def test_quantize_no_sort_palette_unchanged():
+    image = hopper()
+    a = image.quantize(32).tobytes()
+    b = image.quantize(32, sort_palette=None).tobytes()
+    assert a == b
