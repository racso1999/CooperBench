+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file)
+
+        # No backup should be made unless requested
+        im2 = Image.new("RGB", (10, 10), "#0f0")
+        im2.save(temp_file)
+        assert not temp_file.with_suffix(".png.bak").exists()
+        original_data = temp_file.read_bytes()
+
+        # A backup should be made when backup=True and the file exists
+        im3 = Image.new("RGB", (10, 10), "#00f")
+        im3.save(temp_file, backup=True)
+        backup_file = Path(str(temp_file) + ".bak")
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_data
+
+        with Image.open(temp_file) as reloaded:
+            assert reloaded.getpixel((0, 0)) == (0, 0, 255)
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file)
+        original_data = temp_file.read_bytes()
+
+        im2 = Image.new("RGB", (10, 10), "#0f0")
+        im2.save(temp_file, backup=True, backup_suffix=".backup")
+
+        backup_file = Path(str(temp_file) + ".backup")
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_data
+        assert not Path(str(temp_file) + ".bak").exists()
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file, backup=True)
+
+        assert not Path(str(temp_file) + ".bak").exists()
+
+    def test_save_backup_file_object(self) -> None:
+        im = Image.new("RGB", (10, 10), "#f00")
+        buf = io.BytesIO()
+        # backup has no effect when saving to a file object, and shouldn't
+        # raise
+        im.save(buf, format="PNG", backup=True)
+
     def test_dump(self, tmp_path: Path) -> None:
