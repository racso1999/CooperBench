+_PROCESS_PRIORITY_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+
+def _set_nice_priority(value: int) -> None:
+    try:
+        os.nice(value)
+    except OSError:
+        # Not permitted to change priority (e.g. raising it without
+        # sufficient privileges). Fall back to the default priority.
+        pass
+
+
+def _get_priority_popen_kwargs(process_priority: str | None) -> dict[str, t.Any]:
+    if process_priority not in _PROCESS_PRIORITY_NICE_VALUES:
+        return {}
+
+    if WIN:
+        import subprocess
+
+        windows_classes = {
+            "low": subprocess.IDLE_PRIORITY_CLASS,
+            "below_normal": subprocess.BELOW_NORMAL_PRIORITY_CLASS,
+            "normal": subprocess.NORMAL_PRIORITY_CLASS,
+            "above_normal": subprocess.ABOVE_NORMAL_PRIORITY_CLASS,
+            "high": subprocess.HIGH_PRIORITY_CLASS,
+        }
+        return {"creationflags": windows_classes[process_priority]}
+
+    nice_value = _PROCESS_PRIORITY_NICE_VALUES[process_priority]
+    return {"preexec_fn": lambda: _set_nice_priority(nice_value)}
+
+
