+    def _token_start_positions(self, tokens: Sequence[int]) -> list[int]:
+        """Computes the starting character position of each token, as produced by `encode`.
+
+        Each position is the index into the original text corresponding to the start of the
+        token. If UTF-8 character boundaries do not line up with token boundaries, the position
