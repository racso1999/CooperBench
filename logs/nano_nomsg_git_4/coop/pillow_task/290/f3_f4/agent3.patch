diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..fbcb738f4 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,31 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(64, sort_palette=sort_palette)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    # the sorted palette should represent the same colors as the unsorted one
+    unsorted = image.quantize(64)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    palette = converted.getpalette()
+    used_indexes = sorted(set(converted.getdata()))
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in used_indexes]
+
+    if sort_palette == "brightness":
+        luminance = [0.299 * r + 0.587 * g + 0.114 * b for r, g, b in colors]
+        assert luminance == sorted(luminance)
+    else:
+        assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(64, sort_palette="unknown")
