+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette according to ``sort_palette``, and
+        remaps the pixel data to match. Used by :py:meth:`~PIL.Image.quantize`.
+        """
+        if sort_palette not in ("brightness", "rgb"):
+            raise ValueError("sort_palette must be 'brightness', 'rgb' or None")
+
+        mode = self.palette.mode
+        channels = len(mode)
+        palette_bytes = bytes(self.palette.palette)
+        num_colors = len(palette_bytes) // channels
+        colors = [
+            palette_bytes[i * channels : (i + 1) * channels]
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "brightness":
+
+            def sort_key(color):
+                if len(color) >= 3:
+                    r, g, b = color[0], color[1], color[2]
+                    return 0.299 * r + 0.587 * g + 0.114 * b
+                return color[0]
+
+        else:
+
+            def sort_key(color):
+                return tuple(color)
+
+        order = sorted(range(num_colors), key=lambda i: sort_key(colors[i]))
+
+        # old_to_new[old_index] = new_index
+        old_to_new = [0] * num_colors
+        for new_index, old_index in enumerate(order):
+            old_to_new[old_index] = new_index
+
+        new_palette_bytes = bytearray(len(palette_bytes))
+        for old_index, new_index in enumerate(old_to_new):
+            new_palette_bytes[new_index * channels : (new_index + 1) * channels] = (
+                colors[old_index]
+            )
+
+        lut = old_to_new + list(range(num_colors, 256))
+        im = self.point(lut, "P")
+        im.putpalette(bytes(new_palette_bytes), mode)
         return im
 
