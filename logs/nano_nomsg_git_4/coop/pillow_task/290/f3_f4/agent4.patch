+        if error_threshold > 0:
+            from . import ImageChops, ImageStat
+
+            reference_im = self if self.mode == "RGB" else self.convert("RGB")
+
+            def mean_square_error(n):
+                candidate = quantize_to_colors(n).convert("RGB")
+                diff = ImageChops.difference(reference_im, candidate)
+                stat = ImageStat.Stat(diff)
+                return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+            if mean_square_error(colors) > error_threshold:
+                # The error threshold cannot be met, even using the maximum
+                # number of colors allowed, so fall back to using all of them.
