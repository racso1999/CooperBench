+            else:
+                # Find the fewest colors, up to the requested maximum, that
+                # are needed to satisfy the error threshold.
+                low, high = 1, colors
+                best = colors
+                while low <= high:
+                    mid = (low + high) // 2
+                    if mean_square_error(mid) <= error_threshold:
+                        best = mid
+                        high = mid - 1
+                    else:
+                        low = mid + 1
+                im = quantize_to_colors(best)
+        else:
