@@ -77,6 +77,33 @@ def test_quantize_dither_diff():
     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should allow the quantizer to use fewer colors
+    # than the maximum requested.
+    low_quality = image.quantize(colors=256, error_threshold=10000)
+    assert len(low_quality.getcolors()) <= 256
+
+    # A very low, but non-zero, threshold should behave close to using
+    # the maximum requested number of colors.
+    high_quality = image.quantize(colors=32, error_threshold=1)
+    assert len(high_quality.getcolors()) <= 32
+
+    # The higher quality image should generally be a closer match
+    # to the original image than the lower quality one.
+    assert_image_similar(high_quality.convert("RGB"), image, 30)
+
+
+def test_quantize_error_threshold_uses_max_colors_when_unmet():
+    image = hopper()
+
+    # An impossibly small error threshold cannot be met, so the quantizer
+    # should fall back to using the maximum number of requested colors.
+    converted = image.quantize(colors=64, error_threshold=0.0001)
+    assert len(converted.getcolors()) == 64
+
+
