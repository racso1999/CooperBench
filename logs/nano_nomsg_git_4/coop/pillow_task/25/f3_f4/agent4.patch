+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        backup_out = tmp_path / "temp.png.bak"
+
+        # No existing file, so no backup should be created
+        im = hopper()
+        im.save(out, backup=True)
+        assert not backup_out.exists()
+
+        with Image.open(out) as original:
+            original_bytes = original.tobytes()
+
+        # File now exists, so saving again should create a backup
+        im2 = hopper("L")
+        im2.save(out, backup=True)
+        assert backup_out.exists()
+
+        with Image.open(backup_out) as backup:
+            assert backup.tobytes() == original_bytes
+
+        with Image.open(out) as reloaded:
+            assert reloaded.mode == "L"
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        backup_out = tmp_path / "temp.png.backup"
+
+        im = hopper()
+        im.save(out)
+        im.save(out, backup=True, backup_suffix=".backup")
+
+        assert backup_out.exists()
+
+    def test_save_no_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        backup_out = tmp_path / "temp.png.bak"
+
+        im = hopper()
+        im.save(out)
+        im.save(out)
+
+        assert not backup_out.exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
