-        for key in kwds:
-            self[key] = kwds[key]
+                self._update_value(key, value)
+        for key, value in kwds.items():
+            self._update_value(key, value)
+
+    def _update_value(self, key: str, value: FeatureType):
+        # If the key already exists and both the current and new values are dictionaries
+        # (possibly wrapped in a `Sequence`), merge them recursively instead of overwriting.
+        if key in self:
+            current = self[key]
+            current_dict = current.feature if isinstance(current, Sequence) else current
+            value_dict = value.feature if isinstance(value, Sequence) else value
+            if isinstance(current_dict, dict) and isinstance(value_dict, dict):
+                _deep_update_dict(current_dict, value_dict)
+                self[key] = current
+                return
+        self[key] = value
 
     def __reduce__(self):
         return Features, (dict(self),)
