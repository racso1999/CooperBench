+def _deep_update_dict(d: dict, u: dict) -> None:
+    """Recursively update dict `d` in place with the values from dict `u`."""
+    for k, v in u.items():
+        if isinstance(d.get(k), dict) and isinstance(v, dict):
+            _deep_update_dict(d[k], v)
+        else:
+            d[k] = v
+
