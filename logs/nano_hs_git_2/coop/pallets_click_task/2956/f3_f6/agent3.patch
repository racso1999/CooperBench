+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution of options whose ``default`` was
+        given as a dynamic default mapping (``{"--source": {value:
+        default}}``). This runs after every parameter has been parsed
+        from the command line, environment variables, and default
+        maps, so the source options' final values are available.
+
+        Only applies to options whose value still comes from
+        :attr:`ParameterSource.DEFAULT` (i.e. no explicit value was
+        given for the option itself).
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:
+                continue
+
+            resolved = None
+
+            for src_opt, mapping in dynamic_default.items():
+                src_param = next(
+                    (
+                        p
+                        for p in params
+                        if src_opt in p.opts or src_opt in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if src_param is None:
+                    continue
+
+                src_value = ctx.params.get(src_param.name)
+                key = str(src_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved
+
     def invoke(self, ctx: Context) -> t.Any:
