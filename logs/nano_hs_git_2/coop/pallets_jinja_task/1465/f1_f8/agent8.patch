+
+def _group_by(
+    value: "t.Iterable[V]",
+    expr: t.Callable[[t.Any], t.Any],
+    case_sensitive: bool,
+    with_counts: bool,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    sort_key = expr if case_sensitive else (lambda item: ignore_case(expr(item)))
+    out = []
+
+    for key, values in groupby(sorted(value, key=sort_key), sort_key):
+        values = list(values)
+
+        if not case_sensitive:
+            # Preserve the case of the first item's attribute in this
+            # group, rather than the case-normalized sort key.
+            key = expr(values[0])
+
+        if with_counts:
+            out.append(_GroupTupleWithCount(key, values, len(values)))
+        else:
+            out.append(_GroupTuple(key, values))
+
+    return out
 
 
