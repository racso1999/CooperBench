+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+
+        original = hopper()
+        original.save(out)
+        assert not os.path.exists(str(out) + ".bak")
+
+        with Image.open(out) as im:
+            original_bytes = im.tobytes()
+
+        modified = hopper().rotate(90)
+        modified.save(out, backup=True)
+
+        assert os.path.exists(str(out) + ".bak")
+        with Image.open(str(out) + ".bak") as backup_im:
+            assert backup_im.tobytes() == original_bytes
+
+        with Image.open(out) as reloaded:
+            assert_image_equal(modified, reloaded)
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+
+        hopper().save(out)
+        hopper().rotate(90).save(out, backup=True, backup_suffix=".backup")
+
+        assert os.path.exists(str(out) + ".backup")
+        assert not os.path.exists(str(out) + ".bak")
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+
+        hopper().save(out, backup=True)
+
+        assert os.path.exists(out)
+        assert not os.path.exists(str(out) + ".bak")
+
+    def test_save_backup_false(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+
+        hopper().save(out)
+        hopper().rotate(90).save(out, backup=False)
+
+        assert not os.path.exists(str(out) + ".bak")
+
