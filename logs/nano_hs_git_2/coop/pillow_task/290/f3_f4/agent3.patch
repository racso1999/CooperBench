+def test_quantize_error_threshold():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    # A very high error threshold should be satisfiable with few colors
+    lenient = image.quantize(colors=256, error_threshold=1000000)
+    assert len(lenient.getcolors()) <= len(converted.getcolors())
+
+
+def test_quantize_error_threshold_unmet_uses_max_colors():
+    image = hopper()
+
+    # An unreasonably strict threshold cannot be met, so the maximum
+    # number of colors should be used
+    converted = image.quantize(colors=8, error_threshold=0)
+    unrestricted = image.quantize(colors=8)
+    assert len(converted.getcolors()) == len(unrestricted.getcolors())
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=100)
+
