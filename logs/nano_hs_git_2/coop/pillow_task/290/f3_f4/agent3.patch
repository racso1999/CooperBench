+def make_swatches_image():
+    colors = [(255, 0, 0), (0, 255, 0), (0, 0, 255), (255, 255, 255), (0, 0, 0)]
+    image = Image.new("RGB", (10, 10))
+    px = image.load()
+    for i in range(10):
+        for j in range(10):
+            px[i, j] = colors[(i + j) % len(colors)]
+    return image
+
+
+def test_quantize_sort_palette_brightness():
+    image = make_swatches_image()
+
+    converted = image.quantize(colors=5, sort_palette="brightness")
+    palette = converted.getpalette()[:15]
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 15, 3)]
+
+    assert colors == [
+        (0, 0, 0),
+        (0, 0, 255),
+        (255, 0, 0),
+        (0, 255, 0),
+        (255, 255, 255),
+    ]
+
+    # Sorting the palette should not change how the image looks
+    assert_image_similar(
+        converted.convert("RGB"), image.quantize(colors=5).convert("RGB"), 1
+    )
+
+
+def test_quantize_sort_palette_rgb():
+    image = make_swatches_image()
+
+    converted = image.quantize(colors=5, sort_palette="rgb")
+    palette = converted.getpalette()[:15]
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 15, 3)]
+
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_none():
+    image = hopper()
+
+    unsorted = image.quantize(100, Image.FASTOCTREE)
+    default = image.quantize(100, Image.FASTOCTREE, sort_palette=None)
+
+    assert unsorted.getpalette() == default.getpalette()
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="bad-value")
+
+
+def test_quantize_sort_palette_rgba():
+    image = hopper("RGBA")
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="brightness")
+    assert converted.palette.mode == "RGBA"
+
+    assert_image_similar(
+        converted.convert("RGBA"),
+        image.quantize(100, Image.FASTOCTREE).convert("RGBA"),
+        1,
+    )
