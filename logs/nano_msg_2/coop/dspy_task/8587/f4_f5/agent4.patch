+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and, if so, emit a terminal empty chunk.
+
+        This is not driven by incoming chunks, so it must be called periodically by the streaming system (e.g. on a
+        timer) to detect a stream that stalled upstream without ever reaching a proper end delimiter.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so that a stalled stream
+        # doesn't leave the listener stuck in a started state.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
