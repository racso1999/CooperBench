+    def _popen_priority_kwargs(self) -> dict[str, t.Any]:
+        """Build the extra ``subprocess.Popen`` kwargs needed to launch
+        the editor with the requested ``process_priority``, if any.
+
+        Unsupported or invalid priority values, as well as any platform
+        errors while applying them, are silently ignored so the editor
+        always still launches with the default priority.
+        """
+        if self.process_priority is None:
+            return {}
+
+        if WIN:
+            creationflags = _WIN_PRIORITY_CLASSES.get(self.process_priority)
+            if creationflags is None:
+                return {}
+            return {"creationflags": creationflags}
+
+        nice_value = _UNIX_PRIORITY_NICE_VALUES.get(self.process_priority)
+        if nice_value is None:
+            return {}
+
+        def _set_priority() -> None:
+            try:
+                os.nice(nice_value)
+            except OSError:
+                pass
+
+        return {"preexec_fn": _set_priority}
+
