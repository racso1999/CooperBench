+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve any :class:`Option` whose ``default`` is a dynamic
+        default mapping. This runs after every parameter has consumed its
+        value from the command line, environment variables, and the
+        default map, so the values of the referenced source options are
+        already final.
+
+        Only options whose value source is still :attr:`ParameterSource.DEFAULT`
+        are affected. Later entries in the mapping take precedence over
+        earlier ones when more than one source option matches.
+        """
+        if ctx.resilient_parsing:
+            return
+
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if opt_name in p.opts or opt_name in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
