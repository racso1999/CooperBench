         )
 
 
+def _batched(
+    values: cabc.Sequence[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Group ``values`` into consecutive chunks of at most ``batch_size``
+    items each, yielded as tuples.
+    """
+    for i in range(0, len(values), batch_size):
+        yield tuple(values[i : i + batch_size])
+
