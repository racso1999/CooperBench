+def test_quantize_error_threshold():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    # A very high threshold should allow far fewer colors than requested.
+    few_colors = image.quantize(colors=256, error_threshold=1000)
+    many_colors = image.quantize(colors=256, error_threshold=1)
+    assert len(few_colors.getcolors()) <= len(many_colors.getcolors())
+
+
+def test_quantize_error_threshold_max_colors():
+    # A tiny threshold that can't be reached should fall back to the
+    # requested maximum number of colors.
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0.0001)
+    assert len(converted.getcolors()) <= 8
+
+
+def test_quantize_error_threshold_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=0)
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
