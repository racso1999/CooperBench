+    def _quantize_mse(self, colors, method, kmeans):
+        # Returns the mean squared error between this image and the result
+        # of quantizing it down to the given number of colors.
+        im = self._new(self.im.quantize(colors, method, kmeans))
+
+        from . import ImagePalette
+
+        mode = im.im.getpalettemode()
+        im.palette = ImagePalette.ImagePalette(mode, im.im.getpalette(mode, mode))
+
+        compare_mode = "RGBA" if self.mode == "RGBA" else "RGB"
+        original = self.convert(compare_mode)
+        requantized = im.convert(compare_mode)
+
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(original, requantized)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_colors_for_error_threshold(
+        self, colors, method, kmeans, error_threshold
+    ):
+        # Finds the smallest number of colors, up to the given limit, for
+        # which the quantization error stays at or below error_threshold.
+        # Falls back to the given limit if the threshold can't be reached.
+        low, high = 1, colors
+        best = colors
+        while low <= high:
+            mid = (low + high) // 2
+            if self._quantize_mse(mid, method, kmeans) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+        return best
+
