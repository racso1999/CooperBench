+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(16, sort_palette=Image.SORT_LUMINANCE)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 30)
+
+    palette = converted.getpalette()
+    luminances = [
+        r * 299 + g * 587 + b * 114
+        for r, g, b in (palette[i : i + 3] for i in range(0, len(palette), 3))
+    ]
+    assert luminances == sorted(luminances)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(16, sort_palette=Image.SORT_RGB)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 30)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(16, sort_palette=999)
+
