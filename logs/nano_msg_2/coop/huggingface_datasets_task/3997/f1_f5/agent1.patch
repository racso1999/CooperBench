+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the `Features` class in sync with the
+    main dictionary. Used to override the dict methods that alter the content of the `Features` class, so that
+    `_column_requires_decoding` stays up to date, without having to subclass `UserDict` (which comes with a
+    performance overhead and could introduce backward incompatible changes).
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        if args:
+            self: "Features" = args[0]
+            args = args[1:]
+        else:
+            self: "Features" = kwargs.pop("self")
+        out = func(self, *args, **kwargs)
+        assert hasattr(self, "_column_requires_decoding")
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper.__name__ = func.__name__
+    wrapper.__qualname__ = func.__qualname__
+    return wrapper
+
