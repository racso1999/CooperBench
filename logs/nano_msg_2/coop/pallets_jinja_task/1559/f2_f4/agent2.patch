+def _make_new_dgettext(func: t.Callable[[str, str], str]) -> t.Callable[..., str]:
+    @pass_context
+    def dgettext(
+        __context: Context, __domain: str, __string: str, **variables: t.Any
+    ) -> str:
+        rv = __context.call(func, __domain, __string)
+        if __context.eval_ctx.autoescape:
+            rv = Markup(rv)
+        # Always treat as a format string, see gettext comment above.
+        return rv % variables  # type: ignore
+
+    return dgettext
+
+
+def _make_new_dngettext(
+    func: t.Callable[[str, str, str, int], str]
+) -> t.Callable[..., str]:
+    @pass_context
+    def dngettext(
+        __context: Context,
+        __domain: str,
+        __singular: str,
+        __plural: str,
+        __num: int,
+        **variables: t.Any,
+    ) -> str:
+        variables.setdefault("num", __num)
+        rv = __context.call(func, __domain, __singular, __plural, __num)
+        if __context.eval_ctx.autoescape:
+            rv = Markup(rv)
+        # Always treat as a format string, see gettext comment above.
+        return rv % variables  # type: ignore
+
+    return dngettext
+
+
+def _make_fallback_dgettext(gettext: t.Callable[..., str]) -> t.Callable[..., str]:
+    # Used when no domain-aware translation function is installed. The
+    # domain is accepted (and ignored) so `{% trans domain=... %}` still
+    # works, falling back to the regular (non-domain) gettext function.
+    @pass_context
+    def dgettext(context: Context, domain: str, message: str, **variables: t.Any) -> str:
+        return context.call(gettext, message, **variables)
+
+    return dgettext
+
+
+def _make_fallback_dngettext(ngettext: t.Callable[..., str]) -> t.Callable[..., str]:
+    @pass_context
+    def dngettext(
+        context: Context,
+        domain: str,
+        singular: str,
+        plural: str,
+        num: int,
+        **variables: t.Any,
+    ) -> str:
+        return context.call(ngettext, singular, plural, num, **variables)
+
+    return dngettext
+
