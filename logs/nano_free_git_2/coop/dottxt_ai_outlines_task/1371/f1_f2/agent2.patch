+# Registry of filters that have been registered globally via `register_filter`.
+# These filters are made available to every `Prompt` template in addition to
+# the built-in ones defined below.
+_GLOBAL_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is available in every prompt template
+    without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _GLOBAL_FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _GLOBAL_FILTERS.pop(name, None)
+
 
