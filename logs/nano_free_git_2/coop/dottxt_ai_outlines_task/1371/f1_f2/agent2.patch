+def create_jinja_env(
+    loader: Optional[jinja2.BaseLoader], filters: Optional[Dict[str, Callable]] = None
+) -> jinja2.Environment:
+    """Create a Jinja2 environment with the standard outlines filters registered.
+
+    Parameters
+    ----------
+    loader : Optional[jinja2.BaseLoader]
+        The Jinja2 loader to use, if any.
+    filters : Optional[Dict[str, Callable]]
+        A dictionary of custom Jinja2 filters to register, mapping filter
+        names to callables. These take precedence over both the built-in
+        outlines filters and any filter registered globally with
+        `register_filter`.
+
+    Returns
+    -------
+    A Jinja2 `Environment` with the outlines and custom filters registered.
+
+    """
+    env = jinja2.Environment(
+        loader=loader,
+        trim_blocks=True,
+        lstrip_blocks=True,
+        keep_trailing_newline=True,
+        undefined=jinja2.StrictUndefined,
+    )
+    env.filters["name"] = get_fn_name
+    env.filters["description"] = get_fn_description
+    env.filters["source"] = get_fn_source
+    env.filters["signature"] = get_fn_signature
+    env.filters["schema"] = get_schema
+    env.filters["args"] = get_fn_args
+
+    # Filters registered globally via `register_filter` are available to
+    # every template, but locally-provided filters take precedence.
+    env.filters.update(_GLOBAL_FILTERS)
+
+    if filters is not None:
+        env.filters.update(filters)
+
+    return env
