+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a plausible phone number, optionally restricted to a specific
+    country's format.
+
+    This is a pragmatic check suitable for typical application input validation, not a full
+    implementation of the international numbering plan (E.164).
+    """
+
+    # digits (excluding country code) following the leading `0`/`+<code>`
+    _national_lengths = {
+        'US': (10,),
+        'GB': (9, 10),
+    }
+    _country_codes = {
+        'US': '1',
+        'GB': '44',
+    }
+    _generic_re = re.compile(r'\d{7,15}')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) to restrict validation
+                to that country's phone number format. If omitted, any plausible national or
+                international phone number is accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+
+        assert '+33 1 23 45 67 89' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country if self.country else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = re.sub(r'[\s\-.()]', '', other)
+        if not re.fullmatch(r'\+?\d+', cleaned) or cleaned in ('', '+'):
+            return False
+
+        has_plus = cleaned.startswith('+')
+        digits = cleaned[1:] if has_plus else cleaned
+        if not digits:
+            return False
+
+        if self.country in self._national_lengths:
+            code = self._country_codes[self.country]
+            national_lengths = self._national_lengths[self.country]
+            if has_plus:
+                if not digits.startswith(code):
+                    return False
+                return len(digits) - len(code) in national_lengths
+            else:
+                if self.country == 'GB':
+                    return digits.startswith('0') and (len(digits) - 1) in national_lengths
+                else:
+                    return len(digits) in national_lengths
+        elif self.country is not None:
+            # unknown/unsupported country code, fall back to generic international validation
+            return has_plus and bool(self._generic_re.fullmatch(digits))
+        else:
+            return bool(self._generic_re.fullmatch(digits))
+
+
