+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, supporting `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+    `'sha384'` and `'sha512'`.
+    """
+
+    # length in hex characters of the digest produced by each supported algorithm
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The algorithm which was used for the hash, must be one of `'md5'`, `'sha1'`, `'sha224'`,
+                `'sha256'`, `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'foo').hexdigest() == IsHash('md5')
+        assert hashlib.sha1(b'foo').hexdigest() == IsHash('sha1')
+        assert hashlib.sha256(b'foo').hexdigest() == IsHash('sha256')
+
+        assert 'not-a-hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.length = self.hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown algorithm {algorithm!r}')
+        super().__init__(self.algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return len(other) == self.length and re.fullmatch('[0-9a-fA-F]+', other) is not None
