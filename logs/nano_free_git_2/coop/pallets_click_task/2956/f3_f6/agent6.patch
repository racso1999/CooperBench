+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve the value for a dynamic, dictionary-based default by
+        looking at the current values of the option(s) it depends on.
+
+        Returns ``None`` if this option doesn't have a dynamic default,
+        or if none of the mappings match the current values of the
+        options it depends on.
+
+        .. versionadded:: 8.2
+        """
+        if self._dynamic_default is None:
+            return None
+
+        resolved = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_value = None
+
+            for param in ctx.command.get_params(ctx):
+                if isinstance(param, Option) and opt_name in param.opts:
+                    source_value = ctx.params.get(param.name)
+                    break
+
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
+
