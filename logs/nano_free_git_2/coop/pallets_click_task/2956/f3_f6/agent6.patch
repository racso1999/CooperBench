diff --git a/src/click/types.py b/src/click/types.py
index 684cb3b..c5c9023 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -27,6 +27,18 @@ if t.TYPE_CHECKING:
 ParamTypeValue = t.TypeVar("ParamTypeValue")
 
 
+def _batched(
+    values: cabc.Sequence[ParamTypeValue], batch_size: int
+) -> tuple[tuple[ParamTypeValue, ...], ...]:
+    """Split ``values`` into a tuple of chunks, each with up to
+    ``batch_size`` items. Used to implement the ``batch_size`` option
+    on parameters with ``multiple=True``.
+    """
+    return tuple(
+        tuple(values[i : i + batch_size]) for i in range(0, len(values), batch_size)
+    )
+
