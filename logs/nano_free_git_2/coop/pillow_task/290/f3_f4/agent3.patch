+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very loose threshold should be satisfied well before the maximum
+    # number of colors is reached, so fewer colors should be used.
+    loose = image.quantize(colors=256, error_threshold=1000)
+    assert len(loose.getcolors()) < 256
+
+    # An impossible threshold can never be satisfied, so the maximum
+    # number of colors should be used instead.
+    strict = image.quantize(colors=32, error_threshold=0)
+    assert len(strict.getcolors()) == 32
+
+
+def test_quantize_error_threshold_within_bound():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=100)
+
+    diff = ImageChops.difference(image.convert("RGB"), converted.convert("RGB"))
+    stat = ImageStat.Stat(diff)
+    mse = sum(rms**2 for rms in stat.rms) / len(stat.rms)
+    assert mse <= 100
+
