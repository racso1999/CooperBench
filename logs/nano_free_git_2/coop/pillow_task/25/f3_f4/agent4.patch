+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10))
+        im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_save_dry_run_existing_file_not_modified(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10))
+        im.save(temp_file)
+        mtime = os.path.getmtime(temp_file)
+        contents = temp_file.read_bytes()
+
+        im2 = Image.new("RGB", (20, 20), "red")
+        im2.save(temp_file, dry_run=True)
+
+        assert os.path.getmtime(temp_file) == mtime
+        assert temp_file.read_bytes() == contents
+
+    def test_save_dry_run_raises(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_save_dry_run_fp(self) -> None:
+        fp = io.BytesIO(b"original")
+        fp.seek(0, os.SEEK_END)
+
+        im = Image.new("RGB", (10, 10))
+        im.save(fp, format="PNG", dry_run=True)
+
+        assert fp.getvalue() == b"original"
+
