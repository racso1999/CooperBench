+# Global registry of custom filters that should be made available to every
+# prompt template, without having to pass them explicitly to each template.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to be globally available in all prompt templates.
+
+    Once registered, the filter can be used in any template rendered afterwards,
+    with the syntax ``{{ value | name }}``, without needing to pass it explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered custom filter.
+
+    Does nothing if no filter was registered under this name.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
