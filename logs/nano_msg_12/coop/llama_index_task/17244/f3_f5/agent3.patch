+def normalize_image_bytes(image_bytes: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or already base64-encoded image bytes.
+
+    Args:
+        image_bytes (bytes): raw image bytes, or an image already encoded as base64.
+
+    Returns:
+        tuple[bytes, bytes]: a tuple ``(encoded_image, decoded_for_guessing)`` where
+            ``encoded_image`` is the base64 encoding of the image and
+            ``decoded_for_guessing`` is the raw bytes to use for MIME type guessing.
+    """
+    try:
+        decoded_for_guessing = base64.b64decode(image_bytes, validate=True)
+        encoded_image = image_bytes
+    except binascii.Error:
+        decoded_for_guessing = image_bytes
+        encoded_image = base64.b64encode(image_bytes)
+
+    return encoded_image, decoded_for_guessing
+
