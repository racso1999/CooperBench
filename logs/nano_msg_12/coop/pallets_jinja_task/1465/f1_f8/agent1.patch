+def _group_by(
+    value: "t.Iterable[V]",
+    expr: t.Callable[[t.Any], t.Any],
+    case_sensitive: bool,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    sort_key = expr if case_sensitive else (lambda item: ignore_case(expr(item)))
+    groups = []
+
+    for _, values in groupby(sorted(value, key=sort_key), sort_key):
+        values = list(values)
+        groups.append(_GroupTuple(expr(values[0]), values))
+
+    return groups
 
 
