+
+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+# lengths (in hex characters) of the digests produced by each supported algorithm
+_HASH_LENGTHS = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given hash type, e.g. MD5, SHA1, SHA256 etc.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, must be one of `'md5'`, `'sha1'`, `'sha224'`,
+                `'sha256'`, `'sha384'` or `'sha512'` (case-insensitive).
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert 'da39a3ee5e6b4b0d3255bfef95601890afd80709' == IsHash('sha1')
+        assert '9e26dfeeb6e641a33dae4961196235bdb9223263b74602811ee1f463c1f5228' == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('sha256')
+        ```
+        """
+        try:
+            self.length = _HASH_LENGTHS[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        self.algorithm = algorithm
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return len(other) == self.length and bool(re.fullmatch('[0-9a-fA-F]+', other))
