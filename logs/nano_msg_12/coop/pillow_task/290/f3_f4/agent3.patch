+    def _sort_palette(self, sort_palette):
+        """
+        Reorders a "P" mode image's palette using :py:meth:`remap_palette`.
+        Palette entries not currently used by any pixel are dropped.
+
+        :param sort_palette: ``"luminance"``, ``"rgb"``, or a callable taking
+           an RGB tuple and returning a sort key. See :py:meth:`quantize`.
+        """
+        self.load()
+
+        if self.palette.mode != "RGB":
+            # remap_palette() only knows how to rebuild a 3-channel palette
+            raise ValueError(
+                "sort_palette is only supported for images with an RGB "
+                f"palette, not {self.palette.mode!r}"
+            )
+
+        palette_bytes = self.im.getpalette("RGB", "RGB")
+
+        def color_at(index):
+            return tuple(palette_bytes[index * 3 : index * 3 + 3])
+
+        if callable(sort_palette):
+            key = lambda i: sort_palette(color_at(i))  # noqa: E731
+        elif sort_palette == "luminance":
+
+            def key(i):
+                r, g, b = color_at(i)[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+            key = color_at
+        else:
+            raise ValueError(
+                "sort_palette must be 'luminance', 'rgb', or a callable, "
+                f"not {sort_palette!r}"
+            )
+
+        used_palette_colors = [i for i, count in enumerate(self.histogram()) if count]
+        used_palette_colors.sort(key=key)
+
+        return self.remap_palette(used_palette_colors)
+
