--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,67 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(image):
+    palette = image.palette.palette
+    return [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+
+    luminances = [
+        r * 299 + g * 587 + b * 114 for r, g, b in _palette_colors(converted)
+    ]
+    assert luminances == sorted(luminances)
+
+    # the visual result should be unaffected by reordering the palette
+    assert_image_similar(
+        converted.convert("RGB"), image.quantize(32).convert("RGB"), 1
+    )
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(32, sort_palette=lambda rgb: -sum(rgb))
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors, key=lambda rgb: -sum(rgb))
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_rgba_unsupported():
+    image = hopper("RGBA")
+    with pytest.raises(ValueError):
+        image.quantize(32, method=Image.FASTOCTREE, sort_palette="luminance")
+
+
+def test_quantize_sort_palette_with_reference_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+
+    luminances = [
+        r * 299 + g * 587 + b * 114 for r, g, b in _palette_colors(converted)
+    ]
+    assert luminances == sorted(luminances)
