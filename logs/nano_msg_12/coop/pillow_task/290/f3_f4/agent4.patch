+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous error threshold should allow fewer colors than the maximum
+    reduced = image.quantize(colors=256, error_threshold=50)
+    assert_image(reduced, "P", reduced.size)
+    assert len(reduced.getcolors()) < 256
+
+    # An unreachable error threshold should fall back to the maximum
+    # number of colors
+    maxed = image.quantize(colors=64, error_threshold=0.001)
+    assert_image(maxed, "P", maxed.size)
+    assert len(maxed.getcolors()) == 64
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
