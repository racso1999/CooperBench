+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve any :class:`Option` whose ``default`` is a dynamic
+        default mapping, now that every parameter has an initial value.
+
+        A dynamic default is only applied to an option whose value
+        still comes from :attr:`ParameterSource.DEFAULT` (i.e. it
+        wasn't given on the command line, from an environment
+        variable, or from a default map). The mapping is checked
+        against the *resolved* value of each referenced option, so
+        source options can themselves come from any source.
+        """
+        params = self.get_params(ctx)
+        params_by_opt: dict[str, Parameter] = {}
+
+        for param in params:
+            for opt in (*param.opts, *param.secondary_opts):
+                params_by_opt[opt] = param
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if (
+                param.name is None
+                or ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT
+            ):
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = params_by_opt.get(source_opt)
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+
+                if str(source_value) in mapping:
+                    resolved = mapping[str(source_value)]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)
+
