+def validate_dynamic_default(mapping: t.Any) -> None:
+    """Validate the shape of a dynamic default mapping used by
+    :class:`~click.core.Option`.
+
+    :param mapping: the ``dict`` passed as ``default``, mapping source
+        option declarations to a ``dict`` of source value to default
+        value.
+    """
+    for key, value in mapping.items():
+        if not isinstance(key, str):
+            raise TypeError("Dynamic default keys must be strings")
+
+        if not isinstance(value, dict):
+            raise TypeError("Dynamic default values must be dictionaries")
+
+
+def _dynamic_default_sample(mapping: dict[str, dict[t.Any, t.Any]]) -> t.Any:
+    """Return a representative value out of a dynamic default mapping,
+    used only to guess a :class:`ParamType` when one isn't given
+    explicitly.
+    """
+    for sub in mapping.values():
+        for value in sub.values():
+            return value
+
+    return None
+
