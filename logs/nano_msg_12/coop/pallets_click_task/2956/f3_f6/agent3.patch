 import sys
@@ -1065,6 +1066,20 @@ class Tuple(CompositeParamType):
         )
 
 
+def _batched(
+    iterable: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Group elements from ``iterable`` into tuples of ``batch_size``.
+
+    The final tuple may be shorter than ``batch_size`` if the number of
+    items is not evenly divisible. Used to implement ``Option``'s
+    ``batch_size`` for ``multiple`` options.
+    """
+    it = iter(iterable)
+    while batch := tuple(itertools.islice(it, batch_size)):
+        yield batch
+
