+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, independently of `receive()`, so a stream
+        that stalls upstream (and therefore never calls `receive()` again) doesn't leave consumers waiting
+        forever. If the idle window has elapsed, emits a terminal `StreamResponse` with an empty `chunk` and
+        resets the listener state.
+
+        Args:
+            now_ts: The current time in seconds, as returned by `time.time()`. Defaults to `time.time()` if not
+                provided; exposed as a parameter mainly to make this method deterministic to test.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+        if now_ts - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        extra_kwargs = {}
+        if "is_last_chunk" in {f.name for f in dataclasses.fields(StreamResponse)}:
+            # `is_last_chunk` may be added by a separate feature; set it to signal end-of-stream if present.
+            extra_kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **extra_kwargs)
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so a timed-out stream doesn't
+        # get stuck in a started state forever.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
