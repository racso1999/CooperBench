+
+
+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+hash_lengths: Dict[str, int] = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, be it the actual hash or its string representation.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The algorithm to use for the hash, must be one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'`, `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert 'da39a3ee5e6b4b0d3255bfef95601890afd80709' == IsHash('sha1')
+        assert 'not a hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        self.hash_length = hash_lengths[algorithm.lower()]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.hash_length:
+            return False
+
+        return bool(re.fullmatch('[0-9a-fA-F]+', other))
