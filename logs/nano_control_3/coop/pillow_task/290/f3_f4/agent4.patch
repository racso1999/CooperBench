+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high error threshold should be satisfied with very few colors
+    low_quality = image.quantize(colors=256, error_threshold=1000)
+    assert_image(low_quality, "P", low_quality.size)
+    assert len(low_quality.getcolors()) <= 256
+
+    # A very low error threshold cannot be met, so the requested number of
+    # colors should be used instead
+    maxed_out = image.quantize(colors=4, error_threshold=0.0001)
+    assert_image(maxed_out, "P", maxed_out.size)
+    assert len(maxed_out.getcolors()) <= 4
+
+    # Using a higher error threshold should never require more colors than
+    # a lower one
+    fewer_colors = image.quantize(colors=256, error_threshold=1000)
+    more_colors = image.quantize(colors=256, error_threshold=1)
+    assert len(fewer_colors.getcolors()) <= len(more_colors.getcolors())
+
