+    def _quantize_color_count_for_error_threshold(
+        self, colors, method, kmeans, error_threshold
+    ):
+        """
+        Finds the smallest number of colors, up to ``colors``, for which the
+        mean square error (MSE) between this image and its quantized
+        version is less than or equal to ``error_threshold``. Returns
+        ``colors`` if no such number of colors is found, since the error
+        generally decreases as the number of colors increases.
+        """
+        from . import ImageChops, ImageStat
+
+        def mean_square_error(color_count):
+            quantized = self._new(self.im.quantize(color_count, method, kmeans))
+            comparison = quantized.convert(self.mode)
+            diff = ImageChops.difference(self, comparison)
+            stat = ImageStat.Stat(diff)
+            pixel_count = self.size[0] * self.size[1]
+            return sum(stat.sum2) / (pixel_count * len(stat.sum2))
+
+        best_colors = colors
+        low, high = 2, colors
+        while low <= high:
+            mid = (low + high) // 2
+            if mean_square_error(mid) <= error_threshold:
+                best_colors = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        return best_colors
+
