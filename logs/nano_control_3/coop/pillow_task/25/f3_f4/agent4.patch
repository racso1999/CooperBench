+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        # No existing file, so no backup should be created
+        im = hopper()
+        im.save(temp_file, backup=True)
+        assert not os.path.exists(str(temp_file) + ".bak")
+
+        original_data = temp_file.read_bytes()
+
+        # Existing file, so a backup should be created
+        im = hopper("L")
+        im.save(temp_file, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_data
+
+        with Image.open(backup_file) as backup_im:
+            assert backup_im.mode == "RGB"
+        with Image.open(temp_file) as reloaded_im:
+            assert reloaded_im.mode == "L"
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        hopper().save(temp_file)
+
+        hopper("L").save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        hopper().save(temp_file)
+
+        hopper("L").save(temp_file)
+
+        assert not os.path.exists(str(temp_file) + ".bak")
+
     def test_internals(self) -> None:
         im = Image.new("L", (100, 100))
         im.readonly = 1
