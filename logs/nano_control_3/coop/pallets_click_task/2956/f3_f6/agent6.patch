+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        dynamic default mapping (see :class:`Option`). This runs after
+        all parameters have been parsed so that dynamic defaults can be
+        resolved based on the final values of the options they depend on.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved_value = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if source_opt in p.opts or source_opt in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name not in ctx.params:
+                    continue
+
+                source_value = str(ctx.params[source_param.name])
+
+                if source_value in mapping:
+                    resolved_value = mapping[source_value]
+
+            if resolved_value is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                resolved_value = param.process_value(ctx, resolved_value)
+
+            if param.expose_value:
+                ctx.params[param.name] = resolved_value  # type: ignore[index]
+
