+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes text into tokens, additionally tracking the starting character
+        position of each token in `text`.
+
+        Special tokens are matched as whole pieces, so each one maps to a single
+        token/position pair. Ordinary text is split using `_pat_str` (same as the
+        core BPE splitter) and each resulting piece is BPE-encoded; token positions
+        within a piece are derived from the byte lengths of the decoded tokens.
+        """
+        special_pat = _special_token_regex(frozenset(allowed_special)) if allowed_special else None
+        ordinary_pat = regex.compile(self._pat_str)
+
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        pos = 0
+        text_len = len(text)
+        while pos < text_len:
+            match = special_pat.search(text, pos) if special_pat else None
+            segment_end = match.start() if match else text_len
+
+            for piece_match in ordinary_pat.finditer(text, pos, segment_end):
+                piece = piece_match.group()
+                piece_start = piece_match.start()
+                piece_tokens = self._encode_single_piece(piece)
+
+                char_len = 0
+                for token in piece_tokens:
+                    token_bytes = self.decode_single_token_bytes(token)
+                    offset = max(0, char_len - (0x80 <= token_bytes[0] < 0xC0))
+                    positions.append(piece_start + offset)
+                    char_len += sum(1 for b in token_bytes if not 0x80 <= b < 0xC0)
+                tokens.extend(piece_tokens)
+
+            if match is None:
+                break
+
+            positions.append(match.start())
+            tokens.append(self._special_tokens[match.group()])
+            pos = match.end()
+
+        return tokens, positions
+
