+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and, if so, end it.
+
+        This should be called periodically by the streaming system (independently of `receive()`) so that a
+        stalled upstream that never sends another chunk doesn't leave the consumer waiting forever. When the
+        idle window elapses, a `StreamResponse` with an empty `chunk` is emitted to signal termination and the
+        listener's state is reset so it can potentially be reused for a later stream.
+
+        Args:
+            now_ts: The current timestamp to compare against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the state unconditionally so the listener never gets stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self._last_chunk_ts = None
+        if self.debug and self._logger.isEnabledFor(logging.DEBUG):
+            self._logger.debug(
+                f"Idle timeout ({self.idle_timeout_s}s) reached for field '{self.signature_field_name}', "
+                "ending stream"
+            )
+
+        return response
+
