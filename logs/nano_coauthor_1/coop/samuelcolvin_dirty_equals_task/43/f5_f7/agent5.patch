+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number string, optionally restricted to a specific
+    country's format.
+    """
+
+    us_national_re = re.compile(r'^\d{10}$')
+    us_international_re = re.compile(r'^\+1\d{10}$')
+
+    gb_national_re = re.compile(r'^0\d{9,10}$')
+    gb_international_re = re.compile(r'^\+44\d{9,10}$')
+
+    generic_re = re.compile(r'^\+?\d{7,15}$')
+    generic_international_re = re.compile(r'^\+\d{7,15}$')
+
+    def __init__(self, country_code: Optional[str] = None):
+        """
+        Args:
+            country_code: optional ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) used to restrict
+                validation to that country's phone number formats. If omitted, a generic international/national
+                pattern is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert 12345 != IsPhoneNumber
+        ```
+        """
+        self.country_code = country_code
+        super().__init__(country_code or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = re.sub(r'[\s\-.()]', '', other)
+        if not cleaned:
+            return False
+
+        if self.country_code is None:
+            return bool(self.generic_re.fullmatch(cleaned))
+
+        country_code = self.country_code.upper()
+        if country_code == 'US':
+            return bool(self.us_national_re.fullmatch(cleaned) or self.us_international_re.fullmatch(cleaned))
+        elif country_code == 'GB':
+            return bool(self.gb_national_re.fullmatch(cleaned) or self.gb_international_re.fullmatch(cleaned))
+        else:
+            return bool(self.generic_international_re.fullmatch(cleaned))
