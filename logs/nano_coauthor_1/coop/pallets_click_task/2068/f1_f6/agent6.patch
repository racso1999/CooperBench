+_PRIORITY_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+_PRIORITY_WINDOWS_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+
+def _get_priority_popen_kwargs(process_priority: str) -> dict[str, t.Any]:
+    """Return extra ``subprocess.Popen`` kwargs to apply the given
+    priority level, if supported on this platform. Returns an empty
+    dict for unknown priority values or unsupported platforms so the
+    editor still launches normally.
+    """
+    if WIN:
+        creationflags = _PRIORITY_WINDOWS_CLASSES.get(process_priority)
+
+        if creationflags is None:
+            return {}
+
+        return {"creationflags": creationflags}
+
+    nice_value = _PRIORITY_NICE_VALUES.get(process_priority)
+
+    if nice_value is None:
+        return {}
+
+    def _preexec() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            pass
+
+    return {"preexec_fn": _preexec}
+
+
