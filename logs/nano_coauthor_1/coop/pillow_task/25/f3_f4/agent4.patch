+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.bak"
+
+        hopper().save(temp_file)
+        with Image.open(temp_file) as original:
+            original.load()
+
+        with hopper("L") as im:
+            im.save(temp_file, backup=True)
+
+        assert backup_file.exists()
+        with Image.open(backup_file) as backup:
+            assert backup.mode == original.mode
+
+        with Image.open(temp_file) as saved:
+            assert saved.mode == "L"
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.backup"
+
+        hopper().save(temp_file)
+
+        with hopper() as im:
+            im.save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert backup_file.exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.bak"
+
+        with hopper() as im:
+            im.save(temp_file, backup=True)
+
+        assert temp_file.exists()
+        assert not backup_file.exists()
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.bak"
+
+        hopper().save(temp_file)
+        with hopper("L") as im:
+            im.save(temp_file)
+
+        assert not backup_file.exists()
+
     def test_internals(self) -> None:
         im = Image.new("L", (100, 100))
         im.readonly = 1
