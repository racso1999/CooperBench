+        .. versionchanged:: 8.2
+            Added the nesting validation.
         """
+        if self.validate_nesting and self._children:
+            open_children = ", ".join(
+                repr(child.command_path) for child in self._children
+            )
+            raise RuntimeError(
+                f"Tried to close context {self.command_path!r} but it still"
+                f" has open child contexts: {open_children}"
+            )
+
