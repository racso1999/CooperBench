+    def _sort_palette(self, sort_palette):
+        """
+        Sorts the palette of this "P" mode image in place, remapping pixel
+        indices to match the new color order.
+
+        :param sort_palette: ``"luminance"`` to sort colors by perceptual
+           brightness, or ``"rgb"`` to sort colors by their raw RGB value.
+        """
+        mode_len = len(self.palette.mode)
+        palette = self.palette.palette
+        colors = [
+            tuple(palette[i : i + mode_len])
+            for i in range(0, len(palette), mode_len)
+        ]
+
+        # Only the palette entries that are actually used by a pixel need to
+        # be reordered; any trailing unused entries are left untouched.
+        used_indices = [index for _, index in self.getcolors(len(colors)) or []]
+        num_colors = max(used_indices) + 1 if used_indices else len(colors)
+
+        if sort_palette == "luminance":
+
+            def sort_key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color
+
+        else:
+            raise ValueError(f"Unsupported sort_palette value: {sort_palette!r}")
+
+        order = sorted(range(num_colors), key=lambda i: sort_key(colors[i]))
+
+        mapping = list(range(len(colors)))
+        for new_index, old_index in enumerate(order):
+            mapping[old_index] = new_index
+
+        new_palette = bytearray(palette)
+        for new_index, old_index in enumerate(order):
+            new_palette[new_index * mode_len : (new_index + 1) * mode_len] = colors[
+                old_index
+            ]
+
+        self.im = self.point(mapping).im
+        self.putpalette(bytes(new_palette), self.palette.mode)
+
