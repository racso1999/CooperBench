+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+    converted = image.quantize(256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+
+def test_error_threshold_uses_max_colors_if_unmet():
+    image = hopper()
+    converted = image.quantize(4, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_error_threshold_disabled_by_default():
+    image = hopper()
+    normal = image.quantize(64)
+    with_disabled_threshold = image.quantize(64, error_threshold=0)
+    assert normal.tobytes() == with_disabled_threshold.tobytes()
