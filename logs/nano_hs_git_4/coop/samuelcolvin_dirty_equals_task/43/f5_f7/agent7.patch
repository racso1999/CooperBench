+
+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+_HASH_LENGTHS: Dict[str, int] = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given hashing algorithm.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The hashing algorithm to check against.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'hello').hexdigest() == IsHash('md5')
+        assert hashlib.sha1(b'hello').hexdigest() == IsHash('sha1')
+        assert hashlib.sha256(b'hello').hexdigest() == IsHash('sha256')
+        assert 'not_a_hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.length = _HASH_LENGTHS[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hashing algorithm, must be one of {sorted(_HASH_LENGTHS)}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        return bool(re.fullmatch(f'[0-9a-fA-F]{{{self.length}}}', other))
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally checking against a specific
+    country's format. This is a pragmatic check suitable for validating user input, not an exhaustive
+    implementation of international numbering plans.
+    """
+
+    _strip_re = re.compile(r'[\s.()-]')
+    _generic_international_re = re.compile(r'^\+\d{7,15}$')
+    _generic_national_re = re.compile(r'^\d{7,15}$')
+
+    # (national pattern, international pattern) for countries with dedicated rules
+    _country_patterns = {
+        'US': (re.compile(r'^\d{10}$'), re.compile(r'^\+1\d{10}$')),
+        'GB': (re.compile(r'^0\d{9,10}$'), re.compile(r'^\+44\d{9,10}$')),
+    }
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to validate the number's format, if omitted, generic
+                phone number validation is used. Location-specific numbers do not need to include the
+                country's dialing code to be considered valid.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert 'not a phone number' != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country if self.country else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = self._strip_re.sub('', other)
+        if normalized.count('+') > 1 or '+' in normalized[1:]:
+            return False
+
+        if self.country is None:
+            return bool(self._generic_international_re.fullmatch(normalized) or self._generic_national_re.fullmatch(normalized))
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            # unknown country, fall back to generic international validation
+            return bool(self._generic_international_re.fullmatch(normalized))
+
+        national_re, international_re = patterns
+        return bool(national_re.fullmatch(normalized) or international_re.fullmatch(normalized))
