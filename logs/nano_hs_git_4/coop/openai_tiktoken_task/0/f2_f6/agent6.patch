+    def _token_start_offsets(self, token_bytes: Sequence[bytes]) -> list[int]:
+        """Given the decoded bytes of each token (in order), returns the starting character
+        offset of each token within the concatenation of those bytes decoded as UTF-8.
+
+        If UTF-8 character boundaries do not line up with token boundaries, the offset is the
+        index of the first character that contains bytes from the token.
+        """
         text_len = 0
         offsets = []
         for token in token_bytes:
             offsets.append(max(0, text_len - (0x80 <= token[0] < 0xC0)))
