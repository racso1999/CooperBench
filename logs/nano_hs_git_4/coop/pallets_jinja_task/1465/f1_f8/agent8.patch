           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`sort` filter, sorting and grouping is case-insensitive
+    by default. The ``key`` for each group has the case of the first item
+    in that group, and case sensitivity can be controlled with the
+    ``case_sensitive`` parameter.
+
+    You can enable ``with_counts`` to also get the number of items in
+    each group, without needing to call ``|list|length`` on the group.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=True) %}
+          <li>{{ city }} ({{ count }}): {{ items|map(attribute="name")|join(", ") }}</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``with_counts`` parameter.
+
+    .. versionchanged:: 3.1
+        Added the ``case_sensitive`` parameter. Sorting and grouping is
+        case-insensitive by default, matching other filters that do
+        comparisons.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1234,22 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    sort_expr = make_attrgetter(
+        environment,
+        attribute,
+        default=default,
+        postprocess=ignore_case if not case_sensitive else None,
+    )
+    groups = []
+
+    for _, items in groupby(sorted(value, key=sort_expr), sort_expr):
+        items = list(items)
+        groups.append((expr(items[0]), items))
+
+    if with_counts:
+        return [(key, items, len(items)) for key, items in groups]
+
+    return [_GroupTuple(key, items) for key, items in groups]
 
 
