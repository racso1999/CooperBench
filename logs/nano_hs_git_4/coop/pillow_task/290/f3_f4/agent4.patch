+def _mean_square_error(im1, im2):
+    from PIL import ImageChops, ImageStat
+
+    diff = ImageChops.difference(im1.convert("RGB"), im2.convert("RGB"))
+    stat = ImageStat.Stat(diff)
+    return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+
+def test_quantize_error_threshold_sanity():
+    image = hopper()
+    converted = image.quantize(256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert _mean_square_error(converted, image) <= 100
+
+
+def test_quantize_error_threshold_reduces_colors():
+    image = hopper()
+
+    loose = image.quantize(256, error_threshold=10000)
+    tight = image.quantize(256, error_threshold=1)
+
+    assert len(loose.getcolors()) <= len(tight.getcolors())
+
+
+def test_quantize_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    exact = image.quantize(4)
+    converted = image.quantize(4, error_threshold=0)
+
+    assert len(converted.getcolors()) == len(exact.getcolors())
