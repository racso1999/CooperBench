+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        # Find the smallest number of colors (up to ``colors``) whose
+        # quantized output has a mean square error at or below
+        # ``error_threshold``. Falls back to ``colors`` if the threshold
+        # can't be met.
+        from . import ImageChops, ImageStat
+
+        reference = self.convert("RGB")
+
+        def mean_square_error(quantized_im):
+            diff = ImageChops.difference(reference, quantized_im.convert("RGB"))
+            stat = ImageStat.Stat(diff)
+            return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+        best_im = self._new(self.im.quantize(colors, method, kmeans))
+        if mean_square_error(best_im) <= error_threshold:
+            low, high = 2, colors
+            while low <= high:
+                mid = (low + high) // 2
+                candidate_im = self._new(self.im.quantize(mid, method, kmeans))
+                if mean_square_error(candidate_im) <= error_threshold:
+                    best_im = candidate_im
+                    high = mid - 1
+                else:
+                    low = mid + 1
+
+        return best_im
