+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="not_a_method")
+
+
+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(100, sort_palette=sort_palette)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    used_colors = converted.getcolors()
+    assert len(used_colors) == 100
+
+    # The image content itself should be unaffected by the reordering.
+    unsorted = image.quantize(100)
+    assert sorted(converted.convert("RGB").getdata()) == sorted(
+        unsorted.convert("RGB").getdata()
+    )
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[idx * 3 : idx * 3 + 3]) for _, idx in used_colors]
+    if sort_palette == "brightness":
+        key = [sum(color) for color in colors]
+    else:
+        key = colors
+    assert key == sorted(key)
+
