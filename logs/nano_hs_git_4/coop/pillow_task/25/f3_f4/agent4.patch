+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        original = hopper()
+        original.save(out)
+        with open(out, "rb") as f:
+            original_data = f.read()
+
+        modified = hopper().rotate(90)
+        modified.save(out, backup=True)
+
+        backup_file = out + ".bak"
+        assert os.path.exists(backup_file)
+        with open(backup_file, "rb") as f:
+            assert f.read() == original_data
+
+        with Image.open(out) as reloaded:
+            assert_image_equal(modified, reloaded)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        hopper().save(out)
+
+        hopper().save(out, backup=True, backup_suffix=".backup")
+
+        assert os.path.exists(out + ".backup")
+        assert not os.path.exists(out + ".bak")
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        hopper().save(out, backup=True)
+
+        assert not os.path.exists(out + ".bak")
+        with Image.open(out) as reloaded:
+            assert_image_equal(hopper(), reloaded)
+
+    def test_save_no_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        hopper().save(out)
+
+        hopper().save(out)
+
+        assert not os.path.exists(out + ".bak")
+
+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_save_dry_run_fp(self) -> None:
+        im = hopper()
+        fp = io.BytesIO()
+        im.save(fp, "PNG", dry_run=True)
+        assert fp.tell() == 0
+
+    def test_save_dry_run_raises(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.jpg"
+        im = hopper("RGBA")
+        with pytest.raises(OSError):
+            im.save(out, dry_run=True)
+        assert not out.exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
             assert im.mode == "P"
