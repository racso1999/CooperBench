+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dict-based dynamic defaults now that every parameter
+        has a final value, so a dynamic default can depend on another
+        option regardless of the order the options were processed in.
+
+        A dynamic default is a ``dict`` mapping another option's name
+        (e.g. ``"--protocol"``) to a mapping of that option's stringified
+        value to the default value to use. It only applies to options
+        whose value still comes from :attr:`ParameterSource.DEFAULT`. If
+        multiple source options are given, later entries take precedence
+        over earlier ones when they match. If nothing matches, the option
+        remains ``None``.
+        """
+        params = self.get_params(ctx)
+        opt_to_param = {opt: param for param in params for opt in param.opts}
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param.default.items():
+                source_param = opt_to_param.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = str(ctx.params.get(source_param.name))  # type: ignore[arg-type]
+
+                if source_value in mapping:
+                    resolved = mapping[source_value]
+
+            if resolved is None:
+                continue
+
+            value = param.type_cast_value(ctx, resolved)
+
+            if param.callback is not None:
+                value = param.callback(ctx, param, value)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
