+    def _quantize_mse(self, quantized_im):
+        from . import ImageChops, ImageStat
+
+        comparable = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparable)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        low, high = 2, colors
+        best_im = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._quantize(mid, method, kmeans)
+            if self._quantize_mse(candidate) <= error_threshold:
+                best_im = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_im is not None:
+            return best_im
+        return self._quantize(colors, method, kmeans)
+
