+def test_quantize_error_threshold():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    mse = image._quantize_mse(converted)
+    assert mse <= 1000
+
+
+def test_quantize_error_threshold_unmet():
+    image = hopper()
+
+    # An unreasonably strict threshold cannot be met within the colors limit,
+    # so the maximum number of colors should be used instead.
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_negative():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_error_threshold_with_palette():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=100)
+
+
