+def _strip_all_metadata(image: Image.Image) -> None:
+    exif = image.getexif()
+    for tag in list(exif.keys()):
+        del exif[tag]
+    for key in (
+        "exif",
+        "Raw profile type exif",
+        "icc_profile",
+        "comment",
+        "XML:com.adobe.xmp",
+        "xmp",
+        "Raw profile type iptc",
+        "photoshop",
+        "adobe",
+    ):
+        image.info.pop(key, None)
