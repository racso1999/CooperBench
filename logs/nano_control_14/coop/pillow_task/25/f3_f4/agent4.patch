@@ -258,6 +258,43 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        red = Image.new("RGB", (1, 1), "#f00")
+        red.save(temp_file)
+
+        blue = Image.new("RGB", (1, 1), "#00f")
+        blue.save(temp_file, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        with Image.open(backup_file) as im:
+            assert im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as im:
+            assert im.getpixel((0, 0)) == (0, 0, 255)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        red = Image.new("RGB", (1, 1), "#f00")
+        red.save(temp_file)
+
+        blue = Image.new("RGB", (1, 1), "#00f")
+        blue.save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "#f00")
+        im.save(temp_file, backup=True)
+
+        assert temp_file.exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
     def test_dump(self, tmp_path: Path) -> None:
