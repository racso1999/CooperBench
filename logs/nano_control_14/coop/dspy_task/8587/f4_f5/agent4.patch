+    def _reset_state(self):
+        """Reset all per-stream state so the listener is ready for a new stream."""
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If a stream is in progress (started but not
+        yet ended) and no chunk has been received for `idle_timeout_s` seconds, this emits a `StreamResponse` with
+        an empty `chunk` to signal termination, and unconditionally resets the listener state, regardless of
+        `allow_reuse`, so it isn't left stuck in a started state.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        self._reset_state()
+        return response
