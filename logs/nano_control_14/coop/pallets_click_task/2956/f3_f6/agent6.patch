+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second pass over the parsed parameters to resolve dynamic
+        defaults, i.e. :class:`Option` defaults that depend on the
+        values of other options. This runs after every parameter has
+        been parsed so that the values it depends on are final.
+        """
+        opt_lookup: dict[str, Option] = {}
+
+        for param in self.get_params(ctx):
+            if isinstance(param, Option):
+                for opt in (*param.opts, *param.secondary_opts):
+                    opt_lookup[opt] = param
+
+        for param in self.get_params(ctx):
+            if (
+                not isinstance(param, Option)
+                or not param.is_dynamic_default
+                or param.name is None
+                or ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT
+            ):
+                continue
+
+            resolved = None
+            assert param._dynamic_default is not None
+
+            for opt_name, mapping in param._dynamic_default.items():
+                source_param = opt_lookup.get(opt_name)
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                key = str(ctx.params.get(source_param.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                try:
+                    value = param.process_value(ctx, resolved)
+                except Exception:
+                    if not ctx.resilient_parsing:
+                        raise
+
+                    value = None
+
+            if param.expose_value:
+                ctx.params[param.name] = value
+
