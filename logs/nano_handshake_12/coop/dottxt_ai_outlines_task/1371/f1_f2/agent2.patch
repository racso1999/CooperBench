@@ -11,6 +11,46 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+# Global registry of custom filters that are made available to every
+# prompt template, in addition to any filters passed locally.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter becomes available to every prompt template
+    without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function implementing the filter.
+
+    """
+    _FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+
+
+def get_registered_filters() -> Dict[str, Callable]:
+    """Return a copy of the globally registered filters."""
+    return dict(_FILTER_REGISTRY)
+
 
