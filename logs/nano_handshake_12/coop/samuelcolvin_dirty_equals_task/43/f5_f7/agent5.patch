+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a phone number, optionally restricted to a specific country's
+    formatting rules.
+    """
+
+    _strip_re = re.compile(r'[\s\-.()]')
+    _generic_re = re.compile(r'^\+?\d{7,15}$')
+    _international_re = re.compile(r'^\+\d{7,15}$')
+
+    # country: (national_re, international_re)
+    _country_patterns = {
+        'US': (re.compile(r'^\d{10}$'), re.compile(r'^\+1\d{10}$')),
+        'GB': (re.compile(r'^0\d{9,10}$'), re.compile(r'^\+44\d{9,10}$')),
+    }
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to apply country-specific formatting
+                rules, if omitted, generic international/national phone number formats are accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+        assert 123 != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        ```
+        """
+        self.country = country
+        super().__init__(plain_repr('*') if country is None else country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = self._strip_re.sub('', other)
+
+        if self.country is None:
+            return bool(self._generic_re.match(normalized))
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            return bool(self._international_re.match(normalized))
+
+        national_re, international_re = patterns
+        return bool(national_re.match(normalized) or international_re.match(normalized))
