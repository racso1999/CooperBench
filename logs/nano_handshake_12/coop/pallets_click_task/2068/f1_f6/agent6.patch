+_PROCESS_PRIORITIES = ("low", "below_normal", "normal", "above_normal", "high")
+
+
+def _set_process_priority(pid: int, priority: str) -> None:
+    """Best-effort attempt to set the CPU scheduling priority of the
+    process with the given ``pid``. Any failure, such as an
+    unsupported platform, insufficient permissions, or the process
+    having already exited, is silently ignored so that it never
+    prevents the caller from continuing.
+    """
+    if priority not in _PROCESS_PRIORITIES:
+        return
+
+    try:
+        if WIN:
+            import ctypes
+
+            priority_classes = {
+                "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+                "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+                "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+                "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+                "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+            }
+            PROCESS_SET_INFORMATION = 0x0200
+            kernel32 = ctypes.windll.kernel32  # type: ignore[attr-defined]
+            handle = kernel32.OpenProcess(PROCESS_SET_INFORMATION, False, pid)
+            if handle:
+                try:
+                    kernel32.SetPriorityClass(handle, priority_classes[priority])
+                finally:
+                    kernel32.CloseHandle(handle)
+        else:
+            nice_values = {
+                "low": 10,
+                "below_normal": 5,
+                "normal": 0,
+                "above_normal": -5,
+                "high": -10,
+            }
+            os.setpriority(os.PRIO_PROCESS, pid, nice_values[priority])
+    except Exception:
+        pass
+
+
