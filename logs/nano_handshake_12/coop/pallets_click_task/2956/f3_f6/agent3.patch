+def _batched(
+    iterable: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Yield successive tuples of at most ``batch_size`` items from
+    ``iterable`` without accumulating the whole thing in memory.
+    """
+    it = iter(iterable)
+
+    while batch := tuple(islice(it, batch_size)):
+        yield batch
+
