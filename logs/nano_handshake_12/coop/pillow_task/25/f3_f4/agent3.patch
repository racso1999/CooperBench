diff --git a/Tests/test_image.py b/Tests/test_image.py
index c2e850c36..2b4b1ee0e 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -1129,6 +1129,32 @@ class TestImage:
         with pytest.warns(DeprecationWarning):
             assert not Image.isImageType(None)
 
+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file, dry_run=True)
+
+        assert not temp_file.exists()
+
+    def test_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        hopper().save(temp_file)
+        original_bytes = temp_file.read_bytes()
+
+        hopper("L").save(temp_file, dry_run=True)
+
+        assert temp_file.read_bytes() == original_bytes
+
+    def test_dry_run_raises_for_unsupported_mode(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.eps"
+
+        im = hopper("RGBA")
+        with pytest.raises(ValueError):
+            im.save(temp_file, dry_run=True)
+
+        assert not temp_file.exists()
+
 
