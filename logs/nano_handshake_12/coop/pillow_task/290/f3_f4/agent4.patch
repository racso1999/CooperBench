diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..e65244641 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,25 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=1000000)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_caps_at_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_error_threshold_none_is_unaffected():
+    image = hopper()
+
+    with_none = image.quantize(colors=64)
+    explicit_none = image.quantize(colors=64, error_threshold=None)
+    assert with_none.tobytes() == explicit_none.tobytes()
