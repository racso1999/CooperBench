@@ -1,5 +1,7 @@
 from __future__ import annotations
 
+from collections.abc import Sequence
+
 import pytest
 
 from PIL import Image, ImageDraw, ImageOps, ImageStat, features
@@ -580,3 +582,69 @@ def test_autocontrast_preserve_one_color(color: tuple[int, int, int]) -> None:
         img, cutoff=10, preserve_tone=True
     )  # single color 10 cutoff
     assert_image_equal(img, out)
+
+
+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.getexif()[0x0112] == 8
+        expected = im.rotate(90, expand=True)
+
+        def transform_callback(orientation: int) -> Image.Transpose | None:
+            assert orientation == 8
+            return Image.Transpose.ROTATE_90
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=transform_callback
+        )
+        assert 0x0112 not in transposed_im.getexif()
+        assert_image_equal(transposed_im, expected)
+
+
+def test_exif_transpose_transform_callback_sequence() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert im.getexif()[0x0112] == 6
+
+        def transform_callback(
+            orientation: int,
+        ) -> Sequence[Image.Transpose]:
+            # Equivalent to a single ROTATE_270, applied as two steps
+            return (Image.Transpose.ROTATE_180, Image.Transpose.ROTATE_90)
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=transform_callback
+        )
+        expected = im.transpose(Image.Transpose.ROTATE_270)
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+
+def test_exif_transpose_transform_callback_none() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+        original = im.copy()
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: None
+        )
+        assert transposed_im.size == im.size
+        assert_image_equal(transposed_im, original)
+
+        # The orientation tag is only removed when a transposition is applied
+        assert 0x0112 in transposed_im.getexif()
+
+
+def test_exif_transpose_transform_callback_in_place() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+        expected = im.rotate(90, expand=True)
+
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_90,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
