+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and, if so, terminate it.
+
+        This should be called periodically by the streaming system (it is not triggered by `receive()`), since an
+        upstream stall means no new chunks--and therefore no calls to `receive()`--will arrive on their own.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed while the stream was started
+            but not yet ended, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+        if not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally (even if `allow_reuse` is False) so that a stalled stream
+        # doesn't permanently leave the listener stuck in a "started" state.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        on_chunk = getattr(self, "on_chunk", None)
+        if callable(on_chunk):
+            on_chunk(response)
+
+        return response
+
