+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very high threshold should be satisfied with far fewer colors
+    # than requested.
+    low_quality = image.quantize(colors=256, error_threshold=10000)
+    assert_image(low_quality, "P", low_quality.size)
+    assert len(low_quality.getcolors()) < 256
+
+    # An unreachable (very low) threshold should fall back to using the
+    # maximum number of colors allowed.
+    high_quality = image.quantize(colors=100, error_threshold=0.0001)
+    assert_image(high_quality, "P", high_quality.size)
+    assert len(high_quality.getcolors()) == 100
+
+    # Without a threshold, behaviour should be unaffected.
+    default = image.quantize(colors=100)
+    assert len(default.getcolors()) == 100
+
