+    def _quantize_error(self, quantized_im):
+        """
+        Returns the mean square error between this image and a quantized
+        (mode "P") version of it, averaged across bands.
+        """
+        from . import ImageChops, ImageStat
+
+        comparison = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparison)
+        stat = ImageStat.Stat(diff)
+        return sum(rms ** 2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible, up to
+        ``colors``, such that the mean square error against the original
+        image is at most ``error_threshold``. If that is not achievable
+        within ``colors`` colors, quantizes using ``colors`` colors.
+        """
+        low, high = 1, colors
+        best = self._new(self.im.quantize(high, method, kmeans))
+        if self._quantize_error(best) > error_threshold:
+            return best
+
+        while low < high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantize_error(candidate) <= error_threshold:
+                best = candidate
+                high = mid
+            else:
+                low = mid + 1
+
+        return best
+
