+    def _sort_palette(self, sort_palette):
+        """
+        Reorders the palette of a "P" mode image according to the given
+        sorting method, remapping the pixel data to match.
+
+        :param sort_palette: ``"luminance"`` to sort colors from darkest to
+           lightest, or ``"rgb"`` to sort colors by their RGB (or RGBA) tuple
+           value.
+        """
+        if sort_palette not in ("luminance", "rgb"):
+            raise ValueError(
+                "sort_palette must be 'luminance' or 'rgb', "
+                "got %r" % (sort_palette,)
+            )
+
+        mode = self.palette.mode
+        num_bands = len(mode)
+        raw_palette = self.palette.palette
+        total_entries = len(raw_palette) // num_bands
+
+        # Only the entries actually referenced by pixel data need sorting;
+        # any remaining (unused) palette slots are left untouched.
+        num_colors = min(self.getextrema()[1] + 1, total_entries)
+        colors = [
+            tuple(raw_palette[i * num_bands : i * num_bands + num_bands])
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "luminance":
+
+            def sort_key(index):
+                r, g, b = colors[index][:3]
+                return r * 299 + g * 587 + b * 114
+
+        else:
+
+            def sort_key(index):
+                return colors[index]
+
+        dest_map = sorted(range(num_colors), key=sort_key)
+
+        new_positions = list(range(total_entries))
+        for new_index, old_position in enumerate(dest_map):
+            new_positions[old_position] = new_index
+
+        from . import ImagePalette
+
+        mapping_palette = bytearray(new_positions)
+
+        m_im = self.copy()
+        m_im.mode = "P"
+        m_im.palette = ImagePalette.ImagePalette("RGB", palette=mapping_palette * 3)
+        m_im.im.putpalette("RGB;L", m_im.palette.tobytes())
+
+        m_im = m_im.convert("L")
+
+        new_palette_bytes = b"".join(
+            bytes(colors[old_position]) for old_position in dest_map
+        ) + raw_palette[num_colors * num_bands :]
+        m_im.putpalette(new_palette_bytes, mode)
+        m_im.palette = ImagePalette.ImagePalette(mode, palette=new_palette_bytes)
+
+        return m_im
+
