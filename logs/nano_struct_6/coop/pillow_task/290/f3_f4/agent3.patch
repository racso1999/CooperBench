+@pytest.mark.parametrize("sort_palette", ("luminance", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(100, sort_palette=sort_palette)
+
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    num_colors = converted.getextrema()[1] + 1
+    palette = converted.palette.palette
+    colors = [tuple(palette[i : i + 3]) for i in range(0, num_colors * 3, 3)]
+
+    if sort_palette == "luminance":
+        keys = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    else:
+        keys = colors
+    assert keys == sorted(keys)
+
+
+def test_quantize_sort_palette_matches_unsorted():
+    image = hopper()
+    unsorted = image.quantize(100)
+    sorted_im = image.quantize(100, sort_palette="luminance")
+
+    # The sorted image should represent the same colors as the unsorted one,
+    # just with a reordered palette.
+    assert sorted_im.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+
+def test_quantize_sort_palette_rgba():
+    image = hopper("RGBA")
+    unsorted = image.quantize(method=Image.FASTOCTREE)
+    sorted_im = image.quantize(method=Image.FASTOCTREE, sort_palette="rgb")
+
+    assert sorted_im.convert("RGBA").tobytes() == unsorted.convert("RGBA").tobytes()
+
+    num_colors = sorted_im.getextrema()[1] + 1
+    palette = sorted_im.palette.palette
+    colors = [tuple(palette[i : i + 4]) for i in range(0, num_colors * 4, 4)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_invalid_sort_palette():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="unknown")
