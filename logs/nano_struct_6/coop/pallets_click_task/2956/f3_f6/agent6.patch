+    @staticmethod
+    def _validate_dynamic_default(mapping: dict[t.Any, t.Any]) -> None:
+        for key, value in mapping.items():
+            if not isinstance(key, str):
+                raise TypeError("Dynamic default keys must be strings")
+
+            if not isinstance(value, dict):
+                raise TypeError("Dynamic default values must be dictionaries")
+
+    def _resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dynamic (dict-based) default by looking at the
+        current values of the referenced options. Returns ``None`` if
+        no mapping matches.
+        """
+        assert self._dynamic_default is not None
+        resolved: t.Any | None = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_param = next(
+                (
+                    param
+                    for param in ctx.command.get_params(ctx)
+                    if opt_name in param.opts or opt_name in param.secondary_opts
+                ),
+                None,
+            )
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
