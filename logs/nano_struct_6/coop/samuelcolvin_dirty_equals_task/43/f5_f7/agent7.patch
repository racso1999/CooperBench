+
+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+_HASH_LENGTHS: Dict[str, int] = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given hashing algorithm.
+
+    The following algorithms are supported: `md5`, `sha1`, `sha224`, `sha256`, `sha384` and `sha512`.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The algorithm to use for the hash check.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert '2aae6c35c94fcfb415dbe95f408b9ce91ee846ed' == IsHash('sha1')
+        assert 'not a valid hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.length = _HASH_LENGTHS[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.length:
+            return False
+
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+
+        return True
