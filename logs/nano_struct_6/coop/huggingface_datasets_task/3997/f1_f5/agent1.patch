+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the `Features` class synced with the
+    main dictionary.
+
+    This is required so that operations that modify the underlying dict, e.g. `__setitem__`, `__delitem__`,
+    `update`, etc., automatically stay reflected in `_column_requires_decoding`, since we cannot rely on `Features`
+    being a `UserDict` for performance reasons (a plain `dict` subclass is much faster and avoids breaking changes
+    for users relying on `isinstance(features, dict)`).
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        self: "Features" = args[0]
+        out = func(*args, **kwargs)
+        self._column_requires_decoding: Dict[str, bool] = {
+            col: require_decoding(feature) for col, feature in self.items()
+        }
+        return out
+
+    wrapper.__name__ = func.__name__
+    return wrapper
+
+
