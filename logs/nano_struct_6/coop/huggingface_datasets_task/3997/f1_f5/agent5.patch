+    def _update_one(self, key, value):
+        if key in self:
+            current_value = self[key]
+            current_dict = current_value.feature if isinstance(current_value, Sequence) else current_value
+            new_dict = value.feature if isinstance(value, Sequence) else value
+            if isinstance(current_dict, dict) and isinstance(new_dict, dict):
+                self._deep_merge_dicts(current_dict, new_dict)
+                self[key] = current_value
+                return
+        self[key] = value
+
+    @staticmethod
+    def _deep_merge_dicts(target: dict, source: dict):
+        for key, value in source.items():
+            if key in target:
+                target_value = target[key].feature if isinstance(target[key], Sequence) else target[key]
+                new_value = value.feature if isinstance(value, Sequence) else value
+                if isinstance(target_value, dict) and isinstance(new_value, dict):
+                    Features._deep_merge_dicts(target_value, new_value)
+                    continue
+            target[key] = value
 
     def __reduce__(self):
         return Features, (dict(self),)
