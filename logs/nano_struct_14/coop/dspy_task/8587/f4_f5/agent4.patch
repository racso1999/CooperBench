+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If the configured idle timeout has
+        elapsed since the last chunk was received while a stream is in progress, this emits a final,
+        empty-`chunk` `StreamResponse` to unblock consumers and resets the listener state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now = time.time() if now_ts is None else now_ts
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now
+        if now - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        kwargs = {}
+        if any(f.name == "is_last_chunk" for f in dataclass_fields(StreamResponse)):
+            kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **kwargs)
+
+        # The timeout ends the stream, so the listener state must be reset unconditionally, regardless of
+        # `allow_reuse`, otherwise it would be stuck thinking a stream is still in progress.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
