           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
+    case-insensitive by default. The ``key`` for each group will have
+    the case of the first item in that group of values. For example,
+    if a list of users has cities ``["CA", "NY", "ca"]``, the "CA" and
+    "ca" entries will be grouped together, under a "CA" key. Pass
+    ``case_sensitive=true`` to treat the values as distinct.
+
+    .. versionchanged:: 3.1
+        Added the ``case_sensitive`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1221,29 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    out = []
+
+    for key, values in groupby(
+        sorted(
+            value,
+            key=make_attrgetter(
+                environment,
+                attribute,
+                postprocess=ignore_case if not case_sensitive else None,
+                default=default,
+            ),
+        ),
+        make_attrgetter(
+            environment,
+            attribute,
+            postprocess=ignore_case if not case_sensitive else None,
+            default=default,
+        ),
+    ):
+        values = list(values)
+        out.append(_GroupTuple(expr(values[0]), values))
+
+    return out
 
 
