+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very high error threshold should be satisfied almost immediately,
+    # resulting in far fewer colors than the requested maximum.
+    lenient = image.quantize(colors=256, error_threshold=100000)
+    assert_image(lenient, "P", lenient.size)
+    assert len(lenient.getcolors()) < 256
+
+    # An unreachable error threshold should fall back to the requested
+    # maximum number of colors.
+    strict = image.quantize(colors=4, error_threshold=0.0001)
+    assert_image(strict, "P", strict.size)
+    assert len(strict.getcolors()) <= 4
+
+    # Without an error threshold, behaviour should be unaffected.
+    default = image.quantize(colors=64)
+    assert len(default.getcolors()) == 64
+
+    with pytest.raises(ValueError):
+        image.quantize(colors=64, error_threshold=-1)
+
+
