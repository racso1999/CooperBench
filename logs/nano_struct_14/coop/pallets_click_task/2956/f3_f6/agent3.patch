+def _batched(
+    values: cabc.Sequence[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Yield successive batches of up to ``batch_size`` items from
+    ``values``.
+    """
+    it = iter(values)
+
+    while batch := tuple(itertools.islice(it, batch_size)):
+        yield batch
+
