+def _validate_dynamic_default(spec: cabc.Mapping[t.Any, t.Any]) -> None:
+    """Validate the shape of a dynamic default mapping given as an
+    option's ``default``.
+
+    :param spec: A mapping of option declarations (e.g. ``"--protocol"``)
+        to a mapping of stringified source values to the default value
+        that should be used when that source value is in effect.
+    """
+    for key, value in spec.items():
+        if not isinstance(key, str):
+            raise TypeError("Dynamic default keys must be strings")
+
+        if not isinstance(value, dict):
+            raise TypeError("Dynamic default values must be dictionaries")
+
