+    def _resolve_dynamic_option_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution of dictionary-based dynamic defaults.
+
+        Once every option has consumed its command line, environment
+        variable, and default map value, options whose default is a
+        dynamic default mapping (see :class:`Option`) are resolved based
+        on the final values of the options they depend on. This only
+        applies to options whose value source is
+        :attr:`ParameterSource.DEFAULT`, i.e. no explicit value was
+        otherwise provided.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or param.dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore
+                continue
+
+            resolved = None
+
+            for opt_decl, mapping in param.dynamic_default.items():
+                source = next(
+                    (
+                        p
+                        for p in params
+                        if opt_decl in p.opts or opt_decl in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source is None or source.name is None:
+                    continue
+
+                key = str(ctx.params.get(source.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore
+
