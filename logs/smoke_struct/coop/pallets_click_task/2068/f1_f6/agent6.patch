+
+# Nice value deltas used on POSIX systems. 0 is the default priority of a
+# newly spawned process, negative values raise priority (require
+# privileges on most systems), positive values lower it.
+_POSIX_PRIORITY_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
