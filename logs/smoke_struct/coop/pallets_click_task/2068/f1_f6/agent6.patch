+        ``self.process_priority``, if possible. Never raises; if the
+        priority can't be applied on this platform, an empty dict is
+        returned and the editor launches with the default priority.
+        """
+        if self.process_priority is None:
+            return {}
+
+        if WIN:
+            priority_class = _WIN_PRIORITY_CLASSES.get(self.process_priority)
+
+            if priority_class is not None:
+                return {"creationflags": priority_class}
+
+            return {}
+
+        nice_value = _POSIX_PRIORITY_NICE_VALUES.get(self.process_priority)
+
+        if nice_value is None:
+            return {}
+
+        def _apply_nice_value() -> None:
+            try:
+                os.nice(nice_value)
+            except OSError:
