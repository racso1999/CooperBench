         with Image.open(out) as reloaded:
             assert_image_equal(im, reloaded)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+
+        # No existing file, so no backup should be created
+        im = hopper()
+        im.save(out, backup=True)
+        assert not os.path.exists(out + ".bak")
+        with Image.open(out) as reloaded:
+            assert_image_equal(im, reloaded)
+
+        # File already exists, so a backup should be created
+        original_data = Path(out).read_bytes()
+        im2 = hopper("L")
+        im2.save(out, backup=True)
+        assert os.path.exists(out + ".bak")
+        assert Path(out + ".bak").read_bytes() == original_data
+        with Image.open(out) as reloaded:
+            assert_image_equal(im2, reloaded)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+
+        im = hopper()
+        im.save(out)
+
+        original_data = Path(out).read_bytes()
+        im2 = hopper("L")
+        im2.save(out, backup=True, backup_suffix=".backup")
+        assert not os.path.exists(out + ".bak")
+        assert os.path.exists(out + ".backup")
+        assert Path(out + ".backup").read_bytes() == original_data
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
