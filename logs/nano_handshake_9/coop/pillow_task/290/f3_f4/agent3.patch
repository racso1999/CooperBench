     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(im):
+    palette = im.getpalette()
+    return [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+
+
+def _brightness(color):
+    r, g, b = color[:3]
+    return 0.299 * r + 0.587 * g + 0.114 * b
+
+
+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(100, sort_palette=sort_palette)
+
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    # Sorting the palette should not change how the image looks
+    unsorted = image.quantize(100)
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+    colors = _palette_colors(converted)
+    if sort_palette == "brightness":
+        assert colors == sorted(colors, key=_brightness)
+    else:
+        assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_with_reference_palette():
+    image = hopper()
+    palette = image.quantize(32)
+
+    converted = image.quantize(palette=palette, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors)
+
+    # Sorting the palette should not change how the image looks
+    unsorted = image.quantize(palette=palette)
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="invalid")
