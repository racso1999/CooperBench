@@ -11,6 +11,42 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+#: Registry of filters that have been made globally available to all prompt
+#: templates via :func:`register_filter`.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to make it available to all prompt templates.
+
+    Once registered, the filter can be used in any template rendered through
+    the `Prompt` class (e.g. via `@outlines.prompt`, `Prompt.from_str` or
+    `Prompt.from_file`) without having to pass it explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function that implements the filter.
+
+    """
+    _FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+
 
