+#: Maps a ``process_priority`` value to a Unix ``nice`` increment.
+_UNIX_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+#: Maps a ``process_priority`` value to the name of a Windows process
+#: priority class exposed on the :mod:`subprocess` module.
+_WIN_PRIORITY_CLASSES = {
+    "low": "IDLE_PRIORITY_CLASS",
+    "below_normal": "BELOW_NORMAL_PRIORITY_CLASS",
+    "normal": "NORMAL_PRIORITY_CLASS",
+    "above_normal": "ABOVE_NORMAL_PRIORITY_CLASS",
+    "high": "HIGH_PRIORITY_CLASS",
+}
