+def _batched(value: tuple[t.Any, ...], batch_size: int) -> cabc.Iterator[t.Any]:
+    """Yield successive tuples of at most ``batch_size`` items from ``value``."""
+    if not value or batch_size == 0:
+        return
+
+    for i in range(0, len(value), batch_size):
+        yield value[i : i + batch_size]
+
