+    def _quantize_error(self, quantized):
+        """
+        Returns the mean square error (MSE) between this image and a
+        quantized version of it, averaged across bands.
+        """
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(self.convert("RGB"), quantized.convert("RGB"))
+        stat = ImageStat.Stat(diff)
+        pixel_count = diff.size[0] * diff.size[1]
+        if not pixel_count:
+            return 0
+        return sum(stat.sum2) / (len(stat.sum2) * pixel_count)
+
+    def _adjust_palette_lightness(self, lightness_factor):
+        """
+        Adjusts the brightness of this image's palette in place by the
+        given factor, clamping channel values to the 0-255 range.
+        """
+        self.load()
+        palette = self.palette
+        mode_len = len(palette.mode)
+        color_channels = 3 if palette.mode.startswith("RGB") else mode_len
+
+        data = bytearray(palette.tobytes())
+        for i in range(0, len(data), mode_len):
+            for c in range(color_channels):
+                data[i + c] = min(255, max(0, round(data[i + c] * lightness_factor)))
+
+        self.putpalette(bytes(data), palette.mode)
+
