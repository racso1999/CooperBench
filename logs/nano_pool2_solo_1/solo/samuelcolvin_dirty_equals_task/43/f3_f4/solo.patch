+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain.
+    """
+
+    email_regex = re.compile(r'^[^@\s]+@(?P<domain>[^@\s]+\.[^@\s]+)$')
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: The domain of the email address to check, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'sample@example.com' == IsEmail
+        assert 'sample@example.com' == IsEmail(domain='example.com')
+        assert 'sample@example.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(domain if domain is not None else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        match = self.email_regex.match(other)
+        if not match:
+            return False
+
+        if self.domain is not None:
+            return match.group('domain') == self.domain
+
+        return True
+
+
+class IsURL(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid URL, optionally checking the protocol and/or domain.
+    """
+
+    def __init__(self, protocol: Optional[Union[str, List[str]]] = None, domain: Optional[str] = None):
+        """
+        Args:
+            protocol: The protocol (or list of allowed protocols) the URL must use, if omitted, any protocol is
+                accepted.
+            domain: The domain (netloc, including port if present) the URL must use, if omitted, any domain is
+                accepted.
+
+        ```py title="IsURL"
+        from dirty_equals import IsURL
+
+        assert 'https://example.com' == IsURL
+        assert 'https://example.com' == IsURL(protocol='https')
+        assert 'http://example.com' != IsURL(protocol='https')
+        assert 'https://example.com' == IsURL(protocol=['http', 'https'])
+        assert 'https://example.com' == IsURL(domain='example.com')
+        assert 'https://example.com:8000' == IsURL(domain='example.com:8000')
+        assert 'not-a-url' != IsURL
+        ```
+        """
+        self.protocol = protocol
+        self.domain = domain
+
+        repr_args: tuple = ()
+        if protocol is not None:
+            repr_args += (protocol,)
+        if domain is not None:
+            repr_args += (domain,)
+
+        if repr_args:
+            super().__init__(*repr_args)
+        else:
+            super().__init__(plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        try:
+            parsed = urlparse(other)
+        except ValueError:
+            return False
+
+        if not parsed.scheme or not parsed.netloc:
+            return False
+
+        if self.protocol is not None:
+            if isinstance(self.protocol, str):
+                if parsed.scheme != self.protocol:
+                    return False
+            elif parsed.scheme not in self.protocol:
+                return False
+
+        if self.domain is not None and parsed.netloc != self.domain:
+            return False
+
+        return True
