+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given hashing algorithm.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The algorithm to use for the hash, must be one of `'md5'`, `'sha1'`, `'sha224'`,
+                `'sha256'`, `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert 'd0be2dc421be4fcd0172e5afceea3970e2f3d940' == IsHash('sha1')
+        assert '3d85f13c5da9e330cfd15c00da609a2d1d2cd88a' != IsHash('md5')
+        assert '2ef7bde608ce5404e97d5f042f95f89f1c232871' == IsHash('sha1')
+        ```
+        """
+        self.algorithm = algorithm
+        algorithm_lower = algorithm.lower()
+        if algorithm_lower not in _hash_lengths:
+            raise ValueError(f'Unknown algorithm {algorithm!r}')
+        self.hash_length = _hash_lengths[algorithm_lower]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.hash_length:
+            return False
+
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+
+        return True
+
