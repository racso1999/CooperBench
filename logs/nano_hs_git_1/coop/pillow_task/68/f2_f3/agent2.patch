+def test_exif_transpose_strip_metadata() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert "exif" in im.info
+        assert len(im.getexif()) >= 1
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert transposed_im.info == {}
+        assert len(transposed_im.getexif()) == 0
+
+    # No orientation to correct, metadata should still be stripped
+    with Image.open("Tests/images/hopper.jpg") as im:
+        assert im.info != {}
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert transposed_im.info == {}
+        assert len(transposed_im.getexif()) == 0
+
+
+def test_exif_transpose_strip_metadata_in_place() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert "exif" in im.info
+
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert im.info == {}
+        assert len(im.getexif()) == 0
+
+
+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+
+        orientations_seen = []
+
+        def transform_callback(orientation: int) -> Image.Transpose | None:
+            orientations_seen.append(orientation)
+            return Image.Transpose.ROTATE_90
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=transform_callback
+        )
+        assert orientations_seen == [8]
+        assert transposed_im.size == (1, 2)
+        assert 0x0112 not in transposed_im.getexif()
+
+    # A sequence of methods can be returned, and applied in order
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        expected = im.transpose(Image.Transpose.ROTATE_90).transpose(
+            Image.Transpose.FLIP_LEFT_RIGHT
+        )
+
+        def transform_callback_sequence(
+            orientation: int,
+        ) -> list[Image.Transpose]:
+            return [Image.Transpose.ROTATE_90, Image.Transpose.FLIP_LEFT_RIGHT]
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=transform_callback_sequence
+        )
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+    # If the callback returns None, no transposition occurs and the image is
+    # returned as a copy, matching the behavior when no method is found
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+
+        def transform_callback_none(orientation: int) -> None:
+            return None
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=transform_callback_none
+        )
+        assert transposed_im.size == im.size
+        assert 0x0112 in transposed_im.getexif()
+
+    # The callback overrides the default mapping, and can be used in-place
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        expected = im.rotate(90, expand=True)
+
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_90,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
