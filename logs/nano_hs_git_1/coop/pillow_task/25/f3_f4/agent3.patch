+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+
+        # No existing file, so no backup should be created
+        im.save(out, backup=True)
+        assert not os.path.exists(out + ".bak")
+
+        original_data = Path(out).read_bytes()
+
+        # Existing file, so a backup should be created
+        im.rotate(90).save(out, backup=True)
+        assert os.path.exists(out + ".bak")
+        assert Path(out + ".bak").read_bytes() == original_data
+
+        with Image.open(out) as reloaded:
+            assert_image_equal(im.rotate(90), reloaded)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+        im.save(out)
+
+        original_data = Path(out).read_bytes()
+        im.rotate(90).save(out, backup=True, backup_suffix=".backup")
+
+        assert not os.path.exists(out + ".bak")
+        assert os.path.exists(out + ".backup")
+        assert Path(out + ".backup").read_bytes() == original_data
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+        im.save(out)
+        im.rotate(90).save(out)
+
+        assert not os.path.exists(out + ".bak")
+
+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_save_dry_run_raises(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper().convert("CMYK")
+        with pytest.raises(OSError):
+            im.save(out, format="PNG", dry_run=True)
+        assert not out.exists()
+
