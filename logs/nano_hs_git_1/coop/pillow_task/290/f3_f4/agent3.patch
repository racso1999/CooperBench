+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 30)
+
+    palette = converted.palette.palette
+    brightnesses = [
+        sum(palette[i : i + 3]) for i in range(0, len(converted.getcolors()) * 3, 3)
+    ]
+    assert brightnesses == sorted(brightnesses)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 30)
+
+    palette = converted.palette.palette
+    colors = [
+        tuple(palette[i : i + 3]) for i in range(0, len(converted.getcolors()) * 3, 3)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette=lambda color: -sum(color[:3]))
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 30)
+
+    palette = converted.palette.palette
+    brightnesses = [
+        sum(palette[i : i + 3]) for i in range(0, len(converted.getcolors()) * 3, 3)
+    ]
+    assert brightnesses == sorted(brightnesses, reverse=True)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=32, sort_palette="unknown")
+
+
+def test_sort_palette_no_sort_by_default():
+    image = hopper()
+    unsorted = image.quantize(colors=32)
+    sorted_palette = image.quantize(colors=32, sort_palette="brightness")
+    assert unsorted.palette.palette != sorted_palette.palette.palette
