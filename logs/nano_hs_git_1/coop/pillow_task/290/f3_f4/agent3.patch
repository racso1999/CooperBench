+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should allow fewer than the requested colors.
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    # An unreachable threshold should fall back to using the maximum
+    # number of allowed colors.
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
