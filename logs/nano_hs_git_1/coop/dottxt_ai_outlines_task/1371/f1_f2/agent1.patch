+def create_jinja_env(
+    loader: Optional[jinja2.BaseLoader] = None,
+    filters: Optional[Dict[str, Callable]] = None,
+) -> jinja2.Environment:
+    """Create a Jinja2 environment configured for prompt rendering.
+
+    Centralizes environment creation and filter registration so that both
+    string-based and file-based templates share the same configuration and
+    built-in filters, and can be extended with custom filters.
+
+    Parameters
+    ----------
+    loader
+        An optional Jinja2 loader, used when templates are loaded from files.
+    filters
+        A dictionary of custom Jinja2 filters to register on the environment,
+        mapping filter names to callables. These take precedence over the
+        built-in filters if the names collide.
+
+    Returns
+    -------
+    A configured `jinja2.Environment` instance.
+
+    """
+    env = jinja2.Environment(
+        loader=loader,
+        trim_blocks=True,
+        lstrip_blocks=True,
+        keep_trailing_newline=True,
+        undefined=jinja2.StrictUndefined,
+    )
+    env.filters.update(_GLOBAL_FILTERS)
+    env.filters["name"] = get_fn_name
+    env.filters["description"] = get_fn_description
+    env.filters["source"] = get_fn_source
+    env.filters["signature"] = get_fn_signature
+    env.filters["schema"] = get_schema
+    env.filters["args"] = get_fn_args
+
+    if filters:
+        env.filters.update(filters)
+
+    return env
