+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second pass over the parsed parameters to resolve options whose
+        ``default`` is a dynamic default mapping (``{"--other-option":
+        {value: default, ...}}``). This runs after every parameter has
+        already been parsed from the command line, environment variables,
+        and ``Context.default_map`` so that the mappings can key off the
+        final values of the options they depend on.
+        """
+        params = self.get_params(ctx)
+        opt_to_param = {
+            opt: param
+            for param in params
+            if isinstance(param, Option)
+            for opt in (*param.opts, *param.secondary_opts)
+        }
+
+        for param in params:
+            if (
+                not isinstance(param, Option)
+                or param._dynamic_default is None
+                or not param.expose_value
+            ):
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param._dynamic_default.items():
+                source_param = opt_to_param.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore
+
