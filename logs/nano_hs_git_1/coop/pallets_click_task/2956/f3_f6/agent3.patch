 import sys
@@ -27,6 +28,19 @@ if t.TYPE_CHECKING:
 ParamTypeValue = t.TypeVar("ParamTypeValue")
 
 
+def _batched(
+    iterable: cabc.Iterable[ParamTypeValue], batch_size: int
+) -> cabc.Iterator[tuple[ParamTypeValue, ...]]:
+    """Batch items from ``iterable`` into tuples of at most ``batch_size``.
+
+    The final tuple may be shorter than ``batch_size`` if the number of
+    items isn't evenly divisible.
+    """
+    it = iter(iterable)
+    while batch := tuple(itertools.islice(it, batch_size)):
+        yield batch
+
+
