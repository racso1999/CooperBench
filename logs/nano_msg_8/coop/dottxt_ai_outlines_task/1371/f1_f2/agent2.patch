+#: Global registry of custom filters, made available to every prompt
+#: template without having to be passed explicitly. Filters defined on
+#: an individual template (e.g. through `Prompt.from_str`/`from_file`)
+#: take precedence over these when names collide.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to be made available to all prompt templates.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates,
+        e.g. ``{{ text | <name> }}``.
+    func : Callable
+        The function that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered global filter.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove. Does nothing if no filter was
+        registered under this name.
+
+    """
+    _FILTERS.pop(name, None)
+
 
