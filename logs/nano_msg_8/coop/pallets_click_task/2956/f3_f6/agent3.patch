@@ -2,6 +2,7 @@ from __future__ import annotations
 
 import collections.abc as cabc
 import enum
+import itertools
 import os
 import stat
 import sys
@@ -27,6 +28,23 @@ if t.TYPE_CHECKING:
 ParamTypeValue = t.TypeVar("ParamTypeValue")
 
 
+def _batch_values(
+    values: cabc.Iterable[ParamTypeValue], batch_size: int
+) -> cabc.Iterator[tuple[ParamTypeValue, ...]]:
+    """Split ``values`` into consecutive chunks of at most ``batch_size``
+    items each.
+
+    Used by :class:`~click.core.Option` when ``multiple=True`` is combined
+    with ``batch_size`` to avoid materializing every value at once.
+    """
+    it = iter(values)
+    batch = tuple(itertools.islice(it, batch_size))
+
+    while batch:
+        yield batch
+        batch = tuple(itertools.islice(it, batch_size))
+
+
