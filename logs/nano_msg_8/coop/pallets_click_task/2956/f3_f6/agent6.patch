+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        # Runs after all parameters are parsed so referenced options'
+        # final values (from any source) are available for lookup.
+        opt_to_name: dict[str, str] = {}
+
+        for candidate in self.get_params(ctx):
+            if isinstance(candidate, Option) and candidate.name is not None:
+                for opt in (*candidate.opts, *candidate.secondary_opts):
+                    opt_to_name[opt] = candidate.name
+
+        for param in self.get_params(ctx):
+            if (
+                not isinstance(param, Option)
+                or param.dynamic_default is None
+                or param.name is None
+            ):
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param.dynamic_default.items():
+                source_name = opt_to_name.get(source_opt)
+
+                if source_name is None or source_name not in ctx.params:
+                    continue
+
+                key = str(ctx.params[source_name])
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                resolved = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = resolved
+
