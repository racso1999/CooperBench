+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given hash type.
+    """
+
+    HASH_LENGTHS = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The algorithm which was used for the hash to check against.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert '2ef7bde608ce5404e97d5f042f95f89f1c232871' == IsHash('sha1')
+        assert '9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08' == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('md5')
+        ```
+        """
+        normalized_algorithm = algorithm.lower()
+        if normalized_algorithm not in self.HASH_LENGTHS:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}, must be one of {sorted(self.HASH_LENGTHS)}')
+        self.algorithm = algorithm
+        self.length = self.HASH_LENGTHS[normalized_algorithm]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self.length:
+            return False
+        return re.fullmatch(r'[0-9a-fA-F]+', other) is not None
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
