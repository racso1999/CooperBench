 import pytest
 
-from PIL import Image
+from PIL import Image, ImageChops, ImageStat
 
 from .helper import assert_image, assert_image_similar, hopper, is_ppc64le
 
@@ -85,3 +85,44 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000)
+
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+
+def test_quantize_error_threshold_meets_threshold():
+    image = hopper()
+    error_threshold = 500
+    converted = image.quantize(colors=256, error_threshold=error_threshold)
+
+    reference = image.convert("RGB")
+    comparison = converted.convert("RGB")
+    diff = ImageChops.difference(reference, comparison)
+    stat = ImageStat.Stat(diff)
+    mse = sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    assert mse <= error_threshold
+
+
+def test_quantize_error_threshold_falls_back_to_max_colors():
+    # A very strict threshold cannot be reached with so few colors,
+    # so the maximum number of colors allowed should be used instead.
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=100)
