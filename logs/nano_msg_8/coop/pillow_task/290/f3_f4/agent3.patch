     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    colors_used = sorted({i for i in converted.getdata()})
+    brightness = [
+        palette[i * 3] * 299 + palette[i * 3 + 1] * 587 + palette[i * 3 + 2] * 114
+        for i in colors_used
+    ]
+    assert brightness == sorted(brightness)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    colors_used = sorted({i for i in converted.getdata()})
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in colors_used]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(32, sort_palette=lambda c: -sum(c))
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    colors_used = sorted({i for i in converted.getdata()})
+    sums = [sum(palette[i * 3 : i * 3 + 3]) for i in colors_used]
+    assert sums == sorted(sums, reverse=True)
+
+
+def test_sort_palette_preserves_pixels():
+    image = hopper()
+    unsorted = image.quantize(32)
+    sorted_by_brightness = image.quantize(32, sort_palette="brightness")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_by_brightness.convert(
+        "RGB"
+    ).tobytes()
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="invalid")
