+    def _sort_palette(self, colors, sort_palette):
+        mode_len = len(self.palette.mode)
+        raw_palette = self.palette.palette
+        total_colors = len(raw_palette) // mode_len
+        # Only the first `colors` palette entries are actually used by the
+        # quantizer; the remainder is unused zero-padding and is left as-is.
+        num_colors = min(colors, total_colors)
+        palette_colors = [
+            tuple(raw_palette[i * mode_len : (i + 1) * mode_len])
+            for i in range(num_colors)
+        ]
+
+        if callable(sort_palette):
+            key = sort_palette
+        elif sort_palette == "brightness":
+
+            def key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            raise ValueError(
+                "sort_palette must be 'brightness', 'rgb', or a callable"
+            )
+
+        order = sorted(range(num_colors), key=lambda i: key(palette_colors[i]))
+        dest_map = order + list(range(num_colors, total_colors))
+        return self.remap_palette(dest_map)
+
