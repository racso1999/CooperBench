+    def get_image_mimetype(self) -> str | None:
+        """Return the image mimetype, resolving and caching it if needed.
+
+        If `image_mimetype` was not set explicitly, guess it from the image
+        bytes using the filetype library and cache the result on the instance
+        so subsequent calls don't repeat the guess. To avoid resource-intense
+        operations, we won't load the path or the URL to guess the mimetype.
+        """
+        if self.image_mimetype:
+            return self.image_mimetype
+
+        if self.image:
+            guess = filetype.guess(base64.b64decode(self.image))
+            self.image_mimetype = guess.mime if guess else None
+
+        return self.image_mimetype
+
