+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system so that a stalled upstream (one that has
+        started producing the target field but has stopped sending chunks) can be detected even though the
+        listener itself is purely event-driven and has no other way to notice the absence of events.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed, `None` otherwise.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if "is_last_chunk" in getattr(StreamResponse, "__dataclass_fields__", {}):
+            response.is_last_chunk = True
+
+        # Reset the listener's state unconditionally, regardless of `allow_reuse`, so that a stalled stream never
+        # leaves the listener stuck in a started state.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
