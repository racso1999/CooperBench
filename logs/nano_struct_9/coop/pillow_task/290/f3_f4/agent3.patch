+    def _sort_palette(self, mode, palette, sort_palette):
+        band_count = len(mode)
+        colors = [
+            palette[i : i + band_count] for i in range(0, len(palette), band_count)
+        ]
+
+        if sort_palette == "luminance":
+
+            def sort_key(color):
+                return sum(c * w for c, w in zip(color, (0.299, 0.587, 0.114)))
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return tuple(color)
+
+        else:
+            raise ValueError("sort_palette must be 'luminance' or 'rgb'")
+
+        order = sorted(range(len(colors)), key=lambda i: sort_key(colors[i]))
+
+        new_palette = bytearray(len(palette))
+        lut = [0] * len(colors)
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+            start = new_index * band_count
+            new_palette[start : start + band_count] = colors[old_index]
+        new_palette = bytes(new_palette)
+
+        im = self.point(lut)
+        # Update the palette embedded in the image data itself, so that
+        # encoders which read it directly (bypassing the Python-level
+        # ImagePalette) still match the remapped pixel indices.
+        im.putpalette(new_palette, mode)
+        return new_palette, im
+
