     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="not-a-real-method")
+
+
+@pytest.mark.parametrize("sort_palette", ("luminance", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    unsorted = image.quantize(100)
+    sorted_im = image.quantize(100, sort_palette=sort_palette)
+
+    # Sorting the palette shouldn't change how the image looks
+    assert_image_similar(sorted_im.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    palette = sorted_im.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    if sort_palette == "luminance":
+        key = lambda c: c[0] * 299 + c[1] * 587 + c[2] * 114  # noqa: E731
+    else:
+        key = tuple
+    assert colors == sorted(colors, key=key)
+
+    # The unsorted palette shouldn't already happen to be in order
+    unsorted_palette = unsorted.getpalette()
+    unsorted_colors = [
+        tuple(unsorted_palette[i : i + 3]) for i in range(0, len(unsorted_palette), 3)
+    ]
+    assert unsorted_colors != sorted(unsorted_colors, key=key)
