+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high error threshold should be satisfied with very few colors
+    low_quality = image.quantize(colors=256, error_threshold=1000)
+    assert_image(low_quality, "P", low_quality.size)
+    assert len(low_quality.getcolors()) <= 256
+
+    # A very low error threshold cannot be satisfied, so the requested
+    # number of colors should be used instead
+    high_quality = image.quantize(colors=4, error_threshold=0.001)
+    assert_image(high_quality, "P", high_quality.size)
+    assert len(high_quality.getcolors()) <= 4
+
+    # Using more colors should not increase the resulting error
+    default = image.quantize(colors=256)
+    thresholded = image.quantize(colors=256, error_threshold=1000)
+    assert len(thresholded.getcolors()) <= len(default.getcolors())
+
