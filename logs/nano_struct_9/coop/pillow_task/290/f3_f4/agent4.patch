+    def _quantize_colors_for_error_threshold(
+        self, colors, method, kmeans, error_threshold
+    ):
+        """
+        Finds the smallest number of colors (up to ``colors``) that
+        produces a quantized image whose mean square error, relative to
+        this image, is at or below ``error_threshold``. Returns ``colors``
+        if no smaller number of colors meets the threshold.
+        """
+        reference = self.convert("RGB") if self.mode != "RGB" else self
+
+        def mean_square_error(num_colors):
+            quantized = self._new(self.im.quantize(num_colors, method, kmeans))
+            quantized_rgb = quantized.convert("RGB")
+
+            from . import ImageChops, ImageStat
+
+            diff = ImageChops.difference(reference, quantized_rgb)
+            stat = ImageStat.Stat(diff)
+            return sum(s ** 2 for s in stat.mean) / len(stat.mean)
+
+        low, high = 2, colors
+        best = colors
+        while low <= high:
+            mid = (low + high) // 2
+            if mean_square_error(mid) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        return best
+
