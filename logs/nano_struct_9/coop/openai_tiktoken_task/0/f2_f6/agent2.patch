+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes a string into tokens, additionally tracking the starting character
+        position of each token in `text`.
+
+        `allowed_special` must already be resolved to a concrete set (not "all").
+        """
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        if allowed_special:
+            special_pattern = _special_token_regex(frozenset(allowed_special))
+            start = 0
+            for match in special_pattern.finditer(text):
+                before = text[start : match.start()]
+                if before:
+                    self._encode_ordinary_with_positions(before, start, tokens, positions)
+                positions.append(match.start())
+                tokens.append(self._special_tokens[match.group()])
+                start = match.end()
+            remainder = text[start:]
+            if remainder:
+                self._encode_ordinary_with_positions(remainder, start, tokens, positions)
+        else:
+            self._encode_ordinary_with_positions(text, 0, tokens, positions)
+
+        return tokens, positions
+
+    def _encode_ordinary_with_positions(
+        self, text: str, offset: int, tokens: list[int], positions: list[int]
+    ) -> None:
+        """Encodes ordinary (non-special) text into tokens, appending to `tokens` and
+        the corresponding starting character positions (relative to `offset`) to `positions`.
+        """
+        _pat = regex.compile(self._pat_str)
+        for piece_match in _pat.finditer(text):
+            piece = piece_match.group()
+            piece_start = offset + piece_match.start()
+            piece_tokens = self._encode_single_piece(piece)
+
+            char_len = 0
+            for token in piece_tokens:
+                token_bytes = self._core_bpe.decode_single_token_bytes(token)
+                char_offset = max(0, char_len - (0x80 <= token_bytes[0] < 0xC0))
+                positions.append(piece_start + char_offset)
+                tokens.append(token)
+                char_len += sum(1 for c in token_bytes if not 0x80 <= c < 0xC0)
+
     def __getstate__(self) -> object:
