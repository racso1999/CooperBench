+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `Features._column_requires_decoding`, of the `Features` object
+    synced with the main dictionary on all dictionary mutating operations, instead of relying on `Features`
+    subclassing `UserDict` (which introduces performance issues and would be a breaking change).
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        if args:
+            self: "Features" = args[0]
+            args = args[1:]
+        else:
+            self: "Features" = kwargs.pop("self")
+        out = func(self, *args, **kwargs)
+        assert hasattr(self, "_column_requires_decoding")
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper._decorator_name_ = "keep_features_dicts_synced"
+    return wrapper
+
+
