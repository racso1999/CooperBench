+    def get_translation_version(self, message: str) -> t.Optional[str]:
+        """Return the version identifier previously set for ``message``,
+        or ``None`` if no version has been recorded.
+        """
+        return self._translation_versions.get(self._hash_message(message))
+
+    def compare_translation_versions(self, message1: str, message2: str) -> bool:
+        """Return ``True`` if both messages have the same recorded version.
+
+        Returns ``False`` if the versions differ or if either message has
+        no version recorded.
+        """
+        version1 = self.get_translation_version(message1)
+        version2 = self.get_translation_version(message2)
+
+        if version1 is None or version2 is None:
