+    def _get_template_name(self, filename: str) -> t.Optional[str]:
+        """Convert an absolute file path back into a template name
+        relative to one of the search paths, or ``None`` if the file
+        does not live under any of them.
+        """
+        filename = os.path.abspath(filename)
