     #: .. versionadded:: 2.4
     has_source_access = True
 
+    def add_alias(self, alias: str, target: str) -> None:
+        """Register ``alias`` as another name that resolves to the
+        ``target`` template. Aliases are resolved before the template
+        is looked up, so loading the alias behaves identically to
+        loading the target. Calling this again with an existing alias
+        replaces its target.
+
+        Aliases do not chain: if ``target`` is itself an alias, it is
+        used as-is and not resolved further.
+
+        .. versionadded:: 3.2
+        """
+        if not hasattr(self, "_aliases"):
+            self._aliases: t.Dict[str, str] = {}
+
+        self._aliases[alias] = target
+
+    def remove_alias(self, alias: str) -> None:
+        """Remove a previously registered alias. Does nothing if the
+        alias is not registered.
+
+        .. versionadded:: 3.2
+        """
+        if hasattr(self, "_aliases"):
+            self._aliases.pop(alias, None)
+
+    def _resolve_alias(self, name: str) -> str:
+        aliases = getattr(self, "_aliases", None)
+
+        if not aliases:
+            return name
+
+        return aliases.get(name, name)
+
