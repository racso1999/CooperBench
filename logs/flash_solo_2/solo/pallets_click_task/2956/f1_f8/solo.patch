+    def _resolve_option_history_name(self, name: str) -> str | None:
+        """Resolve a parameter name or one of its option flags (for
+        example ``"count"``, ``"--count"``, or ``"-c"``) to the
+        parameter name used to key :attr:`_option_history`.
+        """
+        for param in self.command.params:
+            if name == param.name or name in param.opts or name in param.secondary_opts:
+                return param.name
+
+        return None
+
+    def record_option_history(
+        self, name: str, value: t.Any, source: ParameterSource
+    ) -> None:
+        """Record a value for a parameter in its history, if history
+        tracking is enabled for this context.
+
+        :param name: The parameter name whose value was set.
+        :param value: The value that was set.
+        :param source: Where the value came from.
+
+        .. versionadded:: 8.3
+        """
+        if not self._track_changes:
+            return
+
+        import time
+
+        self._option_history.setdefault(name, []).append(
+            {"value": value, "source": source, "timestamp": time.time()}
+        )
+
+    def get_option_history(self, name: str) -> list[dict[str, t.Any]] | None:
+        """Get the recorded value history for an option.
+
+        Accepts either the parameter name (``"count"``) or one of its
+        declared flags (``"--count"``, ``"-c"``).
+
+        :param name: The parameter name or option flag to look up.
+        :return: A list of history entries, each a dict with ``value``,
+            ``source``, and ``timestamp`` keys. Returns ``None`` if
+            history tracking is disabled for this context (see the
+            command's ``track_changes`` parameter). Returns an empty
+            list if tracking is enabled but ``name`` does not match any
+            parameter.
+
+        .. versionadded:: 8.3
+        """
+        if not self._track_changes:
+            return None
+
+        resolved_name = self._resolve_option_history_name(name)
+
+        if resolved_name is None:
+            return []
+
+        return list(self._option_history.get(resolved_name, []))
+
 
