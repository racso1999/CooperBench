diff --git a/src/click/types.py b/src/click/types.py
index 684cb3b..b98d52c 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -1158,6 +1158,79 @@ BOOL = BoolParamType()
 UUID = UUIDParameterType()
 
 
+def _auto_complete_usernames(
+    ctx: Context, param: Parameter, incomplete: str
+) -> list[CompletionItem]:
+    """Complete system usernames. Used for options such as ``--user``.
+
+    .. versionadded:: 8.3
+    """
+    from click.shell_completion import CompletionItem
+
+    try:
+        import pwd
+
+        names = [entry.pw_name for entry in pwd.getpwall()]
+    except (ImportError, OSError):
+        names = []
+
+    return [CompletionItem(name) for name in names if name.startswith(incomplete)]
+
+
+def _auto_complete_git_branches(
+    ctx: Context, param: Parameter, incomplete: str
+) -> list[CompletionItem]:
+    """Complete git branch names when inside a git repository. Used for
+    options such as ``--branch``.
+
+    .. versionadded:: 8.3
+    """
+    import subprocess
+
+    from click.shell_completion import CompletionItem
+
+    try:
+        output = subprocess.run(
+            ["git", "branch", "-a", "--format=%(refname:short)"],
+            capture_output=True,
+            text=True,
+            check=True,
+        ).stdout
+    except (OSError, subprocess.CalledProcessError):
+        return []
+
+    branches = sorted({line.strip() for line in output.splitlines() if line.strip()})
+    return [CompletionItem(b) for b in branches if b.startswith(incomplete)]
+
+
+def _auto_complete_file_paths(
+    ctx: Context, param: Parameter, incomplete: str
+) -> list[CompletionItem]:
+    """Complete filesystem paths. Used for options such as ``--file``.
+
+    .. versionadded:: 8.3
+    """
+    from click.shell_completion import CompletionItem
+
+    return [CompletionItem(incomplete, type="file")]
+
+
+#: Maps a substring found in an option's name to the completion
+#: function used by :meth:`~click.core.Option._smart_complete` when
+#: ``auto_complete=True`` is set on the option. The first matching
+#: pattern wins.
+#:
+#: .. versionadded:: 8.3
+AUTO_COMPLETE_REGISTRY: dict[
+    str, t.Callable[[Context, Parameter, str], list[CompletionItem]]
+] = {
+    "user": _auto_complete_usernames,
+    "branch": _auto_complete_git_branches,
+    "file": _auto_complete_file_paths,
+    "path": _auto_complete_file_paths,
+}
+
+
