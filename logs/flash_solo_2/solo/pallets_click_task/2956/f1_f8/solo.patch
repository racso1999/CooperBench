+    def _smart_complete(self, ctx: Context, incomplete: str) -> list[CompletionItem]:
+        """Generate completions automatically based on this option's
+        name and the current execution context.
+
+        Looks up :data:`~click.types.AUTO_COMPLETE_REGISTRY` for a
+        pattern found in the option's name, falling back to the
+        option's :attr:`type` completion when nothing matches.
+
+        :param ctx: Invocation context for this command.
+        :param incomplete: Value being completed. May be empty.
+
+        .. versionadded:: 8.3
+        """
+        name = (self.name or "").lower()
+
+        for pattern, complete_func in types.AUTO_COMPLETE_REGISTRY.items():
+            if pattern in name:
+                return complete_func(ctx, self, incomplete)
+
+        return self.type.shell_complete(ctx, self, incomplete)
+
+    def shell_complete(self, ctx: Context, incomplete: str) -> list[CompletionItem]:
+        """Return a list of completions for the incomplete value. If a
+        ``shell_complete`` function was given during init, it is used,
+        taking precedence over :attr:`auto_complete`. Otherwise, if
+        ``auto_complete`` is enabled, :meth:`_smart_complete` is used.
+
+        :param ctx: Invocation context for this command.
+        :param incomplete: Value being completed. May be empty.
+
+        .. versionadded:: 8.3
+        """
+        if self._custom_shell_complete is None and self.auto_complete:
+            return self._smart_complete(ctx, incomplete)
+
+        return super().shell_complete(ctx, incomplete)
+
