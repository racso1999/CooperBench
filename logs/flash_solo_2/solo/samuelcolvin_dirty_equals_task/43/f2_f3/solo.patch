+_mac_formats = {
+    'colon': re.compile(r'^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$'),
+    'hyphen': re.compile(r'^([0-9A-Fa-f]{2}-){5}[0-9A-Fa-f]{2}$'),
+    'dot': re.compile(r'^([0-9A-Fa-f]{4}\.){2}[0-9A-Fa-f]{4}$'),
+    'compact': re.compile(r'^[0-9A-Fa-f]{12}$'),
+}
+
+
+class IsMac(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid MAC address, optionally checking the address format.
+    """
+
+    def __init__(self, format: Optional[Literal['colon', 'hyphen', 'dot', 'compact']] = None):
+        """
+        Args:
+            format: The format of the MAC address to check, if omitted, all formats are accepted.
+
+        ```py title="IsMac"
+        from dirty_equals import IsMac
+
+        assert '00:1B:44:11:3A:B7' == IsMac
+        assert '00-1B-44-11-3A-B7' == IsMac
+        assert '001B.4411.3AB7' == IsMac
+        assert '001b44113ab7' == IsMac
+        assert '00:1B:44:11:3A:B7' == IsMac('colon')
+        assert '00-1B-44-11-3A-B7' != IsMac('colon')
+        ```
+        """
+        if format is not None and format not in _mac_formats:
+            raise ValueError(f'format must be one of {sorted(_mac_formats)}, not {format!r}')
+        self.format = format
+        super().__init__(format or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if self.format is not None:
+            return bool(_mac_formats[self.format].match(other))
+        else:
+            return any(pattern.match(other) for pattern in _mac_formats.values())
+
+
+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain.
+    """
+
+    _email_regex = re.compile(r'^[A-Za-z0-9._%+-]+@(?P<domain>[A-Za-z0-9.-]+\.[A-Za-z]{2,})$')
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: The domain the email address must belong to, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'foo@bar.com' == IsEmail
+        assert 'foo@bar.com' == IsEmail(domain='bar.com')
+        assert 'foo@bar.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(plain_repr('*') if domain is None else domain)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        m = self._email_regex.match(other)
+        if not m:
+            return False
+
+        if self.domain is not None and m.group('domain') != self.domain:
+            return False
+
+        return True
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
