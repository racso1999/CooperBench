+_EMAIL_REGEX = re.compile(
+    r"^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9]"
+    r'(?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?'
+    r'(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$'
+)
+
+
+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain.
+    """
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: The domain to check the email address against, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'foo@example.com' == IsEmail
+        assert 'foo@example.com' == IsEmail(domain='example.com')
+        assert 'foo@example.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(domain or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if not _EMAIL_REGEX.match(other):
+            return False
+
+        if self.domain is not None:
+            _, _, email_domain = other.rpartition('@')
+            return email_domain == self.domain
+
+        return True
+
+
+_HASH_ALGORITHM_LENGTHS = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm, checking length and character set.
+    """
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'` (case insensitive).
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'foo').hexdigest() == IsHash('md5')
+        assert hashlib.sha256(b'foo').hexdigest() == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('md5')
+        ```
+        """
+        algorithm_lower = algorithm.lower()
+        if algorithm_lower not in _HASH_ALGORITHM_LENGTHS:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+
+        self.algorithm = algorithm_lower
+        self.expected_length = _HASH_ALGORITHM_LENGTHS[algorithm_lower]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.expected_length:
+            return False
+
+        return bool(re.fullmatch(r'[0-9a-fA-F]+', other))
