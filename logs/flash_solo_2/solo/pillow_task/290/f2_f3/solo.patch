+    def _sort_palette(self, sort_palette, num_colors=256):
+        """
+        Reorders this image's palette according to ``sort_palette`` and
+        remaps pixel data to match. Used by :py:meth:`~PIL.Image.Image.quantize`.
+
+        :param sort_palette: ``"brightness"`` to sort colors from darkest to
+           lightest, or ``"rgb"`` to sort colors by their RGB value.
+        :param num_colors: Only the first ``num_colors`` palette entries are
+           reordered; entries beyond that are left untouched.
+        :returns: A new image
+        """
+        mode = self.im.getpalettemode()
+        channels = len(mode)
+        palette_bytes = self.im.getpalette(mode, mode)
+        num_colors = min(num_colors, len(palette_bytes) // channels)
+        entries = [
+            palette_bytes[i * channels : (i + 1) * channels]
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "brightness":
+
+            def sort_key(color):
+                r, g, b = color[0], color[1], color[2]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color[:3]
+
+        else:
+            raise ValueError("sort_palette must be 'brightness', 'rgb' or None")
+
+        order = sorted(range(num_colors), key=lambda i: sort_key(entries[i]))
+
+        table = list(range(256))
+        for new_index, old_index in enumerate(order):
+            table[old_index] = new_index
+        im = self.point(table)
+
+        new_palette_bytes = bytearray(palette_bytes)
+        for new_index, old_index in enumerate(order):
+            new_palette_bytes[new_index * channels : (new_index + 1) * channels] = (
+                palette_bytes[old_index * channels : (old_index + 1) * channels]
+            )
+
+        im.putpalette(bytes(new_palette_bytes), mode)
+
         return im
 
