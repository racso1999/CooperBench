@@ -77,6 +77,51 @@ def test_quantize_dither_diff():
     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_quantize_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=100, max_colors=10)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 10
+
+    # max_colors defaults to colors, preserving current behavior
+    converted = image.quantize(colors=10)
+    assert len(converted.getcolors()) <= 10
+
+    # max_colors larger than colors has no effect
+    converted = image.quantize(colors=10, max_colors=100)
+    assert len(converted.getcolors()) <= 10
+
+
+def test_quantize_sort_palette():
+    image = hopper()
+
+    for sort_palette in ("brightness", "rgb"):
+        converted = image.quantize(colors=32, sort_palette=sort_palette)
+        assert_image(converted, "P", converted.size)
+        assert_image_similar(converted.convert("RGB"), image, 25)
+
+        palette = converted.palette.palette
+        mode = converted.im.getpalettemode()
+        channels = len(mode)
+        entries = [
+            palette[i * channels : (i + 1) * channels] for i in range(32)
+        ]
+        if sort_palette == "brightness":
+            keys = [0.299 * e[0] + 0.587 * e[1] + 0.114 * e[2] for e in entries]
+        else:
+            keys = [tuple(e[:3]) for e in entries]
+        assert keys == sorted(keys)
+
+    # sorting the palette should not change the resulting image colors
+    unsorted = image.quantize(colors=32)
+    sorted_image = image.quantize(colors=32, sort_palette="brightness")
+    assert unsorted.convert("RGB").tobytes() == sorted_image.convert("RGB").tobytes()
+
+    with pytest.raises(ValueError):
+        image.quantize(colors=32, sort_palette="invalid")
+
+
