+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="invalid")
+
+
+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette=sort_palette)
+    assert_image(converted, "P", converted.size)
+
+    # Sorting the palette shouldn't change the visual appearance
+    unsorted = image.quantize(colors=32)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    palette = converted.palette.palette
+    used_colors = [
+        tuple(palette[i * 3 : i * 3 + 3])
+        for i in sorted({px for px in converted.getdata()})
+    ]
+    if sort_palette == "brightness":
+        keys = [r * 299 + g * 587 + b * 114 for r, g, b in used_colors]
+    else:
+        keys = used_colors
+    assert keys == sorted(keys)
+
+
+def test_quantize_lightness_factor():
+    image = hopper()
+    converted = image.quantize(colors=32)
+    brighter = image.quantize(colors=32, lightness_factor=1.5)
+    darker = image.quantize(colors=32, lightness_factor=0.5)
+
+    assert_image(brighter, "P", brighter.size)
+    assert_image(darker, "P", darker.size)
+
+    unchanged_palette = converted.palette.palette
+    brighter_palette = brighter.palette.palette
+    darker_palette = darker.palette.palette
+    assert all(
+        brighter_palette[i] >= unchanged_palette[i]
+        for i in range(len(unchanged_palette))
+    )
+    assert all(
+        darker_palette[i] <= unchanged_palette[i]
+        for i in range(len(unchanged_palette))
+    )
+
+
+def test_quantize_lightness_factor_clamped():
+    image = hopper()
+    converted = image.quantize(colors=32, lightness_factor=100)
+    assert max(converted.palette.palette) <= 255
