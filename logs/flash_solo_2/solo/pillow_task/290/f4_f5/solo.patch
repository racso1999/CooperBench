+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible (up to ``colors``)
+        while keeping the mean square error against the original image at or
+        below ``error_threshold``. Falls back to ``colors`` if the threshold
+        cannot be met.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        original = self.convert("RGB") if self.mode != "RGB" else self
+
+        def mse(candidate):
+            candidate_mode = candidate.im.getpalettemode()
+            candidate.palette = ImagePalette.ImagePalette(
+                candidate_mode,
+                candidate.im.getpalette(candidate_mode, candidate_mode),
+            )
+            diff = ImageChops.difference(original, candidate.convert("RGB"))
+            stat = ImageStat.Stat(diff)
+            total_count = sum(stat.count)
+            if not total_count:
+                return 0
+            return sum(stat.sum2) / total_count
+
+        low, high = 2, colors
+        best = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            if mse(candidate) <= error_threshold:
+                best = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best is not None:
+            return best
+
+        # Threshold could not be met; use the maximum allowed colors.
+        return self._new(self.im.quantize(colors, method, kmeans))
+
+    def _adjust_palette_lightness(self, lightness_factor):
+        """
+        Adjusts the RGB entries of this image's palette by ``lightness_factor``,
+        clamping the result to the valid 0-255 range.
+        """
+        channels = len(self.palette.mode)
+        palette_bytes = bytearray(self.palette.palette)
+        for i in range(0, len(palette_bytes) - channels + 1, channels):
+            for c in range(min(channels, 3)):
+                value = round(palette_bytes[i + c] * lightness_factor)
+                palette_bytes[i + c] = max(0, min(255, value))
+        self.putpalette(bytes(palette_bytes), self.palette.mode)
+
