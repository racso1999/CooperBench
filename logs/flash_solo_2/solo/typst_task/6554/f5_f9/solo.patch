+/// The error message when the requested count of grapheme clusters exceeds
+/// the number available in the string.
+#[cold]
+fn count_exceeds_length(count: usize, len: usize) -> EcoString {
+    eco_format!(
+        "cannot extract {} characters from a string with only {} characters",
+        count,
+        len
+    )
