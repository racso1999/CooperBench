+// EnableCORS enables Cross-Origin Resource Sharing on the router using
+// DefaultCORSOptions.
+func (mx *Mux) EnableCORS() {
+	mx.EnableCORSWithOptions(DefaultCORSOptions())
+}
+
+// EnableCORSWithOptions enables Cross-Origin Resource Sharing on the
+// router using the given options. See CORS for the underlying middleware.
+func (mx *Mux) EnableCORSWithOptions(options CORSOptions) {
+	mx.Use(CORS(options))
+}
+
+// WithCORS returns a grouped Router with Cross-Origin Resource Sharing
+// enabled using DefaultCORSOptions.
+func (mx *Mux) WithCORS() Router {
+	return mx.With(CORS(DefaultCORSOptions()))
+}
