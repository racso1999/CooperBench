+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should be satisfied with fewer than the maximum
+    # number of colors.
+    lenient = image.quantize(colors=256, error_threshold=1000)
+    assert_image(lenient, "P", lenient.size)
+    assert len(lenient.getcolors()) < 256
+
+    # A threshold that can't be met should fall back to the maximum number
+    # of colors allowed.
+    strict = image.quantize(colors=64, error_threshold=0.0001)
+    assert_image(strict, "P", strict.size)
+    assert len(strict.getcolors()) == 64
+
+    # A more generous threshold should never need more colors than a
+    # stricter one.
+    less_strict = image.quantize(colors=256, error_threshold=500)
+    more_strict = image.quantize(colors=256, error_threshold=5)
+    assert len(less_strict.getcolors()) <= len(more_strict.getcolors())
+
