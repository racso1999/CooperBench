+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and terminate it if so.
+
+        This should be called periodically by the streaming system, e.g. whenever it polls for new chunks.
+        If the idle timeout has elapsed since the last chunk was received, this emits a `StreamResponse` with an
+        empty `chunk` to signal the end of the stream, and resets the listener state so it doesn't get stuck in a
+        started state.
+
+        Args:
+            now_ts: The current timestamp to compare against. Defaults to `time.time()` if not provided, mainly
+                useful for testing.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so it doesn't get stuck in a
+        # started state after the stream was cut short by the idle timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
