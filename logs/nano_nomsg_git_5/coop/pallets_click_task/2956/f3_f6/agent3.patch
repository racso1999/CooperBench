@@ -1065,6 +1066,23 @@ class Tuple(CompositeParamType):
         )
 
 
+def batch_iterable(
+    value: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Split an iterable of values into tuples of at most
+    ``batch_size`` items each. The last batch may contain fewer items.
+
+    :param value: The values to split into batches.
+    :param batch_size: The maximum number of items per batch.
+
+    .. versionadded:: 8.3
+    """
+    iterator = iter(value)
+
+    while batch := tuple(itertools.islice(iterator, batch_size)):
+        yield batch
+
