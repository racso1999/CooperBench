+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose ``default`` is a dynamic default
+        mapping (``{"--source-option": {"value": default}}``). This
+        runs after every parameter has been processed once, so it can
+        look at the final values of the options it depends on.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+        opts_to_param = {opt: param for param in params for opt in param.opts}
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            source = ctx.get_parameter_source(param.name)  # type: ignore[arg-type]
+
+            if source != ParameterSource.DEFAULT:
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = opts_to_param.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                match = mapping.get(str(source_value))
+
+                if match is not None:
+                    resolved = match
+
+            if resolved is None:
+                continue
+
+            value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
