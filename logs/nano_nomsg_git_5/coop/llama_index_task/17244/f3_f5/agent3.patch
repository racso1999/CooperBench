+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize image bytes to a base64-encoded representation.
+
+    Detects whether ``image`` is already base64-encoded. If so, it's returned
+    as-is alongside the decoded bytes (suitable for mimetype guessing). Otherwise,
+    the raw bytes are base64-encoded and returned alongside the original bytes.
+
+    Returns:
+        A tuple of ``(encoded_image, decoded_for_guessing)``.
+    """
+    try:
+        decoded_for_guessing = base64.b64decode(image, validate=True)
+        return image, decoded_for_guessing
+    except binascii.Error:
+        return base64.b64encode(image), image
+
