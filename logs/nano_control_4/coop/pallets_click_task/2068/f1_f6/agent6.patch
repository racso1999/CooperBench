+# Maps the public priority names to a Unix `nice` increment. Negative
+# values raise priority and typically require elevated permissions.
+_UNIX_PRIORITY_NICE = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -10,
+    "high": -20,
+}
+
+# Maps the public priority names to Windows process creation flags.
+_WINDOWS_PRIORITY_CREATIONFLAGS = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
