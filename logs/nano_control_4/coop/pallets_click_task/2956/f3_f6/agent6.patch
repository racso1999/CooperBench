+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        mapping of other option declarations to value lookup tables (see
+        :class:`Option`). This runs after all command-line arguments,
+        environment variables, and configuration files have been
+        processed by :meth:`parse_args`, so the referenced options'
+        final values are available.
+        """
+        params_by_decl: dict[str, Parameter] = {}
+
+        for param in self.get_params(ctx):
+            for decl in (*param.opts, *param.secondary_opts):
+                params_by_decl[decl] = param
+
+        for param in self.get_params(ctx):
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:
+                continue
+
+            value = None
+
+            for source_decl, mapping in dynamic_default.items():
+                source_param = params_by_decl.get(source_decl)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    value = mapping[key]
+
+            if value is not None:
+                ctx.params[param.name] = value
+
