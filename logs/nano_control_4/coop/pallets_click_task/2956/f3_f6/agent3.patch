+def _batch_size_iter(
+    iterable: cabc.Iterable[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Split ``iterable`` into chunks of at most ``batch_size`` items.
+
+    Unlike :func:`batch`, the final chunk is yielded even if it has
+    fewer than ``batch_size`` items.
+    """
+    it = iter(iterable)
+
+    while chunk := tuple(islice(it, batch_size)):
+        yield chunk
