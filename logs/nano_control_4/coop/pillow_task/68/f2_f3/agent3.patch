+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        assert base_im.size == (2, 1)
+        assert base_im.getexif()[0x0112] == 8
+        expected = base_im.rotate(90, expand=True)
+
+        def transform_callback(orientation: int) -> Image.Transpose | None:
+            if orientation == 8:
+                return Image.Transpose.ROTATE_90
+            return None
+
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=transform_callback
+            )
+            assert transposed_im.size == (1, 2)
+            assert 0x0112 not in transposed_im.getexif()
+            assert_image_equal(transposed_im, expected)
+
+    # A sequence of methods should be applied in order
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        expected = base_im.rotate(90, expand=True).transpose(
+            Image.Transpose.FLIP_LEFT_RIGHT
+        )
+
+        def transform_callback_sequence(
+            orientation: int,
+        ) -> list[Image.Transpose] | None:
+            if orientation == 8:
+                return [Image.Transpose.ROTATE_90, Image.Transpose.FLIP_LEFT_RIGHT]
+            return None
+
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=transform_callback_sequence
+            )
+            assert transposed_im.size == (1, 2)
+            assert_image_equal(transposed_im, expected)
+
+    # Returning None from the callback should mean no transposition occurs,
+    # even though the default mapping would have applied one
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im, transform_callback=lambda o: None)
+        assert transposed_im.size == im.size
+        assert transposed_im is not im
+
+
+def test_exif_transpose_transform_callback_in_place() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        expected = im.rotate(90, expand=True)
+
+        def transform_callback(orientation: int) -> Image.Transpose | None:
+            if orientation == 8:
+                return Image.Transpose.ROTATE_90
+            return None
+
+        ImageOps.exif_transpose(
+            im, in_place=True, transform_callback=transform_callback
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
