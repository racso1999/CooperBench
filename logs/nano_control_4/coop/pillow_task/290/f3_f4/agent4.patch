+
+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=200)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=32, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 32
+
+
+def test_error_threshold_lower_uses_fewer_or_equal_colors():
+    image = hopper()
+
+    loose = image.quantize(colors=64, error_threshold=200)
+    strict = image.quantize(colors=64, error_threshold=20)
+
+    assert len(loose.getcolors()) <= len(strict.getcolors())
