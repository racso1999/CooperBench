+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using as few colors as possible (up to ``colors``) so that
+        the mean square error against the original image is at most
+        ``error_threshold``. Falls back to ``colors`` if the threshold can't
+        be met.
+        """
+        from . import ImageChops, ImageStat
+
+        reference = self.convert("RGB") if self.mode != "RGB" else self
+
+        def mean_square_error(candidate):
+            diff = ImageChops.difference(candidate.convert("RGB"), reference)
+            stat = ImageStat.Stat(diff)
+            return sum(
+                sum2 / count for sum2, count in zip(stat.sum2, stat.count)
+            ) / len(stat.count)
+
+        for num_colors in range(2, colors):
+            candidate = self._new(self.im.quantize(num_colors, method, kmeans))
+            if mean_square_error(candidate) <= error_threshold:
+                return candidate
+
+        return self._new(self.im.quantize(colors, method, kmeans))
