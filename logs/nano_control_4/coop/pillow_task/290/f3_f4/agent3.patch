+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping pixel indexes to match.
+        See :py:meth:`~PIL.Image.Image.quantize` for the accepted values of
+        ``sort_palette``.
+        """
+        band = len(self.palette.mode)
+        palette = self.palette.palette
+        num_colors = self.getextrema()[1] + 1
+
+        def brightness(i):
+            r, g, b = palette[i * band : i * band + 3]
+            return 0.299 * r + 0.587 * g + 0.114 * b
+
+        def rgb(i):
+            return tuple(palette[i * band : i * band + band])
+
+        try:
+            key = {"brightness": brightness, "rgb": rgb}[sort_palette]
+        except KeyError:
+            raise ValueError(f"Unknown sort_palette method: {sort_palette}")
+
+        dest_map = sorted(range(num_colors), key=key)
+        return self.remap_palette(dest_map)
+
