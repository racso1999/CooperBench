     assert len(converted.getcolors()) == 100
 
 
+def test_sort_palette():
+    image = hopper()
+
+    converted = image.quantize(100, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    num_colors = len(converted.getcolors())
+    brightnesses = [
+        0.299 * palette[i] + 0.587 * palette[i + 1] + 0.114 * palette[i + 2]
+        for i in range(0, num_colors * 3, 3)
+    ]
+    assert brightnesses == sorted(brightnesses)
+
+    converted_rgb = image.quantize(100, sort_palette="rgb")
+    assert_image(converted_rgb, "P", converted_rgb.size)
+    assert_image_similar(converted_rgb.convert("RGB"), image, 20)
+
+    palette_rgb = converted_rgb.getpalette()
+    num_colors = len(converted_rgb.getcolors())
+    colors = [tuple(palette_rgb[i : i + 3]) for i in range(0, num_colors * 3, 3)]
+    assert colors == sorted(colors)
+
+    # Sorting shouldn't change which colors are used, only their order
+    assert converted.convert("RGB").tobytes() == image.quantize(100).convert(
+        "RGB"
+    ).tobytes()
+
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="not_a_real_method")
+
+
