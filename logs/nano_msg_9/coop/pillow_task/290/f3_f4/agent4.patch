+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should let the quantizer stop early, using
+    # fewer colors than the requested maximum while still satisfying it.
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+    assert image._quantize_mse(converted) <= 100
+
+
+def test_quantize_error_threshold_unreachable():
+    image = hopper()
+
+    # An unreasonably strict threshold cannot be satisfied within the
+    # requested color limit, so the maximum number of colors is used.
+    converted = image.quantize(colors=8, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 8
+
+
