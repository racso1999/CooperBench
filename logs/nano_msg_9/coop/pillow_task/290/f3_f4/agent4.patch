+    def _quantize_mse(self, quantized_im):
+        from . import ImageChops, ImageStat
+
+        comparable = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparable)
+        rms_per_band = ImageStat.Stat(diff).rms
+        return sum(rms**2 for rms in rms_per_band) / len(rms_per_band)
+
+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        # Use as many colors as requested; if even that isn't enough to
+        # satisfy the error threshold, fall back to it as-is.
+        max_colors_im = self._quantize(colors, method, kmeans)
+        if self._quantize_mse(max_colors_im) > error_threshold:
+            return max_colors_im
+
+        # Otherwise, binary search for the fewest colors (down to 2) that
+        # still keep the error at or below the threshold.
+        best_im = max_colors_im
+        lo, hi = 2, colors
+        while lo <= hi:
+            mid = (lo + hi) // 2
+            im = self._quantize(mid, method, kmeans)
+            if self._quantize_mse(im) <= error_threshold:
+                best_im = im
+                hi = mid - 1
+            else:
+                lo = mid + 1
+
+        return best_im
