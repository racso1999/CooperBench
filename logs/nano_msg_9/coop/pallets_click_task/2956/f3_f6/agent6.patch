+        Only applies to options whose value still comes from
+        ``ParameterSource.DEFAULT``, i.e. no explicit value was given
+        on the command line, an environment variable, or a default map.
+        """
+        dynamic_params = [
+            param
+            for param in self.get_params(ctx)
+            if isinstance(param, Option) and param._dynamic_default is not None
+        ]
+
+        if not dynamic_params:
+            return
+
+        option_values = {
+            opt: ctx.params.get(param.name)  # type: ignore[arg-type]
+            for param in self.get_params(ctx)
+            if isinstance(param, Option)
+            for opt in param.opts
+        }
+
+        for param in dynamic_params:
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param._dynamic_default.items():  # type: ignore[union-attr]
+                source_value = option_values.get(source_opt)
+
+                if source_value is None:
+                    continue
+
+                match = mapping.get(str(source_value))
+
+                if match is not None:
+                    resolved = match
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved  # type: ignore[index]
+
