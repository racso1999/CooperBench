+#: Global registry of custom Jinja2 filters made available to every prompt
+#: template, in addition to any filters passed locally to a given template.
+GLOBAL_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is available in every prompt template
+    (e.g. via ``{{ text | <name> }}``) without having to be passed
+    explicitly to each template.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function implementing the filter.
+
+    """
+    GLOBAL_FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered Jinja2 filter.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove. This is a no-op if no filter
+        was registered under that name.
+
+    """
+    GLOBAL_FILTER_REGISTRY.pop(name, None)
+
 
