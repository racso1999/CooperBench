+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, e.g. on a timer, so that a stream stuck on a
+        stalled upstream can still be terminated deterministically. If the idle window has elapsed while a stream
+        is in progress, this emits a final `StreamResponse` with an empty `chunk` and resets the listener state.
+
+        Args:
+            now_ts: The current time to compare against the timestamp of the last received chunk. Defaults to
+                `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream timed out, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Unconditionally reset the listener state, regardless of `allow_reuse`, so a timeout never leaves the
+        # listener stuck thinking a stream is still in progress.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
 
