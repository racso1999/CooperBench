+    def set_ttl(self, ttl: Optional[int]) -> None:
+        """Set the default TTL (in seconds) for new cache entries.
+
+        The disk cache honors the new TTL for entries written from now on; the in-memory cache is
+        swapped for a `TTLCache`/`LRUCache` (preserving its current entries and `maxsize`) so the new
+        TTL takes effect immediately.
+
+        Args:
+            ttl: The number of seconds after which a cache entry expires. If `None`, cache entries
+                never expire.
+        """
+        with self._lock:
+            self.ttl = ttl
+            if self.enable_memory_cache:
+                maxsize = self.memory_cache.maxsize
+                items = dict(self.memory_cache)
+                if ttl is not None:
+                    self.memory_cache = TTLCache(maxsize=maxsize, ttl=ttl)
+                else:
+                    self.memory_cache = LRUCache(maxsize=maxsize)
+                self.memory_cache.update(items)
+
 
