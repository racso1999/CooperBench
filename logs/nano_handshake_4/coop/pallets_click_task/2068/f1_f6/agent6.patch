+# Maps the public `process_priority` values to a POSIX `nice` increment.
+_PRIORITY_TO_NICE_VALUE = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -10,
+    "high": -20,
+}
+
+# Maps the public `process_priority` values to a Windows process creation
+# priority class flag, for use with `subprocess.Popen(creationflags=...)`.
+_PRIORITY_TO_WIN32_CREATIONFLAG = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+
+def _nice_preexec_fn(nice_value: int) -> t.Callable[[], None]:
+    def _set_priority() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            # Raising a lower nice value (higher priority) commonly
+            # requires elevated privileges. Fall back to default priority.
+            pass
+
+    return _set_priority
+
+
