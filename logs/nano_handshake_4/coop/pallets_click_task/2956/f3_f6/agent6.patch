+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dynamic defaults (dict-based ``default`` values on
+        :class:`Option`) now that every parameter has a final value.
+
+        A dynamic default only applies to options whose value still
+        comes from :attr:`ParameterSource.DEFAULT`; it maps the current
+        values of other options (referenced by option name, e.g.
+        ``"--protocol"``) to the default that should be used.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore
+                continue
+
+            resolved = None
+
+            for source_decl, value_map in param.default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if isinstance(p, Option)
+                        and source_decl in (*p.opts, *p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore
+                match = value_map.get(str(source_value))
+
+                if match is not None:
+                    resolved = match
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)  # type: ignore
+
