+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very high error threshold should be satisfied almost immediately,
+    # resulting in far fewer colors than the requested maximum.
+    lenient = image.quantize(colors=256, error_threshold=1000000)
+    assert len(lenient.getcolors()) < 256
+
+    # A very low error threshold cannot be met, so the maximum number of
+    # colors should be used instead.
+    strict = image.quantize(colors=32, error_threshold=0.0001)
+    assert len(strict.getcolors()) == 32
+
+    # Without a threshold, the full requested number of colors is used.
+    default = image.quantize(colors=64)
+    assert len(default.getcolors()) == 64
+
