+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or already base64-encoded image bytes.
+
+    Returns a tuple of ``(encoded_image, decoded_for_guessing)`` where
+    ``encoded_image`` is guaranteed to be base64-encoded (ready to store) and
+    ``decoded_for_guessing`` is the raw, non-base64 bytes suitable for MIME
+    type detection.
+    """
+    try:
+        decoded = base64.b64decode(image, validate=True)
+        if base64.b64encode(decoded) == image:
+            # `image` was already base64-encoded.
+            return image, decoded
+    except (binascii.Error, ValueError):
+        pass
+
+    return base64.b64encode(image), image
+
