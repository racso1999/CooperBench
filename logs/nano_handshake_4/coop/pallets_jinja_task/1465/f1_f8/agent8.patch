+    You can set ``with_counts`` to ``True`` to also get the number of
+    items in each group, without having to do ``items|list|length`` in
+    the template. This yields ``(grouper, list, count)`` tuples instead.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=True) %}
+          <li>{{ city }} ({{ count }})</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``with_counts`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,6 +1224,16 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
+
+    if with_counts:
+        out = []
+
+        for key, values in groupby(sorted(value, key=expr), expr):
+            items = list(values)
+            out.append((key, items, len(items)))
+
+        return out
+
     return [
         _GroupTuple(key, list(values))
         for key, values in groupby(sorted(value, key=expr), expr)
