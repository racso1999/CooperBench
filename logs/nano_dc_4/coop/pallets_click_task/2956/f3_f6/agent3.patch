+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Fill in values for options with a dynamic (dict-based) default
+        that were not given an explicit value, by looking up the resolved
+        value of one or more other options in the dynamic default's mapping.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt_name, value_map in dynamic_default.items():
+                source_param = next(
+                    (p for p in params if source_opt_name in p.opts), None
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in value_map:
+                    resolved = value_map[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved  # type: ignore[index]
+
