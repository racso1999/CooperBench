     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_error_threshold_reduces_colors():
+    # a low-detail image needs far fewer than 256 colors to stay
+    # within a lenient error threshold
+    image = Image.new("RGB", (100, 100), (120, 130, 140))
+    for x in range(100):
+        for y in range(100):
+            image.putpixel((x, y), (120 + x // 20, 130, 140))
+
+    converted = image.quantize(colors=256, error_threshold=50)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+
+def test_error_threshold_uses_max_colors_if_unmet():
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_error_threshold_default_none():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, error_threshold=None)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+    assert len(converted.getcolors()) == 100
+
+
