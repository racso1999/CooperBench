     raise ValueError("illegal expression")
 
 
+def _mean_square_error(im1, im2):
+    from . import ImageChops, ImageStat
+
+    diff = ImageChops.difference(im1, im2)
+    stat = ImageStat.Stat(diff)
+    pixels = diff.size[0] * diff.size[1]
+    return sum(stat.sum2) / (pixels * len(stat.sum2))
+
+
+def _sort_quantized_palette(im, sort_palette):
+    mode = im.palette.mode
+    channels = len(mode)
+    palette_bytes = im.palette.palette
+    n = len(palette_bytes) // channels
+    colors = [
+        tuple(palette_bytes[i * channels : (i + 1) * channels]) for i in range(n)
+    ]
+
+    if sort_palette == "rgb":
+
+        def key(i):
+            return colors[i][:3]
+
+    else:
+
+        def key(i):
+            r, g, b = colors[i][:3]
+            return 0.299 * r + 0.587 * g + 0.114 * b
+
+    order = sorted(range(n), key=key)
+
+    lut = list(range(256))
+    for new_index, old_index in enumerate(order):
+        lut[old_index] = new_index
+
+    im = im.point(lut)
+    new_palette_bytes = b"".join(bytes(colors[old_index]) for old_index in order)
+
+    from . import ImagePalette
+
+    im.palette = ImagePalette.ImagePalette(mode, new_palette_bytes)
+    return im
+
+
