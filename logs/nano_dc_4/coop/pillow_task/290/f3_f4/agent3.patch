     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_none():
+    image = hopper()
+    default = image.quantize(colors=100, method=Image.FASTOCTREE)
+    explicit_none = image.quantize(
+        colors=100, method=Image.FASTOCTREE, sort_palette=None
+    )
+
+    assert default.getpalette() == explicit_none.getpalette()
+    assert default.tobytes() == explicit_none.tobytes()
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(
+        colors=100, method=Image.FASTOCTREE, sort_palette="rgb"
+    )
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(
+        colors=100, method=Image.FASTOCTREE, sort_palette="brightness"
+    )
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    brightness = [0.299 * r + 0.587 * g + 0.114 * b for r, g, b in colors]
+    assert brightness == sorted(brightness)
+
+
+def test_sort_palette_invalid_value():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=100, sort_palette="invalid")
+
+
+def test_sort_palette_with_reference_palette_raises():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, sort_palette="rgb")
