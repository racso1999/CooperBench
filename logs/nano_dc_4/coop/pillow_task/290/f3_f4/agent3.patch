+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette colors (ascending, by ``"rgb"`` value
+        or perceived ``"brightness"``) and remaps pixel indices to match.
+        """
+        mode = self.palette.mode
+        channels = len(mode)
+        palette_bytes = self.palette.palette
+        num_entries = len(palette_bytes) // channels
+        entries = [
+            tuple(palette_bytes[i * channels : (i + 1) * channels])
+            for i in range(num_entries)
+        ]
+
+        if sort_palette == "brightness":
+            def sort_key(index):
+                r, g, b = entries[index][:3]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        else:
+            def sort_key(index):
+                return entries[index][:3]
+
+        order = sorted(range(num_entries), key=sort_key)
+
+        lut = [0] * 256
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+
+        from . import ImagePalette
+
+        im = self.point(lut)
+        im.palette = ImagePalette.ImagePalette(
+            mode, b"".join(bytes(entries[old_index]) for old_index in order)
+        )
+        im.palette.dirty = 1
         return im
 
