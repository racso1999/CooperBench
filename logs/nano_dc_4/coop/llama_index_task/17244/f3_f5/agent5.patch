+    def get_image_mimetype(self, raw_image: bytes | None = None) -> str | None:
+        """Lazily resolve and cache the image's mimetype.
+
+        If the mimetype has already been resolved, the cached value is returned
+        directly. Otherwise, it's guessed from the raw (non-base64) image bytes
