+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize image bytes that may or may not already be base64-encoded.
+
+    Returns a tuple of (base64_encoded_bytes, raw_bytes), where raw_bytes is
+    always suitable for mimetype guessing (e.g. via filetype.guess) and
+    base64_encoded_bytes is always safe to store without double-encoding.
+    """
+    try:
+        raw_bytes = base64.b64decode(image, validate=True)
+        return image, raw_bytes
+    except (binascii.Error, ValueError):
+        return base64.b64encode(image), image
+
