+# Filters registered globally via `register_filter` and made available to
+# every prompt template without having to pass them explicitly.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a Jinja2 filter globally.
+
+    Once registered, the filter is available in every prompt template
+    without having to pass it explicitly to `prompt`, `Prompt.from_str` or
+    `Prompt.from_file`.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered Jinja2 filter.
+
+    Does nothing if no filter was registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
+
+def create_jinja_env(
+    loader: Optional[jinja2.BaseLoader], filters: Optional[Dict[str, Callable]] = None
+) -> jinja2.Environment:
+    """Create a Jinja2 environment with the built-in and custom filters.
+
+    Parameters
+    ----------
+    loader
+        The Jinja2 loader to use, if any.
+    filters
+        A dictionary mapping filter names to callables, that will be
+        registered on top of the built-in filters and take precedence over
+        globally registered filters of the same name.
+
+    Returns
+    -------
+    A `jinja2.Environment` instance ready to render or load templates.
+
+    """
+    env = jinja2.Environment(
+        loader=loader,
+        trim_blocks=True,
+        lstrip_blocks=True,
+        keep_trailing_newline=True,
+        undefined=jinja2.StrictUndefined,
+    )
+    env.filters["name"] = get_fn_name
+    env.filters["description"] = get_fn_description
+    env.filters["source"] = get_fn_source
+    env.filters["signature"] = get_fn_signature
+    env.filters["schema"] = get_schema
+    env.filters["args"] = get_fn_args
+
+    env.filters.update(_FILTERS)
+    if filters is not None:
+        env.filters.update(filters)
+
+    return env
+
 
