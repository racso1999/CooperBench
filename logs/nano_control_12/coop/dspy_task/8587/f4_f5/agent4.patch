+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system (e.g. on a timer, independent of chunk
+        arrival) so a stalled upstream that stops sending chunks can still be detected. If the listener has
+        started but not ended, and no chunk has arrived within `idle_timeout_s`, this emits a `StreamResponse`
+        with an empty `chunk` to signal termination and resets the listener's state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        if self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if any(f.name == "is_last_chunk" for f in fields(StreamResponse)):
+            response.is_last_chunk = True
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so it isn't left stuck in a
+        # started state after the timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
