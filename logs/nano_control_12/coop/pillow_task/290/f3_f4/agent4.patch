@@ -77,6 +83,25 @@ def test_quantize_dither_diff():
     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high error threshold should be satisfied well before using the
+    # maximum number of requested colors.
+    lenient = image.quantize(colors=256, error_threshold=5000)
+    assert len(lenient.getcolors()) < 256
+    assert mean_square_error(image, lenient) <= 5000
+
+    # An unreachably low error threshold can't be satisfied, so the
+    # maximum number of requested colors should be used instead.
+    strict = image.quantize(colors=32, error_threshold=0.0001)
+    assert len(strict.getcolors()) == 32
+
+    # Without an error threshold, behaviour is unchanged.
+    default = image.quantize(colors=32)
+    assert len(default.getcolors()) == 32
+
+
