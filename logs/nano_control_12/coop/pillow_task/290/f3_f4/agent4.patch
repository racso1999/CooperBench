+from PIL import Image, ImageChops, ImageStat
 
 from .helper import assert_image, assert_image_similar, hopper, is_ppc64le
 
 
+def mean_square_error(im1, im2):
+    diff = ImageChops.difference(im1.convert("RGB"), im2.convert("RGB"))
+    rms_per_band = ImageStat.Stat(diff).rms
+    return sum(rms ** 2 for rms in rms_per_band) / len(rms_per_band)
+
