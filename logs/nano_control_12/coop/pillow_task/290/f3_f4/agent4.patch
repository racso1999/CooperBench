+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the smallest number of colors, up to ``colors``, for which the
+        quantized image's mean square error against the original stays at or
+        below ``error_threshold``. Falls back to ``colors`` if no smaller
+        number of colors meets the threshold.
+        """
+        from . import ImageChops, ImageStat
+
+        reference = self.convert("RGB")
+
+        def mean_square_error(num_colors):
+            candidate = self._new(self.im.quantize(num_colors, method, kmeans))
+            diff = ImageChops.difference(reference, candidate.convert("RGB"))
+            rms_per_band = ImageStat.Stat(diff).rms
+            return sum(rms ** 2 for rms in rms_per_band) / len(rms_per_band)
+
+        low, high = 2, colors
+        best = colors
+        while low <= high:
+            mid = (low + high) // 2
+            if mean_square_error(mid) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        return self._new(self.im.quantize(best, method, kmeans))
+
