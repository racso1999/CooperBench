index c2e850c36..c94c1b749 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,43 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file)
+        assert not os.path.exists(str(temp_file) + ".bak")
+
+        im = Image.new("RGB", (10, 10), "#0f0")
+        im.save(temp_file, backup=True)
+
+        backup_file = Path(str(temp_file) + ".bak")
+        assert backup_file.exists()
+        with Image.open(backup_file) as backup_im:
+            assert backup_im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as saved_im:
+            assert saved_im.getpixel((0, 0)) == (0, 255, 0)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file)
+
+        im = Image.new("RGB", (10, 10), "#0f0")
+        im.save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert os.path.exists(str(temp_file) + ".backup")
+        assert not os.path.exists(str(temp_file) + ".bak")
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "new_temp.png"
+
+        im = Image.new("RGB", (10, 10), "#f00")
+        im.save(temp_file, backup=True)
+
+        assert not os.path.exists(str(temp_file) + ".bak")
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
