+# (national format regex, international format regex) for countries with dedicated rules;
+# national numbers deliberately don't require the country's dialing code to be present.
+_COUNTRY_PHONE_PATTERNS: Dict[str, Tuple[Pattern[str], Pattern[str]]] = {
+    'US': (
+        re.compile(r'^[2-9]\d{9}$'),
+        re.compile(r'^\+1[2-9]\d{9}$'),
+    ),
+    'GB': (
+        re.compile(r'^0\d{9,10}$'),
+        re.compile(r'^\+44\d{9,10}$'),
+    ),
+}
+_GENERIC_INTERNATIONAL_RE = re.compile(r'^\+\d{7,15}$')
+_GENERIC_PHONE_RE = re.compile(r'^\+?\d{7,15}$')
+_ALLOWED_DELIMITERS_RE = re.compile(r'[\s\-.()]')
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a phone number, optionally checking it against a specific country's format.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) used to apply country-specific
+                validation. If omitted, generic phone number validation is used.
+
+        Numbers may include or omit the international dialing code, and may be formatted with spaces, dashes,
+        dots or parentheses as delimiters.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert 123 != IsPhoneNumber
+        ```
+        """
+        self.country = country
+        super().__init__(country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = _ALLOWED_DELIMITERS_RE.sub('', other.strip())
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(_GENERIC_PHONE_RE.fullmatch(cleaned))
+
+        patterns = _COUNTRY_PHONE_PATTERNS.get(self.country.upper())
+        if patterns is None:
+            return bool(_GENERIC_INTERNATIONAL_RE.fullmatch(cleaned))
+
+        national_re, international_re = patterns
+        return bool(national_re.fullmatch(cleaned) or international_re.fullmatch(cleaned))
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
