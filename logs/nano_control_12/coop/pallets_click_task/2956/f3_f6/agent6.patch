+    def resolve_dynamic_default(self, ctx: Context) -> None:
+        """If this option's ``default`` is a dynamic default mapping,
+        resolve it now that every parameter for the command has an
+        initial value, and store the result on the context.
+
+        A dynamic default only applies if this option's value still
+        comes from its default (nothing was given on the command line,
+        environment, or default map). Later entries in the mapping take
+        precedence over earlier ones. If nothing matches, the value
+        remains unset.
+
+        .. versionadded:: 8.3
+        """
+        if not isinstance(self.default, dict):
+            return
+
+        if ctx.get_parameter_source(self.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+            return
+
+        resolved = None
+        found_match = False
+
+        for opt_decl, mapping in self.default.items():
+            source_param = _find_option_by_decl(ctx.command, opt_decl)
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            key = str(ctx.params.get(source_param.name))
+
+            if key in mapping:
+                resolved = mapping[key]
+                found_match = True
+
+        if not found_match:
+            return
+
+        value = self.process_value(ctx, resolved)
+
+        if self.expose_value:
+            ctx.params[self.name] = value  # type: ignore[index]
+
+
+def _find_option_by_decl(command: Command, decl: str) -> Option | None:
+    """Find the :class:`Option` on ``command`` that is declared with the
+    given option string (e.g. ``"--protocol"``), used to resolve dynamic
+    defaults.
+    """
+    for param in command.params:
+        if isinstance(param, Option) and (
+            decl in param.opts or decl in param.secondary_opts
+        ):
+            return param
+
+    return None
+
 
