+# Network types
+
+# Matches an IPv6 address in full 8-group hexadecimal notation, e.g.
+# 2001:0db8:85a3:0000:0000:8a2e:0370:7334. Compressed (`::`) and mixed
+# IPv4/IPv6 notations are not supported.
+ipv6 = Regex(r"([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}")
+
+# Matches HTTP and HTTPS URLs, including optional port, path, query
+# parameters and fragment.
+url = Regex(
+    r"https?://(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]*[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}(?::\d{1,5})?(?:/[^\s]*)?"
+)
