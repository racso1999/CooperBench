@@ -85,3 +85,71 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    mode_len = len(converted.palette.mode)
+    palette = converted.palette.palette
+    brightness = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), mode_len)
+    ]
+    assert brightness == sorted(brightness)
+
+    # Sorting the palette should not change the visible image
+    assert_image_similar(
+        converted.convert("RGB"), image.quantize(32).convert("RGB"), 1
+    )
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    mode_len = len(converted.palette.mode)
+    palette = converted.palette.palette
+    colors = [
+        tuple(palette[i : i + mode_len]) for i in range(0, len(palette), mode_len)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+
+    def by_green(color):
+        return color[1]
+
+    converted = image.quantize(32, sort_palette=by_green)
+    assert_image(converted, "P", converted.size)
+
+    mode_len = len(converted.palette.mode)
+    palette = converted.palette.palette
+    greens = [palette[i + 1] for i in range(0, len(palette), mode_len)]
+    assert greens == sorted(greens)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="unknown")
+
+
+def test_error_threshold():
+    image = hopper()
+
+    # A high error threshold should be satisfied with very few colors
+    loose = image.quantize(256, error_threshold=10000)
+    assert_image(loose, "P", loose.size)
+    assert len(loose.getcolors()) < 256
+
+    # A very tight error threshold cannot be met, so all requested
+    # colors should be used
+    tight = image.quantize(256, error_threshold=0.0001)
+    assert_image(tight, "P", tight.size)
+    assert len(tight.getcolors()) == 256
