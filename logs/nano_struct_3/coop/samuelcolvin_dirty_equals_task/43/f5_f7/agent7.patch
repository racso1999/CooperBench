+
+
+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+_hash_lengths: Dict[str, int] = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm, that is, that it has the
+    correct length and characters for that algorithm's hex digest.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The algorithm to check the hash against. Can be one of
+                `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`, `'sha384'`, `'sha512'`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'foo').hexdigest() == IsHash('md5')
+        assert hashlib.sha256(b'foo').hexdigest() == IsHash('sha256')
+        assert 'not_a_hash' != IsHash('sha256')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.length = _hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown algorithm {algorithm!r}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.length:
+            return False
+
+        return bool(re.fullmatch(r'[0-9a-fA-F]+', other))
