+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a phone number, optionally validating against a specific
+    country's numbering format.
+    """
+
+    # (national format, international format)
+    _country_patterns = {
+        'US': (re.compile(r'^\d{10}$'), re.compile(r'^\+1\d{10}$')),
+        'GB': (re.compile(r'^0\d{10}$'), re.compile(r'^\+44\d{10}$')),
+    }
+    _generic_pattern = re.compile(r'^\+?\d{7,15}$')
+    _generic_international_pattern = re.compile(r'^\+\d{8,17}$')
+    _allowed_chars_pattern = re.compile(r'^\+?[\d\s\-.()]+$')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code to validate the phone number against, if omitted,
+                generic phone number validation is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert 123 != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(plain_repr('*') if country is None else self.country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if not self._allowed_chars_pattern.match(other):
+            return False
+
+        normalized = self._normalize(other)
+
+        if self.country is None:
+            return bool(self._generic_pattern.match(normalized))
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            return bool(self._generic_international_pattern.match(normalized))
+
+        national_pattern, international_pattern = patterns
+        return bool(national_pattern.match(normalized)) or bool(international_pattern.match(normalized))
+
+    @staticmethod
+    def _normalize(phone: str) -> str:
+        phone = phone.strip()
+        has_plus = phone.startswith('+')
+        digits = re.sub(r'\D', '', phone)
+        return f'+{digits}' if has_plus else digits
