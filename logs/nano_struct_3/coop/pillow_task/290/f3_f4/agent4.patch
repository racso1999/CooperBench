+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should be satisfied well before the maximum
+    # number of colors is used.
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+    # An unreachable threshold should fall back to the requested maximum.
+    converted = image.quantize(colors=8, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 8
+
