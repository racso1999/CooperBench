+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette according to ``sort_palette``, remapping
+        pixel values to match. See :py:meth:`~PIL.Image.Image.quantize` for the
+        accepted values of ``sort_palette``.
+        """
+        if sort_palette not in ("brightness", "rgb"):
+            raise ValueError("sort_palette must be 'brightness' or 'rgb'")
+
+        self.load()
+        palette = self.im.getpalette("RGB", "RGB")
+        # Only the palette entries actually referenced by pixel data need to be
+        # reordered; higher indexes are unused padding and sorting them in would
+        # scatter them among the real colors, since they default to (0, 0, 0).
+        num_colors = min(len(palette) // 3, self.getextrema()[1] + 1)
+
+        def color_at(i):
+            return palette[i * 3 : i * 3 + 3]
+
+        if sort_palette == "brightness":
+
+            def sort_key(i):
+                r, g, b = color_at(i)
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        else:
+
+            def sort_key(i):
+                return tuple(color_at(i))
+
+        dest_map = sorted(range(num_colors), key=sort_key)
+        return self.remap_palette(dest_map)
+
