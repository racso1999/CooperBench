+def set_ttl(seconds: Optional[int] = None) -> None:
+    """Set the time-to-live (TTL), in seconds, for entries in the default DSPy cache.
+
+    Args:
+        seconds: The number of seconds after which cache entries expire. Pass `None` to disable
+            expiration, i.e., cache entries live indefinitely.
+    """
+    import dspy
+
+    cache = dspy.cache
+    cache.ttl = seconds
+    if cache.enable_memory_cache:
+        maxsize = cache.memory_cache.maxsize
+        if seconds is not None:
+            cache.memory_cache = TTLCache(maxsize=maxsize, ttl=seconds)
+        else:
+            cache.memory_cache = LRUCache(maxsize=maxsize)
+
+
 def enable_litellm_logging():
