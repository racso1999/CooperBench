+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and, if so, force-terminate it.
+
+        This should be called periodically by the streaming system, since the listener is otherwise purely
+        event-driven and has no way to notice that the upstream chunk source has stalled.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream timed out, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+
+        if now_ts - last_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the state unconditionally, regardless of `allow_reuse`, so a timed-out listener never stays
+        # stuck in a started state.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
