+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second pass over the parsed parameters to resolve options
+        whose default depends on the values of other options (see
+        :attr:`Option._dynamic_default`). This runs after every other
+        source (command line, envvar, config) has already been applied,
+        so it can look at the final value of the options it depends on.
+        """
+        for param in self.get_params(ctx):
+            if not isinstance(param, Option) or param._dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved: t.Any = None
+            found = False
+
+            for opt_name, mapping in param._dynamic_default.items():
+                source_param = next(
+                    (
+                        candidate
+                        for candidate in self.get_params(ctx)
+                        if opt_name in candidate.opts
+                        or opt_name in candidate.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                key = str(ctx.params.get(source_param.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+                    found = True
+
+            if not found:
+                continue
+
+            try:
+                value = param.process_value(ctx, resolved)
+            except Exception:
+                if not ctx.resilient_parsing:
+                    raise
+                value = None
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
