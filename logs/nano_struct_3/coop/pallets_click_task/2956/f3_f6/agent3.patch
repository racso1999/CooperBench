+def _batched(value: cabc.Iterable[t.Any], batch_size: int) -> cabc.Iterator[t.Any]:
+    """Split an iterable into tuples of up to ``batch_size`` items each."""
+    it = iter(value)
+
+    while batch := tuple(islice(it, batch_size)):
+        yield batch
