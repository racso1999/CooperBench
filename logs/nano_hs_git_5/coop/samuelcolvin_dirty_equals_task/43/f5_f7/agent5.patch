@@ -0,0 +1,66 @@
+import re
+from typing import Any, Optional
+
+from ._base import DirtyEquals
+from ._utils import plain_repr
+
+# characters commonly used to visually separate parts of a phone number
+_DELIMITERS_RE = re.compile(r'[\s\-.()]')
+
+_GENERIC_RE = re.compile(r'^\+?\d{7,15}$')
+_INTL_ONLY_RE = re.compile(r'^\+\d{7,15}$')
+
+_US_NATIONAL_RE = re.compile(r'^\d{10}$')
+_US_INTL_RE = re.compile(r'^\+1\d{10}$')
+
+_GB_NATIONAL_RE = re.compile(r'^0\d{9,10}$')
+_GB_INTL_RE = re.compile(r'^\+44\d{9,10}$')
+
+_COUNTRY_PATTERNS = {
+    'US': (_US_NATIONAL_RE, _US_INTL_RE),
+    'GB': (_GB_NATIONAL_RE, _GB_INTL_RE),
+}
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: optional ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) to restrict validation to. If
+                omitted, generic national or international phone number formats are accepted.
+
+        Note that country-specific numbers do not need to include the country's dialing code to be valid,
+        national formats (e.g. `020 7946 0958` for GB) are accepted too.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        ```
+        """
+        self.country = country
+        super().__init__(plain_repr('*') if country is None else country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = _DELIMITERS_RE.sub('', other)
+
+        if self.country is None:
+            return bool(_GENERIC_RE.fullmatch(normalized))
+
+        patterns = _COUNTRY_PATTERNS.get(self.country)
+        if patterns is None:
+            return bool(_INTL_ONLY_RE.fullmatch(normalized))
+
+        national_re, intl_re = patterns
+        return bool(national_re.fullmatch(normalized) or intl_re.fullmatch(normalized))
