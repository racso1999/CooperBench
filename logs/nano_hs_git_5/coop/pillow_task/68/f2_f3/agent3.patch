+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+
+        # A callback can override the default orientation-to-method mapping
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: Image.Transpose.ROTATE_90
+        )
+        assert transposed_im.size == (1, 2)
+        assert 0x0112 not in transposed_im.getexif()
+        assert_image_equal(transposed_im, im.rotate(90, expand=True))
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        # A callback can return a sequence of methods, applied in order
+        transposed_im = ImageOps.exif_transpose(
+            im,
+            transform_callback=lambda orientation: (
+                Image.Transpose.ROTATE_90,
+                Image.Transpose.FLIP_LEFT_RIGHT,
+            ),
+        )
+        assert transposed_im.size == (1, 2)
+        assert 0x0112 not in transposed_im.getexif()
+        expected = im.rotate(90, expand=True).transpose(
+            Image.Transpose.FLIP_LEFT_RIGHT
+        )
+        assert_image_equal(transposed_im, expected)
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        # Returning None from the callback means no transformation is applied
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: None
+        )
+        assert transposed_im.size == (2, 1)
+        assert 0x0112 in transposed_im.getexif()
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        # The callback receives the orientation value
+        received_orientations = []
+
+        def transform_callback(orientation: int) -> Image.Transpose:
+            received_orientations.append(orientation)
+            return Image.Transpose.ROTATE_90
+
+        ImageOps.exif_transpose(im, transform_callback=transform_callback)
+        assert received_orientations == [8]
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        # transform_callback also works with in_place=True
+        expected = im.rotate(90, expand=True)
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_90,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
+def test_exif_transpose_strip_metadata() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert "exif" in im.info
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert transposed_im.info == {}
+        assert not transposed_im.getexif()
+
+    # in_place=True
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert "exif" in im.info
+
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert im.info == {}
+        assert not im.getexif()
+
+    # No orientation tag, so no transposition is performed,
+    # but metadata should still be stripped
+    with Image.open("Tests/images/hopper.jpg") as im:
+        im.info["comment"] = b"Test"
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert transposed_im.info == {}
+
+    with Image.open("Tests/images/hopper.jpg") as im:
+        im.info["comment"] = b"Test"
+
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert im.info == {}
+
+    # Default behaviour is unaffected
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im)
+        assert transposed_im.info != {}
+
+
