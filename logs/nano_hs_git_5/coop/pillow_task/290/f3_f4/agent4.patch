+    def _quantize_colors_for_error_threshold(
+        self, colors, method, kmeans, error_threshold
+    ):
+        """
+        Finds the smallest number of colors (up to ``colors``) that keeps
+        the mean square error of the quantized image at or below
+        ``error_threshold``. Falls back to ``colors`` if no smaller color
+        count satisfies the threshold.
+        """
+        from . import ImageChops, ImageStat
+
+        if colors < 2:
+            return colors
+
+        reference = self.convert("RGB") if self.mode != "RGB" else self
+
+        def mean_square_error(count):
+            candidate = self._new(self.im.quantize(count, method, kmeans))
+            candidate_rgb = candidate.convert("RGB")
+            diff = ImageChops.difference(reference, candidate_rgb)
+            stat = ImageStat.Stat(diff)
+            return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+        best = colors
+        lo, hi = 2, colors
+        while lo <= hi:
+            mid = (lo + hi) // 2
+            if mean_square_error(mid) <= error_threshold:
+                best = mid
+                hi = mid - 1
+            else:
+                lo = mid + 1
+
+        return best
+
+    def _reorder_palette(self, sort_palette):
+        """
+        Returns a copy of this "P"-mode image with its palette colors
+        reordered according to ``sort_palette``, remapping pixel data so
+        the image continues to look the same. See :py:meth:`~PIL.Image.Image.quantize`
+        for the accepted values of ``sort_palette``.
+        """
+        mode = self.palette.mode
+        channels = len(mode)
+        palette = self.palette.palette
+        num_colors = len(palette) // channels
+
+        def get_color(i):
+            return tuple(palette[i * channels : (i + 1) * channels])
+
+        if callable(sort_palette):
+            key = lambda i: sort_palette(get_color(i))  # noqa: E731
+        elif sort_palette == "luminance":
+
+            def key(i):
+                r, g, b = get_color(i)[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+            key = get_color
+        else:
+            raise ValueError(
+                "sort_palette must be 'luminance', 'rgb', or a callable, "
+                f"not {sort_palette!r}"
+            )
+
+        # Only the palette entries that are actually used by a pixel need to
+        # be reordered. Unused entries are left untouched at the end.
+        used_indices = [i for i, count in enumerate(self.histogram()) if count > 0]
+        sorted_indices = sorted(used_indices, key=key)
+
+        mapping = list(range(num_colors))
+        for new_index, old_index in enumerate(sorted_indices):
+            mapping[old_index] = new_index
+
+        new_im = self.point(mapping)
+
+        new_palette = bytearray(palette)
+        for new_index, old_index in enumerate(sorted_indices):
+            new_palette[new_index * channels : (new_index + 1) * channels] = palette[
+                old_index * channels : (old_index + 1) * channels
+            ]
+
+        # Install the reordered palette directly on the new image's core,
+        # since Image.putpalette() discards the alpha channel of "RGBA"
+        # palettes instead of pushing it via putpalettealphas().
+        if mode == "RGBA":
+            rgb = bytes(v for i, v in enumerate(new_palette) if i % 4 != 3)
+            new_im.im.putpalette("RGB", rgb)
+            new_im.im.putpalettealphas(bytes(new_palette[3::4]))
+        else:
+            new_im.im.putpalette(mode, bytes(new_palette))
+
+        from . import ImagePalette
+
+        new_im.palette = ImagePalette.ImagePalette(mode, bytes(new_palette))
+
+        return new_im
+
