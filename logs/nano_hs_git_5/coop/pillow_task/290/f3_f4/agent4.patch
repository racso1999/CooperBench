+def test_error_threshold_reduces_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=200)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_meets_quality():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=10)
+    assert_image_similar(converted.convert("RGB"), image, 10)
+
+
+def test_error_threshold_falls_back_to_colors():
+    image = hopper()
+
+    # An unreasonably strict threshold should fall back to using
+    # the maximum number of colors allowed.
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+    assert len(converted.getcolors()) <= 4
+
+
+def get_used_colors(im):
+    used = sorted(set(im.getdata()))
+    return [tuple(im.palette.palette[i * 3 : i * 3 + 3]) for i in used]
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(colors=100, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = get_used_colors(converted)
+    luminances = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    assert luminances == sorted(luminances)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(colors=100, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = get_used_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def by_green(color):
+        return color[1]
+
+    converted = image.quantize(colors=100, sort_palette=by_green)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = get_used_colors(converted)
+    assert [c[1] for c in colors] == sorted(c[1] for c in colors)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=8, sort_palette="invalid")
+
+
+def test_quantize_sort_palette_with_reference_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, sort_palette="rgb")
