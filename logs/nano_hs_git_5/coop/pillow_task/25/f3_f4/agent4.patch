+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_save_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        out.write_bytes(b"not an image")
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert out.read_bytes() == b"not an image"
+
+    def test_save_dry_run_fp(self) -> None:
+        fp = io.BytesIO()
+        im = hopper()
+        im.save(fp, "PNG", dry_run=True)
+        assert fp.tell() == 0
+
+    def test_save_dry_run_raises_errors(self, tmp_path: Path) -> None:
