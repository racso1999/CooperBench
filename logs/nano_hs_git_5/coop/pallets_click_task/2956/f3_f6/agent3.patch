+    @staticmethod
+    def _validate_dynamic_default(value: dict[t.Any, t.Any]) -> None:
+        """Validate the shape of a dynamic default mapping.
+
+        :raises TypeError: if a key is not a string, or a value is not
+            a dictionary.
+        """
+        for key, mapping in value.items():
+            if not isinstance(key, str):
+                raise TypeError("Dynamic default keys must be strings")
+
+            if not isinstance(mapping, dict):
+                raise TypeError("Dynamic default values must be dictionaries")
+
+    def resolve_dynamic_default(
+        self, ctx: Context, params: cabc.Sequence[Parameter]
+    ) -> t.Any | None:
+        """Resolve this option's dynamic default by matching the
+        current values of the referenced options, in ``params``,
+        against the mapping stored in :attr:`default`.
+
+        Later entries in the mapping take precedence when more than
+        one referenced option matches. Returns ``None`` if no mapping
+        matches.
+        """
+        assert isinstance(self.default, dict)
+        resolved = None
+        matched = False
+
+        for opt_name, mapping in self.default.items():
+            for source in params:
+                if opt_name in source.opts or opt_name in source.secondary_opts:
+                    key = str(ctx.params.get(source.name))
+
+                    if key in mapping:
+                        resolved = mapping[key]
+                        matched = True
+
+                    break
+
+        if not matched:
+            return None
+
+        return self.process_value(ctx, resolved)
+
