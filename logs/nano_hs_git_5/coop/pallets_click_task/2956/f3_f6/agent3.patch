+) -> cabc.Iterator[tuple[V, ...]]:
+    """Group ``iterable`` into chunks of at most ``batch_size`` items,
+    yielding each chunk as a tuple. Unlike :func:`batch`, a final chunk
+    smaller than ``batch_size`` is yielded rather than dropped.
+    """
+    it = iter(iterable)
+
+    while chunk := tuple(islice(it, batch_size)):
