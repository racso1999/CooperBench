+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or already base64-encoded image bytes.
+
+    Args:
+        image (bytes): the raw or base64-encoded image bytes.
+
+    Returns:
+        tuple[bytes, bytes]: a tuple of `(encoded_image, decoded_for_guessing)`,
+            where `encoded_image` is the base64-encoded image bytes and
+            `decoded_for_guessing` is the raw bytes suitable for mimetype guessing.
+    """
+    try:
+        decoded = base64.b64decode(image, validate=True)
+        if base64.b64encode(decoded) == image:
+            return image, decoded
+    except Exception:
+        pass
+
+    return base64.b64encode(image), image
+
