+IpAddress = Union[ipaddress.IPv4Address, ipaddress.IPv6Address]
+
+
+class IsIP(DirtyEquals[IpAddress]):
+    """
+    A class that checks if a value is a valid IP address, optionally checking IP version and netmask.
+    """
+
+    def __init__(self, version: Literal[None, 4, 6] = None, *, netmask: Optional[str] = None):
+        """
+        Args:
+            version: The version of the IP to check, if omitted, versions 4 and 6 are both accepted.
+            netmask: The netmask to check, if omitted, no netmask is checked.
+
+        ```py title="IsIP"
+        import ipaddress
+
+        from dirty_equals import IsIP
+
+        assert '127.0.0.1' == IsIP
+        assert '127.0.0.1' == IsIP(4)
+        assert '::1' == IsIP(6)
+        assert '127.0.0.1' != IsIP(6)
+        assert '2001:db8::1' == IsIP(6)
+        assert 3232235521 == IsIP(4)
+        assert b'\\xc0\\xa8\\x00\\x01' == IsIP(4)
+        assert '192.168.0.0/16' == IsIP(version=4, netmask='255.255.0.0')
+        assert '192.168.0.0/16' != IsIP(version=4, netmask='255.255.255.128')
+        assert ipaddress.IPv4Address('127.0.0.1') == IsIP(4)
+        assert ipaddress.IPv4Network('192.168.0.0/24') == IsIP(4, netmask='255.255.255.0')
+        ```
+        """
+        if netmask is not None and version is None:
+            raise TypeError('To check the netmask you must specify the IP version')
+        self.version = version
+        self.netmask = netmask
+        super().__init__(version or Omit, netmask=Omit if netmask is None else netmask)
+
+    def equals(self, other: Any) -> bool:
+        other_network = ipaddress.ip_network(other, strict=False)
+
+        if self.version is not None and other_network.version != self.version:
+            return False
+
+        if self.netmask is not None:
+            base = '0.0.0.0' if other_network.version == 4 else '::'
+            expected_netmask = ipaddress.ip_network(f'{base}/{self.netmask}', strict=False).netmask
+            if other_network.netmask != expected_netmask:
+                return False
+
+        return True
+
+
+class IsMac(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid MAC address, optionally checking a specific format.
+    """
+
+    formats = {
+        'colon': re.compile(r'^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$'),
+        'hyphen': re.compile(r'^([0-9A-Fa-f]{2}-){5}[0-9A-Fa-f]{2}$'),
+        'dot': re.compile(r'^([0-9A-Fa-f]{4}\.){2}[0-9A-Fa-f]{4}$'),
+        'compact': re.compile(r'^[0-9A-Fa-f]{12}$'),
+    }
+
+    def __init__(self, format: Literal[None, 'colon', 'hyphen', 'dot', 'compact'] = None):
+        """
+        Args:
+            format: The format of the MAC address to check, if omitted, any known format is accepted.
+
+        ```py title="IsMac"
+        from dirty_equals import IsMac
+
+        assert '00:1B:44:11:3A:B7' == IsMac
+        assert '00:1B:44:11:3A:B7' == IsMac('colon')
+        assert '00-1B-44-11-3A-B7' == IsMac('hyphen')
+        assert '001B.4411.3AB7' == IsMac('dot')
+        assert '001b44113ab7' == IsMac('compact')
+        assert '00:1B:44:11:3A:B7' != IsMac('hyphen')
+        assert 'not-a-mac-address' != IsMac
+        ```
+        """
+        self.format = format
+        super().__init__(format or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if self.format is not None:
+            return bool(self.formats[self.format].match(other))
+        else:
+            return any(pattern.match(other) for pattern in self.formats.values())
