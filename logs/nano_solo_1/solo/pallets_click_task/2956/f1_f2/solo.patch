diff --git a/src/click/types.py b/src/click/types.py
index 684cb3b..890bd5a 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -1163,3 +1163,67 @@ class OptionHelpExtra(t.TypedDict, total=False):
     default: str
     range: str
     required: str
+
+
+#: Signature shared by validator callables passed to ``Option(validators=...)``.
+#: Each validator receives the converted value and the current context, and
+#: should raise an exception (typically :class:`~click.exceptions.BadParameter`)
+#: if the value is invalid.
+ValidatorFunc = t.Callable[[t.Any, "Context"], t.Any]
+
+
+def _complete_usernames(incomplete: str) -> list[CompletionItem]:
+    """Complete system usernames for options like ``--user``."""
+    from .shell_completion import CompletionItem
+
+    try:
+        import pwd
+
+        names = [entry.pw_name for entry in pwd.getpwall()]
+    except Exception:
+        return []
+
+    return [CompletionItem(name) for name in names if name.startswith(incomplete)]
+
+
+def _complete_git_branches(incomplete: str) -> list[CompletionItem]:
+    """Complete local and remote git branch names for options like ``--branch``."""
+    from .shell_completion import CompletionItem
+
+    try:
+        import subprocess
+
+        output = subprocess.run(
+            ["git", "branch", "-a", "--format=%(refname:short)"],
+            capture_output=True,
+            text=True,
+            check=True,
+            timeout=5,
+        ).stdout
+    except Exception:
+        return []
+
+    branches = {line.strip() for line in output.splitlines() if line.strip()}
+    return [
+        CompletionItem(branch)
+        for branch in sorted(branches)
+        if branch.startswith(incomplete)
+    ]
+
+
+def _complete_paths(incomplete: str) -> list[CompletionItem]:
+    """Complete filesystem paths for options like ``--file``."""
+    from .shell_completion import CompletionItem
+
+    return [CompletionItem(incomplete, type="file")]
+
+
+#: Maps common option name substrings to the completion function that should
+#: be used for :func:`click.option`'s ``auto_complete=True``. Checked in
+#: order, first match wins.
+AUTO_COMPLETE_REGISTRY: dict[str, t.Callable[[str], "list[CompletionItem]"]] = {
+    "user": _complete_usernames,
+    "branch": _complete_git_branches,
+    "file": _complete_paths,
+    "path": _complete_paths,
+}
