+    def process_value(self, ctx: Context, value: t.Any) -> t.Any:
+        value = super().process_value(ctx, value)
+
+        for validator in self.validators:
+            value = validator(value, ctx)
+
+        return value
+
+    def _smart_complete(self, ctx: Context, incomplete: str) -> list[CompletionItem]:
+        """Guess a completion strategy from the option's name and return
+        matching completions, based on common patterns such as
+        ``--user``, ``--branch``, and ``--file``.
+
+        .. versionadded:: 8.3
+        """
+        from .types import AUTO_COMPLETE_REGISTRY
+
+        names = [self.name or "", *(_split_opt(opt)[1] for opt in self.opts)]
+        names = [name.replace("-", "_").lower() for name in names]
+
+        for pattern, complete_func in AUTO_COMPLETE_REGISTRY.items():
+            if any(pattern in name for name in names):
+                return complete_func(incomplete)
+
+        return []
+
+    def shell_complete(self, ctx: Context, incomplete: str) -> list[CompletionItem]:
+        """Return a list of completions for the incomplete value. If
+        ``auto_complete`` is enabled and no custom ``shell_complete``
+        callback was given, an appropriate completion strategy is
+        guessed from the option's name.
+
+        .. versionadded:: 8.3
+        """
+        if self._custom_shell_complete is None and self.auto_complete:
+            results = self._smart_complete(ctx, incomplete)
+
+            if results:
+                return results
+
+        return super().shell_complete(ctx, incomplete)
+
