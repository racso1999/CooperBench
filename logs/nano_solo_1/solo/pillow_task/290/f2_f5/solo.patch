+def _adjust_palette_lightness(mode, palette_data, lightness_factor):
+    channels = len(mode)
+    adjusted = bytearray(palette_data)
+    for i in range(0, len(adjusted), channels):
+        # Only the color channels are adjusted, so any alpha channel is preserved.
+        for c in range(min(channels, 3)):
+            value = round(adjusted[i + c] * lightness_factor)
+            adjusted[i + c] = min(255, max(0, value))
+    return bytes(adjusted)
+
