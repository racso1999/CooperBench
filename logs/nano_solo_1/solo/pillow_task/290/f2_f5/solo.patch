@@ -85,3 +85,50 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=100, max_colors=50)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 50
+
+
+def test_quantize_max_colors_defaults_to_colors():
+    image = hopper()
+
+    with_max = image.quantize(colors=32, max_colors=32)
+    without_max = image.quantize(colors=32)
+    assert with_max.tobytes() == without_max.tobytes()
+
+
+def test_quantize_lightness_factor():
+    image = Image.new("RGB", (2, 2), (60, 100, 140))
+
+    converted = image.quantize(colors=1)
+    brighter = image.quantize(colors=1, lightness_factor=1.5)
+    darker = image.quantize(colors=1, lightness_factor=0.5)
+
+    converted_palette = converted.getpalette()[:3]
+    brighter_palette = brighter.getpalette()[:3]
+    darker_palette = darker.getpalette()[:3]
+
+    assert sum(brighter_palette) > sum(converted_palette)
+    assert sum(darker_palette) < sum(converted_palette)
+    assert brighter_palette == [90, 150, 210]
+    assert darker_palette == [30, 50, 70]
+
+    # Values must stay within the valid range
+    very_bright = image.quantize(colors=1, lightness_factor=3)
+    assert max(very_bright.getpalette()[:3]) <= 255
+
+
+def test_quantize_lightness_factor_default_no_change():
+    image = hopper()
+
+    default = image.quantize(colors=32)
+    explicit = image.quantize(colors=32, lightness_factor=1.0)
+
+    assert default.tobytes() == explicit.tobytes()
+    assert default.getpalette() == explicit.getpalette()
