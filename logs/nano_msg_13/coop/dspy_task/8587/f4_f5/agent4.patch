+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check for upstream idleness and force-terminate the stream if it timed out.
+
+        The listener is event-driven and otherwise has no way to notice that the upstream has stalled, so this
+        should be called periodically (e.g., by the streaming system's send loop) to provide a deterministic
+        termination signal when no chunk has arrived for `idle_timeout_s` seconds.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed since the stream started
+            receiving chunks, else `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+        if now_ts - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response_kwargs = {}
+        if "is_last_chunk" in {f.name for f in dataclass_fields(StreamResponse)}:
+            # `is_last_chunk` may be added to `StreamResponse` by a separate feature; set it when present.
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **response_kwargs)
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so it isn't left stuck
+        # in a started state after a timeout.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
