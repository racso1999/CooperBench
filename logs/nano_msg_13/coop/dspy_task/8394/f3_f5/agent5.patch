+# Magic header used to identify DSPy cache blobs that have gone through our own
+# pickle -> (optional) compress -> header encoding, as opposed to raw values that
+# diskcache pickles/stores itself. This lets us safely mix compressed and
+# uncompressed (or pre-feature legacy) entries in the same cache.
+_MAGIC = b"DSPC"
+_CODEC_NONE = 0x00
+_CODEC_GZIP = 0x01
+_CODEC_ZLIB = 0x02
+_VALID_CODECS = (None, "gzip", "zlib")
+
+
+def _validate_codec(codec: Optional[str]) -> None:
+    if codec not in _VALID_CODECS:
+        raise ValueError(f"Invalid compression codec: {codec!r}. Must be one of 'gzip', 'zlib', or None.")
+
+
+def _encode_for_disk(value: Any, codec: Optional[str]) -> bytes:
+    """Pickle `value`, optionally compress it, and prepend the magic header."""
+    payload = pickle.dumps(value)
+    if codec == "gzip":
+        payload = gzip.compress(payload)
+        codec_byte = _CODEC_GZIP
+    elif codec == "zlib":
+        payload = zlib.compress(payload)
+        codec_byte = _CODEC_ZLIB
+    else:
+        codec_byte = _CODEC_NONE
+    return _MAGIC + bytes([codec_byte]) + payload
+
+
+def _decode_from_disk(raw: Any) -> Any:
+    """Reverse `_encode_for_disk`. Values without the magic header (i.e. entries
+    written before this feature existed, or written while compression was
+    disabled) are returned unmodified for backward compatibility."""
+    if not isinstance(raw, bytes) or raw[:4] != _MAGIC:
+        return raw
+
+    codec_byte = raw[4]
+    payload = raw[5:]
+    if codec_byte == _CODEC_GZIP:
+        payload = gzip.decompress(payload)
+    elif codec_byte == _CODEC_ZLIB:
+        payload = zlib.decompress(payload)
+    elif codec_byte != _CODEC_NONE:
+        raise ValueError(f"Unknown compression codec byte in cache entry: {codec_byte}")
+    return pickle.loads(payload)
+
 
