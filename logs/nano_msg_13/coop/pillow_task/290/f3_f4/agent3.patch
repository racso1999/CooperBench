+def _sort_quantized_palette(im, sort_palette):
+    """
+    Reorders the palette of a quantized image, remapping pixel indices to
+    match. Used by :py:meth:`~PIL.Image.Image.quantize`.
+    """
+    mode = im.palette.mode
+    nbands = len(mode)
+    palette_bytes = im.palette.palette
+    num_entries = len(palette_bytes) // nbands
+    colors = [
+        tuple(palette_bytes[i * nbands : (i + 1) * nbands])
+        for i in range(num_entries)
+    ]
+
+    if sort_palette == "luminance":
+
+        def sort_key(color):
+            r, g, b = color[:3]
+            return r * 299 + g * 587 + b * 114
+
+    elif sort_palette == "rgb":
+
+        def sort_key(color):
+            return color
+
+    elif callable(sort_palette):
+        sort_key = sort_palette
+    else:
+        msg = "sort_palette must be None, 'luminance', 'rgb', or a callable"
+        raise ValueError(msg)
+
+    order = sorted(range(num_entries), key=lambda i: sort_key(colors[i]))
+
+    new_palette = bytearray()
+    mapping = [0] * num_entries
+    for new_index, old_index in enumerate(order):
+        new_palette.extend(colors[old_index])
+        mapping[old_index] = new_index
+
+    im = im.point(mapping)
+    im.putpalette(bytes(new_palette), mode)
+    return im
+
+
