+@pytest.mark.parametrize("sort_palette", ("luminance", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(colors=8)
+    sorted_converted = image.quantize(colors=8, sort_palette=sort_palette)
+
+    # Sorting the palette should not change the visual result
+    assert_image_equal(converted.convert("RGB"), sorted_converted.convert("RGB"))
+
+    # The palette order should have changed
+    assert converted.palette.palette != sorted_converted.palette.palette
+
+
+def test_quantize_sort_palette_luminance_order():
+    image = hopper()
+    converted = image.quantize(colors=8, sort_palette="luminance")
+
+    palette = converted.palette.palette
+    luminances = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), 3)
+    ]
+    assert luminances == sorted(luminances)
+
+
+def test_quantize_sort_palette_rgb_order():
+    image = hopper()
+    converted = image.quantize(colors=8, sort_palette="rgb")
+
+    palette = converted.palette.palette
+    colors = [
+        tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(colors=8)
+    sorted_converted = image.quantize(
+        colors=8, sort_palette=lambda color: -sum(color[:3])
+    )
+
+    assert_image_equal(converted.convert("RGB"), sorted_converted.convert("RGB"))
+
+    palette = sorted_converted.palette.palette
+    sums = [
+        sum(palette[i : i + 3]) for i in range(0, len(palette), 3)
+    ]
+    assert sums == sorted(sums, reverse=True)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=8, sort_palette="unknown")
+
