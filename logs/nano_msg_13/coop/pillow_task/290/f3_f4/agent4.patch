+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible (up to
+        ``colors``), stopping once the mean square error against the
+        original image falls to or below ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        reference = self.convert("RGB") if self.mode != "RGB" else self
+        pixel_count = reference.size[0] * reference.size[1]
+
+        def mean_square_error(candidate):
+            diff = ImageChops.difference(reference, candidate.convert("RGB"))
+            stat = ImageStat.Stat(diff)
+            return sum(stat.sum2) / (pixel_count * len(stat.sum2))
+
+        result = None
+        for n in range(2, colors + 1):
+            candidate = self._new(self.im.quantize(n, method, kmeans))
+            if mean_square_error(candidate) <= error_threshold:
+                result = candidate
+                break
+
+        if result is None:
+            result = self._new(self.im.quantize(colors, method, kmeans))
+
+        return result
+
