+
+
+def test_error_threshold_uses_fewer_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=2000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_disabled_by_default():
+    image = hopper()
+
+    default = image.quantize(colors=32)
+    explicit_zero = image.quantize(colors=32, error_threshold=0)
+    assert default.tobytes() == explicit_zero.tobytes()
+
+
+def test_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=32, error_threshold=0.0001)
+    assert len(converted.getcolors()) == 32
