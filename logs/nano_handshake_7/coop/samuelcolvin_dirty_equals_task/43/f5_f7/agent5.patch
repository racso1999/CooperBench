@@ -0,0 +1,59 @@
+import re
+from typing import Any, Optional
+
+from ._base import DirtyEquals
+from ._utils import plain_repr
+
+# country-specific patterns are matched against the phone number after formatting characters
+# (spaces, dashes, dots, parentheses) have been stripped out, keeping any leading '+'.
+_COUNTRY_PATTERNS = {
+    # 10 digit national number, or +1 followed by the 10 digit national number
+    'US': re.compile(r'^(\+1)?[2-9]\d{9}$'),
+    # national number starting with a leading 0, or +44 followed by the national number without the leading 0
+    'GB': re.compile(r'^(0\d{9,10}|\+44\d{9,10})$'),
+}
+
+_GENERIC_INTERNATIONAL_PATTERN = re.compile(r'^\+[1-9]\d{6,14}$')
+_GENERIC_NATIONAL_PATTERN = re.compile(r'^\d{7,15}$')
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) to restrict validation to.
+                If omitted, generic phone number validation is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '+33 1 42 68 53 00' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country: Optional[str] = country.upper() if country else None
+        super().__init__(self.country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = re.sub(r'[\s\-.()]', '', other)
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(_GENERIC_INTERNATIONAL_PATTERN.match(cleaned) or _GENERIC_NATIONAL_PATTERN.match(cleaned))
+
+        pattern = _COUNTRY_PATTERNS.get(self.country)
+        if pattern is not None:
+            return bool(pattern.match(cleaned))
+        else:
+            return bool(_GENERIC_INTERNATIONAL_PATTERN.match(cleaned))
