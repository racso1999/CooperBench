--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -1,6 +1,6 @@
 import pytest
 
-from PIL import Image
+from PIL import Image, ImageChops, ImageStat
 
 from .helper import assert_image, assert_image_similar, hopper, is_ppc64le
 
@@ -85,3 +85,37 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    # A flat color image can be perfectly represented with very few colors,
+    # so a generous error_threshold should let quantize use fewer than the
+    # requested maximum.
+    image = Image.new("RGB", (100, 100), (255, 0, 0))
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert len(converted.getcolors()) < 256
+
+
+def test_quantize_error_threshold_meets_threshold():
+    image = hopper()
+    error_threshold = 50
+    converted = image.quantize(colors=256, error_threshold=error_threshold)
+
+    diff = ImageChops.difference(image, converted.convert("RGB"))
+    stat = ImageStat.Stat(diff)
+    mse = sum(rms**2 for rms in stat.rms) / len(stat.rms)
+    assert mse <= error_threshold or len(converted.getcolors()) == 256
+
+
+def test_quantize_error_threshold_uses_max_colors_when_unmet():
+    # An impossibly strict threshold cannot be met, so quantize should fall
+    # back to using the maximum number of colors allowed.
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0)
+    assert len(converted.getcolors()) <= 8
+
+
+def test_quantize_without_error_threshold_unaffected():
+    image = hopper()
+    converted = image.quantize(colors=100)
+    assert len(converted.getcolors()) == 100
