+    def _sort_palette(self, sort_palette):
+        """
+        Returns a copy of this "P" mode image with its palette colors
+        reordered, remapping pixel values so the image still looks the same.
+
+        :param sort_palette: ``"brightness"`` to sort colors from darkest to
+           lightest, using perceived luminance, or ``"rgb"`` to sort colors
+           by their (R, G, B) tuple value.
+        """
+        if sort_palette not in ("brightness", "rgb"):
+            raise ValueError("sort_palette must be 'brightness', 'rgb' or None")
+
+        palette = self.getpalette()
+        num_colors = len(palette) // 3
+        colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in range(num_colors)]
+
+        if sort_palette == "brightness":
+            def sort_key(i):
+                r, g, b = colors[i]
+                return r * 299 + g * 587 + b * 114
+
+        else:  # "rgb"
+            def sort_key(i):
+                return colors[i]
+
+        dest_map = sorted(range(num_colors), key=sort_key)
+        return self.remap_palette(dest_map)
+
