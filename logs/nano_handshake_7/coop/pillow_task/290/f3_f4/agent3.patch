index bd9db362c..0e1236a62 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,44 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not-a-real-method")
+
+
+def _palette_colors(im):
+    palette = im.getpalette()
+    return [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+
+
+def test_quantize_sort_palette_none_matches_default():
+    image = hopper()
+    default = image.quantize(100)
+    unsorted = image.quantize(100, sort_palette=None)
+
+    assert default.tobytes() == unsorted.tobytes()
+    assert default.getpalette() == unsorted.getpalette()
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = _palette_colors(converted)
+    brightness = [r * 299 + g * 587 + b * 114 for r, g, b in colors]
+    assert brightness == sorted(brightness)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors)
