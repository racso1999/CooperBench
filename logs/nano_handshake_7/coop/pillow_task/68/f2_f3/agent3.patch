+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        assert base_im.getexif()[0x0112] == 8
+
+        # A callback that always returns a fixed method should override
+        # the default orientation-to-method mapping.
+        transposed_im = ImageOps.exif_transpose(
+            base_im, transform_callback=lambda orientation: Image.Transpose.ROTATE_90
+        )
+        expected = base_im.rotate(90, expand=True)
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        # A callback returning a sequence of methods should apply them in order.
+        transposed_im = ImageOps.exif_transpose(
+            base_im,
+            transform_callback=lambda orientation: (
+                Image.Transpose.ROTATE_90,
+                Image.Transpose.FLIP_LEFT_RIGHT,
+            ),
+        )
+        expected = base_im.rotate(90, expand=True).transpose(
+            Image.Transpose.FLIP_LEFT_RIGHT
+        )
+        assert_image_equal(transposed_im, expected)
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        # A callback returning None should mean no transformation is applied,
+        # but the orientation tag should still be removed.
+        transposed_im = ImageOps.exif_transpose(
+            base_im, transform_callback=lambda orientation: None
+        )
+        assert_image_equal(transposed_im, base_im)
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        # The callback should receive the orientation value from the EXIF data.
+        seen_orientations = []
+
+        def callback(orientation: int) -> Image.Transpose | None:
+            seen_orientations.append(orientation)
+            return None
+
+        ImageOps.exif_transpose(im, in_place=True, transform_callback=callback)
+        assert seen_orientations == [8]
+
+
