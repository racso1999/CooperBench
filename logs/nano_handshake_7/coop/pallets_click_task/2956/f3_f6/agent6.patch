@@ -1086,6 +1086,17 @@ def convert_type(ty: t.Any | None, default: t.Any | None = None) -> ParamType:
                     ty = tuple(map(type, item))
                 else:
                     ty = type(item)
+        elif isinstance(default, dict) and default and all(
+            isinstance(value, dict) for value in default.values()
+        ):
+            # A dynamic default maps other option values to the actual
+            # default, e.g. {"--protocol": {"http": 80, "https": 443}}.
+            # Infer the type from one of the mapped values instead of
+            # from the outer dict itself.
+            for mapping in default.values():
+                if mapping:
+                    ty = type(next(iter(mapping.values())))
+                    break
         else:
