+    def resolve_dynamic_default(self, ctx: Context) -> None:
+        """Resolve a dictionary-based dynamic default now that every
+        parameter for this command has been parsed, using the current
+        values of the options named in the mapping.
+
+        This only takes effect if this option's value came from its
+        default (no value was given on the command line, environment,
+        or default map) and a dynamic default mapping was provided.
+
+        .. versionadded:: 8.2
+        """
+        if self._dynamic_default is None:
+            return
+
+        if ctx.get_parameter_source(self.name) != ParameterSource.DEFAULT:  # type: ignore
+            return
+
+        opt_decl_map: dict[str, Parameter] = {}
+
+        for param in ctx.command.get_params(ctx):
+            for decl in (*param.opts, *param.secondary_opts):
+                opt_decl_map[decl] = param
+
+        resolved: t.Any | None = None
+
+        for source_decl, mapping in self._dynamic_default.items():
+            source_param = opt_decl_map.get(source_decl)
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)  # type: ignore
+            key = str(source_value)
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        if resolved is None:
+            return
+
+        value = self.type_cast_value(ctx, resolved)
+
+        if self.callback is not None:
+            value = self.callback(ctx, self, value)
+
+        if self.expose_value:
+            ctx.params[self.name] = value  # type: ignore
+
     def _parse_decls(
         self, decls: cabc.Sequence[str], expose_value: bool
     ) -> tuple[str | None, list[str], list[str]]:
