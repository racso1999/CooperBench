+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter becomes available to every `Prompt`
+    template rendered afterwards, without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function implementing the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered custom Jinja2 filter.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
