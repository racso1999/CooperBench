+    def test_dry_run_no_file_created(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_dry_run_does_not_modify_existing_file(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        original = out.read_bytes()
+
+        other = Image.new("RGB", (5, 5), "#0f0")
+        other.save(out, dry_run=True)
+
+        assert out.read_bytes() == original
+
+    def test_dry_run_raises_errors(self, tmp_path: Path) -> None:
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(tmp_path / "temp.jpg", dry_run=True)
+
+    def test_dry_run_with_file_object(self) -> None:
+        im = hopper()
+        fp = io.BytesIO()
+        im.save(fp, format="PNG", dry_run=True)
+        assert fp.getvalue() == b""
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
             assert im.mode == "P"
