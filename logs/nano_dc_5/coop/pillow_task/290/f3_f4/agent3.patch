     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(im, count):
+    mode_len = len(im.palette.mode)
+    palette = im.palette.palette
+    return [
+        tuple(palette[i : i + mode_len])
+        for i in range(0, count * mode_len, mode_len)
+    ]
+
+
+def test_quantize_sort_palette_none():
+    image = hopper()
+    converted = image.quantize(8, Image.FASTOCTREE)
+    converted_explicit = image.quantize(8, Image.FASTOCTREE, sort_palette=None)
+
+    assert converted.palette.palette == converted_explicit.palette.palette
+    assert converted.tobytes() == converted_explicit.tobytes()
+
+
+def test_quantize_sort_palette_luminosity():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="luminosity")
+
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+    assert len(converted.getcolors()) == 100
+
+    colors = _palette_colors(converted, 100)
+    luminosities = [0.299 * r + 0.587 * g + 0.114 * b for r, g, b in colors]
+    assert luminosities == sorted(luminosities)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+    assert len(converted.getcolors()) == 100
+
+    colors = _palette_colors(converted, 100)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(8, Image.FASTOCTREE, sort_palette="not-a-real-method")
