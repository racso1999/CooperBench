+    def _sort_palette(self, sort_palette):
+        if sort_palette == "luminosity":
+
+            def key(color):
+                return 0.299 * color[0] + 0.587 * color[1] + 0.114 * color[2]
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            raise ValueError(f"Unknown sort_palette method: {sort_palette}")
+
+        # Only the palette entries actually referenced by a pixel need to be
+        # reordered; the rest of the (zero-padded) palette is left as-is.
+        histogram = self.histogram()
+        used = max((i for i, count in enumerate(histogram) if count), default=-1) + 1
+        if used == 0:
+            return
+
+        mode_len = len(self.palette.mode)
+        palette = self.palette.palette
+        colors = [
+            tuple(palette[i : i + mode_len])
+            for i in range(0, used * mode_len, mode_len)
+        ]
+
+        order = sorted(range(used), key=lambda i: key(colors[i]))
+        remap = list(range(256))
+        for new_index, old_index in enumerate(order):
+            remap[old_index] = new_index
+
+        new_palette = bytearray(palette)
+        for new_index, old_index in enumerate(order):
+            new_palette[new_index * mode_len : (new_index + 1) * mode_len] = colors[
+                old_index
+            ]
+
+        self.im = self.im.point(remap, "P")
+        self.im.putpalette(self.palette.mode, bytes(new_palette))
+        self.palette.palette = self.im.getpalette(
+            self.palette.mode, self.palette.mode
+        )
+
