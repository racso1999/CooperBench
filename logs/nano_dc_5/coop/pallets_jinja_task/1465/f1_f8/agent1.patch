         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    sort_expr = make_attrgetter(
+        environment,
+        attribute,
+        postprocess=ignore_case if not case_sensitive else None,
+        default=default,
+    )
+    groups = []
+
+    for _, values in groupby(sorted(value, key=sort_expr), sort_expr):
+        values = list(values)
+        groups.append((expr(values[0]), values))
+
+    if with_counts:
+        return [_GroupTupleWithCount(key, vals, len(vals)) for key, vals in groups]
+
+    return [_GroupTuple(key, vals) for key, vals in groups]
 
 
