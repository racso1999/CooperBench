@@ -1272,6 +1272,42 @@ class Command:
 
         return results
 
+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dict-based dynamic defaults on this command's options
+        using the final values of the options they depend on.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in param.default.items():
+                source_param = None
+
+                for other in params:
+                    if opt_name in other.opts or opt_name in other.secondary_opts:
+                        source_param = other
+                        break
+
+                if source_param is None:
+                    continue
+
+                key = str(ctx.params.get(source_param.name))  # type: ignore
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)  # type: ignore
+
     @t.overload
     def main(
         self,
