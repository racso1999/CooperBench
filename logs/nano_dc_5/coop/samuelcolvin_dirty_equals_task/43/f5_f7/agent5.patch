+_PHONE_NUMBER_CHARS_RE = re.compile(r'^\+?[\d\s\-.()]+$')
+_PHONE_NUMBER_DELIMITERS_RE = re.compile(r'[\s\-.()]')
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+
+    Note that this provides pragmatic, not exhaustive, phone number validation - it's not a replacement for a
+    dedicated phone number validation library.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: the country to validate the phone number against, currently `'US'` and `'GB'` have
+                specific validation rules, other countries fall back to generic international number
+                validation. If omitted, generic validation (with or without a country code) is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert 123 != IsPhoneNumber()
+        ```
+        """
+        self.country: Optional[str] = country.upper() if country else None
+        super().__init__(self.country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if not _PHONE_NUMBER_CHARS_RE.fullmatch(other):
+            return False
+
+        cleaned = _PHONE_NUMBER_DELIMITERS_RE.sub('', other)
+        has_plus = cleaned.startswith('+')
+        digits = cleaned[1:] if has_plus else cleaned
+
+        if not digits or not digits.isdigit():
+            return False
+
+        if self.country is None:
+            return 7 <= len(digits) <= 15
+        elif self.country == 'US':
+            if has_plus:
+                return digits.startswith('1') and len(digits) == 11
+            else:
+                return len(digits) == 10
+        elif self.country == 'GB':
+            if has_plus:
+                return digits.startswith('44') and len(digits) == 12
+            else:
+                return digits.startswith('0') and len(digits) == 11
+        else:
+            return has_plus and 7 <= len(digits) <= 15
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
