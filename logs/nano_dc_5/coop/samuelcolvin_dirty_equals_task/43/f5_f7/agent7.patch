+_HASH_LENGTHS = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+    'sha3_224': 56,
+    'sha3_256': 64,
+    'sha3_384': 96,
+    'sha3_512': 128,
+    'shake_128': 32,
+    'shake_256': 64,
+    'blake2b': 128,
+    'blake2s': 64,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a specific algorithm/format.
+    """
+
+    def __init__(
+        self,
+        algorithm: Literal[
+            'md5',
+            'sha1',
+            'sha224',
+            'sha256',
+            'sha384',
+            'sha512',
+            'sha3_224',
+            'sha3_256',
+            'sha3_384',
+            'sha3_512',
+            'shake_128',
+            'shake_256',
+            'blake2b',
+            'blake2s',
+        ],
+    ):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, e.g. `'md5'`, `'sha1'`, `'sha256'`. Comparison of the
+                algorithm name is case-insensitive.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert 'aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d' == IsHash('sha1')
+        assert '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm.lower()
+        if self.algorithm not in _HASH_LENGTHS:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        self.length = _HASH_LENGTHS[self.algorithm]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self.length:
+            return False
+        return bool(re.fullmatch(r'[0-9a-fA-F]+', other))
