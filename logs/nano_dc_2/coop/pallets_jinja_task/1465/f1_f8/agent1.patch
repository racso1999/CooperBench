+        key_func = expr
+    else:
+
+        def key_func(item: t.Any) -> t.Any:
+            return ignore_case(expr(item))
+
+    result = []
+    for _, values in groupby(sorted(value, key=key_func), key_func):
+        values = list(values)
+        # Use the actual value of the first item so the original case is
+        # preserved even when grouping case-insensitively.
