           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
+    case-insensitive by default. The ``key`` for each group uses the case
+    of the first matching item. For example, if a list of users has cities
+    ``["CA", "NY", "ca"]``, the "CA" and "ca" entries will be grouped
+    together, under the "CA" key. This can be disabled by passing
+    ``case_sensitive=True``.
+
+    You can also use ``with_counts=True`` to get the number of items in
+    each group without a separate ``|length`` call.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=true) %}
+          <li>{{ city }} ({{ count }}): {{ items|map(attribute="name")|join(", ") }}</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.2
+        Added the ``case_sensitive`` and ``with_counts`` parameters.
+        Sorting and grouping is case-insensitive by default, matching
+        the behavior of the ``sort`` filter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1233,10 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    out = _group_by(value, expr, case_sensitive)
+    if with_counts:
+        return [(key, items, len(items)) for key, items in out]
+    return [_GroupTuple(key, items) for key, items in out]
 
 
