+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, checking the length and characters used.
+    """
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The algorithm to use to check the hash against.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'foo').hexdigest() == IsHash('md5')
+        assert hashlib.sha1(b'foo').hexdigest() == IsHash('sha1')
+        assert hashlib.sha256(b'foo').hexdigest() == IsHash('sha256')
+        assert 'not_a_hash' != IsHash('md5')
+        ```
+        """
+        self.algorithm = algorithm
+        self.hash_length_map: dict = {
+            'md5': 32,
+            'sha1': 40,
+            'sha224': 56,
+            'sha256': 64,
+            'sha384': 96,
+            'sha512': 128,
+        }
+        if self.algorithm.lower() not in self.hash_length_map:
+            raise ValueError(f'Unknown hash algorithm: {self.algorithm!r}')
+
+        self.algorithm_hash_length = self.hash_length_map[self.algorithm.lower()]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.algorithm_hash_length:
+            return False
+
+        return bool(re.fullmatch('[0-9a-fA-F]+', other))
+
