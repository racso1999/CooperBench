+_PRIORITY_VALUES = ("low", "below_normal", "normal", "above_normal", "high")
+
+# Windows priority classes, looked up lazily since they only exist on
+# Windows and pywin32 may not be installed.
+_WIN_PRIORITY_CLASSES = {
+    "low": "IDLE_PRIORITY_CLASS",
+    "below_normal": "BELOW_NORMAL_PRIORITY_CLASS",
+    "normal": "NORMAL_PRIORITY_CLASS",
+    "above_normal": "ABOVE_NORMAL_PRIORITY_CLASS",
+    "high": "HIGH_PRIORITY_CLASS",
+}
+
+# Unix nice value deltas relative to the default priority (0).
+_UNIX_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+
+def _set_process_priority(pid: int, process_priority: str | None) -> None:
+    """Best-effort attempt to set the CPU priority of the process with
+    the given ``pid``. Any failure (missing permissions, missing
+    platform support, missing optional dependency, invalid value) is
+    silently ignored so the editor still launches normally.
+    """
+    if process_priority not in _PRIORITY_VALUES:
+        return
+
+    try:
+        if WIN:
+            import psutil
+
+            priority_class = getattr(
+                psutil, _WIN_PRIORITY_CLASSES[process_priority]
+            )
+            psutil.Process(pid).nice(priority_class)
+        else:
+            os.setpriority(os.PRIO_PROCESS, pid, _UNIX_NICE_VALUES[process_priority])
+    except Exception:
+        pass
+
+
