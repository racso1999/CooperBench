     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_disabled_matches_default():
+    image = hopper()
+    default = image.quantize(64)
+    disabled = image.quantize(64, error_threshold=0)
+    assert default.tobytes() == disabled.tobytes()
+
+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+    lenient = image.quantize(256, error_threshold=10000)
+    assert len(lenient.getcolors()) <= 256
+
+
+def test_error_threshold_uses_max_colors_when_unmet():
+    image = hopper()
+    converted = image.quantize(32, error_threshold=0.0001)
+    assert len(converted.getcolors()) == 32
+
+
+def test_error_threshold_ignored_with_palette():
+    image = hopper()
+    converted = image.quantize(palette=hopper("P"), error_threshold=1)
+    assert_image(converted, "P", converted.size)
