diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..dca4b6268 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,44 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_luminance(im):
+    palette = im.getpalette()
+    used = sorted({index for _, index in im.getcolors(maxcolors=256)})
+    return [
+        palette[i * 3] * 299 + palette[i * 3 + 1] * 587 + palette[i * 3 + 2] * 114
+        for i in used
+    ]
+
+
+def test_quantize_sort_palette_default_unaffected():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE)
+    unsorted = image.quantize(100, Image.FASTOCTREE, sort_palette=False)
+    assert converted.tobytes() == unsorted.tobytes()
+    assert converted.palette.palette == unsorted.palette.palette
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=True)
+    assert_image(converted, "P", converted.size)
+
+    luminance = _palette_luminance(converted)
+    assert luminance == sorted(luminance)
+
+    # Pixel data should be visually unaffected by the palette reordering
+    unsorted = image.quantize(100, Image.FASTOCTREE)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    used = sorted({index for _, index in converted.getcolors(maxcolors=256)})
+    triples = [tuple(palette[i * 3 : i * 3 + 3]) for i in used]
+    assert triples == sorted(triples)
