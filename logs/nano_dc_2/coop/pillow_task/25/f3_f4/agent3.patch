             assert_image_equal(im, reloaded)
 
+    def test_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+        # A subsequent real save should still work correctly
+        im.save(out)
+        with Image.open(out) as reloaded:
+            assert_image_equal(im, reloaded)
+
+    def test_dry_run_string(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not os.path.exists(out)
+
+    def test_dry_run_raises_for_unsupported_mode(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.jpg"
+        im = hopper().convert("HSV")
+        with pytest.raises(OSError, match="cannot write mode HSV as JPEG"):
+            im.save(out, dry_run=True)
+        assert not out.exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
             assert im.mode == "P"
