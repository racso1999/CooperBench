+def test_exif_transpose_transform_callback_basic() -> None:
+    # A callback that reproduces the default orientation-to-method mapping
+    # should give the same result as not passing a callback at all.
+    method = Image.Transpose.ROTATE_270
+
+    def transform_callback(orientation: int) -> Image.Transpose | None:
+        assert orientation == 6
+        return method
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        expected = ImageOps.exif_transpose(im)
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        actual = ImageOps.exif_transpose(im, transform_callback=transform_callback)
+
+    assert_image_equal(actual, expected)
+    assert 0x0112 not in actual.getexif()
+
+
+def test_exif_transpose_transform_callback_sequence() -> None:
+    methods = [Image.Transpose.FLIP_LEFT_RIGHT, Image.Transpose.ROTATE_180]
+
+    def transform_callback(orientation: int) -> list[Image.Transpose]:
+        return methods
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        actual = ImageOps.exif_transpose(im, transform_callback=transform_callback)
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        expected = im.transpose(methods[0]).transpose(methods[1])
+
+    assert_image_equal(actual, expected)
+    assert 0x0112 not in actual.getexif()
+
+
+def test_exif_transpose_transform_callback_none() -> None:
+    def transform_callback(orientation: int) -> None:
+        return None
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        original = im.copy()
+        actual = ImageOps.exif_transpose(im, transform_callback=transform_callback)
+
+    # No transposition should have been applied, and since nothing was
+    # transposed, the orientation tag is left untouched, same as when the
+    # default mapping yields no method (e.g. orientation 1).
+    assert_image_equal(actual, original)
+    assert actual.getexif()[0x0112] == 6
+
+
+def test_exif_transpose_transform_callback_receives_orientation() -> None:
+    seen_orientations = []
+
+    def transform_callback(orientation: int) -> Image.Transpose | None:
+        seen_orientations.append(orientation)
+        return None
+
+    for i in range(2, 9):
+        with Image.open(f"Tests/images/hopper_orientation_{i}.jpg") as im:
+            ImageOps.exif_transpose(im, transform_callback=transform_callback)
+
+    assert seen_orientations == list(range(2, 9))
+
+
