+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be satisfied with very few colors
+    loose = image.quantize(colors=256, error_threshold=10000)
+    assert_image(loose, "P", loose.size)
+    assert len(loose.getcolors()) <= 256
+
+    # A very low threshold cannot be met, so the max number of colors is used
+    strict = image.quantize(colors=4, error_threshold=0)
+    assert_image(strict, "P", strict.size)
+    assert len(strict.getcolors()) <= 4
+
+    # Using a threshold should never need more colors than the unconstrained case
+    unconstrained = image.quantize(colors=256)
+    assert len(loose.getcolors()) <= len(unconstrained.getcolors())
+
+
 def test_quantize():
