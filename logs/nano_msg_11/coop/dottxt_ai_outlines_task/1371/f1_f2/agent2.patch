+# Registry of filters that should be made available to every prompt
+# template, without having to pass them explicitly each time.
+GLOBAL_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter in the global filter registry.
+
+    Once registered, the filter is automatically available to every
+    prompt template rendered afterwards, under the given name.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter can be used in templates
+        (e.g. ``{{ value | name }}``).
+    func : Callable
+        The callable that implements the filter.
+
+    """
+    GLOBAL_FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove.
+
+    """
+    GLOBAL_FILTER_REGISTRY.pop(name, None)
+
 
