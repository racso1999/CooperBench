+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle and, if so, terminate it.
+
+        This should be called periodically by the streaming system (independently of `receive()`) so that a
+        stalled upstream that never sends another chunk still results in a deterministic stream termination.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if `idle_timeout_s` has elapsed since the last received
+            chunk while the stream had started but not yet ended, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener state unconditionally so it doesn't stay stuck in a "started" state, regardless of
+        # `allow_reuse`.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
