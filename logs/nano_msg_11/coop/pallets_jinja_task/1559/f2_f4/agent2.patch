+def _make_new_dgettext(func: t.Callable[[str, str], str]) -> t.Callable[..., str]:
+    @pass_context
+    def dgettext(
+        __context: Context, __domain: str, __string: str, **variables: t.Any
+    ) -> str:
+        rv = __context.call(func, __domain, __string)
+        if __context.eval_ctx.autoescape:
+            rv = Markup(rv)
+        # Always treat as a format string, see gettext comment above.
+        return rv % variables  # type: ignore
+
+    return dgettext
+
+
+def _make_new_dngettext(
+    func: t.Callable[[str, str, str, int], str]
+) -> t.Callable[..., str]:
+    @pass_context
+    def dngettext(
+        __context: Context,
+        __domain: str,
+        __singular: str,
+        __plural: str,
+        __num: int,
+        **variables: t.Any,
+    ) -> str:
+        variables.setdefault("num", __num)
+        rv = __context.call(func, __domain, __singular, __plural, __num)
+        if __context.eval_ctx.autoescape:
+            rv = Markup(rv)
+        # Always treat as a format string, see gettext comment above.
+        return rv % variables  # type: ignore
+
+    return dngettext
+
+
+def _make_domain_fallback_gettext(
+    func: t.Callable[[str], str]
+) -> t.Callable[[str, str], str]:
+    """Used when the installed translations don't provide a domain-aware
+    ``dgettext``. The domain is accepted but ignored so templates using
+    ``{% trans domain="..." %}`` keep working against plain translations.
+    """
+
+    def dgettext(domain: str, message: str) -> str:
+        return func(message)
+
+    return dgettext
+
+
+def _make_domain_fallback_ngettext(
+    func: t.Callable[[str, str, int], str]
+) -> t.Callable[[str, str, str, int], str]:
+    def dngettext(domain: str, singular: str, plural: str, num: int) -> str:
+        return func(singular, plural, num)
+
+    return dngettext
+
