+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dictionary-based dynamic default by looking at the
+        current values of the referenced options on ``ctx``.
+
+        Later entries in the dynamic default mapping take precedence
+        over earlier ones when more than one referenced option matches.
+
+        .. versionadded:: 8.3
+        """
+        assert self._dynamic_default is not None
+
+        result: t.Any | None = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_param: Parameter | None = None
+
+            for param in ctx.command.get_params(ctx):
+                if opt_name in param.opts or opt_name in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None:
+                continue
+
+            current_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+            key = str(current_value)
+
+            if key in mapping:
+                result = mapping[key]
+
+        return result
+
