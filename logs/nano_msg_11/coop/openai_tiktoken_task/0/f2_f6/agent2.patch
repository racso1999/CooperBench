+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes a string into tokens, also returning each token's starting
+        character position in `text`.
+
+        Splits `text` around any allowed special tokens (which are themselves single
+        tokens), then runs the ordinary regex + BPE pipeline over each in-between chunk,
+        tracking character offsets as it goes.
+        """
+        special_pat = _special_token_regex(frozenset(allowed_special)) if allowed_special else None
+        ordinary_pat = regex.compile(self._pat_str)
+
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        start = 0
+        text_len = len(text)
+        while True:
+            special_match = special_pat.search(text, start) if special_pat else None
+            end = special_match.start() if special_match else text_len
+
+            for piece_match in ordinary_pat.finditer(text, start, end):
+                piece = piece_match.group()
+                piece_start = piece_match.start()
+                piece_tokens = self._core_bpe.encode_single_piece(piece.encode("utf-8"))
+
+                # A single regex piece can be split into several tokens by BPE merges;
+                # walk the decoded bytes of each token to recover its char offset.
+                chars_seen = 0
+                for token in piece_tokens:
+                    token_bytes = self._core_bpe.decode_single_token_bytes(token)
+                    offset = max(0, chars_seen - (0x80 <= token_bytes[0] < 0xC0))
+                    tokens.append(token)
+                    positions.append(piece_start + offset)
+                    chars_seen += sum(1 for b in token_bytes if not 0x80 <= b < 0xC0)
+
+            if special_match is None:
+                break
+
+            special_text = special_match.group()
+            tokens.append(self._special_tokens[special_text])
+            positions.append(special_match.start())
+            start = special_match.end()
+
+        return tokens, positions
+
     def __getstate__(self) -> object:
         import tiktoken.registry
 
