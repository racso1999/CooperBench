+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricting checks to a specific
+    country's format. This provides pragmatic validation, suitable for everyday application use, rather
+    than exhaustive compliance with numbering plans.
+    """
+
+    # national formats require the leading digit/trunk prefix, international formats require the `+` and
+    # calling code, bare digit runs without a `+` or trunk prefix are rejected to avoid ambiguity between countries
+    country_patterns: Dict[str, Pattern[str]] = {
+        'US': re.compile(r'\+1\d{10}|\d{10}'),
+        'GB': re.compile(r'\+44\d{9,10}|0\d{9,10}'),
+    }
+
+    generic_pattern = re.compile(r'\+?\d{7,15}')
+    generic_international_pattern = re.compile(r'\+\d{7,15}')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to restrict validation to that country's phone
+                number format, if omitted, generic validation is performed. Currently `'US'` and `'GB'`
+                have dedicated format checks, other country codes fall back to generic international
+                validation (a `+` followed by 7-15 digits).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+
+        assert '+33 1 23 45 67 89' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = re.sub(r'[\s\-.()]', '', other)
+
+        if self.country is None:
+            pattern = self.generic_pattern
+        else:
+            pattern = self.country_patterns.get(self.country, self.generic_international_pattern)
+
+        m = pattern.fullmatch(cleaned)
+        return m is not None
+
