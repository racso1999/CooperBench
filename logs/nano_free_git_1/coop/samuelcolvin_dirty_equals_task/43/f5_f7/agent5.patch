+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm/hash type, using a length and character
+    check.
+    """
+
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, hash_type: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            hash_type: The type of hash to check, options are: `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'`, `'sha512'`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        s = 'Testing IsHash'
+
+        md5 = hashlib.md5(s.encode()).hexdigest()
+        sha1 = hashlib.sha1(s.encode()).hexdigest()
+        sha256 = hashlib.sha256(s.encode()).hexdigest()
+
+        assert md5 == IsHash('md5')
+        assert sha1 == IsHash('sha1')
+        assert sha256 == IsHash('sha256')
+        assert md5 != IsHash('sha1')
+        assert sha1 != IsHash('md5')
+        assert sha256 != IsHash('md5')
+        ```
+        """
+        self.hash_type = hash_type
+        self.hash_type_lower = hash_type.lower()
+        if self.hash_type_lower not in self.hash_lengths:
+            raise ValueError(f'Unknown hash type: {hash_type!r}')
+        self.length = self.hash_lengths[self.hash_type_lower]
+        super().__init__(hash_type)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.length:
+            return False
+
+        return bool(re.fullmatch('[0-9a-fA-F]+', other))
+
