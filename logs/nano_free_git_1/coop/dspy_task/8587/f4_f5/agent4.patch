+def _debug_preview(text: str | None, max_len: int = _DEBUG_PREVIEW_MAX_LEN) -> str:
+    """Truncate and escape a string for safe inclusion in a debug log message."""
+    if not text:
+        return ""
+    escaped = text.replace("\\", "\\\\").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
+    if len(escaped) > max_len:
+        return escaped[:max_len] + "..."
+    return escaped
