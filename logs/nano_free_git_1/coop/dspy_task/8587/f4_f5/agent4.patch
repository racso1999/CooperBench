+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and, if so, emit a terminal chunk.
+
+        This is independent of `receive()` and is meant to be called periodically by the streaming
+        system, since a stalled upstream never delivers the chunk that would otherwise signal the
+        end of the stream. If `idle_timeout_s` has elapsed since the last chunk was received for a
+        stream that has started but not yet ended, a `StreamResponse` with an empty `chunk` is
+        returned and the listener state is reset unconditionally (regardless of `allow_reuse`) so it
+        isn't left stuck in a started state.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if "is_last_chunk" in getattr(StreamResponse, "__dataclass_fields__", {}):
+            # `is_last_chunk` may be introduced by a separate feature; when present, a timeout is
+            # always the last chunk of the stream.
+            response.is_last_chunk = True
+
+        # Unconditionally reset the state, regardless of `allow_reuse`, so the listener doesn't stay
+        # stuck thinking a stream is in progress.
