+    def _sort_palette(self, sort_palette):
+        """
+        Reorders a "P" mode image's palette, without changing the appearance
+        of the image.
+
+        :param sort_palette: ``"luminance"``, ``"rgb"``, or a callable that
+           accepts an ``(r, g, b)`` tuple and returns a sort key.
+        :returns: An :py:class:`~PIL.Image.Image` object.
+        """
+        if callable(sort_palette):
+            key = sort_palette
+        elif sort_palette == "luminance":
+
+            def key(rgb):
+                r, g, b = rgb
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(rgb):
+                return rgb
+
+        else:
+            raise ValueError(
+                "sort_palette must be 'luminance', 'rgb', or a callable"
+            )
+
+        self.load()
+        palette = self.im.getpalette("RGB")
+        colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+
+        order = sorted(range(len(colors)), key=lambda i: key(colors[i]))
+
+        return self.remap_palette(order)
