+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be satisfiable with far fewer than 256 colors
+    lenient = image.quantize(colors=256, error_threshold=1000)
+    assert len(lenient.getcolors()) <= 256
+    assert image._quantize_mse(lenient.convert("RGB")) <= 1000
+
+    # A threshold of 0 can't necessarily be met, so it should fall back to
+    # using the maximum number of colors allowed
+    strict = image.quantize(colors=64, error_threshold=0)
+    assert len(strict.getcolors()) <= 64
+
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    luminance = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), 3)
+    ]
+    assert luminance == sorted(luminance)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def sort_key(rgb):
+        return -sum(rgb)
+
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=sort_key)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    sums = [sum(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert sums == sorted(sums, reverse=True)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, Image.FASTOCTREE, sort_palette="bad")
+
