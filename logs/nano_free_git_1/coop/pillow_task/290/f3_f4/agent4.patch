+    def _quantize_mse(self, quantized):
+        """
+        Returns the mean square error between this image and a quantized
+        version of it, used by :py:meth:`~PIL.Image.Image.quantize` to
+        evaluate ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        comparable = self.convert("RGB") if self.mode == "RGBA" else self
+        diff = ImageChops.difference(comparable, quantized.convert(comparable.mode))
+        stat = ImageStat.Stat(diff)
+        total_count = sum(stat.count)
+        if not total_count:
+            return 0
+        return sum(stat.sum2) / total_count
+
+    def _quantize_colors_for_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the smallest number of colors, up to ``colors``, for which
+        quantizing this image keeps the mean square error at or below
+        ``error_threshold``. Assumes that error decreases monotonically as
+        the number of colors increases. Falls back to ``colors`` if the
+        threshold cannot be met.
+        """
+        low, high = 1, colors
+        best = colors
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantize_mse(candidate) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+        return best
+
