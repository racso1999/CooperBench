+    def _sort_palette(self, sort_palette):
+        """
+        Sorts the palette of a "P" mode image, remapping pixel indices so
+        that they continue to point at the same colors.
+
+        :param sort_palette: ``"luminance"``, ``"rgb"``, or a callable that
+           accepts a palette color tuple and returns a sortable key.
+        :returns: A new "P" mode :py:class:`~PIL.Image.Image` object.
+        """
+        if callable(sort_palette):
+            key = sort_palette
+        elif sort_palette == "luminance":
+
+            def key(rgb):
+                r, g, b = rgb[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(rgb):
+                return rgb
+
+        else:
+            raise ValueError(
+                "sort_palette must be 'luminance', 'rgb', or a callable"
+            )
+
+        mode = self.palette.mode
+        mode_len = len(mode)
+        palette_bytes = self.palette.palette
+
+        used_indexes = [index for _, index in self.getcolors(256)]
+        order = sorted(
+            used_indexes,
+            key=lambda i: key(
+                tuple(palette_bytes[i * mode_len : (i + 1) * mode_len])
+            ),
+        )
+
+        lut = list(range(256))
+        new_palette_bytes = bytearray(palette_bytes)
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+            new_palette_bytes[
+                new_index * mode_len : (new_index + 1) * mode_len
+            ] = palette_bytes[old_index * mode_len : (old_index + 1) * mode_len]
+
+        im = self.point(lut)
+        im.putpalette(bytes(new_palette_bytes), mode)
         return im
 
