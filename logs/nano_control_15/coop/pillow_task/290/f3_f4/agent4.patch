+    @staticmethod
+    def _quantize_mse(reference, quantized):
+        """
+        Computes the mean square error, over the RGB channels, between
+        ``reference`` and a quantized version of it. Used by
+        :py:meth:`~PIL.Image.Image.quantize` to support ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        diff = ImageChops.difference(reference, quantized.convert("RGB"))
+        stat = ImageStat.Stat(diff)
+        return sum(stat.sum2) / sum(stat.count)
