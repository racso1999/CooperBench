+
+#: ``nice`` offsets used to approximate the requested priority on
+#: Unix-like systems. Lower ``nice`` values mean higher scheduling priority.
+_UNIX_PROCESS_PRIORITIES = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
