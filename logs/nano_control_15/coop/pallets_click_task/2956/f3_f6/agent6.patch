+    def _resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dynamic default (a mapping of other option names to
+        value-to-default mappings) against the already processed values
+        of those other options.
+
+        Later entries in the mapping take precedence over earlier ones
+        when more than one source option matches.
+        """
+        assert self._dynamic_default is not None
+        resolved = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_param = next(
+                (
+                    param
+                    for param in ctx.command.get_params(ctx)
+                    if opt_name in param.opts or opt_name in param.secondary_opts
+                ),
+                None,
+            )
+
+            if source_param is None or source_param.name not in ctx.params:
+                continue
+
+            key = str(ctx.params[source_param.name])
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
+
