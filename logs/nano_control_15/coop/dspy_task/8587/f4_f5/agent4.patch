+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and, if so, force it to end.
+
+        This is meant to be called periodically by the streaming system, independent of `receive()`, so a
+        stalled upstream doesn't leave a consumer waiting forever. If more than `idle_timeout_s` seconds have
+        passed since the last chunk was received while the field is mid-stream, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`; callers may pass an explicit value (e.g. in tests).
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = time.time() if now_ts is None else now_ts
+        if self._last_chunk_ts is not None and now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Unconditionally reset the listener state (regardless of `allow_reuse`) so a timed-out stream never
+        # gets stuck thinking it's still started. `stream_end` still respects `allow_reuse` via the lazy reset
+        # in `receive()`, matching the behavior of a naturally ended stream.
+        self.stream_start = False
+        self.stream_end = True
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
