+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes a string into tokens, also tracking the starting character position of
+        each token in `text`. Special tokens in `allowed_special` are recognised and encoded
+        as such; all other text is run through the ordinary regex + BPE splitting."""
+        try:
+            return self._encode_with_positions_inner(text, allowed_special)
+        except UnicodeEncodeError:
+            # See comment in encode
+            text = text.encode("utf-16", "surrogatepass").decode("utf-16", "replace")
+            return self._encode_with_positions_inner(text, allowed_special)
+
+    def _encode_with_positions_inner(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        special_regex = _special_token_regex(frozenset(allowed_special)) if allowed_special else None
+        pat = regex.compile(self._pat_str)
+
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        pos = 0
+        text_len = len(text)
+        while pos < text_len:
+            match = special_regex.search(text, pos) if special_regex else None
+            segment_end = match.start() if match else text_len
+
+            segment_pos = pos
+            for piece in regex.findall(pat, text[pos:segment_end]):
+                piece_tokens = self._core_bpe.encode_single_piece(piece.encode("utf-8"))
+                piece_token_bytes = [
+                    self._core_bpe.decode_single_token_bytes(t) for t in piece_tokens
+                ]
+                for token, offset in zip(piece_tokens, _token_char_offsets(piece_token_bytes)):
+                    tokens.append(token)
+                    positions.append(segment_pos + offset)
+                segment_pos += len(piece)
+
+            if match is None:
+                break
+
+            tokens.append(self._special_tokens[match.group()])
+            positions.append(match.start())
+            pos = match.end()
+
+        return tokens, positions
+
     def _encode_bytes(self, text: bytes) -> list[int]:
         return self._core_bpe._encode_bytes(text)
 
