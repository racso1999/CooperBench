+def test_exif_transpose_logger_callable() -> None:
+    messages = []
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im, logger=messages.append)
+        assert 0x0112 not in transposed_im.getexif()
+    assert messages
+    assert any("orientation" in message for message in messages)
+
+
+def test_exif_transpose_logger_standard_logger() -> None:
+    logger = logging.getLogger("PIL.ImageOps.tests")
+    messages = []
+    with mock.patch.object(logger, "info", side_effect=messages.append):
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(im, logger=logger)
+            assert 0x0112 not in transposed_im.getexif()
+    assert messages
+
+
+def test_exif_transpose_logger_no_transposition() -> None:
+    messages = []
+    with Image.open("Tests/images/hopper.jpg") as im:
+        ImageOps.exif_transpose(im, logger=messages.append)
+    assert messages
+    assert any("no transposition needed" in message for message in messages)
+
+
+def test_exif_transpose_no_logger() -> None:
+    # Logging is opt-in; passing no logger should not raise or change behavior
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(im)
+        assert 0x0112 not in transposed_im.getexif()
+
