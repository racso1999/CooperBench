diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..52652b6a6 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,66 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    luminance = [
+        0.299 * palette[i] + 0.587 * palette[i + 1] + 0.114 * palette[i + 2]
+        for i in range(0, len(converted.getcolors()) * 3, 3)
+    ]
+    assert luminance == sorted(luminance)
+
+    # Sorting the palette should not change the rendered image
+    unsorted = image.quantize(100)
+    assert list(unsorted.convert("RGB").getdata()) == list(
+        converted.convert("RGB").getdata()
+    )
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    num_colors = len(converted.getcolors())
+    colors = [tuple(palette[i : i + 3]) for i in range(0, num_colors * 3, 3)]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+
+    def by_red(color):
+        return color[0]
+
+    converted = image.quantize(100, sort_palette=by_red)
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    num_colors = len(converted.getcolors())
+    reds = [palette[i] for i in range(0, num_colors * 3, 3)]
+    assert reds == sorted(reds)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="unknown")
+
+
+def test_sort_palette_rgba():
+    image = hopper("RGBA")
+    converted = image.quantize(sort_palette="luminance")
+    assert converted.mode == "P"
+
+    unsorted = image.quantize()
+    assert list(unsorted.convert("RGB").getdata()) == list(
+        converted.convert("RGB").getdata()
+    )
diff --git a/src/PIL/Image.py b/src/PIL/Image.py
