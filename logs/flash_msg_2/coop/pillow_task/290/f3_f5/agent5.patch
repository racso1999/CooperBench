+def test_quantize_lightness_factor():
+    image = hopper()
+
+    converted = image.quantize(100)
+    brighter = image.quantize(100, lightness_factor=1.5)
+    darker = image.quantize(100, lightness_factor=0.5)
+
+    assert converted.palette.palette != brighter.palette.palette
+    assert converted.palette.palette != darker.palette.palette
+
+    unchanged = image.quantize(100, lightness_factor=1.0)
+    assert converted.palette.palette == unchanged.palette.palette
+
+    # Values should be clamped to the valid 0-255 range
+    very_bright = image.quantize(100, lightness_factor=100)
+    assert max(very_bright.palette.palette) == 255
+
+
