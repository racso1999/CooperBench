+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.palette.palette
+    used_indexes = sorted({pixel for pixel in converted.getdata()})
+    brightnesses = [sum(palette[i * 3 : i * 3 + 3]) for i in used_indexes]
+    assert brightnesses == sorted(brightnesses)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.palette.palette
+    used_indexes = sorted({pixel for pixel in converted.getdata()})
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in used_indexes]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_preserves_colors():
+    image = hopper()
+    unsorted = image.quantize(100)
+    sorted_by_brightness = image.quantize(100, sort_palette="brightness")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_by_brightness.convert(
+        "RGB"
+    ).tobytes()
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="invalid")
+
+
