+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping pixel indexes to match.
+
+        :param sort_palette: ``"brightness"`` or ``"rgb"``. See
+           :py:meth:`~PIL.Image.Image.quantize` for details.
+        :returns: A new image
+        """
+        palette = self.palette.palette
+        num_colors = len(palette) // 3
+        colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in range(num_colors)]
+
+        if sort_palette == "brightness":
+            def sort_key(i):
+                return sum(colors[i])
+
+        else:
+
+            def sort_key(i):
+                return colors[i]
+
+        dest_map = sorted(range(num_colors), key=sort_key)
+        return self.remap_palette(dest_map)
+
