+def test_quantize_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=100, max_colors=50)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 50
+
+
+def test_quantize_max_colors_defaults_to_colors():
+    image = hopper()
+
+    with_max_colors = image.quantize(colors=100, max_colors=100)
+    without_max_colors = image.quantize(colors=100)
+    assert with_max_colors.tobytes() == without_max_colors.tobytes()
+
+
+def test_quantize_max_colors_greater_than_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=50, max_colors=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 50
+
