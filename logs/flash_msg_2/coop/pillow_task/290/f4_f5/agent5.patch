diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..018fb195b 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,50 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_lightness_factor_default_unchanged():
+    image = hopper()
+    normal = image.quantize(colors=8)
+    unchanged = image.quantize(colors=8, lightness_factor=1.0)
+    assert normal.palette.palette == unchanged.palette.palette
+
+
+def test_quantize_lightness_factor_brighter():
+    image = hopper()
+    normal = image.quantize(colors=8)
+    brighter = image.quantize(colors=8, lightness_factor=1.5)
+
+    assert brighter.palette.palette != normal.palette.palette
+    assert sum(brighter.palette.palette) > sum(normal.palette.palette)
+
+
+def test_quantize_lightness_factor_darker():
+    image = hopper()
+    normal = image.quantize(colors=8)
+    darker = image.quantize(colors=8, lightness_factor=0.5)
+
+    assert darker.palette.palette != normal.palette.palette
+    assert sum(darker.palette.palette) < sum(normal.palette.palette)
+
+
+def test_quantize_lightness_factor_clamped():
+    image = hopper()
+    converted = image.quantize(colors=8, lightness_factor=10)
+    assert all(0 <= value <= 255 for value in converted.palette.palette)
+    assert 255 in converted.palette.palette
+
+    converted = image.quantize(colors=8, lightness_factor=0)
+    assert all(value == 0 for value in converted.palette.palette)
+
+
+def test_quantize_lightness_factor_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    normal = image.quantize(palette=palette)
+    brighter = image.quantize(palette=palette, lightness_factor=1.5)
+
+    assert brighter.palette.palette != normal.palette.palette
+    assert sum(brighter.palette.palette) > sum(normal.palette.palette)
