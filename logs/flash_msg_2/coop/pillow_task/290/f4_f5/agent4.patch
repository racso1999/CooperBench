+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high error threshold should allow fewer colors than requested to be
+    # used, since the quality loss from doing so is within the threshold.
+    high_threshold = image.quantize(colors=256, error_threshold=1000)
+    assert_image(high_threshold, "P", high_threshold.size)
+    assert len(high_threshold.getcolors()) < 256
+
+    # A very low error threshold cannot be reached, so the requested number
+    # of colors should be used instead.
+    low_threshold = image.quantize(colors=32, error_threshold=0.001)
+    assert_image(low_threshold, "P", low_threshold.size)
+    assert len(low_threshold.getcolors(256)) == 32
+
+
+def test_quantize_error_threshold_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
