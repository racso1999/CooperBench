+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        hopper().save(temp_file)
+        with open(temp_file, "rb") as fp:
+            original_contents = fp.read()
+
+        im = Image.new("RGB", (20, 20), "blue")
+        im.save(temp_file, dry_run=True)
+
+        with open(temp_file, "rb") as fp:
+            assert fp.read() == original_contents
+
+    def test_dry_run_fp(self) -> None:
+        im = hopper()
+        fp = io.BytesIO()
+        im.save(fp, format="PNG", dry_run=True)
+
+        assert fp.tell() == 0
+
+    def test_dry_run_raises_on_error(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
