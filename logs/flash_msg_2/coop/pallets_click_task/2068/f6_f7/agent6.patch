+    def _get_priority_popen_kwargs(self) -> dict[str, t.Any]:
+        """Build extra ``subprocess.Popen`` kwargs to apply
+        ``self.process_priority``, if it names a supported priority
+        level. Unsupported or unrecognized values are ignored so that
+        editing never fails because of the priority setting.
+        """
+        kwargs: dict[str, t.Any] = {}
+
+        if self.process_priority is None:
+            return kwargs
+
+        if WIN:
+            import subprocess
+
+            class_name = _WIN_PRIORITY_CLASS_NAMES.get(self.process_priority)
+            priority_class = getattr(subprocess, class_name, None) if class_name else None
+
+            if priority_class is not None:
+                kwargs["creationflags"] = priority_class
+        elif self.process_priority in _POSIX_PRIORITY_NICE_VALUES:
+            nice_value = _POSIX_PRIORITY_NICE_VALUES[self.process_priority]
+
+            def _preexec_set_priority() -> None:
+                try:
+                    os.nice(nice_value)
+                except OSError:
+                    pass
+
+            kwargs["preexec_fn"] = _preexec_set_priority
+
+        return kwargs
