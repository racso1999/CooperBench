+def _compress_adjacent_duplicates(tokens: list[int]) -> list[int]:
+    """Removes adjacent repeated tokens, keeping only the first occurrence of each run."""
+    if not tokens:
+        return tokens
+    compressed = [tokens[0]]
+    for token in tokens[1:]:
+        if token != compressed[-1]:
+            compressed.append(token)
+    return compressed
