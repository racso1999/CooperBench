+    def _record_cache_event(self, event: str) -> None:
+        """Update global and per-call cache statistics for a `get()` outcome.
+
+        `event` is one of "mem_hits", "disk_hits", or "misses".
+        """
+        with self._lock:
+            self._stats[event] += 1
+            if event in ("mem_hits", "disk_hits"):
+                self._stats["hits"] += 1
+
+        usage_tracker = settings.usage_tracker
+        if usage_tracker is not None:
+            usage_tracker.add_cache_event(event)
+
+    def stats(self) -> Dict[str, int]:
+        """Return the global cache hit/miss counters accumulated across all cache operations."""
+        with self._lock:
+            return dict(self._stats)
+
+    def reset_stats(self) -> None:
+        """Reset the global cache hit/miss counters to zero."""
+        with self._lock:
+            self._stats = Counter(hits=0, mem_hits=0, disk_hits=0, misses=0)
