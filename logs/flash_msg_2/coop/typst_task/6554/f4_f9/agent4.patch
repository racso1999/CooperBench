+/// The error message when the string does not have enough grapheme
+/// clusters to satisfy the requested `repeat` count.
+#[cold]
+fn not_enough_graphemes(repeat: usize, len: usize) -> EcoString {
+    eco_format!(
+        "string has only {len} grapheme cluster{}, but repeat count is {repeat}",
+        if len == 1 { "" } else { "s" }
+    )
+}
