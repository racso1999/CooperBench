+// methodNames maps chi's internal method bitmask values back to their
+// standard HTTP method name, used to report available methods for a
+// resource (e.g. for CORS preflight and Allow headers).
+var methodNames = map[methodTyp]string{
+	mCONNECT: http.MethodConnect,
+	mDELETE:  http.MethodDelete,
+	mGET:     http.MethodGet,
+	mHEAD:    http.MethodHead,
+	mOPTIONS: http.MethodOptions,
+	mPATCH:   http.MethodPatch,
+	mPOST:    http.MethodPost,
+	mPUT:     http.MethodPut,
+	mTRACE:   http.MethodTrace,
+}
+
+// GetMethodName returns the standard HTTP method name for a chi internal
+// method bitmask value, or an empty string if it isn't a single known method.
+func GetMethodName(method methodTyp) string {
+	return methodNames[method]
+}
+
 // Route describes the details of a routing handler.
 // Handlers map key is an HTTP method
 type Route struct {
