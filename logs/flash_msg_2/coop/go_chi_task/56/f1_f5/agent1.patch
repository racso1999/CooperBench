+// methodTypsToStrings converts a slice of methodTyp values, in the order
+// given, to their string names for use in the Allow header.
+func methodTypsToStrings(methods []methodTyp) []string {
+	names := make([]string, 0, len(methods))
+	for _, m := range methods {
+		if s, ok := reverseMethodMap[m]; ok {
+			names = append(names, s)
+		}
+	}
+	return names
+}
