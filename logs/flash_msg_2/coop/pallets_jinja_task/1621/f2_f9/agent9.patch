+    def _get_template_name(self, file_path: str) -> t.Optional[str]:
+        """Convert an absolute file path to the template name it would
+        be loaded as, based on :attr:`searchpath`. Returns ``None`` if
+        the path is not below any search path.
+        """
+        file_path = os.path.abspath(file_path)
+
+        for searchpath in self.searchpath:
+            searchpath = os.path.abspath(searchpath)
+
+            if os.path.commonpath([file_path, searchpath]) != searchpath:
+                continue
+
+            rel_path = os.path.relpath(file_path, searchpath)
+            return rel_path.replace(os.path.sep, "/")
+
+        return None
+
+    def _on_template_changed(self, file_paths: t.List[str]) -> None:
+        """Invalidate cached templates in all tracked environments
+        whose source file is one of ``file_paths``. ``file_paths`` is a
+        list of absolute paths to files that were created, modified,
+        or deleted.
+
+        This is called automatically as search paths are monitored
+        when ``auto_reload`` is enabled, but can also be called
+        directly, for example in tests.
+        """
+        names = set()
+
+        for file_path in file_paths:
+            name = self._get_template_name(file_path)
+
+            if name is not None:
+                names.add(name)
+
+        if not names:
+            return
+
+        for environment in self._environments:
+            cache = environment.cache
+
+            if not cache:
+                continue
+
+            for cache_key in list(cache.keys()):
+                _, name = cache_key
+
+                if name in names:
+                    del cache[cache_key]
+
