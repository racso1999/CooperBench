         super().__init__("torch")
 
+    def _get_memory_usage(self) -> float:
+        """Return the current process memory usage in MB, or 0.0 if it
+        cannot be determined."""
+        try:
+            import psutil
+
+            return psutil.Process().memory_info().rss / (1024 * 1024)
+        except Exception:
+            try:
+                import resource
+
+                return (
+                    resource.getrusage(resource.RUSAGE_SELF).ru_maxrss
+                    / 1024
+                )
+            except Exception:
+                return 0.0
+
+    def _update_memory_stats(self, memory_mb: float) -> None:
+        """Update the running memory usage statistics with a new sample."""
+        self._memory_stats["total_calls"] += 1
+        self._memory_stats["memory_history"].append(memory_mb)
+        self._memory_stats["peak_memory_mb"] = max(
+            self._memory_stats["peak_memory_mb"], memory_mb
+        )
+
+        total_calls = self._memory_stats["total_calls"]
+        if total_calls % 10 == 0:
+            avg_memory = sum(self._memory_stats["memory_history"]) / len(
+                self._memory_stats["memory_history"]
+            )
+            logger.info(
+                "XGrammarLogitsProcessor memory usage after %d calls: "
+                "current=%.2fMB peak=%.2fMB avg=%.2fMB",
+                total_calls,
+                memory_mb,
+                self._memory_stats["peak_memory_mb"],
+                avg_memory,
+            )
+
+    def get_memory_stats(self) -> dict:
+        """Return the collected memory usage statistics.
+
+        Returns
+        -------
+        dict
+            A dictionary containing `peak_memory_mb`, `total_calls`,
+            `avg_memory_per_call_mb` and `memory_history`.
+
+        """
+        history = self._memory_stats["memory_history"]
+        avg_memory = sum(history) / len(history) if history else 0.0
+        return {
+            "peak_memory_mb": self._memory_stats["peak_memory_mb"],
+            "total_calls": self._memory_stats["total_calls"],
+            "avg_memory_per_call_mb": avg_memory,
+            "memory_history": list(history),
+        }
+
