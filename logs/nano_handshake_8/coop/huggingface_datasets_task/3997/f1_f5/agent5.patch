diff --git a/src/datasets/features/features.py b/src/datasets/features/features.py
index 6a0da6401..9ddd11165 100644
--- a/src/datasets/features/features.py
+++ b/src/datasets/features/features.py
@@ -1246,14 +1246,33 @@ class Features(dict):
         del self._column_requires_decoding[column_name]
 
     def update(self, iterable, **kwds):
+        def merge_value(key, value):
+            # Deep-merge when both the existing and incoming values are dictionaries
+            # (this also covers nested Features, since Features is a dict subclass),
+            # or when both are Sequences wrapping dictionaries.
+            if key in self:
+                current_value = self[key]
+                if isinstance(current_value, dict) and isinstance(value, dict):
+                    current_value.update(value)
+                    return current_value
+                if (
+                    isinstance(current_value, Sequence)
+                    and isinstance(value, Sequence)
+                    and isinstance(current_value.feature, dict)
+                    and isinstance(value.feature, dict)
+                ):
+                    current_value.feature.update(value.feature)
+                    return current_value
+            return value
+
         if hasattr(iterable, "keys"):
             for key in iterable.keys():
-                self[key] = iterable[key]
+                self[key] = merge_value(key, iterable[key])
         else:
             for key, value in iterable:
-                self[key] = value
-        for key in kwds:
-            self[key] = kwds[key]
+                self[key] = merge_value(key, value)
+        for key, value in kwds.items():
+            self[key] = merge_value(key, value)
 
     def __reduce__(self):
         return Features, (dict(self),)
