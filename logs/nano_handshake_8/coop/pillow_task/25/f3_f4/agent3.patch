index c2e850c36..0e518a14f 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,44 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        im = Image.new("RGB", (10, 10))
+        temp_file = tmp_path / "temp.png"
+
+        im.save(temp_file, dry_run=True)
+        assert not temp_file.exists()
+
+        im.save(temp_file)
+        assert temp_file.exists()
+
+    def test_save_dry_run_file_object(self) -> None:
+        im = Image.new("RGB", (10, 10))
+        fp = io.BytesIO()
+
+        im.save(fp, format="PNG", dry_run=True)
+        assert fp.tell() == 0
+
+    def test_save_dry_run_raises_error(self, tmp_path: Path) -> None:
+        im = Image.new("RGBA", (10, 10))
+        temp_file = tmp_path / "temp.jpg"
+
+        with pytest.raises(OSError):
+            im.save(temp_file, dry_run=True)
+        assert not temp_file.exists()
+
+    def test_save_dry_run_does_not_overwrite_existing_file(
+        self, tmp_path: Path
+    ) -> None:
+        im = Image.new("RGB", (10, 10))
+        temp_file = tmp_path / "temp.png"
+        im.save(temp_file)
+        original_contents = temp_file.read_bytes()
+
+        im2 = Image.new("RGB", (10, 10), "red")
+        im2.save(temp_file, dry_run=True)
+
+        assert temp_file.read_bytes() == original_contents
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
