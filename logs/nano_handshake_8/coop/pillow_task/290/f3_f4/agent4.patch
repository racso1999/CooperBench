+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using the smallest number of colors (up to
+        ``colors``) whose mean square error against the original image is
+        at or below ``error_threshold``, falling back to ``colors`` colors
+        if the threshold cannot be met.
+        """
+        if error_threshold < 0:
+            raise ValueError("error_threshold must be non-negative")
+
+        from . import ImageChops, ImagePalette, ImageStat
+
+        comparison = self if self.mode in ("RGB", "L") else self.convert("RGB")
+
+        candidate = None
+        for n in range(2, max(colors, 2) + 1):
+            candidate = self._new(self.im.quantize(n, method, kmeans))
+
+            mode = candidate.im.getpalettemode()
+            candidate.palette = ImagePalette.ImagePalette(
+                mode, candidate.im.getpalette(mode, mode)
+            )
+
+            converted = candidate.convert(comparison.mode)
+            diff = ImageChops.difference(comparison, converted)
+            stat = ImageStat.Stat(diff)
+            mse = sum(stat.sum2) / (stat.count[0] * len(stat.bands))
+
+            if mse <= error_threshold:
+                break
+
+        return candidate
+
