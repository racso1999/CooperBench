+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=10000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=256, error_threshold=10000)
+    assert len(converted.getcolors()) < 256
+
+
+def test_quantize_error_threshold_falls_back_to_colors():
+    image = hopper()
+
+    # An unreachable threshold should fall back to using "colors" colors
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_negative():
+    image = hopper()
+
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_error_threshold_ignored_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    # error_threshold has no effect when a reference palette is given
+    with_threshold = image.quantize(palette=palette, error_threshold=0)
+    without_threshold = image.quantize(palette=palette)
+    assert with_threshold.tobytes() == without_threshold.tobytes()
