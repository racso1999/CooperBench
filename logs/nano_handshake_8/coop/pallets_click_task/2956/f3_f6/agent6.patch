+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dict-based dynamic defaults now that every option has
+        been assigned a value from the command line, environment
+        variables, and configuration files.
+
+        A dynamic default is only applied to a parameter whose value is
+        still coming from :attr:`ParameterSource.DEFAULT`. Later entries
+        in a parameter's mapping take precedence over earlier ones when
+        more than one referenced option matches.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+        opt_to_name = {
+            opt: param.name for param in params for opt in (*param.opts, *param.secondary_opts)
+        }
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for dep_opt, mapping in dynamic_default.items():
+                dep_name = opt_to_name.get(dep_opt)
+
+                if dep_name is None:
+                    continue
+
+                dep_value = str(ctx.params.get(dep_name))
+
+                if dep_value in mapping:
+                    resolved = mapping[dep_value]
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved  # type: ignore[index]
+
     def invoke(self, ctx: Context) -> t.Any:
