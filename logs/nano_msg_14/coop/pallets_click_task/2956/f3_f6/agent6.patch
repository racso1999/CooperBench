+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second pass over the parsed parameters to resolve any dynamic
+        defaults (a ``dict`` mapping other option declarations to value
+        mappings) now that every option has its final value.
+
+        Only applies to parameters whose value still comes from their own
+        (static) default, i.e. no value was given on the command line, in
+        an environment variable, or a configuration file.
+
+        .. versionadded:: 8.3
+        """
+        for param in self.get_params(ctx):
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:
+                continue
+
+            value = param.resolve_dynamic_default(ctx)  # type: ignore[attr-defined]
+
+            if value is not None and param.expose_value:
+                ctx.params[param.name] = value
+
