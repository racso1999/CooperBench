+    You can pass ``with_counts=True`` to also get the number of items in
+    each group, yielding ``(grouper, list, count)`` tuples instead. This
+    avoids having to materialize the list a second time with something
+    like ``items|list|length`` just to display a group's size.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=True) %}
+          <li>{{ city }} ({{ count }})</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``with_counts`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,6 +1225,14 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
+
+    if with_counts:
+        out = []
+        for key, values in groupby(sorted(value, key=expr), expr):
+            values = list(values)
+            out.append((key, values, len(values)))
+        return out
+
     return [
         _GroupTuple(key, list(values))
         for key, values in groupby(sorted(value, key=expr), expr)
