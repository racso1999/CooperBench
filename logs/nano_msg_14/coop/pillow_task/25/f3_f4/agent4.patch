@@ -258,6 +258,36 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file)
+        assert not os.path.exists(str(temp_file) + ".bak")
+
+        # No backup should be made for a file that doesn't exist yet
+        new_file = tmp_path / "new.png"
+        im.save(new_file, backup=True)
+        assert not os.path.exists(str(new_file) + ".bak")
+
+        # A backup should be made when overwriting an existing file
+        with Image.open(temp_file) as im2:
+            im2.save(temp_file, backup=True)
+        assert os.path.exists(str(temp_file) + ".bak")
+        with Image.open(str(temp_file) + ".bak") as backup_im:
+            assert_image_equal(im, backup_im)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file)
+
+        with Image.open(temp_file) as im2:
+            im2.save(temp_file, backup=True, backup_suffix=".backup")
+        assert os.path.exists(str(temp_file) + ".backup")
+        assert not os.path.exists(str(temp_file) + ".bak")
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
