diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..06cf6ae62 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,72 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _make_multicolor_image():
+    im = Image.new("RGB", (8, 8))
+    px = im.load()
+    colors = [(255, 0, 0), (0, 255, 0), (0, 0, 255), (10, 10, 10)]
+    for y in range(8):
+        for x in range(8):
+            px[x, y] = colors[(x + y) % len(colors)]
+    return im
+
+
+def test_quantize_sort_palette_luminance():
+    image = _make_multicolor_image()
+    converted = image.quantize(colors=4, sort_palette="luminance")
+
+    palette = converted.palette.palette
+    channels = len(converted.palette.mode)
+    luminances = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, channels * 4, channels)
+    ]
+    assert luminances == sorted(luminances)
+
+    # Pixel data should still round-trip to the original colors
+    assert_image_similar(converted.convert("RGB"), image, 1)
+
+
+def test_quantize_sort_palette_rgb():
+    image = _make_multicolor_image()
+    converted = image.quantize(colors=4, sort_palette="rgb")
+
+    palette = converted.palette.palette
+    channels = len(converted.palette.mode)
+    colors = [
+        tuple(palette[i : i + channels]) for i in range(0, channels * 4, channels)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = _make_multicolor_image()
+
+    def key(color):
+        return -sum(color[:3])
+
+    converted = image.quantize(colors=4, sort_palette=key)
+
+    palette = converted.palette.palette
+    channels = len(converted.palette.mode)
+    colors = [
+        tuple(palette[i : i + channels]) for i in range(0, channels * 4, channels)
+    ]
+    assert colors == sorted(colors, key=key)
+
+
+def test_quantize_sort_palette_invalid():
+    image = _make_multicolor_image()
+    with pytest.raises(ValueError):
+        image.quantize(colors=4, sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_default_unchanged():
+    image = _make_multicolor_image()
+    without_sort = image.quantize(colors=4)
+    explicit_none = image.quantize(colors=4, sort_palette=None)
+
+    assert without_sort.palette.palette == explicit_none.palette.palette
+    assert without_sort.tobytes() == explicit_none.tobytes()
