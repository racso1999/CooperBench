+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette according to ``sort_palette``, and
+        remaps the image data to match. See :py:meth:`~PIL.Image.Image.quantize`
+        for the accepted values of ``sort_palette``.
+        """
+        if callable(sort_palette):
+            key = sort_palette
+        elif sort_palette == "luminance":
+
+            def key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            raise ValueError(
+                "sort_palette must be 'luminance', 'rgb', a callable, or None"
+            )
+
+        mode = self.palette.mode
+        channels = len(mode)
+        palette_bytes = self.palette.palette
+        colors = [
+            tuple(palette_bytes[i : i + channels])
+            for i in range(0, len(palette_bytes), channels)
+        ]
+
+        dest_map = sorted(range(len(colors)), key=lambda i: key(colors[i]))
+        return self.remap_palette(dest_map)
+
