+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+
+    # A generous error threshold should let the quantizer settle for far
+    # fewer colors than the requested maximum.
+    converted = image.quantize(256, error_threshold=1000)
+    assert len(converted.getcolors(256)) < 256
+    assert image._quantize_mse(converted) <= 1000
+
+
+def test_quantize_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    # An unreachable error threshold should fall back to the requested
+    # maximum number of colors, matching a plain quantize() call.
+    plain = image.quantize(64)
+    converted = image.quantize(64, error_threshold=0)
+    assert converted.tobytes() == plain.tobytes()
+
+
