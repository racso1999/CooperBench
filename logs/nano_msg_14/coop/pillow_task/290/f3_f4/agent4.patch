+    def _quantize_mse(self, quantized_im):
+        """
+        Returns the mean squared error between this image and the given
+        quantized version of it, averaged across bands.
+        """
+        from . import ImageChops, ImageStat
+
+        comparable = self if self.mode in ("RGB", "L") else self.convert("RGB")
+        converted = quantized_im.convert(comparable.mode)
+
+        diff = ImageChops.difference(comparable, converted)
+        rms_per_band = ImageStat.Stat(diff).rms
+        return sum(rms ** 2 for rms in rms_per_band) / len(rms_per_band)
+
+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using the smallest number of colors (up to ``colors``)
+        whose mean squared error is at or below ``error_threshold``. Falls
+        back to ``colors`` colors if the threshold cannot be met.
+        """
+        low, high = 1, colors
+        best_im = self._new(self.im.quantize(colors, method, kmeans))
+
+        while low <= high:
+            mid = (low + high) // 2
+            im = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantize_mse(im) <= error_threshold:
+                best_im = im
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        return best_im
+
