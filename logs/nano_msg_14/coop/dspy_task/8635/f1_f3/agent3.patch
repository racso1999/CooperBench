+    def _select_tip_with_weights(self):
+        """Select a tip key/value pair, optionally biased by ``self.tip_weights``.
+
+        When ``self.tip_weights`` is ``None``, this preserves the original uniform draw
+        via ``self.rng.choice()``. Otherwise, weights are normalized into a probability
+        distribution and ``self.rng.random()`` is used with a cumulative distribution to
+        select a tip deterministically for a fixed seed. Missing weight entries default
+        to 1.0, and nonpositive weights are treated as 0. If all weights are zero/invalid,
+        this falls back to a uniform draw.
+        """
+        tip_keys = list(TIPS.keys())
+
+        if self.tip_weights is None:
+            selected_key = self.rng.choice(tip_keys)
+            return selected_key, TIPS[selected_key]
+
+        weights = [max(0.0, self.tip_weights.get(key, 1.0)) for key in tip_keys]
+        total_weight = sum(weights)
+
+        if total_weight <= 0:
+            selected_key = self.rng.choice(tip_keys)
+            return selected_key, TIPS[selected_key]
+
+        probabilities = [weight / total_weight for weight in weights]
+        threshold = self.rng.random()
+        cumulative = 0.0
+        for key, probability in zip(tip_keys, probabilities):
+            cumulative += probability
+            if threshold < cumulative:
+                return key, TIPS[key]
+
+        # Guard against floating point rounding leaving `threshold` >= cumulative total.
+        return tip_keys[-1], TIPS[tip_keys[-1]]
+
