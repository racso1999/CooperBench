+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check for stream idle timeout and emit a terminal chunk if the stream has stalled.
+
+        This is intended to be called periodically by the streaming system (independent of chunk arrival)
+        so that a stalled upstream doesn't leave a consumer waiting on a chunk that will never come.
+
+        Args:
+            now_ts: The timestamp to compare against the last received chunk's timestamp. Defaults to the
+                current time if not provided.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if `idle_timeout_s` has elapsed since the last chunk
+            while the field was being streamed, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        # `is_last_chunk` may not exist yet on `StreamResponse`; set it when available so a future
+        # end-of-stream flag reflects that this chunk is timeout-terminated.
+        extra_kwargs = {"is_last_chunk": True} if "is_last_chunk" in StreamResponse.__dataclass_fields__ else {}
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **extra_kwargs)
+
+        # Reset the listener state unconditionally (regardless of `allow_reuse`) so a stalled stream never
+        # leaves the listener stuck mid-field.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
