+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, matching the given hash algorithm's length and character set.
+    """
+
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '1f3870be274f6c49b3e31a0c6728957f' == IsHash('md5')
+        assert 'd0be2dc421be4fcd0172e5afceea3970e2f3d940' == IsHash('sha1')
+        assert '3a7bd3e2360a3d29eea436fcfb7e44c735d117c42d1c1835420b6b9942dd4f1b' == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('sha256')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.hash_length = self.hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self.hash_length:
+            return False
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+        return True
+
