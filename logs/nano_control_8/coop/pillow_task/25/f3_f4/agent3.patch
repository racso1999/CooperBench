+    def test_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_dry_run_existing_file(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        contents = out.read_bytes()
+
+        im.save(out, dry_run=True)
+        assert out.read_bytes() == contents
+
+    def test_dry_run_error(self) -> None:
+        im = hopper("RGBA")
+        with pytest.raises(OSError):
+            im.save("out.jpg", format="JPEG", dry_run=True)
+
     def test_pathlib(self, tmp_path: Path) -> None:
