+@pytest.mark.parametrize("sort_palette", ("rgb", "brightness"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    unsorted = image.quantize(100)
+    sorted_im = image.quantize(100, sort_palette=sort_palette)
+
+    assert_image(sorted_im, "P", sorted_im.size)
+
+    # Sorting the palette does not change which color each pixel is mapped
+    # to, so the resulting image should look the same
+    assert_image_similar(sorted_im.convert("RGB"), unsorted.convert("RGB"), 0)
+
+    palette = sorted_im.palette.palette
+    bands = len(sorted_im.palette.mode)
+    colors = len(sorted_im.getcolors())
+    entries = [tuple(palette[i * bands : i * bands + bands]) for i in range(colors)]
+
+    if sort_palette == "rgb":
+        key = list
+    else:
+
+        def key(entry):
+            r, g, b = entry[0], entry[1], entry[2]
+            return r * 299 + g * 587 + b * 114
+
+    assert entries == sorted(entries, key=key)
