+    def _quantize_mse(self, core_im):
+        # Mean square error between this image and a quantized core image.
+        from . import ImageChops, ImageStat
+
+        quantized = self._new(core_im).convert("RGB")
+        original = self.convert("RGB")
+
+        diff = ImageChops.difference(original, quantized)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        # Find the smallest number of colors, up to ``colors``, whose
+        # quantization error stays at or below ``error_threshold``. Falls
+        # back to ``colors`` if the threshold cannot be reached.
+        low, high = 1, colors
+        max_colors_im = self.im.quantize(colors, method, kmeans)
+        if self._quantize_mse(max_colors_im) > error_threshold:
+            return max_colors_im
+
+        best = max_colors_im
+        while low < high:
+            mid = (low + high) // 2
+            candidate = self.im.quantize(mid, method, kmeans)
+            if self._quantize_mse(candidate) <= error_threshold:
+                best = candidate
+                high = mid
+            else:
+                low = mid + 1
+
+        return best
+
