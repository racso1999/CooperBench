+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or base64-encoded image bytes.
+
+    Detects whether ``image`` is already base64-encoded. If it is, the bytes
+    are returned unchanged; otherwise they are base64-encoded. Also returns
+    the raw (non-base64) bytes suitable for MIME type guessing.
+
+    Args:
+        image (bytes): Raw or base64-encoded image bytes.
+
+    Returns:
+        tuple[bytes, bytes]: A tuple of (encoded_image, decoded_for_guessing).
+    """
+    try:
+        decoded_for_guessing = base64.b64decode(image, validate=True)
+        encoded_image = image
+    except Exception:
+        decoded_for_guessing = image
+        encoded_image = base64.b64encode(image)
+
+    return encoded_image, decoded_for_guessing
+
+
 class ImageBlock(BaseModel):
