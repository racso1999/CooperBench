+# Registry of filters that are made available to every prompt template,
+# without having to pass them explicitly. Filters defined directly on a
+# template's environment (e.g. the built-in `name`, `description`, etc.
+# filters) take precedence over filters registered here.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter to make it globally available in prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
