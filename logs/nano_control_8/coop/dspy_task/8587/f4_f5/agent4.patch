+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If the field's stream has started but not
+        ended, and no chunk has arrived within `idle_timeout_s`, this emits a final `StreamResponse` with an empty
+        `chunk` to signal termination and resets the listener's state so it can process (or be reused for) the
+        next stream.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the listener's state unconditionally so it isn't left in a started state, regardless of
+        # `allow_reuse`.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
 
