+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        mapping of other option names to value lookups (see
+        :class:`Option`). This runs after every parameter has consumed
+        its command line, environment variable, and default map value,
+        so dynamic defaults can depend on the final values of other
+        options regardless of declaration order.
+        """
+        params = self.get_params(ctx)
+        option_by_opt: dict[str, Parameter] = {}
+
+        for param in params:
+            for opt in param.opts:
+                option_by_opt[opt] = param
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = option_by_opt.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
