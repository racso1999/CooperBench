+def _batch_values(
+    values: cabc.Sequence[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Yield ``values`` in chunks of up to ``batch_size`` items each,
+    including a final, possibly smaller, chunk for any remainder.
+    """
+    for start in range(0, len(values), batch_size):
+        yield tuple(values[start : start + batch_size])
+
