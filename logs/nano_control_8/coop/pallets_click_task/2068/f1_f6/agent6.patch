+_PRIORITY_NICE_VALUES = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -10,
+    "high": -20,
+}
+
+# ctypes.windll only exists on Windows, referenced lazily in _set_windows_priority.
+_WIN_PRIORITY_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+
+def _set_process_priority(pid: int, process_priority: str) -> None:
+    """Best-effort attempt to set the priority of a process. Any
+    failure is silently ignored, as priority control is a courtesy,
+    not a requirement for the editor to function.
+    """
+    try:
+        if WIN:
+            import ctypes
+
+            priority_class = _WIN_PRIORITY_CLASSES[process_priority]
+            handle = ctypes.windll.kernel32.OpenProcess(  # type: ignore[attr-defined]
+                0x0200 | 0x0400, False, pid  # PROCESS_SUSPEND_RESUME | PROCESS_QUERY_INFORMATION
+            )
+            if handle:
+                try:
+                    ctypes.windll.kernel32.SetPriorityClass(  # type: ignore[attr-defined]
+                        handle, priority_class
+                    )
+                finally:
+                    ctypes.windll.kernel32.CloseHandle(handle)  # type: ignore[attr-defined]
+        else:
+            os.setpriority(os.PRIO_PROCESS, pid, _PRIORITY_NICE_VALUES[process_priority])
+    except (OSError, AttributeError, KeyError, ValueError):
+        pass
+
