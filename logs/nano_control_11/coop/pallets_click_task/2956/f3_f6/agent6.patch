+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose ``default`` is a mapping of other
+        option declarations to value mappings (a "dynamic default").
+
+        This is run after all parameters have been processed from the
+        command line, environment variables, and default map, so the
+        dynamic default can be chosen based on the final values of the
+        options it depends on. It only applies to options whose value
+        source is still :attr:`ParameterSource.DEFAULT`, i.e. no value
+        was explicitly provided for them.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            dynamic_default: types.DynamicDefaultType = param.default
+            resolved = None
+
+            for opt_name, mapping in dynamic_default.items():
+                source = next(
+                    (
+                        p
+                        for p in params
+                        if opt_name in p.opts or opt_name in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source is None:
+                    continue
+
+                key = str(ctx.params.get(source.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore[index]
+
