+    def _quantize_mean_square_error(self, quantized):
+        from . import ImageChops
+
+        diff = ImageChops.difference(self.convert("RGB"), quantized.convert("RGB"))
+        histogram = diff.histogram()
+
+        channels = len(histogram) // 256
+        total_error = 0
+        total_count = 0
+        for channel in range(channels):
+            offset = channel * 256
+            for value in range(256):
+                count = histogram[offset + value]
+                total_error += count * value * value
+                total_count += count
+        return total_error / total_count if total_count else 0
+
+    def _quantize_to_error_threshold(
+        self, colors, method, kmeans, dither, error_threshold
+    ):
+        # Quantizing with the maximum number of colors establishes whether
+        # the error threshold is achievable at all within the given limit.
+        max_colors_im = self.quantize(colors, method, kmeans, dither=dither)
+        if self._quantize_mean_square_error(max_colors_im) > error_threshold:
+            return max_colors_im
+
+        # Binary search for the fewest colors that still satisfy the
+        # threshold, assuming error decreases as the color count increases.
+        lo, hi = 2, colors
+        while lo < hi:
+            mid = (lo + hi) // 2
+            candidate = self.quantize(mid, method, kmeans, dither=dither)
+            if self._quantize_mean_square_error(candidate) <= error_threshold:
+                hi = mid
+            else:
+                lo = mid + 1
+
+        if lo == colors:
+            return max_colors_im
+        return self.quantize(lo, method, kmeans, dither=dither)
+
