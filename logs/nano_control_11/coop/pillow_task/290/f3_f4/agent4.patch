+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should be satisfied using fewer than 256 colors,
+    # and the resulting image should actually meet that threshold.
+    converted = image.quantize(colors=256, error_threshold=50)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+    assert image._quantize_mean_square_error(converted) <= 50
+
+    # An unreachable threshold should fall back to the requested color limit.
+    converted = image.quantize(colors=8, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 8
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
