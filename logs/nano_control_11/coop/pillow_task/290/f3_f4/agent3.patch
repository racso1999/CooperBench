diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..8cd801551 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,49 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image.quantize(32).convert("RGB"), 0)
+
+    def brightness(color):
+        r, g, b = color[:3]
+        return r * 299 + g * 587 + b * 114
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    brightnesses = [brightness(color) for color in colors]
+    assert brightnesses == sorted(brightnesses)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+
+    def reverse_green(color):
+        return -color[1]
+
+    converted = image.quantize(32, sort_palette=reverse_green)
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    greens = [palette[i + 1] for i in range(0, len(palette), 3)]
+    assert greens == sorted(greens, reverse=True)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="not-a-real-method")
