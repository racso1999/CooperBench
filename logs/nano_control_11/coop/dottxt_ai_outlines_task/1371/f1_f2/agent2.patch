+# Registry of custom filters that should be made available to every
+# prompt template, without having to pass them explicitly each time.
+GLOBAL_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter globally so it is available to all prompt templates.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The function that implements the filter.
+
+    """
+    GLOBAL_FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove from the global registry.
+
+    """
+    GLOBAL_FILTER_REGISTRY.pop(name, None)
+
 
