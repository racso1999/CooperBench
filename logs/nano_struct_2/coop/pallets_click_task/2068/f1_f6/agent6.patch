+    def _get_windows_creationflags(self) -> int:
+        """Return extra ``subprocess.Popen`` creation flags to apply the
+        configured ``process_priority`` on Windows. Returns ``0`` if no
+        priority is configured or the priority class isn't available.
+        """
+        import subprocess
+
+        class_name = _WIN_PRIORITY_CLASSES.get(self.process_priority or "")
+
+        if class_name is None:
+            return 0
+
+        return t.cast(int, getattr(subprocess, class_name, 0))
+
+    def _apply_unix_priority(self, pid: int) -> None:
+        """Best-effort attempt to renice the editor process on Unix-like
+        systems. Any failure (e.g. lack of permission to raise priority)
+        is silently ignored so editing still proceeds.
+        """
+        niceness = _NICE_VALUES.get(self.process_priority or "")
+
+        if niceness is None:
+            return
+
+        try:
+            os.setpriority(os.PRIO_PROCESS, pid, niceness)
+        except (AttributeError, OSError, PermissionError):
+            pass
