+def _batched(
+    value: cabc.Sequence[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Yield successive tuples of up to ``batch_size`` items from ``value``."""
+    it = iter(value)
+
+    while batch := tuple(islice(it, batch_size)):
+        yield batch
