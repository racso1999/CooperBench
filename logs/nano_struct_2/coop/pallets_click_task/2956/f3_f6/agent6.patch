+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dictionary-based dynamic defaults now that every
+        parameter has been parsed.
+
+        An :class:`Option` may specify its default as a mapping of
+        ``{source_opt: {source_value: default}}``. Such a default can
+        only be evaluated once the other options it depends on have
+        been parsed, so this runs as a second pass after
+        :meth:`parse_args` has processed every parameter.
+        """
+        for param in self.params:
+            if (
+                not isinstance(param, Option)
+                or param._dynamic_default is None
+                or ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT  # type: ignore[arg-type]
+            ):
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param._dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in self.params
+                        if source_opt in p.opts or source_opt in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore[arg-type]
+
