+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and, if so, force-terminate it.
+
+        This should be called periodically by the streaming system. If the configured idle timeout has elapsed
+        since the last received chunk, and the stream has started but not yet ended, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination, then resets the listener's state.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout was hit, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        if self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        on_chunk = getattr(self, "on_chunk", None)
+        if callable(on_chunk):
+            on_chunk(response)
+
+        # Always reset the listener state after a timeout, regardless of `allow_reuse`, so it isn't left
+        # stuck in a started state.
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self._last_chunk_ts = None
+
+        return response
+
