+HashTypes = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, matching the length and characters expected for
+    the given hash algorithm.
+    """
+
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5eb63bbbe01eeed093cb22bb8f5acdc3' == IsHash('md5')
+        assert '2aae6c35c94fcfb415dbe95f408b9ce91ee846ed' == IsHash('sha1')
+        assert '2aae6c35c94fcfb415dbe95f408b9ce91ee846ed' != IsHash('md5')
+        ```
+        """
+        algorithm_lower = algorithm.lower()
+        if algorithm_lower not in self.hash_lengths:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        self.algorithm = algorithm
+        self.length = self.hash_lengths[algorithm_lower]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self.length:
+            return False
+        return re.fullmatch('[0-9a-fA-F]+', other) is not None
+
