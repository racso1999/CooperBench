+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or base64-encoded image bytes.
+
+    Detects whether the given bytes are already base64-encoded (rather than
+    blindly re-encoding), so callers don't need to duplicate that check.
+
+    Returns:
+        A tuple of ``(encoded_image, decoded_for_guessing)`` where
+        ``encoded_image`` is the base64-encoded image bytes and
+        ``decoded_for_guessing`` is the raw bytes suitable for MIME type
+        guessing (e.g. via the ``filetype`` library).
+    """
+    try:
+        decoded = base64.b64decode(image, validate=True)
+        if base64.b64encode(decoded) == image:
+            return image, decoded
+    except Exception:
+        pass
+
+    return base64.b64encode(image), image
+
