+# Global registry of custom filters that are made available to every
+# prompt template without having to be passed explicitly.
+_FILTERS_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to be made available to all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _FILTERS_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a custom filter from the global filter registry.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS_REGISTRY.pop(name, None)
+
 
