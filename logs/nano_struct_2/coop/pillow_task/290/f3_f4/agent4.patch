+    def _quantize_mean_square_error(self, quantized_im):
+        """
+        Returns the mean square error between this image and a quantized
+        version of it, used by :py:meth:`~PIL.Image.Image.quantize` when an
+        ``error_threshold`` is given.
+        """
+        from . import ImageChops, ImageStat
+
+        comparison = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparison)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible, up to
+        ``colors``, so that the mean square error against the original
+        image is at or below ``error_threshold``. If ``colors`` isn't
+        enough to reach the threshold, it is used as-is.
+        """
+
+        def quantize_with(n):
+            im = self._new(self.im.quantize(n, method, kmeans))
+            return im, self._quantize_mean_square_error(im)
+
+        best_im, error = quantize_with(colors)
+        if error > error_threshold:
+            return best_im
+
+        lo, hi = 2, colors
+        while lo < hi:
+            mid = (lo + hi) // 2
+            im, error = quantize_with(mid)
+            if error <= error_threshold:
+                best_im = im
+                hi = mid
+            else:
+                lo = mid + 1
+
+        return best_im
+
