     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be reachable with fewer than the requested
+    # number of colors.
+    loose = image.quantize(256, error_threshold=1000)
+    assert len(loose.getcolors(256)) < 256
+    assert image._quantize_mean_square_error(loose) <= 1000
+
+    # A threshold of 0 can't be met within the colors limit, so the
+    # maximum number of colors is used instead.
+    strict = image.quantize(256, error_threshold=0)
+    assert len(strict.getcolors(256)) == 256
+
+
+def test_quantize_error_threshold_lower_than_unconstrained():
+    image = hopper()
+
+    unconstrained = image.quantize(256)
+    constrained = image.quantize(256, error_threshold=1000)
+
+    assert len(constrained.getcolors(256)) <= len(unconstrained.getcolors(256))
