+def test_sort_palette():
+    image = hopper()
+    unsorted = image.quantize(100)
+
+    def brightness(color):
+        return color[0] * 0.299 + color[1] * 0.587 + color[2] * 0.114
+
+    keys = {"rgb": lambda color: color, "brightness": brightness}
+    for sort_palette, key in keys.items():
+        converted = image.quantize(100, sort_palette=sort_palette)
+        assert_image(converted, "P", converted.size)
+        assert_image_similar(converted.convert("RGB"), image, 20)
+        assert len(converted.getcolors()) == 100
+
+        # The appearance of the image should be unaffected by sorting
+        assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+        used_indexes = sorted(
+            i for i, count in enumerate(converted.histogram()) if count
+        )
+        palette = converted.getpalette()
+        rgb_values = [tuple(palette[i * 3 : i * 3 + 3]) for i in used_indexes]
+        assert [key(color) for color in rgb_values] == sorted(
+            key(color) for color in rgb_values
+        )
+
+
+def test_sort_palette_invalid_value():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not_a_real_method")
