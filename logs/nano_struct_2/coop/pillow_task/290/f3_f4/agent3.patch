+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping the image data so that its
+        appearance is unchanged.
+
+        :param sort_palette: ``"brightness"`` to sort colors by perceived
+           brightness, or ``"rgb"`` to sort colors by RGB value.
+        :returns: A new image
+        """
+        if sort_palette == "brightness":
+
+            def key(color):
+                return color[0] * 0.299 + color[1] * 0.587 + color[2] * 0.114
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            raise ValueError("sort_palette must be 'brightness', 'rgb' or None")
+
+        source_palette = self.im.getpalette("RGB")[:768]
+        used_indexes = [i for i, count in enumerate(self.histogram()) if count]
+        used_colors = [tuple(source_palette[i * 3 : i * 3 + 3]) for i in used_indexes]
+
+        sort_order = sorted(
+            range(len(used_indexes)), key=lambda i: key(used_colors[i])
+        )
+
+        dest_map = list(range(256))
+        for new_index, old_index in zip(used_indexes, sort_order):
+            dest_map[new_index] = used_indexes[old_index]
+
+        return self.remap_palette(dest_map)
+
