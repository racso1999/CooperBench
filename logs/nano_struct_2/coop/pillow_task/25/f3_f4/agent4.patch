+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        # No backup is created unless requested
+        im.save(out)
+        assert not (tmp_path / "temp.png.bak").exists()
+
+        # backup=True copies the existing file before overwriting it
+        red = Image.new("RGB", im.size, "#f00")
+        red.save(out, backup=True)
+        assert (tmp_path / "temp.png.bak").exists()
+        with Image.open(tmp_path / "temp.png.bak") as backup_im:
+            assert_image_equal(im, backup_im)
+        with Image.open(out) as reloaded:
+            assert_image_equal(red, reloaded)
+
+        # A custom backup_suffix changes the backup filename
+        blue = Image.new("RGB", im.size, "#00f")
+        blue.save(out, backup=True, backup_suffix=".backup")
+        assert (tmp_path / "temp.png.backup").exists()
+        with Image.open(tmp_path / "temp.png.backup") as backup_im:
+            assert_image_equal(red, backup_im)
+
+        # No backup is made when the file does not already exist
+        new_out = tmp_path / "new.png"
+        im.save(new_out, backup=True)
+        assert not (tmp_path / "new.png.bak").exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
