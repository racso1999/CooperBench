+#: Mapping of the public ``process_priority`` values to Unix ``nice``
+#: increments (higher ``nice`` values mean lower scheduling priority).
+_NICE_VALUES = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+#: Mapping of the public ``process_priority`` values to the names of the
+#: Windows priority class constants exposed by the :mod:`subprocess` module.
+_WIN32_PRIORITY_CLASSES = {
+    "low": "IDLE_PRIORITY_CLASS",
+    "below_normal": "BELOW_NORMAL_PRIORITY_CLASS",
+    "normal": "NORMAL_PRIORITY_CLASS",
+    "above_normal": "ABOVE_NORMAL_PRIORITY_CLASS",
+    "high": "HIGH_PRIORITY_CLASS",
+}
+
+
+def _nice_preexec_fn(nice_value: int) -> t.Callable[[], None]:
+    def _set_priority() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            # Not permitted to raise/lower priority, or not supported on
+            # this platform. Fall back to the default priority.
+            pass
+
+    return _set_priority
+
