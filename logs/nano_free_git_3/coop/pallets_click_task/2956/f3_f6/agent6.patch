+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dynamic (dictionary based) default by looking at the
+        current values of the option(s) it depends on.
+
+        :param ctx: Current context, used to look up the resolved values
+            of the options referenced by the dynamic default mapping.
+
+        .. versionadded:: 8.2
+        """
+        if not self._dynamic_default:
+            return None
+
+        result = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_param = None
+
+            for param in ctx.command.params:
+                if opt_name in param.opts or opt_name in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+            key = str(source_value)
+
+            if key in mapping:
+                result = mapping[key]
+
+        return result
+
