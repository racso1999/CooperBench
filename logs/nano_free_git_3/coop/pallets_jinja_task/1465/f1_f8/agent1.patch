+        attribute,
+        postprocess=ignore_case if not case_sensitive else None,
+        default=default,
+    )
+    out_expr = (
+        make_attrgetter(environment, attribute, default=default)
+        if not case_sensitive
+        else expr
+    )
+
+    groups = []
+
+    for _, values in groupby(sorted(value, key=expr), expr):
+        values_list = list(values)
+        key = out_expr(values_list[0])
+
+        if with_counts:
+            groups.append(_GroupTupleWithCount(key, values_list, len(values_list)))
+        else:
+            groups.append(_GroupTuple(key, values_list))
+
+    return groups
 
 
