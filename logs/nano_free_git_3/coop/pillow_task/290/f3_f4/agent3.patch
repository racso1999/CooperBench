+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=Image.SORT_BRIGHTNESS)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+    assert len(converted.getcolors()) == 100
+
+    mode = converted.im.getpalettemode()
+    palette = converted.im.getpalette(mode, mode)
+    channels = len(mode)
+    colors = [palette[i : i + channels] for i in range(0, len(palette), channels)]
+    brightness = [sum(color) / len(color) for color in colors]
+    assert brightness == sorted(brightness)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=Image.SORT_RGB)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+    assert len(converted.getcolors()) == 100
+
+    mode = converted.im.getpalettemode()
+    palette = converted.im.getpalette(mode, mode)
+    channels = len(mode)
+    colors = [
+        tuple(palette[i : i + channels]) for i in range(0, len(palette), channels)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_none():
+    image = hopper()
+    default = image.quantize(100, Image.FASTOCTREE)
+    unsorted = image.quantize(100, Image.FASTOCTREE, sort_palette=Image.SORT_NONE)
+    assert default.tobytes() == unsorted.tobytes()
+    assert default.palette.palette == unsorted.palette.palette
+
+
+def test_quantize_sort_palette_invalid_method():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, Image.FASTOCTREE, sort_palette=99)
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be satisfied with very few colors.
+    low_quality = image.quantize(colors=256, error_threshold=1000)
+    assert_image(low_quality, "P", low_quality.size)
+    assert len(low_quality.getcolors()) <= 256
+
+    # A threshold of 0 can't be satisfied below the colors limit, so the
+    # colors limit should be used instead.
+    capped = image.quantize(colors=4, error_threshold=0)
+    assert_image(capped, "P", capped.size)
+    assert len(capped.getcolors()) <= 4
+
+    # Without a threshold, behaviour should match plain quantize().
+    plain = image.quantize(colors=64)
+    unthresholded = image.quantize(colors=64, error_threshold=None)
+    assert plain.tobytes() == unthresholded.tobytes()
+
