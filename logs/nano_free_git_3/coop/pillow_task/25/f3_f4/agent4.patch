+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        backup = tmp_path / "temp.png.bak"
+        assert not backup.exists()
+
+        im2 = hopper("L")
+        im2.save(out, backup=True)
+        assert backup.exists()
+        with Image.open(backup) as reloaded:
+            assert_image_equal(im, reloaded)
+        with Image.open(out) as reloaded:
+            assert_image_equal(im2.convert("RGB"), reloaded.convert("RGB"))
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        backup = tmp_path / "temp.png.backup"
+        im2 = hopper("L")
+        im2.save(out, backup=True, backup_suffix=".backup")
+        assert backup.exists()
+        with Image.open(backup) as reloaded:
+            assert_image_equal(im, reloaded)
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        backup = tmp_path / "temp.png.bak"
+
+        im = hopper()
+        im.save(out, backup=True)
+        assert out.exists()
+        assert not backup.exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
