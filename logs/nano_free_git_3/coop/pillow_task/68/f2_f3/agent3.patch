+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        assert base_im.getexif()[0x0112] == 8
+
+        # A callback returning a single method overrides the default mapping
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=lambda orientation: Image.Transpose.ROTATE_180
+            )
+            assert 0x0112 not in transposed_im.getexif()
+            assert_image_equal(transposed_im, base_im.rotate(180))
+
+        # A callback returning a sequence of methods applies them in order
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im,
+                transform_callback=lambda orientation: (
+                    Image.Transpose.FLIP_LEFT_RIGHT,
+                    Image.Transpose.ROTATE_90,
+                ),
+            )
+            expected = base_im.transpose(Image.Transpose.FLIP_LEFT_RIGHT).transpose(
+                Image.Transpose.ROTATE_90
+            )
+            assert 0x0112 not in transposed_im.getexif()
+            assert_image_equal(transposed_im, expected)
+
+        # A callback returning None means no transposition is applied,
+        # matching the behavior when there is no orientation to correct
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=lambda orientation: None
+            )
+            assert_image_equal(transposed_im, base_im)
+
+        # The callback receives the orientation value from the EXIF data
+        received_orientations = []
+
+        def record_orientation(
+            orientation: int,
+        ) -> Image.Transpose | None:
+            received_orientations.append(orientation)
+            return None
+
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            ImageOps.exif_transpose(im, transform_callback=record_orientation)
+        assert received_orientations == [8]
+
+    # in_place also respects the callback
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        expected = im.rotate(270, expand=True)
+
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_270,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
+def test_exif_transpose_strip_metadata() -> None:
+    with Image.open("Tests/images/hopper_orientation_2.jpg") as im:
+        assert "exif" in im.info
+        assert len(im.getexif()) >= 1
+
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert "exif" not in transposed_im.info
+        assert len(transposed_im.getexif()) == 0
+
+    # No orientation to correct, but metadata should still be stripped
+    with Image.open("Tests/images/hopper.jpg") as im:
+        assert 0x0112 not in im.getexif()
+        im.info["comment"] = b"test comment"
+        transposed_im = ImageOps.exif_transpose(im, strip_metadata=True)
+        assert "comment" not in transposed_im.info
+
+    # in_place, with an orientation to correct
+    with Image.open("Tests/images/hopper_orientation_2.jpg") as im:
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert "exif" not in im.info
+        assert len(im.getexif()) == 0
+
+    # in_place, with no orientation to correct
+    with Image.open("Tests/images/hopper.jpg") as im:
+        assert 0x0112 not in im.getexif()
+        im.info["comment"] = b"test comment"
+        ImageOps.exif_transpose(im, in_place=True, strip_metadata=True)
+        assert "comment" not in im.info
+
+
