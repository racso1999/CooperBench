+#: Global registry of custom Jinja2 filters made available to every prompt
+#: template. Populate it with `register_filter` and remove entries with
+#: `unregister_filter`.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally available to all prompt templates.
+
+    Once registered, the filter can be used in any template, current or future,
+    with the `{{ value | name }}` syntax, without having to pass it explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter is exposed in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter previously registered with `register_filter`.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+
 
