+def create_jinja_env(
+    loader: Optional[jinja2.BaseLoader],
+    filters: Optional[Dict[str, Callable]] = None,
+) -> jinja2.Environment:
+    """Create a Jinja2 environment with the default and custom filters.
+
+    Parameters
+    ----------
+    loader
+        The Jinja2 loader to use for the environment, if any.
+    filters
+        A dictionary of custom Jinja2 filters to register with the
+        environment, mapping filter names to callables.
+
+    Returns
+    -------
+    A Jinja2 `Environment` with the built-in, custom, and globally registered
+    filters available. Filters passed explicitly via `filters` take precedence
+    over filters registered globally with `register_filter`.
+
+    """
+    env = jinja2.Environment(
+        loader=loader,
+        trim_blocks=True,
+        lstrip_blocks=True,
+        keep_trailing_newline=True,
+        undefined=jinja2.StrictUndefined,
+    )
+    local_filters = {
+        "name": get_fn_name,
+        "description": get_fn_description,
+        "source": get_fn_source,
+        "signature": get_fn_signature,
+        "schema": get_schema,
+        "args": get_fn_args,
+    }
+    if filters is not None:
+        local_filters.update(filters)
+
+    # Stored so `Prompt.__call__` can refresh the environment's filters with
+    # the latest globally registered filters on every render, while keeping
+    # these local filters (built-ins and any explicitly passed in) taking
+    # precedence over same-named global ones.
+    env._outlines_local_filters = local_filters
+    env.filters = {**_FILTER_REGISTRY, **local_filters}
+
+    return env
 
 
