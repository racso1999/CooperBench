+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally checking it against a specific
+    country's phone number format.
+    """
+
+    # (international pattern, national pattern) for countries with dedicated rules
+    _country_patterns = {
+        'US': (re.compile(r'\+1\d{10}'), re.compile(r'\d{10}')),
+        'GB': (re.compile(r'\+44\d{10}'), re.compile(r'0\d{10}')),
+    }
+    _generic_international_pattern = re.compile(r'\+\d{7,15}')
+    _generic_pattern = re.compile(r'\+?\d{7,15}')
+    _delimiters = re.compile(r'[\s().-]')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: The ISO 3166-1 alpha-2 country code to validate the phone number against, e.g. `'US'` or
+                `'GB'`. If omitted, generic international/national phone number validation is used. Countries
+                without dedicated rules fall back to generic international format validation.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber()
+        assert '555-123-4567' == IsPhoneNumber()
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert 5551234567 != IsPhoneNumber()
+        ```
+        """
+        self.country = country
+        super().__init__(plain_repr('*') if country is None else country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = self._delimiters.sub('', other)
+        if not normalized:
+            return False
+
+        # only a single, leading `+` is allowed
+        if normalized.count('+') > 1 or ('+' in normalized and not normalized.startswith('+')):
+            return False
+
+        if self.country is None:
+            return self._generic_pattern.fullmatch(normalized) is not None
+
+        patterns = self._country_patterns.get(self.country.upper())
+        if patterns is not None:
+            international_pattern, national_pattern = patterns
+            return (
+                international_pattern.fullmatch(normalized) is not None
+                or national_pattern.fullmatch(normalized) is not None
+            )
+        else:
+            return self._generic_international_pattern.fullmatch(normalized) is not None
