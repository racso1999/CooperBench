index c2e850c36..4f03f7395 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,34 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_existing_file_not_modified(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        hopper().save(temp_file)
+        with open(temp_file, "rb") as f:
+            original_contents = f.read()
+
+        im = hopper().convert("L")
+        im.save(temp_file, dry_run=True)
+
+        with open(temp_file, "rb") as f:
+            assert f.read() == original_contents
+
+    def test_dry_run_raises_for_invalid_mode(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.bmp"
+
+        im = Image.new("LA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
