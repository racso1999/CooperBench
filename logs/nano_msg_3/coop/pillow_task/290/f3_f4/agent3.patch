+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping pixel data so that the
+        image is unchanged visually. Used by :py:meth:`~PIL.Image.Image.quantize`.
+
+        :param sort_palette: ``"brightness"``, ``"rgb"``, or a callable
+           taking a color tuple and returning a sort key.
+        :returns: A new image
+        """
+        palette = self.palette
+        mode = palette.mode
+        bands = len(mode)
+        colors = [
+            tuple(palette.palette[i : i + bands])
+            for i in range(0, len(palette.palette), bands)
+        ]
+        if not colors:
+            colors = [(0,) * bands]
+        while len(colors) < 256:
+            colors.append(colors[-1])
+
+        if sort_palette == "brightness":
+
+            def sort_key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color
+
+        elif callable(sort_palette):
+            sort_key = sort_palette
+        else:
+            raise ValueError(
+                "sort_palette must be 'brightness', 'rgb', a callable, or None"
+            )
+
+        order = sorted(range(256), key=lambda i: sort_key(colors[i]))
+        lut = [0] * 256
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+
+        im = self.point(lut)
+        im.putpalette(b"".join(bytes(colors[old_index]) for old_index in order), mode)
         return im
 
