+
+
+def _palette_colors(im):
+    palette = im.palette
+    bands = len(palette.mode)
+    colors = im.getcolors()
+    n = max(index for _, index in colors) + 1
+    return [
+        tuple(palette.palette[i : i + bands]) for i in range(0, n * bands, bands)
+    ]
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    def brightness(color):
+        r, g, b = color[:3]
+        return r * 299 + g * 587 + b * 114
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors, key=brightness)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(
+        100, Image.FASTOCTREE, sort_palette=lambda color: -sum(color[:3])
+    )
+    assert_image(converted, "P", converted.size)
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors, key=lambda color: -sum(color[:3]))
+
+
+def test_quantize_sort_palette_unchanged_appearance():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE)
+    converted_sorted = image.quantize(100, Image.FASTOCTREE, sort_palette="brightness")
+
+    assert_image_equal(converted.convert("RGB"), converted_sorted.convert("RGB"))
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, Image.FASTOCTREE, sort_palette="invalid")
