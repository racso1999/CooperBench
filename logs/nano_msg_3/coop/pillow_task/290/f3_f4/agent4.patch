     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+    error = image._quantization_error(converted)
+    assert error <= 1000 or len(converted.getcolors()) == 256
+
+
+def test_error_threshold_uses_max_colors_when_unreachable():
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 8
+
+
+def test_error_threshold_disabled_by_default():
+    image = hopper()
+    without_threshold = image.quantize(colors=100, method=Image.FASTOCTREE)
+    with_zero_threshold = image.quantize(
+        colors=100, method=Image.FASTOCTREE, error_threshold=0
+    )
+    assert without_threshold.tobytes() == with_zero_threshold.tobytes()
+
+
+def test_error_threshold_ignored_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert converted.palette.palette == palette.palette.palette
