+    def _quantization_error(self, quantized_im):
+        """
+        Calculates the mean square error between this image and a
+        quantized version of it, comparing in RGB space.
+        """
+        from . import ImageChops, ImageStat
+
+        rgb_original = self.convert("RGB")
+        rgb_quantized = quantized_im.convert("RGB")
+        diff = ImageChops.difference(rgb_original, rgb_quantized)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using as few colors as possible, up to ``colors``, so
+        that the mean square error against the original image is at or
+        below ``error_threshold``. Falls back to ``colors`` colors if the
+        threshold cannot be reached.
+        """
+        low, high = 2, colors
+        best_im = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantization_error(candidate) <= error_threshold:
+                best_im = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+        if best_im is None:
+            best_im = self._new(self.im.quantize(colors, method, kmeans))
+        return best_im
+
