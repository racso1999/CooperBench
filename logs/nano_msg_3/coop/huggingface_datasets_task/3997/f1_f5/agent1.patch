+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the :class:`Features` object
+    in sync with the main dictionary.
+
+    Used on all the dict-mutating methods of :class:`Features` (`__setitem__`, `__delitem__`, `update`, `pop`,
+    `popitem`, `clear`, `setdefault`, ...) so that `_column_requires_decoding` never goes stale, without the
+    overhead of subclassing `UserDict`.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        self: "Features" = args[0]
+        out = func(*args, **kwargs)
+        self._column_requires_decoding: Dict[str, bool] = {
+            col: require_decoding(feature) for col, feature in self.items()
+        }
+        return out
+
+    wrapper._decorator_name_ = "_keep_dicts_synced"
+    return wrapper
+
+
