+def _validate_dynamic_default(value: dict[t.Any, t.Any]) -> None:
+    """Validate the mapping passed as a dynamic ``default`` for an
+    :class:`Option`. Keys must be option declaration strings (e.g.
+    ``"--protocol"``) and values must be mappings of stringified source
+    values to the default to use.
+    """
+    for key, mapping in value.items():
+        if not isinstance(key, str):
+            raise TypeError("Dynamic default keys must be strings")
+
+        if not isinstance(mapping, dict):
+            raise TypeError("Dynamic default values must be dictionaries")
+
