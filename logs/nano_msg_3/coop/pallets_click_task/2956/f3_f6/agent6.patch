+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        dynamic mapping (see :class:`Option`). This runs after every
+        parameter has consumed its value from the command line,
+        environment variables, and config/default maps, so the current
+        values of the referenced source options are final.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or param._dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for decl, mapping in param._dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if isinstance(p, Option)
+                        and decl in (*p.opts, *p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+
+                if source_value is None:
+                    continue
+
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
