@@ -11,6 +11,40 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+#: Registry of custom filters that are made available to every prompt
+#: template, without having to be passed explicitly.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter to be globally available in prompt templates.
+
+    Once registered, the filter can be used in any template rendered
+    afterwards with the `{{ value | name }}` syntax, without having to be
+    passed to that template explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The callable implementing the filter.
+
+    """
+    _FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+
 
