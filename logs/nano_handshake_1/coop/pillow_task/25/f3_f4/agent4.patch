@@ -258,6 +258,36 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.bak"
+
+        hopper().save(temp_file)
+        with open(temp_file, "rb") as f:
+            original_data = f.read()
+
+        with Image.open(temp_file) as im:
+            im.rotate(90).save(temp_file, backup=True)
+
+        assert backup_file.exists()
+        with open(backup_file, "rb") as f:
+            assert f.read() == original_data
+
+        # The backup should not be created if the target file does not exist
+        new_file = tmp_path / "new.png"
+        hopper().save(new_file, backup=True)
+        assert not (tmp_path / "new.png.bak").exists()
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.backup"
+
+        hopper().save(temp_file)
+        with Image.open(temp_file) as im:
+            im.rotate(90).save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert backup_file.exists()
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
