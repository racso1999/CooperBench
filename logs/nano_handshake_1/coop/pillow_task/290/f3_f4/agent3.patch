--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,55 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.im.getpalette("RGB", "RGB")
+    num_colors = len(converted.getcolors())
+    luminances = [
+        0.299 * palette[i * 3]
+        + 0.587 * palette[i * 3 + 1]
+        + 0.114 * palette[i * 3 + 2]
+        for i in range(num_colors)
+    ]
+    assert luminances == sorted(luminances)
+
+    # Sorting the palette should not change the visible image
+    unsorted = image.quantize(32)
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.im.getpalette("RGB", "RGB")
+    num_colors = len(converted.getcolors())
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in range(num_colors)]
+    assert colors == sorted(colors)
+
+    unsorted = image.quantize(32)
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+
+def test_sort_palette_with_reference_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette_im:
+        palette_im = palette_im.convert("P")
+
+    converted = image.quantize(palette=palette_im, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    unsorted = image.quantize(palette=palette_im)
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="not-a-real-method")
