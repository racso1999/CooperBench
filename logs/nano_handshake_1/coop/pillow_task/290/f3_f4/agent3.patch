+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette according to ``sort_palette`` and remaps
+        the image data to match. See :py:meth:`~PIL.Image.Image.quantize` for
+        the accepted values of ``sort_palette``.
+
+        :param sort_palette: ``"luminance"`` or ``"rgb"``.
+        :returns: A new image.
+        """
+        palette = self.im.getpalette("RGB", "RGB")
+
+        if sort_palette == "luminance":
+
+            def sort_key(index):
+                r, g, b = palette[index * 3 : index * 3 + 3]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        elif sort_palette == "rgb":
+
+            def sort_key(index):
+                return tuple(palette[index * 3 : index * 3 + 3])
+
+        else:
+            raise ValueError(
+                "sort_palette must be None, 'luminance' or 'rgb', "
+                "not " + repr(sort_palette)
+            )
+
+        # The palette indices actually referenced by the image data are not
+        # guaranteed to be contiguous from 0 (e.g. when quantizing to a
+        # reference image's palette), so use the histogram to tell used
+        # entries apart from unused ones. Used colors are sorted to the front;
+        # unused entries are kept after them, in their original order.
+        histogram = self.histogram()
+        num_colors = len(palette) // 3
+        used = sorted((i for i in range(num_colors) if histogram[i]), key=sort_key)
+        unused = [i for i in range(num_colors) if not histogram[i]]
+
+        return self.remap_palette(used + unused)
+
