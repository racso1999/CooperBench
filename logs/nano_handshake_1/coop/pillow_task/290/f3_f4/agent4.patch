diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..ffce050fd 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,24 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_high_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=100000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_low_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 8
+
+
+def test_error_threshold_matches_default_without_threshold():
+    image = hopper()
+    with_threshold = image.quantize(colors=8, error_threshold=0.0001)
+    without_threshold = image.quantize(colors=8)
+    assert with_threshold.tobytes() == without_threshold.tobytes()
