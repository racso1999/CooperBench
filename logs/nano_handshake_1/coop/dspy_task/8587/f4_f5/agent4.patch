+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle and, if so, emit a terminal empty chunk.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` was configured
+        and no chunk has been received for at least that long while a stream is in progress, this emits
+        a `StreamResponse` with an empty `chunk` to signal termination, and unconditionally resets the
+        listener's state (regardless of `allow_reuse`) so it isn't left stuck in a started state.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the state unconditionally, even if `allow_reuse` is False, so the listener doesn't stay
+        # stuck in a started state after the stream has been abandoned by the caller.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
