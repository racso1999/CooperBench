diff --git a/outlines/prompts.py b/outlines/prompts.py
index 86519ada..02f3e330 100644
--- a/outlines/prompts.py
+++ b/outlines/prompts.py
@@ -293,3 +293,35 @@ def parse_pydantic_schema(raw_schema, definitions):
             simple_schema[name] = f"<{name}>"
 
     return simple_schema
+
+
+FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter in the global filter registry.
+
+    Once registered, the filter becomes available to all prompt templates
+    without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name : str
+        The name under which the filter will be available in templates.
+    func : Callable
+        The callable implementing the filter.
+
+    """
+    FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Parameters
+    ----------
+    name : str
+        The name of the filter to remove.
+
+    """
+    FILTERS.pop(name, None)
