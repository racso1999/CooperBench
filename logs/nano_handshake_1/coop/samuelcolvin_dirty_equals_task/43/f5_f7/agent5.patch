+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a plausible phone number, optionally restricted to the national or
+    international format of a specific country.
+
+    This is pragmatic validation intended for everyday application use (e.g. checking user input), not a
+    full implementation of a numbering plan standard like ITU-T E.164.
+    """
+
+    _generic_international_re = re.compile(r'\+[1-9]\d{6,14}')
+    _generic_national_re = re.compile(r'\d{7,15}')
+    _us_national_re = re.compile(r'\d{10}')
+    _us_international_re = re.compile(r'\+1\d{10}')
+    _gb_national_re = re.compile(r'0\d{9,10}')
+    _gb_international_re = re.compile(r'\+44\d{9,10}')
+    _strip_re = re.compile(r'[\s\-.()]')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code, e.g. `'US'` or `'GB'`, used to restrict validation to
+                that country's phone number formats. If omitted, any reasonably formatted national or
+                international phone number is accepted.
+
+        `US` and `GB` have specific national and international format checks, other country codes fall back
+        to generic international format validation (`+` followed by a country code and 7 to 15 digits).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert 'not-a-number' != IsPhoneNumber
+        assert 1234567890 != IsPhoneNumber
+        ```
+        """
+        self.country = country
+        super().__init__(country if country is not None else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._strip_re.sub('', other)
+        if not cleaned:
+            return False
+
+        country = self.country.upper() if self.country else None
+
+        if country == 'US':
+            return bool(self._us_national_re.fullmatch(cleaned) or self._us_international_re.fullmatch(cleaned))
+        elif country == 'GB':
+            return bool(self._gb_national_re.fullmatch(cleaned) or self._gb_international_re.fullmatch(cleaned))
+        elif country is not None:
+            return bool(self._generic_international_re.fullmatch(cleaned))
+        elif cleaned.startswith('+'):
+            return bool(self._generic_international_re.fullmatch(cleaned))
+        else:
+            return bool(self._generic_national_re.fullmatch(cleaned))
