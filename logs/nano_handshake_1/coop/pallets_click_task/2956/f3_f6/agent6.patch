+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose default value depends on the value of
+        other options, once every parameter has been parsed.
+
+        Only applies to options whose value source is still
+        :attr:`ParameterSource.DEFAULT`; anything given on the command
+        line, through an environment variable, or a default map takes
+        precedence and is left untouched.
+        """
+        if ctx.resilient_parsing:
+            return
+
+        params = self.get_params(ctx)
+        opt_to_param = {opt: param for param in params for opt in param.opts}
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = opt_to_param.get(source_opt)
+
+                if source_param is None:
+                    continue
+
+                key = str(ctx.params.get(source_param.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.process_value(ctx, resolved)  # type: ignore[arg-type]
+
