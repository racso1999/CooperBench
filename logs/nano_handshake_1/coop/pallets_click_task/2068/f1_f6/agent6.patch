+#: Maps a ``process_priority`` value to the ``niceness`` increment used on
+#: Unix-like systems via :func:`os.nice`.
+_UNIX_PRIORITY_NICE = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+#: Maps a ``process_priority`` value to a Windows priority class constant.
+#: See the ``SetPriorityClass`` Win32 API documentation.
+_WINDOWS_PRIORITY_CLASS = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+#: ``PROCESS_SET_INFORMATION`` access right, needed to open a process
+#: handle capable of changing its priority class.
+_WINDOWS_PROCESS_SET_INFORMATION = 0x0200
+
+
+def _set_process_priority(pid: int, process_priority: str) -> None:
+    """Best-effort attempt to set the priority of the process ``pid``.
+
+    Any failure (unsupported platform, missing permissions, process
+    having already exited, ...) is silently ignored so that the edit
+    operation never fails because of this.
+    """
+    if process_priority not in _UNIX_PRIORITY_NICE:
+        return
+
+    try:
+        if WIN:
+            import ctypes
+
+            kernel32 = ctypes.windll.kernel32  # type: ignore[attr-defined]
+            handle = kernel32.OpenProcess(
+                _WINDOWS_PROCESS_SET_INFORMATION, False, pid
+            )
+            if handle:
+                try:
+                    kernel32.SetPriorityClass(
+                        handle, _WINDOWS_PRIORITY_CLASS[process_priority]
+                    )
+                finally:
+                    kernel32.CloseHandle(handle)
+        else:
+            os.setpriority(
+                os.PRIO_PROCESS, pid, _UNIX_PRIORITY_NICE[process_priority]
+            )
+    except Exception:
+        pass
+
+
