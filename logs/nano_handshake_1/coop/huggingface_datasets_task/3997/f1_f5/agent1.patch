+def keep_features_dicts_synced(func):
+    """
+    Wrapper for `Features` methods that mutate the underlying dict (`__setitem__`, `__delitem__`, `update`, etc.).
+
+    Since we use a dict subclass instead of `UserDict` (for performance reasons and to avoid breaking
+    `isinstance(..., dict)` checks), a method can add/remove/replace keys without going through `__setitem__`
+    or `__delitem__` (e.g. `update`, `pop`, `setdefault`). This decorator recomputes `_column_requires_decoding`
+    from scratch after the wrapped call so it always stays in sync with the main dict, regardless of how the
+    wrapped method mutates it internally.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        out = func(*args, **kwargs)
+        assert args and isinstance(args[0], Features)
+        self: "Features" = args[0]
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper._decorator_name_ = "keep_features_dicts_synced"
+    return wrapper
+
