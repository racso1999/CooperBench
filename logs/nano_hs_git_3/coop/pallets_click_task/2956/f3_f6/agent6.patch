+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dict-based dynamic defaults now that every parameter
+        has a value from the command line, environment variables, or a
+        default map.
+
+        A dynamic default maps other options' declarations (e.g.
+        ``"--protocol"``) to a ``{str(value): default}`` mapping. It only
+        applies to options whose value still comes from
+        :attr:`ParameterSource.DEFAULT`, and only options can declare one.
+
+        .. versionadded:: 8.3
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if (
+                not param.expose_value
+                or ctx.get_parameter_source(param.name)  # type: ignore[arg-type]
+                is not ParameterSource.DEFAULT
+            ):
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in param.default.items():
+                source = next(
+                    (
+                        p
+                        for p in params
+                        if isinstance(p, Option)
+                        and opt_name in (*p.opts, *p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source is None:
+                    continue
+
+                key = str(ctx.params.get(source.name))
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                try:
+                    value = param.process_value(ctx, resolved)
+                except Exception:
+                    if not ctx.resilient_parsing:
+                        raise
+
+                    value = None
+
+            ctx.params[param.name] = value  # type: ignore[index]
+
