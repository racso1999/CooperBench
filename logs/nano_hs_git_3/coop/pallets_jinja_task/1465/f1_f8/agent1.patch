+class _GroupCountTuple(t.NamedTuple):
+    grouper: t.Any
+    list: t.List
+    count: int
+
+    # Use the regular tuple repr to hide this subclass if users print
+    # out the value during debugging.
+    def __repr__(self) -> str:
+        return tuple.__repr__(self)
+
+    def __str__(self) -> str:
+        return tuple.__str__(self)
+
+
+def _group_tuples(
+    environment: "Environment",
+    value: "t.Iterable[V]",
+    attribute: t.Union[str, int],
+    default: t.Optional[t.Any] = None,
+    case_sensitive: bool = False,
+    with_counts: bool = False,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    expr = make_attrgetter(environment, attribute, default=default)
+
+    if case_sensitive:
+        key_func = expr
+    else:
+        key_func = make_attrgetter(
+            environment, attribute, postprocess=ignore_case, default=default
+        )
+
+    out = []
+
+    for key, values in groupby(sorted(value, key=key_func), key_func):
+        values = list(values)
+
+        if not case_sensitive:
+            key = expr(values[0])
+
+        if with_counts:
+            out.append(_GroupCountTuple(key, values, len(values)))
+        else:
+            out.append(_GroupTuple(key, values))
+
+    return out
+
+
