+    def _update_value(self, key, value):
+        # Deep-merge dict-like feature definitions instead of overwriting them outright
+        if key in self:
+            current_value = self[key]
+            if isinstance(current_value, dict) and isinstance(value, dict):
+                self._deep_merge_dict(current_value, value)
+                self[key] = current_value
+                return
+            if (
+                isinstance(current_value, Sequence)
+                and isinstance(value, Sequence)
+                and isinstance(current_value.feature, dict)
+                and isinstance(value.feature, dict)
+            ):
+                self._deep_merge_dict(current_value.feature, value.feature)
+                self[key] = current_value
+                return
+        self[key] = value
+
+    @staticmethod
+    def _deep_merge_dict(target: dict, source: dict) -> dict:
+        for key, value in source.items():
+            if key in target and isinstance(target[key], dict) and isinstance(value, dict):
