+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very high error threshold should be satisfied by very few colors.
+    high_threshold = image.quantize(colors=256, error_threshold=1000000)
+    assert len(high_threshold.getcolors()) < 256
+
+    # An unreachable error threshold should fall back to the requested
+    # number of colors.
+    low_threshold = image.quantize(colors=16, error_threshold=0)
+    assert len(low_threshold.getcolors()) == 16
+
+
+def test_quantize_error_threshold_negative():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_error_threshold_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
