+def _luma(color):
+    r, g, b = color[:3]
+    return r * 299 + g * 587 + b * 114
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(16, Image.FASTOCTREE, sort_palette="brightness")
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)][:16]
+    lumas = [_luma(color) for color in colors]
+    assert lumas == sorted(lumas)
+
+    # Pixel indices should have been remapped, so the image still looks the same
+    unsorted = image.quantize(16, Image.FASTOCTREE)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(16, Image.FASTOCTREE, sort_palette="rgb")
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)][:16]
+    assert colors == sorted(colors)
+
+    unsorted = image.quantize(16, Image.FASTOCTREE)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+    converted = image.quantize(
+        16, Image.FASTOCTREE, sort_palette=lambda color: -_luma(color)
+    )
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)][:16]
+    assert [_luma(color) for color in colors] == sorted(
+        (_luma(color) for color in colors), reverse=True
+    )
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(16, Image.FASTOCTREE, sort_palette="not-a-real-option")
+
+
+def test_quantize_sort_palette_with_reference_palette():
+    image = hopper()
+    reference = image.quantize(16, Image.FASTOCTREE)
+
+    converted = image.quantize(palette=reference, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(
+        converted.convert("RGB"), image.quantize(palette=reference).convert("RGB"), 1
+    )
