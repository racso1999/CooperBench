+    def _sort_palette(self, sort_palette):
+        # Sorts this image's palette in place, remapping pixel indices so the
+        # image still looks the same. Used by quantize()'s sort_palette param.
+        if sort_palette == "brightness":
+
+            def key(color):
+                r, g, b = color[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color[:3]
+
+        elif callable(sort_palette):
+            key = sort_palette
+        else:
+            raise ValueError(
+                "sort_palette must be 'brightness', 'rgb', or a callable, "
+                f"not {sort_palette!r}"
+            )
+
+        palette = self.palette
+        mode_len = len(palette.mode)
+        palette_bytes = palette.palette
+        all_colors = [
+            tuple(palette_bytes[i : i + mode_len])
+            for i in range(0, len(palette_bytes), mode_len)
+        ]
+
+        # Only sort the palette entries actually used by a pixel, leaving any
+        # unused trailing entries as-is.
+        used = [i for i, count in enumerate(self.histogram()[:256]) if count > 0]
+        num_colors = max(used) + 1 if used else 0
+        if num_colors <= 1:
+            return
+
+        colors = all_colors[:num_colors]
+        order = sorted(range(num_colors), key=lambda i: key(colors[i]))
+
+        lut = list(range(256))
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+        self.im = self.im.point(lut, None)
+
+        new_palette_data = bytearray()
+        for old_index in order:
+            new_palette_data.extend(colors[old_index])
+        new_palette_data.extend(palette_bytes[num_colors * mode_len :])
+        palette.palette = bytes(new_palette_data)
+        palette.dirty = 1
+        self.load()
+
+    def _quantize_mse(self, quantized_im):
+        """
+        Returns the mean square error between this image and a quantized
+        version of it, used by :py:meth:`~PIL.Image.Image.quantize` to
+        evaluate ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        comparison = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparison)
+        rms_per_band = ImageStat.Stat(diff).rms
+        return sum(rms ** 2 for rms in rms_per_band) / len(rms_per_band)
+
