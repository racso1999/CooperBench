+    You can also use ``with_counts`` to get the number of items in each
+    group without having to materialize the list separately, such as
+    with ``items|list|length``.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=true) %}
+          <li>{{ city }} ({{ count }})</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``with_counts`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1224,17 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    out = []
+
+    for key, values in groupby(sorted(value, key=expr), expr):
+        values = list(values)
+
+        if with_counts:
+            out.append((key, values, len(values)))
+        else:
+            out.append(_GroupTuple(key, values))
+
+    return out
 
 
