+_PHONE_NUMBER_CLEAN_REGEX = re.compile(r'[\s\-.()]')
+
+_GENERIC_PHONE_REGEX = re.compile(r'^\+?\d{7,15}$')
+_GENERIC_INTERNATIONAL_PHONE_REGEX = re.compile(r'^\+\d{7,15}$')
+
+_US_NATIONAL_PHONE_REGEX = re.compile(r'^\d{10}$')
+_US_INTERNATIONAL_PHONE_REGEX = re.compile(r'^\+1\d{10}$')
+
+_GB_NATIONAL_PHONE_REGEX = re.compile(r'^0\d{9,10}$')
+_GB_INTERNATIONAL_PHONE_REGEX = re.compile(r'^\+44\d{9,10}$')
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number string, optionally restricted to a specific
+    country's format.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) to validate the number against
+                that country's national/international format. If omitted, a generic, permissive phone
+                number format is accepted. Countries without dedicated rules fall back to a generic
+                international check (`+` followed by 7-15 digits).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert 12345 != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country is not None else None
+        super().__init__(country if country is not None else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = _PHONE_NUMBER_CLEAN_REGEX.sub('', other)
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(_GENERIC_PHONE_REGEX.fullmatch(cleaned))
+        elif self.country == 'US':
+            return bool(
+                _US_NATIONAL_PHONE_REGEX.fullmatch(cleaned) or _US_INTERNATIONAL_PHONE_REGEX.fullmatch(cleaned)
+            )
+        elif self.country == 'GB':
+            return bool(
+                _GB_NATIONAL_PHONE_REGEX.fullmatch(cleaned) or _GB_INTERNATIONAL_PHONE_REGEX.fullmatch(cleaned)
+            )
+        else:
+            return bool(_GENERIC_INTERNATIONAL_PHONE_REGEX.fullmatch(cleaned))
+
+
 AnyJson = object
 JsonType = TypeVar('JsonType', AnyJson, Any)
 
