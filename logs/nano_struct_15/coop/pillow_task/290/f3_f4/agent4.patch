     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very loose threshold should be satisfied with very few colors.
+    loose = image.quantize(colors=256, error_threshold=10000)
+    assert len(loose.getcolors()) < 256
+
+    # A very tight threshold cannot be met, so the full color budget is used.
+    tight = image.quantize(colors=256, error_threshold=0)
+    assert len(tight.getcolors()) == 256
+
+    assert len(loose.getcolors()) <= len(tight.getcolors())
+
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
