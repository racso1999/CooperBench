     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(16, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    brightness = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, 16 * 3, 3)
+    ]
+    assert brightness == sorted(brightness)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(16, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 16 * 3, 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(16, sort_palette="invalid")
+
+
