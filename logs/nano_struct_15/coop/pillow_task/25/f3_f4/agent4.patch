+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "#f00")
+        im.save(temp_file)
+
+        im2 = Image.new("RGB", (1, 1), "#0f0")
+        im2.save(temp_file, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert os.path.exists(backup_file)
+        with Image.open(backup_file) as im:
+            assert im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as im:
+            assert im.getpixel((0, 0)) == (0, 255, 0)
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "#f00")
+        im.save(temp_file)
+
+        im2 = Image.new("RGB", (1, 1), "#0f0")
+        im2.save(temp_file, backup=True, backup_suffix=".backup")
+
+        backup_file = tmp_path / "temp.png.backup"
+        assert os.path.exists(backup_file)
+        assert not os.path.exists(tmp_path / "temp.png.bak")
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "#f00")
+        im.save(temp_file, backup=True)
+
+        assert os.path.exists(temp_file)
+        assert not os.path.exists(tmp_path / "temp.png.bak")
+
+    def test_save_backup_file_object(self) -> None:
+        im = Image.new("RGB", (1, 1), "#f00")
+        buf = io.BytesIO()
+        # backup has no effect when saving to a file object
+        im.save(buf, format="PNG", backup=True)
+        assert buf.getvalue()
+
