+def _try_set_nice(nice_level: int) -> None:
+    """Best-effort attempt to renice the current process before exec.
+
+    This is used as a ``preexec_fn`` for the editor subprocess on
+    Unix-like systems. Failures (e.g. insufficient permissions to
+    increase priority) are silently ignored so that the editor still
+    launches with its default priority.
+    """
+    try:
+        os.nice(nice_level)
+    except OSError:
+        pass
