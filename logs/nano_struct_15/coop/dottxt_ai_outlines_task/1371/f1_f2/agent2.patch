+#: Registry of filters that are made available to every prompt template
+#: without having to be passed explicitly. See `register_filter` and
+#: `unregister_filter`.
+FILTER_REGISTRY: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter that will be available in all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    FILTER_REGISTRY[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a previously registered global filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    FILTER_REGISTRY.pop(name, None)
+
 
