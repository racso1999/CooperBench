+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_save_dry_run_format_conversion(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.webp"
+
+        im = hopper()
+        im.save(temp_file, format="WEBP", dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_save_dry_run_raises(self) -> None:
+        im = Image.new("RGB", (0, 0))
+        with pytest.raises(ValueError):
+            im.save("out.jpg", dry_run=True)
+
+    def test_save_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = hopper()
+        im.save(temp_file)
+        mtime = os.path.getmtime(temp_file)
+        with open(temp_file, "rb") as fp:
+            contents = fp.read()
+
+        im.save(temp_file, dry_run=True)
+
+        assert os.path.getmtime(temp_file) == mtime
+        with open(temp_file, "rb") as fp:
+            assert fp.read() == contents
+
