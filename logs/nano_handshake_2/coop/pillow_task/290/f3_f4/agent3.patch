diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..9ce29b6bf 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,54 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(colors=8, sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.palette.palette
+    luminances = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), 3)
+    ]
+    assert luminances == sorted(luminances)
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(colors=8, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.palette.palette
+    colors = [
+        tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)
+    ]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_pixels_unchanged():
+    image = hopper()
+    unsorted = image.quantize(colors=8)
+    sorted_by_luminance = image.quantize(colors=8, sort_palette="luminance")
+
+    # Reordering the palette shouldn't change the visible colors, only
+    # where they sit in the palette.
+    assert_image_similar(
+        unsorted.convert("RGB"), sorted_by_luminance.convert("RGB"), 10
+    )
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_default_unaffected():
+    image = hopper()
+    a = image.quantize(colors=8)
+    b = image.quantize(colors=8, sort_palette=None)
+    assert a.palette.palette == b.palette.palette
+    assert a.tobytes() == b.tobytes()
