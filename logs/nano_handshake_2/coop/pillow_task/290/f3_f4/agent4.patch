index bd9db362c..ab32b4e53 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,33 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_loose_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=100000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors(256)) < 256
+
+
+def test_error_threshold_tight_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0.00001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors(256)) == 8
+
+
+def test_error_threshold_ignored_with_palette():
+    image = hopper()
+    converted = image.quantize(palette=hopper("P"), error_threshold=100000)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 60)
+
+
+def test_error_threshold_none_matches_default_behavior():
+    image = hopper()
+    without_threshold = image.quantize(colors=100, method=Image.FASTOCTREE)
+    with_none_threshold = image.quantize(
+        colors=100, method=Image.FASTOCTREE, error_threshold=None
+    )
+    assert without_threshold.tobytes() == with_none_threshold.tobytes()
