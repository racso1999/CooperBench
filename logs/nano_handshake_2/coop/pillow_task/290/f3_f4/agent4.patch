+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using the fewest colors, from 2 up to
+        ``colors``, whose mean squared error against the original image is
+        no greater than ``error_threshold``. If none of them satisfy the
+        threshold, quantizes using ``colors``.
+        """
+        from . import ImageChops, ImageStat
+
+        rgb_im = self.convert("RGB")
+
+        def mean_squared_error(candidate):
+            comparison = candidate.convert("RGB")
+            diff = ImageChops.difference(rgb_im, comparison)
+            stat = ImageStat.Stat(diff)
+            return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+        for num_colors in range(2, colors):
+            candidate = self._new(self.im.quantize(num_colors, method, kmeans))
+            if mean_squared_error(candidate) <= error_threshold:
+                return candidate
+
+        return self._new(self.im.quantize(colors, method, kmeans))
+
