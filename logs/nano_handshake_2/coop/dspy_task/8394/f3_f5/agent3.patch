+def set_ttl(seconds: Optional[int]):
+    """Set the time-to-live (in seconds) for entries added to the DSPy cache from now on.
+
+    Args:
+        seconds: The time-to-live (in seconds) for cache entries. If None, cache entries never expire.
+    """
+    import dspy
+    from cachetools import LRUCache, TTLCache
+
+    cache = dspy.cache
+    cache.ttl = seconds
+    if cache.enable_memory_cache:
+        maxsize = cache.memory_cache.maxsize
+        if seconds is not None:
+            cache.memory_cache = TTLCache(maxsize=maxsize, ttl=seconds)
+        else:
+            cache.memory_cache = LRUCache(maxsize=maxsize)
+
+
