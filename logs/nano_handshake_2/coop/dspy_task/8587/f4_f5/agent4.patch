+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check for an idle stream and, if timed out, emit a terminal empty-chunk `StreamResponse`.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` is set and no chunk
+        has been received within that window since the stream started, this emits a `StreamResponse` with an
+        empty `chunk` to signal termination of an otherwise stuck stream, then resets the listener's state.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()` if not provided.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset state unconditionally (regardless of `allow_reuse`) so the listener isn't left stuck in a
+        # started state after a timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
 
