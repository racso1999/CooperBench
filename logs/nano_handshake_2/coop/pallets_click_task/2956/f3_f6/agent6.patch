+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution of options with a dict-based dynamic
+        default, run after all parameters have been parsed. Only applies
+        when the option's value still comes from its default.
+
+        .. versionadded:: 8.3
+        """
+        for param in self.get_params(ctx):
+            if not isinstance(param, Option) or not param.dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            value = param.resolve_dynamic_default(ctx)
+
+            if value is not None:
+                ctx.params[param.name] = value  # type: ignore[index]
+
