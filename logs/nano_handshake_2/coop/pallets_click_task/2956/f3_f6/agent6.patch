+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve this option's value from :attr:`dynamic_default` based on
+        the current, final values of the options it references.
+
+        Returns ``None`` if there is no dynamic default, or if none of the
+        referenced options' values match a key in the mapping.
+
+        .. versionadded:: 8.3
+        """
+        if not self.dynamic_default:
+            return None
+
+        resolved = None
+
+        for opt_name, mapping in self.dynamic_default.items():
+            source_param = None
+
+            for param in ctx.command.get_params(ctx):
+                if opt_name in param.opts or opt_name in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            key = str(ctx.params.get(source_param.name))
+
+            if key in mapping:
+                resolved = mapping[key]
+
+        return resolved
+
