+#: Mapping of supported ``process_priority`` values to POSIX ``nice``
+#: increments (lower is higher priority).
+_PRIORITY_NICE_VALUES = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+#: Mapping of supported ``process_priority`` values to Windows priority
+#: classes, as accepted by ``SetPriorityClass``.
+_PRIORITY_WINDOWS_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+
+def _set_process_priority(pid: int, priority: str | None) -> None:
+    """Best-effort attempt to set the CPU priority of the process with
+    the given ``pid``. Does nothing if ``priority`` is ``None`` or not
+    a recognized value, and silently ignores failures, since priority
+    is a resource-management hint and should never break editing.
+    """
+    if priority is None:
+        return
+
+    if WIN:
+        windows_class = _PRIORITY_WINDOWS_CLASSES.get(priority)
+        if windows_class is None:
+            return
+
+        try:
+            import ctypes
+
+            # PROCESS_SET_INFORMATION
+            handle = ctypes.windll.kernel32.OpenProcess(0x0200, False, pid)  # type: ignore[attr-defined]
+            if handle:
+                try:
+                    ctypes.windll.kernel32.SetPriorityClass(handle, windows_class)  # type: ignore[attr-defined]
+                finally:
+                    ctypes.windll.kernel32.CloseHandle(handle)  # type: ignore[attr-defined]
+        except Exception:
+            pass
+    else:
+        nice_value = _PRIORITY_NICE_VALUES.get(priority)
+        if nice_value is None:
+            return
+
+        try:
+            os.setpriority(os.PRIO_PROCESS, pid, nice_value)
+        except (AttributeError, OSError, PermissionError):
+            pass
+
+
