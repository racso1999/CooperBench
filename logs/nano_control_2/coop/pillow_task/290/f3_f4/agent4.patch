+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using the fewest colors (up to ``colors``) whose mean square
+        error against the original image is at or below ``error_threshold``,
+        falling back to ``colors`` if that threshold can't be met.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        def quantize_to(n):
+            candidate = self._new(self.im.quantize(n, method, kmeans))
+            mode = candidate.im.getpalettemode()
+            candidate.palette = ImagePalette.ImagePalette(
+                mode, candidate.im.getpalette(mode, mode)
+            )
+            return candidate
+
+        def mean_square_error(candidate):
+            comparable = candidate.convert(self.mode)
+            stat = ImageStat.Stat(ImageChops.difference(self, comparable))
+            total_count = sum(stat.count)
+            return sum(stat.sum2) / total_count if total_count else 0
+
+        low, high = 2, colors
+        best = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = quantize_to(mid)
+            if mean_square_error(candidate) <= error_threshold:
+                best = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        return best if best is not None else quantize_to(colors)
+
