+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, independent of `receive()`, since an idle
+        stream produces no chunks to trigger a check on its own. If the idle window has elapsed while the field
+        is being streamed (started but not yet ended), a final `StreamResponse` with an empty `chunk` is emitted
+        to signal termination, and the listener's state is reset.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream timed out, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if hasattr(response, "is_last_chunk"):
+            response.is_last_chunk = True
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so a timed-out listener is never
+        # left stuck in a started state.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
