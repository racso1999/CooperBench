+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose ``default`` is a dynamic default mapping.
+
+        This runs after every parameter has been processed once, so that
+        the current value of any option referenced by a dynamic default
+        is already known, regardless of declaration or invocation order.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or param._dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in param._dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if isinstance(p, Option)
+                        and (opt_name in p.opts or opt_name in p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = str(ctx.params.get(source_param.name))  # type: ignore[arg-type]
+
+                if source_value in mapping:
+                    resolved = mapping[source_value]
+
+            if resolved is None:
+                continue
+
+            with augment_usage_errors(ctx, param=param):
+                try:
+                    value = param.process_value(ctx, resolved)
+                except Exception:
+                    if not ctx.resilient_parsing:
+                        raise
+
+                    value = None
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[arg-type]
+
