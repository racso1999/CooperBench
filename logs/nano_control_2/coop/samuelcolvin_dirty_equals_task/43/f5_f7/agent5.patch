+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's
+    format. This is intended for pragmatic, application-level validation rather than exhaustive
+    telecommunications compliance.
+    """
+
+    # (international pattern, national pattern) for each supported country
+    _country_patterns: Dict[str, Tuple['re.Pattern[str]', 're.Pattern[str]']] = {
+        'US': (
+            re.compile(r'^\+1\d{10}$'),
+            re.compile(r'^\d{10}$'),
+        ),
+        'GB': (
+            re.compile(r'^\+44\d{9,10}$'),
+            re.compile(r'^0\d{9,10}$'),
+        ),
+    }
+
+    _generic_international = re.compile(r'^\+\d{7,15}$')
+    _generic_national = re.compile(r'^\d{7,15}$')
+    _delimiters = re.compile(r'[\s\-.()]')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code to restrict validation to, e.g. `'US'` or `'GB'`. If
+                omitted, generic international/national phone number validation is used. Countries without
+                dedicated rules fall back to generic international validation (`+` followed by 7-15 digits).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert '+33 1 42 68 53 00' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(plain_repr('*') if self.country is None else self.country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        value = other.strip()
+        if not value:
+            return False
+
+        normalized = self._delimiters.sub('', value)
+
+        if self.country is None:
+            return bool(self._generic_international.match(normalized) or self._generic_national.match(normalized))
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            return bool(self._generic_international.match(normalized))
+
+        international_pattern, national_pattern = patterns
+        return bool(international_pattern.match(normalized) or national_pattern.match(normalized))
