+                    ctx.params[self.name] = None  # type: ignore
+
+                return None, args
+
+        return super().handle_parse_result(ctx, opts, args)
+
+    def resolve_dynamic_default(self, ctx: Context) -> t.Any:
+        """Resolve this option's dynamic default by looking up the
+        current values of the options it depends on. Returns ``None`` if
+        none of the mappings match.
+        """
+        assert self._dynamic_default is not None
+        result: t.Any = None
+
+        for opt_name, mapping in self._dynamic_default.items():
+            source_param = None
+
+            for param in ctx.command.params:
+                if opt_name in param.opts or opt_name in param.secondary_opts:
+                    source_param = param
+                    break
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)  # type: ignore
+            key = str(source_value)
+
+            if key in mapping:
+                result = mapping[key]
+
+        return result
+
