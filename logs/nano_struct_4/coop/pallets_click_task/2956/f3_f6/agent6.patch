+def is_dynamic_default(value: t.Any) -> bool:
+    """Return whether ``value`` is a dynamic default specification for an
+    :class:`~click.core.Option`, i.e. a mapping of source option names to
+    mappings of stringified source values to defaults.
+    """
+    return isinstance(value, dict)
+
+
+def validate_dynamic_default(value: dict[str, t.Any]) -> None:
+    """Validate the structure of a dynamic default specification.
+
+    :raises TypeError: if a key is not a string or a value is not a
+        dictionary.
+    """
+    for key, mapping in value.items():
+        if not isinstance(key, str):
+            raise TypeError("Dynamic default keys must be strings")
+
+        if not isinstance(mapping, dict):
+            raise TypeError("Dynamic default values must be dictionaries")
+
+
