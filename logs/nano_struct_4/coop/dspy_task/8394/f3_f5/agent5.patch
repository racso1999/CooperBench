+# Magic header used to identify DSPy cache blobs that carry a compression codec byte.
+# Legacy entries written before compression support was added won't have this prefix,
+# so we can safely fall back to treating them as raw pickle bytes.
+_CACHE_MAGIC = b"DSPC"
+_CODEC_NONE = 0x00
+_CODEC_GZIP = 0x01
+_CODEC_ZLIB = 0x02
+
+_COMPRESSION_CODECS = {
+    "gzip": _CODEC_GZIP,
+    "zlib": _CODEC_ZLIB,
+}
+
+
+def _encode_cache_value(value: Any, compress: Optional[str]) -> bytes:
+    payload = pickle.dumps(value)
+    codec_id = _CODEC_NONE
+    if compress is not None:
+        codec_id = _COMPRESSION_CODECS[compress]
+        if codec_id == _CODEC_GZIP:
+            payload = gzip.compress(payload)
+        elif codec_id == _CODEC_ZLIB:
+            payload = zlib.compress(payload)
+    return _CACHE_MAGIC + bytes([codec_id]) + payload
+
+
+def _decode_cache_value(data: bytes) -> Any:
+    if not isinstance(data, (bytes, bytearray)) or data[:4] != _CACHE_MAGIC:
+        # No magic header, so this is a legacy raw pickle blob written before
+        # compression support existed.
+        return pickle.loads(data)
+
+    codec_id = data[4]
+    payload = data[5:]
+    if codec_id == _CODEC_GZIP:
+        payload = gzip.decompress(payload)
+    elif codec_id == _CODEC_ZLIB:
+        payload = zlib.decompress(payload)
+    elif codec_id != _CODEC_NONE:
+        raise ValueError(f"Unknown cache compression codec id: {codec_id}")
+    return pickle.loads(payload)
+
 
