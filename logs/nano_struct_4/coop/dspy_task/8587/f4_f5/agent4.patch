+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system (independently of `receive()`) so that a
+        stalled upstream that stops sending chunks doesn't leave a listener stuck open forever. If the timeout
+        has elapsed, this emits a final `StreamResponse` with an empty `chunk` and resets the listener's state
+        unconditionally so it's ready to be reused.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.time()`.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response_kwargs = {}
+        if any(field.name == "is_last_chunk" for field in dataclasses.fields(StreamResponse)):
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **response_kwargs)
+
+        # Reset the listener's state unconditionally so it doesn't stay stuck in a "started" state, regardless
+        # of `allow_reuse`.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
