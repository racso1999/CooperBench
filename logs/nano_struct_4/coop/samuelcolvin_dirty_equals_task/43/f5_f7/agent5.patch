+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's
+    formatting rules.
+    """
+
+    # national format, or international format with the country's dialing code
+    _country_regexes: Dict[str, 're.Pattern[str]'] = {
+        'US': re.compile(r'^(?:\+1[-.\s]?)?\(?\d{3}\)?[-.\s]?\d{3}[-.\s]?\d{4}$'),
+        'GB': re.compile(r'^(?:\+44[-.\s]?|0)\d{2,4}[-.\s]?\d{3,4}[-.\s]?\d{0,4}$'),
+    }
+
+    _generic_regex = re.compile(r'^\+?[\d\s.\-()]+$')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: The ISO 3166-1 alpha-2 country code to validate against, if omitted, generic phone number
+                validation is used. Countries without dedicated rules fall back to generic international
+                validation (a `+` followed by the country's dialing code and 7 to 15 digits in total).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '+33 1 23 45 67 89' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country = country
+        super().__init__(country if country is not None else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        value = other.strip()
+        if not self._generic_regex.match(value):
+            return False
+
+        digit_count = len(re.sub(r'\D', '', value))
+
+        if self.country is None:
+            return 7 <= digit_count <= 15
+
+        regex = self._country_regexes.get(self.country)
+        if regex is not None:
+            return bool(regex.match(value))
+        else:
+            # unknown country, fall back to generic international validation
+            return value.startswith('+') and 7 <= digit_count <= 15
+
