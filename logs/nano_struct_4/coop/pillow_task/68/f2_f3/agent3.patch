--- a/Tests/test_imageops.py
+++ b/Tests/test_imageops.py
@@ -448,6 +448,61 @@ def test_exif_transpose() -> None:
     assert 0x0112 not in transposed_im.getexif()
 
 
+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        assert im.getexif()[0x0112] == 6
+
+        # A callback that returns a custom method overrides the default mapping
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: Image.Transpose.FLIP_LEFT_RIGHT
+        )
+        expected = im.transpose(Image.Transpose.FLIP_LEFT_RIGHT)
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        # A callback that returns a sequence of methods applies them in order
+        transposed_im = ImageOps.exif_transpose(
+            im,
+            transform_callback=lambda orientation: (
+                Image.Transpose.FLIP_LEFT_RIGHT,
+                Image.Transpose.ROTATE_90,
+            ),
+        )
+        expected = im.transpose(Image.Transpose.FLIP_LEFT_RIGHT).transpose(
+            Image.Transpose.ROTATE_90
+        )
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        # A callback that returns None falls back to the default mapping
+        transposed_im = ImageOps.exif_transpose(im, transform_callback=lambda o: None)
+        expected = im.transpose(Image.Transpose.ROTATE_270)
+        assert_image_equal(transposed_im, expected)
+        assert 0x0112 not in transposed_im.getexif()
+
+    with Image.open("Tests/images/hopper_orientation_6.jpg") as im:
+        # A callback that returns an empty sequence performs no transposition,
+        # and leaves the EXIF orientation tag untouched
+        transposed_im = ImageOps.exif_transpose(im, transform_callback=lambda o: [])
+        assert_image_equal(transposed_im, im)
+        assert transposed_im.getexif()[0x0112] == 6
+
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+        expected = im.rotate(90, expand=True)
+
+        # in_place also respects the callback
+        ImageOps.exif_transpose(
+            im, in_place=True, transform_callback=lambda o: Image.Transpose.ROTATE_90
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
 def test_exif_transpose_xml_without_xmp() -> None:
     with Image.open("Tests/images/xmp_tags_orientation.png") as im:
         assert im.getexif()[0x0112] == 3
