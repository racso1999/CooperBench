+    def _reorder_palette(self, sort_palette):
+        """
+        Reorders this "P" mode image's palette according to ``sort_palette``,
+        remapping pixel values to match. Used by :py:meth:`~PIL.Image.Image.quantize`.
+
+        :param sort_palette: ``"brightness"`` or ``"rgb"``.
+        :returns: A new image
+        """
+        mode = self.palette.mode
+        channels = len(mode)
+        entries = [
+            tuple(self.palette.palette[i : i + channels])
+            for i in range(0, len(self.palette.palette), channels)
+        ]
+
+        if sort_palette == "brightness":
+
+            def sort_key(color):
+                r, g, b = color[0], color[1], color[2]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color[:3]
+
+        else:
+            raise ValueError(
+                "sort_palette must be one of 'brightness' or 'rgb', "
+                "not " + repr(sort_palette)
+            )
+
+        order = sorted(range(len(entries)), key=lambda i: sort_key(entries[i]))
+
+        # mapping from old index to new index
+        new_index = [0] * len(order)
+        for new_i, old_i in enumerate(order):
+            new_index[old_i] = new_i
+
+        new_palette = bytearray()
+        for old_i in order:
+            new_palette.extend(entries[old_i])
+
+        im = self._new(self.im.point(new_index, self.mode))
+        im.im.putpalette(mode, bytes(new_palette))
+
+        from . import ImagePalette
+
+        im.palette = ImagePalette.ImagePalette(mode, im.im.getpalette(mode, mode))
+
         return im
 
