+
+
+def test_error_threshold_uses_fewer_colors():
+    from PIL import ImageChops, ImageStat
+
+    image = hopper()
+    full = image.quantize(256)
+    reduced = image.quantize(256, error_threshold=50)
+
+    assert len(reduced.getcolors()) <= len(full.getcolors())
+
+    diff = ImageChops.difference(image, reduced.convert("RGB"))
+    stat = ImageStat.Stat(diff)
+    mse = sum(rms**2 for rms in stat.rms) / len(stat.rms)
+    assert mse <= 50
+
+
+def test_error_threshold_falls_back_to_max_colors():
+    image = hopper()
+    converted = image.quantize(8, error_threshold=0.0001)
+
+    assert len(converted.getcolors()) <= 8
+
+
+def test_error_threshold_none_is_unaffected():
+    image = hopper()
+    with_threshold = image.quantize(64, error_threshold=None)
+    without_threshold = image.quantize(64)
+
+    assert with_threshold.tobytes() == without_threshold.tobytes()
