+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        from . import ImageChops, ImageStat
+
+        original = self.convert("RGB")
+
+        def mean_square_error(n_colors):
+            candidate = self._new(self.im.quantize(n_colors, method, kmeans))
+            diff = ImageChops.difference(original, candidate.convert("RGB"))
+            stat = ImageStat.Stat(diff)
+            return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+        low, high = 1, colors
+        best = None
+        while low <= high:
+            mid = (low + high) // 2
+            if mean_square_error(mid) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        n_colors = best if best is not None else colors
+        return self._new(self.im.quantize(n_colors, method, kmeans))
