+#: Filters registered globally, made available to every prompt template.
+_FILTER_REGISTRY: Dict[str, Callable] = {}
+
+#: Jinja2 environments created so far, so registering or unregistering a
+#: filter can update templates that already exist and not just new ones.
+_FILTER_ENVIRONMENTS: "weakref.WeakSet[jinja2.Environment]" = weakref.WeakSet()
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter for use in all prompt templates.
+
+    Once registered, the filter is available in every template, current
+    or future, under the given name, e.g. ``{{ text | name }}``, without
+    having to pass it explicitly to each prompt.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    _FILTER_REGISTRY[name] = func
+    for env in _FILTER_ENVIRONMENTS:
+        env.filters[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove from the global registry.
+
+    """
+    _FILTER_REGISTRY.pop(name, None)
+    for env in _FILTER_ENVIRONMENTS:
+        env.filters.pop(name, None)
+
 
