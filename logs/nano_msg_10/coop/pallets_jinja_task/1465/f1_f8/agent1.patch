           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
+    case-insensitive by default. The ``key`` for each group will have
+    the case of the first item in that group of values. For example, if
+    a list of items has cities ``["CA", "NY", "ca"]``, the "CA" and
+    "ca" items will be grouped together, under the "CA" or "ca" key
+    depending on which appeared first.
+
+    .. versionchanged:: 3.1
+        Added the ``case_sensitive`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1221,20 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+    sort_expr = make_attrgetter(
+        environment,
+        attribute,
+        default=default,
+        postprocess=ignore_case if not case_sensitive else None,
+    )
+    groups = []
+
+    for key, values in groupby(sorted(value, key=sort_expr), sort_expr):
+        values = list(values)
+        grouper = key if case_sensitive else expr(values[0])
+        groups.append(_GroupTuple(grouper, values))
+
+    return groups
 
 
