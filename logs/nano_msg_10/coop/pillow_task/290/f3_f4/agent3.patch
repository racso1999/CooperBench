+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(32, sort_palette=sort_palette)
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    num_colors = len(converted.getcolors())
+    colors = colors[:num_colors]
+
+    if sort_palette == "brightness":
+        key = lambda color: sum(color) / len(color)  # noqa: E731
+    else:
+        key = lambda color: color  # noqa: E731
+    assert colors == sorted(colors, key=key)
+
+    # Sorting the palette should not change the decoded pixel data
+    unsorted = image.quantize(32)
+    assert sorted(converted.convert("RGB").getdata()) == sorted(
+        unsorted.convert("RGB").getdata()
+    )
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="bad")
+
+
