+    def _quantize_mse(self, colors, method, kmeans):
+        from . import ImageChops, ImageStat
+
+        quantized = self._new(self.im.quantize(colors, method, kmeans))
+
+        original = self.convert("RGB")
+        comparison = quantized.convert("RGB")
+        diff = ImageChops.difference(original, comparison)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _find_quantize_colors(self, colors, method, kmeans, error_threshold):
+        if colors < 2 or self._quantize_mse(colors, method, kmeans) > error_threshold:
+            # The threshold cannot be met, even with the maximum allowed
+            # number of colors.
+            return colors
+
+        low, high = 2, colors
+        best = colors
+        while low <= high:
+            mid = (low + high) // 2
+            if self._quantize_mse(mid, method, kmeans) <= error_threshold:
+                best = mid
+                high = mid - 1
+            else:
+                low = mid + 1
+        return best
+
