+
+
+def test_error_threshold_reduces_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=100)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_meets_quality():
+    image = hopper()
+    threshold = 100
+    converted = image.quantize(colors=256, error_threshold=threshold)
+
+    mse = image._quantize_mse(len(converted.getcolors()), Image.MEDIANCUT, 0)
+    assert mse <= threshold
+
+
+def test_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+    with_threshold = image.quantize(colors=4, error_threshold=0.001)
+    without_threshold = image.quantize(colors=4)
+    assert len(with_threshold.getcolors()) == len(without_threshold.getcolors())
+
+
+def test_error_threshold_with_palette_raises():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=10)
