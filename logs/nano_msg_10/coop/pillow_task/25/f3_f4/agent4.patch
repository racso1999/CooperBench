+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        backup_file = tmp_path / "temp.png.bak"
+
+        red = Image.new("RGB", (1, 1), "#f00")
+        blue = Image.new("RGB", (1, 1), "#00f")
+
+        # No backup should be created when the file does not already exist
+        red.save(temp_file, backup=True)
+        assert not backup_file.exists()
+
+        # A backup of the previous contents should be created
+        blue.save(temp_file, backup=True)
+        assert backup_file.exists()
+        with Image.open(backup_file) as im:
+            assert im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as im:
+            assert im.getpixel((0, 0)) == (0, 0, 255)
+
+        # A custom backup_suffix should be respected
+        custom_backup_file = tmp_path / "temp.png.backup"
+        red.save(temp_file, backup=True, backup_suffix=".backup")
+        assert custom_backup_file.exists()
+
+        # No backup should be created when backup is not requested
+        another_backup_file = tmp_path / "temp2.png.bak"
+        temp_file2 = tmp_path / "temp2.png"
+        red.save(temp_file2)
+        blue.save(temp_file2)
+        assert not another_backup_file.exists()
+
     def test_internals(self) -> None:
         im = Image.new("L", (100, 100))
         im.readonly = 1
