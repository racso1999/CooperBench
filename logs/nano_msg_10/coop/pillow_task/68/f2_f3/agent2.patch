+def _strip_all_metadata(image: Image.Image) -> None:
+    exif = image.getexif()
+    exif.clear()
+    for key in (
+        "exif",
+        "icc_profile",
+        "comment",
+        "xmp",
+        "XML:com.adobe.xmp",
+        "Raw profile type exif",
+        "Raw profile type iptc",
+    ):
+        image.info.pop(key, None)
