+    def _encode_with_positions(
+        self, text: str, allowed_special: AbstractSet[str]
+    ) -> tuple[list[int], list[int]]:
+        """Encodes a string into tokens, tracking each token's starting character position."""
+        tokens: list[int] = []
+        positions: list[int] = []
+
+        if allowed_special:
+            special_pattern = _special_token_regex(frozenset(allowed_special))
+            last_end = 0
+            for match in special_pattern.finditer(text):
+                start, end = match.span()
+                if start > last_end:
+                    self._encode_ordinary_with_positions(
+                        text[last_end:start], last_end, tokens, positions
+                    )
+                tokens.append(self._special_tokens[match.group()])
+                positions.append(start)
+                last_end = end
+            if last_end < len(text):
+                self._encode_ordinary_with_positions(text[last_end:], last_end, tokens, positions)
+        else:
+            self._encode_ordinary_with_positions(text, 0, tokens, positions)
+
+        return tokens, positions
+
+    def _encode_ordinary_with_positions(
+        self, text: str, offset: int, tokens: list[int], positions: list[int]
+    ) -> None:
+        """Encodes ordinary (non-special) text, appending tokens and their positions in place."""
+        _unused_pat = regex.compile(self._pat_str)
+        for match in regex.finditer(_unused_pat, text):
+            piece_tokens = self._core_bpe.encode_single_piece(match.group().encode("utf-8"))
+            tokens.extend(piece_tokens)
+            positions.extend([offset + match.start()] * len(piece_tokens))
+
     def _encode_bytes(self, text: bytes) -> list[int]:
