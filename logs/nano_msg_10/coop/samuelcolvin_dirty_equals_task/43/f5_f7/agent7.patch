+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, specifically checking the length of the hash, and that it's
+    a valid hexadecimal string.
+    """
+
+    def __init__(self, algorithm: HashTypes):
+        """
+        Args:
+            algorithm: The algorithm of the hash, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`, `'sha384'`
+                or `'sha512'`.
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert 'da39a3ee5e6b4b0d3255bfef95601890afd80709' == IsHash('sha1')
+        assert 'not-a-hash' != IsHash('sha1')
+        ```
+        """
+        self.algorithm = algorithm
+        self.expected_length = hash_expected_length[algorithm.lower()]  # type: ignore[index]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.expected_length:
+            return False
+
+        return all(c in string.hexdigits for c in other)
