+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose ``default`` is a mapping of other
+        option declarations to value-based overrides, e.g.
+        ``default={"--protocol": {"http": 80, "https": 443}}``.
+
+        This runs after every parameter has consumed its command line
+        argument, environment variable, and configuration value, so the
+        mapping can be resolved using the final values of the options it
+        depends on. Only applies to options whose value still comes from
+        their default, i.e. no explicit value was provided.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in param.default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if opt_name in (*p.opts, *p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                value = param.process_value(ctx, resolved)
+
+                if param.expose_value:
+                    ctx.params[param.name] = value  # type: ignore[index]
+
