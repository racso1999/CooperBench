index c2e850c36..e66d81776 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,44 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "red")
+        im.save(temp_file)
+        with Image.open(temp_file) as original:
+            original.load()
+
+        im2 = Image.new("RGB", (10, 10), "blue")
+        im2.save(temp_file, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        with Image.open(backup_file) as backup:
+            assert backup.getpixel((0, 0)) == original.getpixel((0, 0))
+        with Image.open(temp_file) as saved:
+            assert saved.getpixel((0, 0)) == im2.getpixel((0, 0))
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "red")
+        im.save(temp_file)
+
+        im2 = Image.new("RGB", (10, 10), "blue")
+        im2.save(temp_file, backup=True, backup_suffix=".backup")
+
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "red")
+        im.save(temp_file, backup=True)
+
+        assert not (tmp_path / "temp.png.bak").exists()
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
