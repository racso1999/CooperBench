     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, Image.MEDIANCUT, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, 32 * 3, 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, Image.MEDIANCUT, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+
+    def brightness(i):
+        r, g, b = palette[i : i + 3]
+        return r * 299 + g * 587 + b * 114
+
+    brightnesses = [brightness(i) for i in range(0, 32 * 3, 3)]
+    assert brightnesses == sorted(brightnesses)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def sort_by_red_descending(color):
+        return -color[0]
+
+    converted = image.quantize(32, Image.MEDIANCUT, sort_palette=sort_by_red_descending)
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    reds = [palette[i] for i in range(0, 32 * 3, 3)]
+    assert reds == sorted(reds, reverse=True)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, Image.MEDIANCUT, sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_ignored_with_reference_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette_image:
+        palette_image = palette_image.convert("P")
+
+    converted = image.quantize(
+        dither=0, palette=palette_image, sort_palette="brightness"
+    )
+    assert converted.palette.palette == palette_image.palette.palette
