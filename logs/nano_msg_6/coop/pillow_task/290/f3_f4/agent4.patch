+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be trivially satisfied with very few colors
+    lenient = image.quantize(colors=256, error_threshold=1000)
+    assert len(lenient.getcolors()) <= 256
+
+    # A threshold of 0 should behave like no threshold was given at all
+    baseline = image.quantize(colors=32)
+    disabled = image.quantize(colors=32, error_threshold=0)
+    assert disabled.tobytes() == baseline.tobytes()
+
+    # If the threshold can't be met within the given number of colors,
+    # the maximum number of colors should be used
+    strict = image.quantize(colors=4, error_threshold=0.001)
+    assert len(strict.getcolors()) <= 4
+
