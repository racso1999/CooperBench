+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using the fewest colors (down to 2) that still keep the
+        mean square error against the original image at or below
+        ``error_threshold``, falling back to ``colors`` if no smaller
+        palette meets the threshold.
+        """
+        from . import ImageChops, ImageStat
+
+        original = self.convert("RGB")
+
+        def mse(candidate):
+            diff = ImageChops.difference(original, candidate.convert("RGB"))
+            stat = ImageStat.Stat(diff)
+            return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+        low, high = 2, colors
+        best = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = self._new(self.im.quantize(mid, method, kmeans))
+            if mse(candidate) <= error_threshold:
+                best = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best is None:
+            best = self._new(self.im.quantize(colors, method, kmeans))
+        return best
+
