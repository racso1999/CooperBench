+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose default is a mapping of other option
+        values to a default value, once every option has an initial
+        value.
+
+        A dynamic default only takes effect if the option's value still
+        comes from its (unresolved) default, and only if one of the
+        referenced source options has a value matching one of the keys
+        in its mapping. If multiple source options are given, later ones
+        take precedence when they also match.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param, Option) or param.name is None:
+                continue
+
+            dynamic_default = param._dynamic_default
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:
+                continue
+
+            resolved: t.Any = None
+
+            for source_decl, value_map in dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if isinstance(p, Option)
+                        and p.name is not None
+                        and (source_decl in p.opts or source_decl in p.secondary_opts)
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+                key = str(source_value)
+
+                if key in value_map:
+                    resolved = value_map[key]
+
+            if resolved is not None:
+                ctx.params[param.name] = resolved
+
