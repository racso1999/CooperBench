+
+
+_PHONE_NUMBER_CLEAN_RE = re.compile(r'[\s\-.()]')
+_GENERIC_INTERNATIONAL_PHONE_RE = re.compile(r'^\+[1-9]\d{6,14}$')
+_GENERIC_NATIONAL_PHONE_RE = re.compile(r'^\d{7,15}$')
+
+_COUNTRY_PHONE_RULES: Dict[str, Dict[str, Any]] = {
+    'US': {
+        'national': re.compile(r'^\d{10}$'),
+        'international': re.compile(r'^\+1\d{10}$'),
+    },
+    'GB': {
+        'national': re.compile(r'^0\d{9,10}$'),
+        'international': re.compile(r'^\+44\d{9,10}$'),
+    },
+}
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: An optional ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) used to restrict
+                validation to that country's phone number formats. If omitted, generic validation is used
+                which accepts common national and international formats.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert 'not a phone number' != IsPhoneNumber
+
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        ```
+        """
+        self.country = country
+        super().__init__(self.country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = _PHONE_NUMBER_CLEAN_RE.sub('', other)
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(_GENERIC_INTERNATIONAL_PHONE_RE.match(cleaned) or _GENERIC_NATIONAL_PHONE_RE.match(cleaned))
+
+        rules = _COUNTRY_PHONE_RULES.get(self.country.upper())
+        if rules is None:
+            # unknown country, fall back to generic international validation
+            return bool(_GENERIC_INTERNATIONAL_PHONE_RE.match(cleaned))
+
+        return bool(rules['national'].match(cleaned) or rules['international'].match(cleaned))
