+# Global registry of custom filters that are made available to every
+# prompt template, in addition to the filters built into `outlines`.
+GLOBAL_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter in the global filter registry.
+
+    Once registered, the filter becomes available to every prompt template
+    (via `{{ ... | name }}`) without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be exposed in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    GLOBAL_FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry, if present."""
+    GLOBAL_FILTERS.pop(name, None)
+
 
