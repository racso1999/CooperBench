+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a pragmatically valid phone number, optionally restricted to the format
+    of a specific country.
+    """
+
+    # (national digit-count, national leading digit prefix, country-code digit-count, country-code prefix)
+    _country_rules: Dict[str, Tuple[int, str, int, str]] = {
+        'US': (10, '', 11, '1'),
+        'GB': (11, '0', 12, '44'),
+    }
+
+    _allowed_chars_re = re.compile(r'^\+?[\d\s\-.()]+$')
+    _non_digits_re = re.compile(r'\D')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code to restrict validation to, if omitted, generic
+                international/national phone number formats are accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '+33 1 42 68 53 00' == IsPhoneNumber('FR')
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country if self.country else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        value = other.strip()
+        if not value or not self._allowed_chars_re.match(value):
+            return False
+
+        has_country_code = value.startswith('+')
+        digits = self._non_digits_re.sub('', value)
+        if not digits:
+            return False
+
+        if self.country is None:
+            return 7 <= len(digits) <= 15
+
+        rule = self._country_rules.get(self.country)
+        if rule is None:
+            # unknown country, fall back to generic international validation
+            return has_country_code and 8 <= len(digits) <= 18
+
+        national_len, national_prefix, intl_len, intl_prefix = rule
+        if has_country_code:
+            return len(digits) == intl_len and digits.startswith(intl_prefix)
+        else:
+            return len(digits) == national_len and (not national_prefix or digits.startswith(national_prefix))
+
