@@ -11,6 +11,42 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+# Registry of filters that should be made available to every prompt
+# template, without having to be passed explicitly to each of them.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a filter to make it available to all prompt templates.
+
+    Once registered, the filter can be used in any template rendered
+    through `Prompt`, e.g. `{{ text | my_filter }}`, without having to
+    pass it explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
