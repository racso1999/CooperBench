+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A generous threshold should be satisfiable with fewer than the
+    # requested maximum number of colors.
+    reduced = image.quantize(colors=256, error_threshold=50)
+    assert_image(reduced, "P", reduced.size)
+    assert len(reduced.getcolors()) < 256
+
+    # An unreachable threshold should fall back to using the maximum
+    # number of colors allowed.
+    maxed_out = image.quantize(colors=32, error_threshold=0.0001)
+    assert_image(maxed_out, "P", maxed_out.size)
+    assert len(maxed_out.getcolors()) == 32
+
+    # error_threshold=0 (the default) should behave exactly as before,
+    # always using the requested number of colors.
+    unthresholded = image.quantize(colors=32)
+    assert_image(unthresholded, "P", unthresholded.size)
+    assert len(unthresholded.getcolors()) == 32
+
