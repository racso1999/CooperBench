+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+
+        # No existing file, so no backup should be created
+        im.save(out, backup=True)
+        assert not (tmp_path / "temp.png.bak").exists()
+
+        # File exists, so a backup should be created
+        original_data = out.read_bytes()
+        im.rotate(45).save(out, backup=True)
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_data
+
+        with Image.open(out) as reloaded:
+            assert_image_equal(im.rotate(45), reloaded)
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        original_data = out.read_bytes()
+        im.rotate(45).save(out, backup=True, backup_suffix=".backup")
+        backup_file = tmp_path / "temp.png.backup"
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_data
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        im.rotate(45).save(out)
+        assert not (tmp_path / "temp.png.bak").exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
         with Image.open(Path("Tests/images/multipage-mmap.tiff")) as im:
             assert im.mode == "P"
