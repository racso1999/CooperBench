+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        mapping of other option declarations to value lookups (see
+        :class:`Option`). Runs after every parameter has consumed its
+        command line, environment variable, and config file value, so
+        that dynamic defaults can be based on the final resolved values
+        of the options they depend on.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) != ParameterSource.DEFAULT:
+                continue
+
+            resolved = None
+
+            for opt_decl, mapping in dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if opt_decl in p.opts or opt_decl in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                match = mapping.get(str(source_value))
+
+                if match is not None:
+                    resolved = match
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)
+
