+def _batched(
+    iterable: cabc.Iterable[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Yield successive tuples of up to ``batch_size`` items from
+    ``iterable``, including a final, possibly shorter, tuple.
+    """
+    iterator = iter(iterable)
+    while chunk := tuple(islice(iterator, batch_size)):
+        yield chunk
