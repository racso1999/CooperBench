+    def _quantize_mse(self, quantized_im):
+        """
+        Computes the mean square error, across all channels, between this
+        image and a quantized version of it. Used by :py:meth:`~PIL.Image.
+        Image.quantize` to evaluate ``error_threshold``.
+        """
+        from . import ImageChops, ImageStat
+
+        original_rgb = self.convert("RGB")
+        quantized_rgb = quantized_im.convert("RGB")
+        diff = ImageChops.difference(original_rgb, quantized_rgb)
+        stat = ImageStat.Stat(diff)
+
+        total_sum2 = sum(stat.sum2)
+        total_count = sum(stat.count)
+        return total_sum2 / total_count if total_count else 0
+
+    def _adjust_palette_lightness(self, lightness_factor):
+        """
+        Multiplies each color channel of this image's palette by
+        ``lightness_factor``, clamping results to 0-255, and installs the
+        adjusted palette. Used by :py:meth:`~PIL.Image.Image.quantize`.
+        """
+        self.load()
+
+        mode = self.im.getpalettemode()
+        channels = len(mode)
+        data = bytearray(self.im.getpalette(mode, mode))
+        for i in range(0, len(data), channels):
+            # Only adjust color channels, leaving any alpha channel alone.
+            for c in range(min(channels, 3)):
+                value = round(data[i + c] * lightness_factor)
+                data[i + c] = max(0, min(255, value))
+        self.putpalette(bytes(data), mode)
+
