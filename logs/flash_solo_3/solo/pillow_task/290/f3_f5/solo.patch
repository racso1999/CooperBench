diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..1fc932eb8 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,54 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    brightness = [
+        palette[i] * 299 + palette[i + 1] * 587 + palette[i + 2] * 114
+        for i in range(0, len(palette), 3)
+    ]
+    assert brightness == sorted(brightness)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 25)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="invalid")
+
+
+def test_lightness_factor():
+    image = hopper()
+
+    unchanged = image.quantize(32, lightness_factor=1.0)
+    brighter = image.quantize(32, lightness_factor=1.5)
+    darker = image.quantize(32, lightness_factor=0.5)
+
+    assert sum(brighter.getpalette()) > sum(unchanged.getpalette())
+    assert sum(darker.getpalette()) < sum(unchanged.getpalette())
+
+
+def test_lightness_factor_clamped():
+    image = hopper()
+    converted = image.quantize(32, lightness_factor=10)
+    assert max(converted.getpalette()) == 255
+
+    converted = image.quantize(32, lightness_factor=0)
+    assert max(converted.getpalette()) == 0
