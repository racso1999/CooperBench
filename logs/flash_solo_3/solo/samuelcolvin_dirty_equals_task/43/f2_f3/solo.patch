+class IsMac(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid MAC address, optionally checking the format.
+    """
+
+    _mac_regexes = {
+        'colon': re.compile(r'^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$'),
+        'hyphen': re.compile(r'^([0-9a-fA-F]{2}-){5}[0-9a-fA-F]{2}$'),
+        'dot': re.compile(r'^([0-9a-fA-F]{4}\.){2}[0-9a-fA-F]{4}$'),
+        'compact': re.compile(r'^[0-9a-fA-F]{12}$'),
+    }
+
+    def __init__(self, format: Literal[None, 'colon', 'hyphen', 'dot', 'compact'] = None):
+        """
+        Args:
+            format: The format of the MAC address to check, if omitted, any recognised format is accepted.
+
+        ```py title="IsMac"
+        from dirty_equals import IsMac
+
+        assert '00:1B:44:11:3A:B7' == IsMac
+        assert '00:1b:44:11:3a:b7' == IsMac
+        assert '00-1B-44-11-3A-B7' == IsMac('hyphen')
+        assert '001B.4411.3AB7' == IsMac('dot')
+        assert '001b44113ab7' == IsMac('compact')
+        assert '00:1B:44:11:3A:B7' != IsMac('hyphen')
+        assert 'not-a-mac-address' != IsMac
+        ```
+        """
+        if format is not None and format not in self._mac_regexes:
+            raise ValueError(f'Invalid format {format!r}, must be one of {", ".join(self._mac_regexes)}')
+        self.format = format
+        super().__init__(format or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if self.format is not None:
+            return bool(self._mac_regexes[self.format].fullmatch(other))
+
+        return any(regex.fullmatch(other) for regex in self._mac_regexes.values())
+
+
+class IsEmail(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid email address, optionally checking the domain.
+    """
+
+    _email_regex = re.compile(r'^[^@\s]+@[^@\s]+\.[^@\s]+$')
+
+    def __init__(self, domain: Optional[str] = None):
+        """
+        Args:
+            domain: The domain the email address must belong to, if omitted, any domain is accepted.
+
+        ```py title="IsEmail"
+        from dirty_equals import IsEmail
+
+        assert 'sam@example.com' == IsEmail
+        assert 'sam@example.com' == IsEmail(domain='example.com')
+        assert 'sam@example.com' != IsEmail(domain='other.com')
+        assert 'not-an-email' != IsEmail
+        ```
+        """
+        self.domain = domain
+        super().__init__(domain or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str) or not self._email_regex.fullmatch(other):
+            return False
+
+        if self.domain is not None:
+            return other.rsplit('@', 1)[-1] == self.domain
+
+        return True
