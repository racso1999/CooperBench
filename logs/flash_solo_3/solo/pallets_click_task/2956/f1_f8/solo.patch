+    def _resolve_option_history_name(self, name: str) -> str:
+        """Resolve a parameter name or option flag (e.g. ``"--count"`` or
+        ``"-c"``) to the parameter's canonical name (e.g. ``"count"``).
+        """
+        for param in self.command.params:
+            if name == param.name or name in param.opts or name in param.secondary_opts:
+                if param.name is not None:
+                    return param.name
+
+        return name
+
+    def record_option_change(self, name: str, value: t.Any, source: ParameterSource) -> None:
+        """Record a value change for a parameter in the option history.
+        Does nothing unless history tracking is enabled for this context.
+
+        :param name: The canonical parameter name.
+        :param value: The value that was set.
+        :param source: The :class:`ParameterSource` the value came from.
+        """
+        if not self._track_changes:
+            return
+
+        import time
+
+        self._option_history.setdefault(name, []).append(
+            {"value": value, "source": source, "timestamp": time.time()}
+        )
+
+    def get_option_history(self, name: str) -> list[dict[str, t.Any]] | None:
+        """Get the recorded history of values for an option, in the
+        order they were set.
+
+        Accepts either the parameter name (``"count"``) or one of its
+        option flags (``"--count"``, ``"-c"``).
+
+        :param name: The parameter name or option flag.
+        :return: ``None`` if history tracking is disabled for this
+            context, an empty list if tracking is enabled but the option
+            has no recorded history (or does not exist), otherwise a
+            list of history entries with ``value``, ``source``, and
+            ``timestamp`` keys.
+        """
+        if not self._track_changes:
+            return None
+
+        resolved_name = self._resolve_option_history_name(name)
+        return self._option_history.get(resolved_name, [])
+
 
