+class _EditorProcessMonitor:
+    """Runs in a background thread while an editor subprocess is
+    active and reports lifecycle events to a user-supplied callback.
+
+    Suspend/resume detection relies on ``/proc/<pid>/stat`` and is
+    therefore only available on Linux; it is silently skipped
+    elsewhere.
+    """
+
+    _POLL_INTERVAL = 0.2
+
+    def __init__(
+        self,
+        callback: t.Callable[[str, int, str, float], None],
+        process: t.Any,
+        editor_command: str,
+    ) -> None:
+        self.callback = callback
+        self.process = process
+        self.editor_command = editor_command
+        self._terminated = False
+        self._stop_event: t.Any = None
+        self._thread: t.Any = None
+
+    def start(self) -> None:
+        import threading
+
+        self._stop_event = threading.Event()
+        self._thread = threading.Thread(target=self._run, daemon=True)
+        self._invoke_callback("start")
+        self._thread.start()
+
+    def stop(self) -> None:
+        if self._stop_event is not None:
+            self._stop_event.set()
+        if self._thread is not None:
+            self._thread.join()
+        if not self._terminated:
+            self._terminated = True
+            self._invoke_callback("terminate")
+
+    def _invoke_callback(self, event_type: str) -> None:
+        import warnings
+
+        try:
+            self.callback(event_type, self.process.pid, self.editor_command, time.time())
+        except Exception as e:
+            warnings.warn(
+                f"monitor_process callback raised an exception for event "
+                f"{event_type!r}: {e}",
+                UserWarning,
+                stacklevel=2,
+            )
+
+    def _get_process_state(self) -> str | None:
+        if WIN:
+            return None
+
+        try:
+            with open(f"/proc/{self.process.pid}/stat") as f:
+                data = f.read()
+            return data.rsplit(") ", 1)[-1].split(" ", 1)[0]
+        except OSError:
+            return None
+
+    def _run(self) -> None:
+        suspended = False
+
+        while not self._stop_event.is_set():
+            if self.process.poll() is not None:
+                self._terminated = True
+                self._invoke_callback("terminate")
+                return
+
+            state = self._get_process_state()
+
+            if state == "T" and not suspended:
+                suspended = True
+                self._invoke_callback("suspend")
+            elif state is not None and state != "T" and suspended:
+                suspended = False
+                self._invoke_callback("resume")
+
+            self._stop_event.wait(self._POLL_INTERVAL)
+
+
