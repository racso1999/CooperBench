+    def add_alias(self, alias: str, target: str) -> None:
+        """Register ``alias`` as another name that resolves to the
+        ``target`` template. Loading ``alias`` will load ``target``
+        instead. Aliases do not chain: if ``target`` is itself
+        registered as an alias, it is used literally rather than
+        resolved further.
+
+        Calling this again with an existing ``alias`` overwrites the
+        previous target.
+
+        :param alias: The name that should resolve to ``target``.
+        :param target: The template name ``alias`` resolves to.
+
+        .. versionadded:: 3.1
+        """
+        self._get_alias_map()[alias] = target
+
+    def remove_alias(self, alias: str) -> None:
+        """Remove a previously registered alias. Does nothing if
+        ``alias`` was not registered.
+
+        :param alias: The alias name to remove.
+
+        .. versionadded:: 3.1
+        """
+        self._get_alias_map().pop(alias, None)
+
+    def _get_alias_map(self) -> t.Dict[str, str]:
+        # Stored lazily so subclasses don't need to call
+        # ``BaseLoader.__init__``/``super().__init__()``.
+        aliases = self.__dict__.get("_aliases")
+        if aliases is None:
+            aliases = {}
+            self._aliases = aliases
+        return aliases
+
+    def _resolve_alias(self, template: str) -> str:
+        return self._get_alias_map().get(template, template)
+
