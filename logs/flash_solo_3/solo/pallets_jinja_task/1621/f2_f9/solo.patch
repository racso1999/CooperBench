+    def _on_template_changed(self, file_paths: t.List[str]) -> None:
+        """Invalidate cached templates whose source files were
+        modified, removed, or added, across every environment tracked
+        by this loader. Intended for use by a file system watcher, and
+        exposed for manual invalidation in tests.
+
+        :param file_paths: Absolute paths of files that changed.
+        """
+        names = set()
+
+        for file_path in file_paths:
+            file_path = os.path.abspath(file_path)
+
+            for searchpath in self.searchpath:
+                searchpath = os.path.abspath(searchpath)
+
+                try:
+                    common = os.path.commonpath([file_path, searchpath])
+                except ValueError:
+                    # paths don't share a drive (Windows) or other
+                    # incomparable path, skip this search path.
+                    continue
+
+                if common != searchpath:
+                    continue
+
+                name = os.path.relpath(file_path, searchpath).replace(
+                    os.path.sep, "/"
+                )
+                names.add(name)
+                break
+
+        if not names:
+            return
+
+        for environment in self._environments:
+            cache = environment.cache
+
+            if cache is None:
+                continue
+
+            for name in names:
+                key = (weakref.ref(self), name)
+
+                if key in cache:
+                    del cache[key]
+
