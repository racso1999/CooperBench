+// EnableCORS turns on built-in CORS support for the router, using
+// DefaultCORSOptions(). It must be called before any routes are
+// registered, following the same rule as Use().
+func (mx *Mux) EnableCORS() {
+	mx.EnableCORSWithOptions(DefaultCORSOptions())
+}
+
+// EnableCORSWithOptions turns on built-in CORS support for the router,
+// using the given options. It applies the CORS middleware to the router
+// and configures the method-not-allowed handler so that preflight
+// OPTIONS requests are answered automatically. It must be called before
+// any routes are registered, following the same rule as Use().
+func (mx *Mux) EnableCORSWithOptions(options CORSOptions) {
+	mx.Use(CORS(options))
+	mx.MethodNotAllowed(corsPreflightHandler(options))
+}
+
+// WithCORS returns a new inline-Mux, with built-in CORS support enabled
+// using DefaultCORSOptions(). See EnableCORS and With.
+func (mx *Mux) WithCORS() Router {
+	im := mx.With(CORS(DefaultCORSOptions())).(*Mux)
+	im.MethodNotAllowed(corsPreflightHandler(DefaultCORSOptions()))
+	return im
+}
+
