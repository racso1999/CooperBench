diff --git a/cors.go b/cors.go
new file mode 100644
index 0000000..8cc5021
--- /dev/null
+++ b/cors.go
@@ -0,0 +1,121 @@
+package chi
+
+import (
+	"net/http"
+	"strconv"
+	"strings"
+)
+
+// CORSOptions describes the configuration used by CORS to set
+// Cross-Origin Resource Sharing headers on responses, and how to
+// respond to preflight OPTIONS requests.
+type CORSOptions struct {
+	// AllowOrigin is the value written to the Access-Control-Allow-Origin
+	// header. Defaults to "*".
+	AllowOrigin string
+
+	// AllowMethods is the value written to the
+	// Access-Control-Allow-Methods header on preflight responses. If
+	// empty, the methods registered for the requested route are used.
+	AllowMethods []string
+
+	// AllowHeaders is the value written to the
+	// Access-Control-Allow-Headers header on preflight responses.
+	AllowHeaders []string
+
+	// ExposeHeaders is the value written to the
+	// Access-Control-Expose-Headers header.
+	ExposeHeaders []string
+
+	// MaxAge is the value, in seconds, written to the
+	// Access-Control-Max-Age header on preflight responses.
+	MaxAge int
+
+	// AllowCredentials sets the Access-Control-Allow-Credentials header
+	// to "true" when enabled.
+	AllowCredentials bool
+}
+
+// DefaultCORSOptions returns a CORSOptions with sensible defaults: any
+// origin allowed, a handful of common request headers allowed, and a
+// one hour preflight cache.
+func DefaultCORSOptions() CORSOptions {
+	return CORSOptions{
+		AllowOrigin:   "*",
+		AllowHeaders:  []string{"Accept", "Content-Type", "Content-Length", "Authorization"},
+		ExposeHeaders: []string{},
+		MaxAge:        3600,
+	}
+}
+
+// CORS returns a middleware that sets Cross-Origin Resource Sharing
+// headers on every response according to options, and completes
+// preflight OPTIONS requests. Preflight requests that don't match a
+// registered route are still routed as usual, so a Mux's
+// MethodNotAllowedHandler must know to respond to them; see
+// Mux.EnableCORS and Mux.EnableCORSWithOptions.
+func CORS(options CORSOptions) func(http.Handler) http.Handler {
+	return func(next http.Handler) http.Handler {
+		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			header := w.Header()
+
+			allowOrigin := options.AllowOrigin
+			if allowOrigin == "" {
+				allowOrigin = "*"
+			}
+			header.Set("Access-Control-Allow-Origin", allowOrigin)
+
+			if options.AllowCredentials {
+				header.Set("Access-Control-Allow-Credentials", "true")
+			}
+			if len(options.ExposeHeaders) > 0 {
+				header.Set("Access-Control-Expose-Headers", strings.Join(options.ExposeHeaders, ", "))
+			}
+
+			if r.Method == http.MethodOptions && r.Header.Get("Access-Control-Request-Method") != "" {
+				if len(options.AllowHeaders) > 0 {
+					header.Set("Access-Control-Allow-Headers", strings.Join(options.AllowHeaders, ", "))
+				}
+				if options.MaxAge > 0 {
+					header.Set("Access-Control-Max-Age", strconv.Itoa(options.MaxAge))
+				}
+			}
+
+			next.ServeHTTP(w, r)
+		})
+	}
+}
+
+// corsPreflightHandler returns the handler installed as a Mux's
+// MethodNotAllowedHandler by EnableCORS/EnableCORSWithOptions. Preflight
+// OPTIONS requests reach here because OPTIONS is typically not a
+// registered method on a route, so it falls through chi's regular 405
+// handling; this responds to genuine preflight requests with 204 and
+// Access-Control-Allow-Methods, and otherwise behaves like the default
+// 405 handler.
+func corsPreflightHandler(options CORSOptions) http.HandlerFunc {
+	return func(w http.ResponseWriter, r *http.Request) {
+		rctx := RouteContext(r.Context())
+		var allowed []string
+		if rctx != nil {
+			allowed = rctx.AllowedMethods()
+		}
+
+		if r.Method == http.MethodOptions && r.Header.Get("Access-Control-Request-Method") != "" {
+			methods := options.AllowMethods
+			if len(methods) == 0 {
+				methods = allowed
+			}
+			if len(methods) > 0 {
+				w.Header().Set("Access-Control-Allow-Methods", strings.Join(methods, ", "))
+			}
+			w.WriteHeader(http.StatusNoContent)
+			return
+		}
+
+		if len(allowed) > 0 {
+			w.Header().Set("Allow", strings.Join(allowed, ", "))
+		}
+		w.WriteHeader(http.StatusMethodNotAllowed)
+	}
+}
