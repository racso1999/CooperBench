+    def _token_positions(
+        self, tokens: Sequence[int], *, token_bytes: list[bytes] | None = None
+    ) -> list[int]:
+        """Computes the starting character position of each token, relative to the text
+        that would be produced by decoding `tokens`.
+        """
+        if token_bytes is None:
+            token_bytes = self.decode_tokens_bytes(tokens)
+
+        text_len = 0
+        positions = []
+        for token in token_bytes:
+            positions.append(max(0, text_len - (0x80 <= token[0] < 0xC0)))
+            text_len += sum(1 for c in token if not 0x80 <= c < 0xC0)
+        return positions
+
+    def _compress_tokens(
+        self, tokens: list[int], positions: list[int] | None = None
+    ) -> tuple[list[int], list[int] | None]:
+        """Removes adjacent repeated tokens, keeping the first occurrence of each run."""
+        if not tokens:
+            return tokens, positions
+
+        compressed_tokens = [tokens[0]]
+        compressed_positions = [positions[0]] if positions is not None else None
+        for i in range(1, len(tokens)):
+            if tokens[i] != tokens[i - 1]:
+                compressed_tokens.append(tokens[i])
+                if positions is not None:
+                    compressed_positions.append(positions[i])
+        return compressed_tokens, compressed_positions
+
