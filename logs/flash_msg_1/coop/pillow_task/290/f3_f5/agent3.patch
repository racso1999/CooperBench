diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..3501858b3 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,48 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _quantized_colors(image):
+    colors = []
+    for _, index in sorted(image.getcolors()):
+        r, g, b = image.palette.palette[index * 3 : index * 3 + 3]
+        colors.append((r, g, b))
+    return colors
+
+
+def test_sort_palette_brightness():
+    image = Image.new("RGB", (4, 1))
+    image.putpixel((0, 0), (255, 0, 0))
+    image.putpixel((1, 0), (0, 255, 0))
+    image.putpixel((2, 0), (0, 0, 255))
+    image.putpixel((3, 0), (255, 255, 255))
+
+    converted = image.quantize(colors=4, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 1)
+
+    colors = _quantized_colors(converted)
+    brightness = [0.299 * r + 0.587 * g + 0.114 * b for r, g, b in colors]
+    assert brightness == sorted(brightness)
+
+
+def test_sort_palette_rgb():
+    image = Image.new("RGB", (4, 1))
+    image.putpixel((0, 0), (255, 0, 0))
+    image.putpixel((1, 0), (0, 255, 0))
+    image.putpixel((2, 0), (0, 0, 255))
+    image.putpixel((3, 0), (255, 255, 255))
+
+    converted = image.quantize(colors=4, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 1)
+
+    colors = _quantized_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="invalid")
