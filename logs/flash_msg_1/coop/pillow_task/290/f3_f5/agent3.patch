+    def _sort_palette(self, sort_palette):
+        """
+        Sorts the colors of a "P" mode image's palette, remapping the
+        image's pixel data to match the new palette order.
+
+        :param sort_palette: ``"brightness"`` to sort colors from darkest
+           to lightest, or ``"rgb"`` to sort colors by their raw channel
+           values.
+        :returns: A new image with a sorted palette.
+        """
+        if sort_palette not in ("brightness", "rgb"):
+            raise ValueError('sort_palette must be "brightness" or "rgb"')
+
+        mode = self.palette.mode
+        channels = len(mode)
+        palette_data = self.palette.palette
+        num_colors = len(palette_data) // channels
+        colors = [
+            tuple(palette_data[i * channels : (i + 1) * channels])
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "brightness":
+
+            def key(color):
+                r, g, b = color[0], color[1], color[2]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        else:
+
+            def key(color):
+                return color
+
+        order = sorted(range(num_colors), key=lambda i: key(colors[i]))
+
+        lut = list(range(256))
+        for new_index, old_index in enumerate(order):
+            lut[old_index] = new_index
+
+        im = self.point(lut)
+
+        new_palette_data = bytearray()
+        for old_index in order:
+            new_palette_data.extend(colors[old_index])
+        im.putpalette(new_palette_data, mode)
+
         return im
 
