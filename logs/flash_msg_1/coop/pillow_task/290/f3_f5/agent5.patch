+    def _adjust_palette_lightness(self, lightness_factor):
+        # Scales each non-alpha palette channel and pushes the result back
+        # to both the low-level palette and the ImagePalette wrapper.
+        mode = self.im.getpalettemode()
+        channels = len(mode)
+        data = bytearray(self.im.getpalette(mode, mode))
+        for i in range(0, len(data), channels):
+            for c in range(channels):
+                if mode[c] == "A":
+                    continue
+                value = round(data[i + c] * lightness_factor)
+                data[i + c] = max(0, min(255, value))
+
+        if mode == "RGBA":
+            rgb = bytes(byte for i, byte in enumerate(data) if i % 4 != 3)
+            alpha = bytes(data[3::4])
+            self.im.putpalette("RGB", rgb)
+            self.im.putpalettealphas(alpha)
+        else:
+            self.im.putpalette("RGB", bytes(data))
+
+        from . import ImagePalette
+
+        self.palette = ImagePalette.ImagePalette(mode, self.im.getpalette(mode, mode))
+
