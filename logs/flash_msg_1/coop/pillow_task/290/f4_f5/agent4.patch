diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..32b360cd0 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,46 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+
+    high_threshold = image.quantize(colors=256, error_threshold=1000)
+    low_threshold = image.quantize(colors=256, error_threshold=1)
+
+    assert len(high_threshold.getcolors()) < len(low_threshold.getcolors())
+    assert len(high_threshold.getcolors()) <= 256
+    assert len(low_threshold.getcolors()) <= 256
+
+
+def test_quantize_error_threshold_solid_color():
+    # A solid color image should need very few colors to stay under
+    # a generous error threshold.
+    im = Image.new("RGB", (100, 100), (255, 0, 0))
+    converted = im.quantize(colors=256, error_threshold=10)
+
+    assert len(converted.getcolors()) < 256
+
+
+def test_quantize_error_threshold_falls_back_to_colors():
+    # If the threshold can't be reached, use the max number of colors.
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_negative():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_error_threshold_none_is_unaffected():
+    image = hopper()
+
+    assert (
+        image.quantize(colors=64).tobytes()
+        == image.quantize(colors=64, error_threshold=None).tobytes()
+    )
