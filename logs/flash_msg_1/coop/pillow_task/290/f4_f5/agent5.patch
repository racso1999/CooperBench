     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_lightness_factor_no_change():
+    image = hopper()
+    unchanged = image.quantize(colors=8)
+    default_factor = image.quantize(colors=8, lightness_factor=1.0)
+    assert unchanged.palette.palette == default_factor.palette.palette
+
+
+def test_quantize_lightness_factor_brighter():
+    im = Image.new("RGB", (10, 10), (100, 150, 200))
+    original = im.quantize(colors=4)
+    brighter = im.quantize(colors=4, lightness_factor=1.2)
+
+    original_color = next(iter(original.palette.colors))
+    brighter_color = next(iter(brighter.palette.colors))
+    assert brighter_color == (120, 180, 240)
+    assert all(b >= o for o, b in zip(original_color, brighter_color))
+
+
+def test_quantize_lightness_factor_darker():
+    im = Image.new("RGB", (10, 10), (100, 150, 200))
+    original = im.quantize(colors=4)
+    darker = im.quantize(colors=4, lightness_factor=0.5)
+
+    original_color = next(iter(original.palette.colors))
+    darker_color = next(iter(darker.palette.colors))
+    assert darker_color == (50, 75, 100)
+    assert all(d <= o for o, d in zip(original_color, darker_color))
+
+
+def test_quantize_lightness_factor_clamped():
+    im = Image.new("RGB", (10, 10), (200, 210, 220))
+    converted = im.quantize(colors=4, lightness_factor=2.0)
+
+    color = next(iter(converted.palette.colors))
+    assert color == (255, 255, 255)
+
+
+def test_quantize_lightness_factor_with_palette():
+    image = hopper()
+    palette_image = image.quantize(colors=8)
+
+    converted = image.quantize(palette=palette_image, lightness_factor=1.5)
+    unadjusted = image.quantize(palette=palette_image)
+    assert converted.palette.palette != unadjusted.palette.palette
