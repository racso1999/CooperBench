+def test_quantize_max_colors():
+    image = hopper()
+
+    # max_colors defaults to colors, preserving previous behavior
+    converted = image.quantize(100)
+    assert len(converted.getcolors()) == 100
+
+    # max_colors caps the number of colors used, even if colors is higher
+    converted = image.quantize(100, max_colors=50)
+    assert len(converted.getcolors()) <= 50
+
+    # max_colors higher than colors has no effect
+    converted = image.quantize(50, max_colors=100)
+    assert len(converted.getcolors()) == 50
+
+    with pytest.raises(ValueError):
+        image.quantize(100, max_colors=0)
+
+    with pytest.raises(ValueError):
+        image.quantize(100, max_colors=257)
+
+
