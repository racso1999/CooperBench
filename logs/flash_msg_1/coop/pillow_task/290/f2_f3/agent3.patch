diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..f790e51f3 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,28 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+@pytest.mark.parametrize("sort_palette", ("brightness", "rgb"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(32, sort_palette=sort_palette)
+    assert_image(converted, "P", converted.size)
+
+    # The visual result should be unaffected by the palette order
+    unsorted = image.quantize(32)
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    def brightness(color):
+        return 0.299 * color[0] + 0.587 * color[1] + 0.114 * color[2]
+
+    palette = converted.palette.palette
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    key = brightness if sort_palette == "brightness" else tuple
+    assert colors == sorted(colors, key=key)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="bogus")
