@@ -258,6 +258,22 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_frombuffer_save_readonly(self, tmp_path: Path) -> None:
+        # Saving to a different filename should not stop the image from
+        # reflecting changes to the underlying buffer
+        data = bytearray(b"\xff")
+        im = Image.frombuffer("L", (1, 1), data)
+        assert im.readonly
+
+        data[0] = 128
+        assert im.getpixel((0, 0)) == 128
+
+        temp_file = tmp_path / "temp.bmp"
+        im.save(temp_file)
+
+        data[0] = 64
+        assert im.getpixel((0, 0)) == 64
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
