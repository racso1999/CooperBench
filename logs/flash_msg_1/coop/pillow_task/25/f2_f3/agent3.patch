+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        with hopper() as im:
+            im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_does_not_modify_existing_file(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        with hopper() as im:
+            im.save(temp_file)
+        before = temp_file.read_bytes()
+
+        with Image.new("RGB", (1, 1)) as im:
+            im.save(temp_file, dry_run=True)
+        assert temp_file.read_bytes() == before
+
+    def test_dry_run_file_object(self) -> None:
+        fp = io.BytesIO()
+        with hopper() as im:
+            im.save(fp, "PNG", dry_run=True)
+        assert fp.tell() == 0
+        assert fp.getvalue() == b""
+
+    def test_dry_run_raises_on_error(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+        with hopper("RGBA") as im:
+            with pytest.raises(OSError):
+                im.save(temp_file, dry_run=True)
+        assert not os.path.exists(temp_file)
+
     def test_internals(self) -> None:
         im = Image.new("L", (100, 100))
         im.readonly = 1
