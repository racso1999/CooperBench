index c2e850c36..d0264ce70 100644
--- a/Tests/test_image.py
+++ b/Tests/test_image.py
@@ -258,6 +258,19 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_preserve_readonly(self, tmp_path: Path) -> None:
+        temp_file = str(tmp_path / "temp.bmp")
+
+        data = bytearray(b"\xff")
+        im = Image.frombuffer("L", (1, 1), data)
+        assert im.readonly
+
+        im.save(temp_file, preserve_readonly=True)
+        assert im.readonly
+
+        data[0] = 64
+        assert im.getpixel((0, 0)) == 64
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
