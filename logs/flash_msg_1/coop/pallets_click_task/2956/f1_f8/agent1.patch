 ParamTypeValue = t.TypeVar("ParamTypeValue")
 
 
+def _complete_usernames(incomplete: str) -> list[CompletionItem]:
+    """Complete system usernames, for options such as ``--user``."""
+    from .shell_completion import CompletionItem
+
+    try:
+        import pwd
+
+        names = [entry.pw_name for entry in pwd.getpwall()]
+    except (ImportError, OSError):
+        names = []
+
+    return [CompletionItem(name) for name in names if name.startswith(incomplete)]
+
+
+def _complete_git_branches(incomplete: str) -> list[CompletionItem]:
+    """Complete local and remote git branch names, for options such as
+    ``--branch``. Only produces results when run inside a git repository.
+    """
+    import subprocess
+
+    from .shell_completion import CompletionItem
+
+    try:
+        output = subprocess.run(
+            ["git", "branch", "-a", "--format=%(refname:short)"],
+            capture_output=True,
+            text=True,
+            timeout=5,
+        )
+    except (OSError, subprocess.SubprocessError):
+        return []
+
+    if output.returncode != 0:
+        return []
+
+    branches = {line.strip() for line in output.stdout.splitlines() if line.strip()}
+    return [
+        CompletionItem(branch) for branch in branches if branch.startswith(incomplete)
+    ]
+
+
+def _complete_env_vars(incomplete: str) -> list[CompletionItem]:
+    """Complete environment variable names, for options such as ``--env``."""
+    from .shell_completion import CompletionItem
+
+    return [CompletionItem(key) for key in os.environ if key.startswith(incomplete)]
+
+
+def _complete_filesystem_paths(incomplete: str) -> list[CompletionItem]:
+    """Complete filesystem paths, for options such as ``--file``."""
+    from .shell_completion import CompletionItem
+
+    return [CompletionItem(incomplete, type="file")]
+
+
+#: Maps common option name patterns to the smart completion function that
+#: should be used for them. Consulted by
+#: :meth:`~click.core.Option._smart_complete` when an option is declared
+#: with ``auto_complete=True`` and has no manual ``shell_complete`` callback.
+SMART_COMPLETION_PATTERNS: dict[str, t.Callable[[str], "list[CompletionItem]"]] = {
+    "user": _complete_usernames,
+    "username": _complete_usernames,
+    "branch": _complete_git_branches,
+    "git_branch": _complete_git_branches,
+    "file": _complete_filesystem_paths,
+    "filename": _complete_filesystem_paths,
+    "path": _complete_filesystem_paths,
+    "env": _complete_env_vars,
+    "envvar": _complete_env_vars,
+    "environment": _complete_env_vars,
+}
+
+
