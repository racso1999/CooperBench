+    def _popen_priority_kwargs(self) -> dict[str, t.Any]:
+        """Build the extra ``subprocess.Popen`` kwargs needed to apply
+        ``self.process_priority`` to the editor process, if supported on
+        this platform. Returns an empty dict if no priority is set or the
+        platform doesn't support it.
+        """
+        if self.process_priority is None:
+            return {}
+
+        if WIN:
+            priority_class = _WIN_PRIORITY_CLASSES.get(self.process_priority)
+            if priority_class is None:
+                return {}
+            return {"creationflags": priority_class}
+
+        nice_value = _POSIX_PRIORITY_NICE_VALUES.get(self.process_priority)
+        if nice_value is None or not hasattr(os, "nice"):
+            return {}
+
+        def _apply_nice() -> None:
+            try:
+                os.nice(nice_value)
+            except OSError:
+                # Raising a negative nice value (higher priority) commonly
+                # requires elevated privileges. Fall back to default
+                # priority rather than failing the edit operation.
+                pass
+
+        return {"preexec_fn": _apply_nice}
+
