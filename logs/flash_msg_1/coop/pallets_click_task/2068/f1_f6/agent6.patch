+#: Nice values used to translate a ``process_priority`` level into a
+#: POSIX ``os.nice()`` offset. Lower nice values mean higher priority.
+_POSIX_PRIORITY_NICE_VALUES = {
+    "low": 19,
+    "below_normal": 10,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+#: Windows process creation flags for each supported priority level.
+#: Values correspond to the *_PRIORITY_CLASS constants from the Win32 API.
+_WIN_PRIORITY_CLASSES = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+ProcessPriority = t.Literal["low", "below_normal", "normal", "above_normal", "high"]
+
