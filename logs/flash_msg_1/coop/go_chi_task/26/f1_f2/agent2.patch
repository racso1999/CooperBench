index 0000000..5ce3a89
--- /dev/null
+++ b/metrics.go
@@ -0,0 +1,66 @@
+package chi
+
+import (
+	"context"
+	"net/http"
+	"time"
+)
+
+// MetricsCollector is the interface used by a Mux to report route hit
+// metrics. Implementations can forward RouteMetric data to whatever
+// monitoring or observability system the application uses.
+type MetricsCollector interface {
+	// RecordHit is called after a matched route's handler has finished
+	// serving a request.
+	RecordHit(ctx context.Context, r *http.Request, duration time.Duration)
+}
+
+// RouteMetric contains the data collected for a single request that was
+// routed to a matched handler.
+type RouteMetric struct {
+	// Pattern is the routing pattern that matched the request, e.g. "/users/{id}".
+	Pattern string
+
+	// Method is the HTTP method of the request.
+	Method string
+
+	// Path is the request URL path that was routed.
+	Path string
+
+	// Duration is how long the matched handler took to serve the request.
+	Duration time.Duration
+
+	// URLParams are the URL parameters captured while matching the route.
+	URLParams RouteParams
+}
+
+// SimpleMetricsCollector is a MetricsCollector implementation that invokes a
+// user-supplied callback function for each recorded route hit. It's intended
+// for basic metric collection scenarios where a full MetricsCollector
+// implementation isn't necessary.
+type SimpleMetricsCollector struct {
+	// Fn is called with the collected RouteMetric for every recorded hit.
+	Fn func(RouteMetric)
+}
+
+// RecordHit implements the MetricsCollector interface.
+func (c *SimpleMetricsCollector) RecordHit(ctx context.Context, r *http.Request, duration time.Duration) {
+	if c.Fn == nil {
+		return
+	}
+
+	rctx, _ := ctx.Value(RouteCtxKey).(*Context)
+
+	metric := RouteMetric{
+		Method:   r.Method,
+		Path:     r.URL.Path,
+		Duration: duration,
+	}
+
+	if rctx != nil {
+		metric.Pattern = rctx.RoutePattern()
+		metric.URLParams = rctx.URLParams
+	}
+
+	c.Fn(metric)
+}
diff --git a/metrics_test.go b/metrics_test.go
new file mode 100644
index 0000000..3d10343
--- /dev/null
+++ b/metrics_test.go
@@ -0,0 +1,101 @@
+package chi
+
+import (
+	"net/http"
+	"net/http/httptest"
+	"testing"
+	"time"
+)
+
+func TestSimpleMetricsCollectorRecordsHit(t *testing.T) {
+	var got RouteMetric
+	var calls int
+
+	collector := &SimpleMetricsCollector{
+		Fn: func(m RouteMetric) {
+			calls++
+			got = m
+		},
+	}
+
+	r := NewMux()
+	r.SetMetricsCollector(collector)
+	r.Get("/users/{id}", func(w http.ResponseWriter, req *http.Request) {
+		time.Sleep(1 * time.Millisecond)
+		w.WriteHeader(http.StatusOK)
+	})
+
+	ts := httptest.NewServer(r)
+	defer ts.Close()
+
+	req := httptest.NewRequest(http.MethodGet, "/users/123", nil)
+	w := httptest.NewRecorder()
+	r.ServeHTTP(w, req)
+
+	if calls != 1 {
+		t.Fatalf("expected RecordHit to be called once, got %d", calls)
+	}
+	if got.Method != http.MethodGet {
+		t.Errorf("expected method %q, got %q", http.MethodGet, got.Method)
+	}
+	if got.Path != "/users/123" {
+		t.Errorf("expected path %q, got %q", "/users/123", got.Path)
+	}
+	if got.Pattern != "/users/{id}" {
+		t.Errorf("expected pattern %q, got %q", "/users/{id}", got.Pattern)
+	}
+	if got.Duration <= 0 {
+		t.Errorf("expected a positive duration, got %v", got.Duration)
+	}
+
+	found := false
+	for i, key := range got.URLParams.Keys {
+		if key == "id" && got.URLParams.Values[i] == "123" {
+			found = true
+		}
+	}
+	if !found {
+		t.Errorf("expected URLParams to contain id=123, got %+v", got.URLParams)
+	}
+}
+
+func TestNoMetricsCollectorConfigured(t *testing.T) {
+	r := NewMux()
+	r.Get("/ping", func(w http.ResponseWriter, req *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	})
+
+	req := httptest.NewRequest(http.MethodGet, "/ping", nil)
+	w := httptest.NewRecorder()
+	r.ServeHTTP(w, req)
+
+	if w.Code != http.StatusOK {
+		t.Fatalf("expected status 200, got %d", w.Code)
+	}
+}
+
+func TestMetricsCollectorNotCalledOnNotFound(t *testing.T) {
+	var calls int
+	collector := &SimpleMetricsCollector{
+		Fn: func(m RouteMetric) {
+			calls++
+		},
+	}
+
+	r := NewMux()
+	r.SetMetricsCollector(collector)
+	r.Get("/ping", func(w http.ResponseWriter, req *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	})
+
+	req := httptest.NewRequest(http.MethodGet, "/nonexistent", nil)
+	w := httptest.NewRecorder()
+	r.ServeHTTP(w, req)
+
+	if w.Code != http.StatusNotFound {
+		t.Fatalf("expected status 404, got %d", w.Code)
+	}
+	if calls != 0 {
+		t.Fatalf("expected RecordHit not to be called for unmatched routes, got %d calls", calls)
+	}
+}
