+// method not allowed. When methodsAllowed is non-empty, the response
+// includes an Allow header listing the registered methods for the route,
+// in stable order, per RFC 9110.
+func methodNotAllowedHandler(methodsAllowed []methodTyp) http.HandlerFunc {
+	return func(w http.ResponseWriter, r *http.Request) {
+		if allow := allowHeaderValue(methodsAllowed); allow != "" {
+			w.Header().Set("Allow", allow)
+		}
+		w.WriteHeader(405)
+		w.Write(nil)
+	}
+}
+
+// allowHeaderValue builds the value of an Allow header from a list of
+// methodTyp, in a stable order (matching declaration/registration order).
+func allowHeaderValue(methodsAllowed []methodTyp) string {
+	if len(methodsAllowed) == 0 {
+		return ""
+	}
+	return strings.Join(sortedMethodNames(methodsAllowed), ", ")
 }
