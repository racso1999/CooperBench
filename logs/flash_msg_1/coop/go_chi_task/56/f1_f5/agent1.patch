diff --git a/middleware/allowed_methods.go b/middleware/allowed_methods.go
new file mode 100644
index 0000000..06a022b
--- /dev/null
+++ b/middleware/allowed_methods.go
@@ -0,0 +1,53 @@
+package middleware
+
+import (
+	"net/http"
+	"strings"
+
+	"github.com/go-chi/chi/v5"
+)
+
+// standardMethods lists the well-known HTTP methods, in a stable order,
+// that SetAllowHeader probes for when building the Allow header.
+var standardMethods = []string{
+	http.MethodConnect,
+	http.MethodDelete,
+	http.MethodGet,
+	http.MethodHead,
+	http.MethodOptions,
+	http.MethodPatch,
+	http.MethodPost,
+	http.MethodPut,
+	http.MethodTrace,
+}
+
+// SetAllowHeader adds the Allow header for 405 responses based on
+// registered methods for the requested path.
+func SetAllowHeader(next http.Handler) http.Handler {
+	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		rctx := chi.RouteContext(r.Context())
+		if rctx == nil || rctx.Routes == nil {
+			next.ServeHTTP(w, r)
+			return
+		}
+
+		path := r.URL.Path
+
+		if !rctx.Routes.Match(chi.NewRouteContext(), r.Method, path) {
+			var allowed []string
+			for _, method := range standardMethods {
+				if method == r.Method {
+					continue
+				}
+				if rctx.Routes.Match(chi.NewRouteContext(), method, path) {
+					allowed = append(allowed, method)
+				}
+			}
+			if len(allowed) > 0 {
+				w.Header().Set("Allow", strings.Join(allowed, ", "))
+			}
+		}
+
+		next.ServeHTTP(w, r)
+	})
+}
