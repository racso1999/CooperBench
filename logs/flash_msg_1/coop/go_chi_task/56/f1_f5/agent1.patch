+// sortedMethodNames converts a list of methodTyp values into their string
+// names, sorted by declaration/registration order, for a stable result
+// (e.g. when building an Allow header).
+func sortedMethodNames(methods []methodTyp) []string {
+	sorted := make([]methodTyp, len(methods))
+	copy(sorted, methods)
+	sort.Slice(sorted, func(i, j int) bool { return sorted[i] < sorted[j] })
+
+	names := make([]string, 0, len(sorted))
+	for _, mt := range sorted {
+		if name, ok := reverseMethodMap[mt]; ok {
+			names = append(names, name)
