+// allowedMethods returns the list of methodTyp values registered on this
+// leaf node, excluding the internal mSTUB and mALL bookkeeping entries.
+// It's used to populate the Allow header on 405 responses.
+func (n *node) allowedMethods() []methodTyp {
+	methods := make([]methodTyp, 0, len(n.endpoints))
+	for mt, h := range n.endpoints {
+		if mt == mSTUB || mt == mALL {
+			continue
+		}
+		if h != nil && h.handler != nil {
+			methods = append(methods, mt)
+		}
+	}
+	return methods
