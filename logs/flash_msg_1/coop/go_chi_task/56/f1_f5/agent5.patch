+// EnableCORS enables chi's built-in CORS support on the Mux using
+// DefaultCORSOptions().
+func (mx *Mux) EnableCORS() {
+	mx.EnableCORSWithOptions(DefaultCORSOptions())
+}
+
+// EnableCORSWithOptions enables chi's built-in CORS support on the Mux with
+// the given options. It registers the CORS middleware, which sets the
+// "always on" CORS response headers, and a MethodNotAllowed handler that
+// answers preflight OPTIONS requests (204, detecting Access-Control-Allow-Methods
+// from the matched route when possible) and reports the Allow header for
+// genuine method-not-allowed responses.
+func (mx *Mux) EnableCORSWithOptions(options CORSOptions) {
+	mx.Use(CORS(options))
+	mx.MethodNotAllowed(corsPreflightHandler(options))
+}
+
+// WithCORS returns a grouped Router with chi's built-in CORS support enabled
+// using DefaultCORSOptions().
+func (mx *Mux) WithCORS() Router {
+	return mx.Group(func(r Router) {
+		if sub, ok := r.(*Mux); ok {
+			sub.EnableCORSWithOptions(DefaultCORSOptions())
+		}
+	})
+}
