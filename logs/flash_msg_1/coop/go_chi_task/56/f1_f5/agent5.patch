+package chi
+
+import (
+	"net/http"
+	"strconv"
+	"strings"
+)
+
+// CORSOptions describes the configuration for chi's built-in Cross-Origin
+// Resource Sharing (CORS) support.
+type CORSOptions struct {
+	// AllowOrigin sets the Access-Control-Allow-Origin header value.
+	AllowOrigin string
+
+	// AllowMethods sets the Access-Control-Allow-Methods header value used
+	// for preflight requests whenever the methods available on the matched
+	// route cannot be detected.
+	AllowMethods []string
+
+	// AllowHeaders sets the Access-Control-Allow-Headers header value.
+	AllowHeaders []string
+
+	// ExposeHeaders sets the Access-Control-Expose-Headers header value.
+	ExposeHeaders []string
+
+	// MaxAge sets the Access-Control-Max-Age header value, in seconds.
+	MaxAge int
+
+	// AllowCredentials sets the Access-Control-Allow-Credentials header value.
+	AllowCredentials bool
+}
+
+// DefaultCORSOptions returns a CORSOptions with sensible defaults: a
+// wildcard origin, a common set of allowed headers/methods, and a 1 hour
+// (3600 second) max age for preflight caching.
+func DefaultCORSOptions() CORSOptions {
+	return CORSOptions{
+		AllowOrigin: "*",
+		AllowMethods: []string{
+			http.MethodGet,
+			http.MethodHead,
+			http.MethodPost,
+			http.MethodPut,
+			http.MethodPatch,
+			http.MethodDelete,
+			http.MethodOptions,
+		},
+		AllowHeaders: []string{
+			"Accept",
+			"Authorization",
+			"Content-Type",
+			"X-CSRF-Token",
+		},
+		ExposeHeaders:    []string{},
+		MaxAge:           3600,
+		AllowCredentials: false,
+	}
+}
+
+// CORS returns a middleware that applies Cross-Origin Resource Sharing
+// response headers to every request, based on options.
+//
+// CORS only sets the "always on" response headers (Access-Control-Allow-Origin,
+// Access-Control-Allow-Credentials and Access-Control-Expose-Headers). Preflight
+// OPTIONS requests and the Access-Control-Allow-Methods/-Allow-Headers/-Max-Age
+// headers they require are handled by the router's MethodNotAllowed handler,
+// see Mux.EnableCORS and Mux.EnableCORSWithOptions which wire this up
+// automatically.
+func CORS(options CORSOptions) func(http.Handler) http.Handler {
+	exposeHeaders := strings.Join(options.ExposeHeaders, ", ")
+
+	return func(next http.Handler) http.Handler {
+		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			header := w.Header()
+
+			header.Set("Access-Control-Allow-Origin", options.AllowOrigin)
+			if exposeHeaders != "" {
+				header.Set("Access-Control-Expose-Headers", exposeHeaders)
+			}
+			if options.AllowCredentials {
+				header.Set("Access-Control-Allow-Credentials", "true")
+			}
+
+			next.ServeHTTP(w, r)
+		})
+	}
+}
+
+// corsPreflightHandler builds the handler chi's router calls whenever a
+// request's method didn't match a registered route (see Mux.MethodNotAllowed).
+// It answers preflight OPTIONS requests with a 204 and the CORS headers
+// browsers require, detecting Access-Control-Allow-Methods from the matched
+// route when possible, and otherwise responds with a plain 405 plus an Allow
+// header, as chi does by default.
+func corsPreflightHandler(options CORSOptions) http.HandlerFunc {
+	allowHeaders := strings.Join(options.AllowHeaders, ", ")
+	maxAge := strconv.Itoa(options.MaxAge)
+	defaultAllowMethods := strings.Join(options.AllowMethods, ", ")
+
+	return func(w http.ResponseWriter, r *http.Request) {
+		allowMethods := defaultAllowMethods
+		if rctx := RouteContext(r.Context()); rctx != nil {
+			if methods := rctx.AllowedMethods(); len(methods) > 0 {
+				allowMethods = strings.Join(methods, ", ")
+			}
+		}
+
+		if r.Method == http.MethodOptions {
+			header := w.Header()
+			header.Set("Access-Control-Allow-Methods", allowMethods)
+			header.Set("Access-Control-Allow-Headers", allowHeaders)
+			header.Set("Access-Control-Max-Age", maxAge)
+			w.WriteHeader(http.StatusNoContent)
+			return
+		}
+
+		w.Header().Set("Allow", allowMethods)
+		w.WriteHeader(http.StatusMethodNotAllowed)
+	}
+}
