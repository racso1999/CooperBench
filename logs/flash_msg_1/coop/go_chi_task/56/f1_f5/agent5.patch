+// allowedMethods returns the sorted, canonical HTTP method names registered
+// as handlers on this leaf node. It's used to populate the Allow header on
+// 405 responses and the Access-Control-Allow-Methods header for chi's
+// built-in CORS preflight support.
+func (n *node) allowedMethods() []string {
+	methods := make([]string, 0, len(n.endpoints))
+	for mt, h := range n.endpoints {
+		if mt == mALL || mt == mSTUB || h == nil || h.handler == nil {
+			continue
+		}
+		if name := GetMethodName(mt); name != "" {
+			methods = append(methods, name)
+		}
+	}
+	sort.Strings(methods)
+	return methods
+}
