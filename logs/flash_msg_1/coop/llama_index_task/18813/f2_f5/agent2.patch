+def _check_max_bytes(buffer: BytesIO, max_bytes: int | None) -> None:
+    """Raise a ValueError if the buffer exceeds max_bytes, without consuming it."""
+    if max_bytes is None:
+        return
+
+    size = len(buffer.getvalue())
+    if size > max_bytes:
+        raise ValueError(
+            f"Resolved buffer size ({size} bytes) exceeds max_bytes ({max_bytes} bytes)"
+        )
