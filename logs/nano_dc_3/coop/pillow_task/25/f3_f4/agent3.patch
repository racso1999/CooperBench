         with Image.open(out) as reloaded:
             assert_image_equal(im, reloaded)
 
+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_save_dry_run_returns_none(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        assert im.save(out, dry_run=True) is None
+
+    def test_save_dry_run_existing_file_not_modified(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        original_mtime = out.stat().st_mtime_ns
+        original_bytes = out.read_bytes()
+
+        im.save(out, dry_run=True)
+
+        assert out.stat().st_mtime_ns == original_mtime
+        assert out.read_bytes() == original_bytes
+
+    def test_save_dry_run_raises_errors(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.jpg"
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(out, dry_run=True)
+        assert not out.exists()
+
+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        original_bytes = out.read_bytes()
+
+        im.save(out, backup=True)
+
+        backup_file = tmp_path / "temp.png.bak"
+        assert backup_file.exists()
+        assert backup_file.read_bytes() == original_bytes
+        assert out.exists()
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+
+        im.save(out, backup=True, backup_suffix=".backup")
+
+        assert (tmp_path / "temp.png.backup").exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out)
+        im.save(out)
+
+        assert not (tmp_path / "temp.png.bak").exists()
+
+    def test_save_backup_new_file(self, tmp_path: Path) -> None:
+        out = tmp_path / "temp.png"
+        im = hopper()
+        im.save(out, backup=True)
+
+        assert out.exists()
+        assert not (tmp_path / "temp.png.bak").exists()
+
     def test_pathlib(self, tmp_path: Path) -> None:
