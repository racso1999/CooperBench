diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..7d1247aa8 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,50 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_none():
+    image = hopper()
+    unsorted = image.quantize(colors=8)
+    converted = image.quantize(colors=8, sort_palette=None)
+    assert converted.getpalette() == unsorted.getpalette()
+    assert converted.tobytes() == unsorted.tobytes()
+
+
+def test_sort_palette_luminosity():
+    image = hopper()
+    unsorted = image.quantize(colors=8)
+    converted = image.quantize(colors=8, sort_palette="luminosity")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    used_colors = len(converted.getcolors())
+    luminosities = [
+        0.299 * palette[i * 3] + 0.587 * palette[i * 3 + 1] + 0.114 * palette[i * 3 + 2]
+        for i in range(used_colors)
+    ]
+    assert luminosities == sorted(luminosities)
+
+    # Sorting the palette should not change how the image looks
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    unsorted = image.quantize(colors=8)
+    converted = image.quantize(colors=8, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    used_colors = len(converted.getcolors())
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for i in range(used_colors)]
+    assert colors == sorted(colors)
+
+    # Sorting the palette should not change how the image looks
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(colors=8, sort_palette="not-a-real-method")
