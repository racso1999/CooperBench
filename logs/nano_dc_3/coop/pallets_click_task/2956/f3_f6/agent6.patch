+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution of options whose ``default`` is a
+        dynamic default mapping. Runs after all command-line arguments,
+        environment variables, and configuration files have been
+        processed, so it can look at the final values of the options a
+        dynamic default depends on.
+
+        Only applies to options whose value source is still
+        :attr:`ParameterSource.DEFAULT`, i.e. no explicit value was
+        otherwise provided.
+        """
+        if ctx.resilient_parsing:
+            return
+
+        for param in self.get_params(ctx):
+            if (
+                isinstance(param, Option)
+                and param._dynamic_default is not None
+                and param.name is not None
+                and ctx.get_parameter_source(param.name) is ParameterSource.DEFAULT
+            ):
+                value = param.resolve_dynamic_default(ctx)
+
+                if value is not None:
+                    value = param.process_value(ctx, value)
+
+                if param.expose_value:
+                    ctx.params[param.name] = value
+
