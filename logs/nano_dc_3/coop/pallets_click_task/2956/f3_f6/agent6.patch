+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Compute this option's value from its dynamic default mapping,
+        based on the already-resolved values of the options it depends on.
+
+        Returns ``None`` if this option has no dynamic default, or if none
+        of the mappings match the current values of the referenced options.
+        """
+        if self._dynamic_default is None:
+            return None
+
+        result = None
+
+        for opt_decl, value_map in self._dynamic_default.items():
+            source_name = None
+
+            for param in ctx.command.get_params(ctx):
+                if opt_decl in param.opts or opt_decl in param.secondary_opts:
+                    source_name = param.name
+                    break
+
+            if source_name is None or source_name not in ctx.params:
+                continue
+
+            key = str(ctx.params[source_name])
+
+            if key in value_map:
+                result = value_map[key]
+
+        return result
+
