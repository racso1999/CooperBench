+    def _sort_palette(self, sort_palette):
+        """
+        Returns a copy of this "P" mode image with its palette colors
+        reordered according to ``sort_palette``, without changing the
+        visible image content.
+
+        :param sort_palette: ``"luminosity"``, ``"rgb"``, or a callable
+           that takes a color tuple and returns a sort key.
+        """
+
+        from . import ImagePalette
+
+        mode = self.palette.mode
+        num_bands = len(mode)
+        palette_bytes = self.im.getpalette(mode, mode)
+        colors = [
+            tuple(palette_bytes[i : i + num_bands])
+            for i in range(0, len(palette_bytes), num_bands)
+        ]
+
+        if sort_palette == "luminosity":
+
+            def key(color):
+                r, g, b = color[:3]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        elif sort_palette == "rgb":
+
+            def key(color):
+                return color
+
+        else:
+            key = sort_palette
+
+        order = sorted(range(len(colors)), key=lambda i: key(colors[i]))
+        remap = list(range(256))
+        for new_index, old_index in enumerate(order):
+            remap[old_index] = new_index
+
+        new_im = self.point(remap)
+        new_palette_bytes = b"".join(bytes(colors[old_index]) for old_index in order)
+        new_im.im.putpalette(mode, new_palette_bytes)
+        new_im.palette = ImagePalette.ImagePalette(mode, new_palette_bytes)
+
+        return new_im
+
