     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _palette_colors(im):
+    mode = im.palette.mode
+    num_bands = len(mode)
+    palette = im.getpalette()
+    colors = im.getcolors()
+    used_indices = sorted(index for _count, index in colors)
+    return [
+        tuple(palette[i * num_bands : (i + 1) * num_bands]) for i in used_indices
+    ]
+
+
+def test_sort_palette_luminosity():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="luminosity")
+
+    def luminosity(color):
+        r, g, b = color[:3]
+        return 0.299 * r + 0.587 * g + 0.114 * b
+
+    colors = _palette_colors(converted)
+    luminosities = [luminosity(color) for color in colors]
+    assert luminosities == sorted(luminosities)
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(colors=32, sort_palette="rgb")
+
+    colors = _palette_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_sort_palette_callable():
+    image = hopper()
+
+    def reverse_luminosity(color):
+        r, g, b = color[:3]
+        return -(0.299 * r + 0.587 * g + 0.114 * b)
+
+    converted = image.quantize(colors=32, sort_palette=reverse_luminosity)
+
+    colors = _palette_colors(converted)
+    keys = [reverse_luminosity(color) for color in colors]
+    assert keys == sorted(keys)
+
+
+def test_sort_palette_preserves_image():
+    image = hopper()
+    converted = image.quantize(colors=32)
+    sorted_converted = image.quantize(colors=32, sort_palette="rgb")
+
+    assert_image(sorted_converted, "P", converted.size)
+    assert converted.convert("RGB").tobytes() == sorted_converted.convert(
+        "RGB"
+    ).tobytes()
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not-a-real-method")
+
+
+def test_sort_palette_with_palette_argument():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, sort_palette="rgb")
