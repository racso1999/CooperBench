+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash string for a given algorithm.
+    """
+
+    _hash_lengths: ClassVar[Dict[str, int]] = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+    _hex_re: ClassVar[Pattern[str]] = re.compile('[0-9a-f]+', re.IGNORECASE)
+
+    def __init__(self, algorithm: str):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'` (case-insensitive).
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '9dd4e461268c8034f5c8564e155c67a6' == IsHash('md5')
+        assert 'not-a-hash' != IsHash('md5')
+        assert '2d711642b726b04401627ca9fbac32f5c8530fb1903cc4db02258717921a4881' == IsHash('sha256')
+        assert '2d711642b726b04401627ca9fbac32f5c8530fb1903cc4db02258717921a4881' != IsHash('md5')
+        ```
+        """
+        if algorithm.lower() not in self._hash_lengths:
+            raise ValueError(f'algorithm must be one of {sorted(self._hash_lengths)}, got {algorithm!r}')
+        self.algorithm = algorithm
+        self._expected_length = self._hash_lengths[algorithm.lower()]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        return len(other) == self._expected_length and bool(self._hex_re.fullmatch(other))
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's format.
+    """
+
+    _cleanup_re: ClassVar[Pattern[str]] = re.compile(r'[\s\-.()]')
+    _generic_re: ClassVar[Pattern[str]] = re.compile(r'\+?\d{7,15}')
+    _generic_international_re: ClassVar[Pattern[str]] = re.compile(r'\+\d{7,15}')
+    _country_patterns: ClassVar[Dict[str, Pattern[str]]] = {
+        'US': re.compile(r'\+1\d{10}|\d{10}'),
+        'GB': re.compile(r'\+44\d{10}|0\d{10}'),
+    }
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) to validate the phone number against.
+                If omitted, generic phone number validation is used.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert 12345 != IsPhoneNumber
+        ```
+        """
+        self.country = country
+        super().__init__(plain_repr('*') if country is None else country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._cleanup_re.sub('', other.strip())
+
+        if self.country is None:
+            return bool(self._generic_re.fullmatch(cleaned))
+
+        pattern = self._country_patterns.get(self.country.upper())
+        if pattern is not None:
+            return bool(pattern.fullmatch(cleaned))
+
+        return bool(self._generic_international_re.fullmatch(cleaned))
+
