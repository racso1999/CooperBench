+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has been idle for longer than `idle_timeout_s` and, if so, terminate it.
+
+        This should be called periodically by the streaming system so that a stalled upstream (e.g. a backend
+        that stops emitting chunks mid-stream) doesn't leave a consumer waiting indefinitely. If the idle window
+        has elapsed since the last received chunk, a final `StreamResponse` with an empty `chunk` is emitted and
+        the listener's state is reset.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream just timed out due to inactivity, otherwise
+            `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        if self.debug and self._logger.isEnabledFor(logging.DEBUG):
+            self._logger.debug(
+                f"Idle timeout: field='{self.signature_field_name}', idle_timeout_s={self.idle_timeout_s}"
+            )
+
