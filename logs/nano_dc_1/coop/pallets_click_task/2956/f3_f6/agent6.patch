+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second pass over the parsed parameters to resolve any
+        dictionary-based dynamic defaults on :class:`Option` params, now
+        that every other option's value is known.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore
+                continue
+
+            resolved = None
+
+            for opt_ref, mapping in dynamic_default.items():
+                source_param = _find_param_by_decl(params, opt_ref)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            with augment_usage_errors(ctx, param=param):
+                try:
+                    value = param.process_value(ctx, resolved)
+                except Exception:
+                    if not ctx.resilient_parsing:
+                        raise
+
+                    value = None
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore
