+def _do_groupby(
+    value: "t.Iterable[V]",
+    expr: t.Callable[[t.Any], t.Any],
+    case_sensitive: bool,
+) -> "t.List[t.Tuple[t.Any, t.List[V]]]":
+    if case_sensitive:
+        key = expr
+    else:
+
+        def key(item: t.Any) -> t.Any:
+            return ignore_case(expr(item))
+
+    out = []
+
+    for _, group in groupby(sorted(value, key=key), key):
+        group_list = list(group)
+        out.append((expr(group_list[0]), group_list))
+
+    return out
 
 
