           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
+    case-insensitive by default. The ``key`` for each group uses the
+    case of the first matching item. For example, if a list of users
+    has cities ``["CA", "NY", "ca"]``, the "CA" and "ca" entries will be
+    grouped together, under the "CA" or "ca" key depending on which came
+    first. Pass ``case_sensitive=True`` to group case sensitively instead.
+
+    You can also use ``with_counts`` to get the number of items in each
+    group without a separate ``|length`` call.
+
+    .. sourcecode:: html+jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=True) %}
+          <li>{{ city }} ({{ count }})
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.1
+        Added the ``case_sensitive`` and ``with_counts`` parameters.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1231,12 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
