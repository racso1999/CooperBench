+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve options whose default is a dynamic default mapping.
+
+        This runs after all command line arguments, environment
+        variables, and configuration files have been processed, so
+        that dynamic defaults can be selected based on the final
+        values of the options they depend on.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "dynamic_default", None)
+
+            if dynamic_default is None:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in dynamic_default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if source_opt in p.opts or source_opt in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+
+                if str(source_value) in mapping:
+                    resolved = mapping[str(source_value)]
+
+            if resolved is not None:
+                ctx.params[param.name] = param.type_cast_value(ctx, resolved)  # type: ignore[arg-type]
+
