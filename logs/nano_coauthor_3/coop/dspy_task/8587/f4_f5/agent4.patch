+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle and, if so, emit a final empty chunk.
+
+        This should be called periodically by the streaming system. If `idle_timeout_s` is set and no chunk has
+        been received for at least that long since the stream started (and the stream hasn't already ended), this
+        emits a `StreamResponse` with an empty `chunk` to signal to consumers that the stream stalled, then resets
+        the listener state so it can be reused.
+
+        Args:
+            now_ts: The current timestamp to compare against the last received chunk's timestamp. Defaults to
+                `time.monotonic()`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.monotonic()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        if self.debug and self._logger.isEnabledFor(logging.DEBUG):
+            self._logger.debug(f"Idle timeout reached for field '{self.signature_field_name}', ending stream")
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset state unconditionally so the listener isn't left in a started state, regardless of `allow_reuse`.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
 
