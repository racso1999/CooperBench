+    def test_save_backup(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        backup_out = out + ".bak"
+
+        im = hopper()
+        im.save(out)
+        assert not os.path.exists(backup_out)
+
+        original_data = Path(out).read_bytes()
+        im.save(out, backup=True)
+        assert os.path.exists(backup_out)
+        assert Path(backup_out).read_bytes() == original_data
+
+    def test_save_backup_custom_suffix(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        backup_out = out + ".backup"
+
+        im = hopper()
+        im.save(out)
+        im.save(out, backup=True, backup_suffix=".backup")
+        assert os.path.exists(backup_out)
+
+    def test_save_backup_no_existing_file(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        backup_out = out + ".bak"
+
+        im = hopper()
+        im.save(out, backup=True)
+        assert not os.path.exists(backup_out)
+
+    def test_save_no_backup_by_default(self, tmp_path: Path) -> None:
+        out = str(tmp_path / "temp.png")
+        backup_out = out + ".bak"
+
+        im = hopper()
+        im.save(out)
+        im.save(out)
+        assert not os.path.exists(backup_out)
+
