     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_error_threshold_low_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=10000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+
+def test_error_threshold_uses_fewer_colors():
+    image = Image.new("RGB", (100, 100), (255, 0, 0))
+    converted = image.quantize(colors=256, error_threshold=1)
+    assert len(converted.getcolors()) < 256
+
+
+def test_error_threshold_unmet_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=8, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 8
