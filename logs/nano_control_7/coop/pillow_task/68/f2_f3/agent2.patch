+def _strip_all_metadata(image: Image.Image) -> None:
+    image.getexif().clear()
+    for key in (
+        "exif",
+        "Raw profile type exif",
+        "XML:com.adobe.xmp",
+        "xmp",
+        "icc_profile",
+        "comment",
