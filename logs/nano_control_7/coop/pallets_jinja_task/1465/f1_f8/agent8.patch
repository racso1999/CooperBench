+
+    if with_counts:
+        out_with_counts = []
+
+        for key, values in groupby(sorted(value, key=expr), expr):
+            values_list = list(values)
+            out_with_counts.append(
+                _GroupTupleWithCount(key, values_list, len(values_list))
+            )
+
+        return out_with_counts
+
