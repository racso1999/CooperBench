+def _batched(
+    iterable: cabc.Iterable[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Like :func:`batch`, but returns an iterator and does not drop a
+    trailing partial batch.
+    """
+    it = iter(iterable)
+
+    while chunk := tuple(islice(it, batch_size)):
+        yield chunk
