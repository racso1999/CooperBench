+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and terminate it if so.
+
+        This is a polling method meant to be called periodically by the streaming system, since the listener
+        itself is purely event-driven and has no other way to notice that the upstream has stalled.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()` when not provided, exposed
+                as a parameter to make this method easier to test.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream timed out, `None` otherwise.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Unconditionally reset the listener state, regardless of `allow_reuse`, so that it isn't left stuck in a
+        # started state after the stream was cut short by the idle timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
