+# On-disk blobs written by this module are prefixed with this magic string followed by a 1-byte
+# codec selector so that compressed and uncompressed entries can be told apart, and so that
+# entries written before this feature existed (which lack the header entirely) can still be
+# loaded as raw legacy pickles.
+_DISK_CACHE_MAGIC = b"DSPC"
+_CODEC_NONE = 0x00
+_CODEC_GZIP = 0x01
+_CODEC_ZLIB = 0x02
+_COMPRESS_NAME_TO_CODEC = {None: _CODEC_NONE, "gzip": _CODEC_GZIP, "zlib": _CODEC_ZLIB}
+
+
+def _encode_disk_value(value: Any, compress: Optional[str]) -> bytes:
+    """Pickle `value`, optionally compress it, and prepend the magic header."""
+    codec = _COMPRESS_NAME_TO_CODEC[compress]
+    payload = pickle.dumps(value)
+    if codec == _CODEC_GZIP:
+        payload = gzip.compress(payload)
+    elif codec == _CODEC_ZLIB:
+        payload = zlib.compress(payload)
+    return _DISK_CACHE_MAGIC + bytes([codec]) + payload
+
+
+def _decode_disk_value(data: Any) -> Any:
+    """Decode a value read from the disk cache.
+
+    If `data` doesn't start with the magic header, diskcache already deserialized it into the
+    original object (i.e. it's a legacy entry written before compression support existed), so it
+    is returned unchanged.
+    """
+    if not isinstance(data, (bytes, bytearray)) or len(data) < 5 or bytes(data[:4]) != _DISK_CACHE_MAGIC:
+        return data
+
+    codec = data[4]
+    payload = bytes(data[5:])
+    if codec == _CODEC_GZIP:
+        payload = gzip.decompress(payload)
+    elif codec == _CODEC_ZLIB:
+        payload = zlib.decompress(payload)
+    return pickle.loads(payload)
+
 
