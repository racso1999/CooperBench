+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the `Features` class in sync with the
+    main dictionary.
+
+    A `Features` object is essentially a `dict` and can be modified with any of the usual `dict` methods (item
+    assignment/deletion, `update`, `pop`, `setdefault`, etc.). This decorator wraps such methods so that
+    `_column_requires_decoding` is recomputed right after the wrapped method runs, regardless of which columns were
+    added, removed or replaced.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        if args:
+            self: "Features" = args[0]
+            out = func(*args, **kwargs)
+            assert hasattr(self, "_column_requires_decoding")
+            self._column_requires_decoding = {
+                col: require_decoding(feature) for col, feature in self.items()
+            }
+            return out
+        else:
+            return func(*args, **kwargs)
+
+    wrapper._decorator_name_ = "_keep_dicts_synced"
+    return wrapper
+
+
