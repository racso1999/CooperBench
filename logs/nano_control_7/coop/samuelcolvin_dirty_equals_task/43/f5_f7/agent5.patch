+
+_phone_strip_re = re.compile(r'[\s\-.()]')
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number string, optionally restricted to the format
+    used by a specific country.
+    """
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code (e.g. `'US'`, `'GB'`) used to restrict validation to that
+                country's phone number format. If omitted, generic national/international validation is used.
+                Countries without dedicated rules fall back to generic international validation.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert '+33 1 23 45 67 89' == IsPhoneNumber('FR')
+        assert 12345 != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = _phone_strip_re.sub('', other)
+        has_country_code = cleaned.startswith('+')
+        digits = cleaned[1:] if has_country_code else cleaned
+
+        if not digits or not digits.isdigit():
+            return False
+
+        if self.country == 'US':
+            return self._is_us(digits, has_country_code)
+        elif self.country == 'GB':
+            return self._is_gb(digits, has_country_code)
+        elif self.country is not None:
+            # unsupported country, fall back to generic international validation
+            return has_country_code and 7 <= len(digits) <= 15
+        else:
+            return 7 <= len(digits) <= 15
+
+    @staticmethod
+    def _is_us(digits: str, has_country_code: bool) -> bool:
+        if has_country_code:
+            return len(digits) == 11 and digits[0] == '1'
+        else:
+            return len(digits) == 10 or (len(digits) == 11 and digits[0] == '1')
+
+    @staticmethod
+    def _is_gb(digits: str, has_country_code: bool) -> bool:
+        if has_country_code:
+            return len(digits) == 12 and digits.startswith('44')
+        else:
+            return len(digits) == 11 and digits.startswith('0')
