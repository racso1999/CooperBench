+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If the stream has started but not
+        yet ended, and no chunk has arrived for at least `idle_timeout_s` seconds, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination. The listener state is then reset
+        unconditionally, regardless of `allow_reuse`, so it isn't left stuck in a started state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        if now_ts is None:
+            now_ts = time.time()
+
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        try:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "", is_last_chunk=True)
+        except TypeError:
+            response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset unconditionally (regardless of `allow_reuse`) so the listener doesn't remain stuck in
+        # a started state.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
