+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve this option's value from its dynamic default mapping,
+        based on the current values of the option(s) it depends on.
+
+        Returns ``None`` if this option has no dynamic default, or if
+        none of the mappings match the current source option values.
+        """
+        if self._dynamic_default is None:
+            return None
+
+        opt_to_name = {
+            opt: param.name
+            for param in ctx.command.get_params(ctx)
+            for opt in (*param.opts, *param.secondary_opts)
+        }
+
+        value = None
+
+        for source_opt, mapping in self._dynamic_default.items():
+            source_name = opt_to_name.get(source_opt)
+
+            if source_name is None:
+                continue
+
+            source_value = ctx.params.get(source_name)
+            key = str(source_value)
+
+            if key in mapping:
+                value = mapping[key]
+
+        return value
+
