+            return {}
+
+        if WIN:
+            import subprocess
+
+            class_name = _PROCESS_WIN32_PRIORITY_CLASSES.get(self.process_priority)
+            creationflags = getattr(subprocess, class_name or "", None)
+
+            if creationflags is None:
+                return {}
+
+            return {"creationflags": creationflags}
+
+        nice_value = _PROCESS_NICE_VALUES.get(self.process_priority)
+
+        if not nice_value:
+            return {}
+
+        def _set_priority() -> None:
+            try:
+                os.nice(nice_value)
+            except OSError:
+                pass
+
+        return {"preexec_fn": _set_priority}
