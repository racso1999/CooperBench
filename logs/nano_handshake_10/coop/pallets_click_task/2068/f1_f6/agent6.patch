+    def _priority_popen_kwargs(self) -> dict[str, t.Any]:
+        """Build extra :class:`subprocess.Popen` kwargs that request the
+        configured ``process_priority``, if any. Returns an empty dict if
+        no priority was requested or the platform-specific mechanism for
+        setting it could not be determined.
