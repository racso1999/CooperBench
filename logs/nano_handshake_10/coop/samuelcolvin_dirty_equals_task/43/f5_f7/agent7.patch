+
+
+_hash_lengths = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+HashAlgorithm = Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, for a given algorithm.
+
+    The check confirms the value is a string of the correct length for the algorithm and that it only
+    contains hexadecimal characters, it does not check that the value is a "real" hash of anything in particular.
+    """
+
+    def __init__(self, algorithm: HashAlgorithm):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'` (case-insensitive).
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '5d41402abc4b2a76b9719d911017c592' == IsHash('md5')
+        assert 'aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d' == IsHash('sha1')
+        assert '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('sha256')
+        ```
+        """
+        try:
+            self._length = _hash_lengths[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Invalid algorithm {algorithm!r}, must be one of {sorted(_hash_lengths)}')
+        self.algorithm = algorithm
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self._length:
+            return False
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+        return True
