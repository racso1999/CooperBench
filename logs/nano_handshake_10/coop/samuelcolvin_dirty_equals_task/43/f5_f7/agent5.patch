+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+    """
+
+    _international_re = re.compile(r'\+\d{7,15}')
+    _national_re = re.compile(r'\d{7,15}')
+    _us_national_re = re.compile(r'\d{10}')
+    _us_international_re = re.compile(r'\+1\d{10}')
+    _gb_national_re = re.compile(r'0\d{10}')
+    _gb_international_re = re.compile(r'\+44\d{10}')
+    _cleanup_re = re.compile(r'[\s\-.()]')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to restrict validation to that country's phone number
+                format, if omitted, generic national and international formats are accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(self.country if self.country else plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._cleanup_re.sub('', other)
+
+        if self.country == 'US':
+            return bool(self._us_international_re.fullmatch(cleaned) or self._us_national_re.fullmatch(cleaned))
+        elif self.country == 'GB':
+            return bool(self._gb_international_re.fullmatch(cleaned) or self._gb_national_re.fullmatch(cleaned))
+        elif self.country is not None:
+            # unsupported/unknown country code, fall back to generic international validation
+            return bool(self._international_re.fullmatch(cleaned))
+        else:
+            return bool(self._international_re.fullmatch(cleaned) or self._national_re.fullmatch(cleaned))
