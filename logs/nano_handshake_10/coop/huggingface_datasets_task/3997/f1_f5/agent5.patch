+++ b/src/datasets/features/features.py
@@ -1247,13 +1247,36 @@ class Features(dict):
 
     def update(self, iterable, **kwds):
         if hasattr(iterable, "keys"):
-            for key in iterable.keys():
-                self[key] = iterable[key]
+            items = [(key, iterable[key]) for key in iterable.keys()]
         else:
-            for key, value in iterable:
-                self[key] = value
-        for key in kwds:
-            self[key] = kwds[key]
+            items = list(iterable)
+        items = items + list(kwds.items())
+        for key, value in items:
+            self[key] = self._merge_value(self[key], value) if key in self else value
+
+    @staticmethod
+    def _merge_value(current, value):
+        """Merge ``value`` into ``current`` when both represent nested dictionaries of features.
+
+        Dictionaries (including nested :class:`Features`) are merged recursively key by key.
+        A :class:`Sequence` whose ``feature`` is itself a dictionary is merged the same way.
+        Otherwise ``value`` simply replaces ``current``.
+        """
+        if isinstance(current, dict) and isinstance(value, dict):
+            merged = dict(current)
+            for key, sub_value in value.items():
+                merged[key] = Features._merge_value(merged[key], sub_value) if key in merged else sub_value
+            return type(current)(merged) if isinstance(current, Features) else merged
+        if (
+            isinstance(current, Sequence)
+            and isinstance(value, Sequence)
+            and isinstance(current.feature, dict)
+            and isinstance(value.feature, dict)
+        ):
+            return Sequence(
+                feature=Features._merge_value(current.feature, value.feature), length=value.length, id=value.id
+            )
+        return value
 
     def __reduce__(self):
         return Features, (dict(self),)
