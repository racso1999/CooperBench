@@ -258,6 +258,37 @@ class TestImage:
             assert im.readonly
             im.save(temp_file)
 
+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1))
+        im.save(temp_file)
+        assert not os.path.exists(str(temp_file) + ".bak")
+
+        # Backup is created when the file already exists
+        im.save(temp_file, backup=True)
+        backup_file = temp_file.with_name(temp_file.name + ".bak")
+        assert os.path.exists(backup_file)
+
+        with Image.open(backup_file) as backup_im:
+            assert backup_im.size == (1, 1)
+
+        # No backup is created when the file does not already exist
+        other_file = tmp_path / "other.png"
+        im.save(other_file, backup=True)
+        assert not os.path.exists(str(other_file) + ".bak")
+
+    def test_save_backup_suffix(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1))
+        im.save(temp_file)
+        im.save(temp_file, backup=True, backup_suffix=".backup")
+
+        backup_file = temp_file.with_name(temp_file.name + ".backup")
+        assert os.path.exists(backup_file)
+        assert not os.path.exists(str(temp_file) + ".bak")
+
     def test_dump(self, tmp_path: Path) -> None:
         im = Image.new("L", (10, 10))
         im._dump(str(tmp_path / "temp_L.ppm"))
