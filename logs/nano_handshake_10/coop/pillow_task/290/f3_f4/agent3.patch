diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..356da82a6 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,38 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _get_used_palette_colors(im):
+    palette = im.getpalette()
+    return [
+        tuple(palette[i * 3 : i * 3 + 3])
+        for i, count in enumerate(im.histogram())
+        if count
+    ]
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not-a-real-method")
+
+
+@pytest.mark.parametrize("sort_palette", ("rgb", "luminance"))
+def test_quantize_sort_palette(sort_palette):
+    image = hopper()
+    unsorted = image.quantize(100)
+    sorted_im = image.quantize(100, sort_palette=sort_palette)
+
+    assert_image(sorted_im, "P", sorted_im.size)
+
+    # the visible image is unaffected by reordering the palette
+    assert_image_similar(sorted_im.convert("RGB"), unsorted.convert("RGB"), 0)
+
+    colors = _get_used_palette_colors(sorted_im)
+    if sort_palette == "rgb":
+        assert colors == sorted(colors)
+    else:
+        assert colors == sorted(
+            colors, key=lambda c: c[0] * 299 + c[1] * 587 + c[2] * 114
+        )
