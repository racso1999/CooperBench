+_PROCESS_PRIORITY_LEVELS = ("low", "below_normal", "normal", "above_normal", "high")
+
+_UNIX_PRIORITY_NICE = {
+    "low": 10,
+    "below_normal": 5,
+    "normal": 0,
+    "above_normal": -5,
+    "high": -10,
+}
+
+_WIN_PRIORITY_CLASS = {
+    "low": 0x00000040,  # IDLE_PRIORITY_CLASS
+    "below_normal": 0x00004000,  # BELOW_NORMAL_PRIORITY_CLASS
+    "normal": 0x00000020,  # NORMAL_PRIORITY_CLASS
+    "above_normal": 0x00008000,  # ABOVE_NORMAL_PRIORITY_CLASS
+    "high": 0x00000080,  # HIGH_PRIORITY_CLASS
+}
+
+
+def _set_process_priority(pid: int, priority: str) -> None:
+    """Best-effort attempt to set the OS priority of ``pid``.
+
+    Priority control is only a resource hint, so any failure (missing
+    permissions, unsupported platform, process already exited, ...) is
+    silently ignored rather than raised.
+    """
+    if priority not in _PROCESS_PRIORITY_LEVELS:
+        return
+
+    try:
+        if WIN:
+            import ctypes
+
+            PROCESS_SET_INFORMATION = 0x0200
+            PROCESS_QUERY_INFORMATION = 0x0400
+            handle = ctypes.windll.kernel32.OpenProcess(  # type: ignore[attr-defined]
+                PROCESS_SET_INFORMATION | PROCESS_QUERY_INFORMATION, False, pid
+            )
+            if handle:
+                try:
+                    ctypes.windll.kernel32.SetPriorityClass(  # type: ignore[attr-defined]
+                        handle, _WIN_PRIORITY_CLASS[priority]
+                    )
+                finally:
+                    ctypes.windll.kernel32.CloseHandle(handle)  # type: ignore[attr-defined]
+        else:
+            os.setpriority(os.PRIO_PROCESS, pid, _UNIX_PRIORITY_NICE[priority])  # type: ignore[attr-defined]
+    except Exception:
+        pass
+
+
