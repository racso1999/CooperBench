@@ -0,0 +1,70 @@
+import re
+from typing import Any, Dict, Optional, Pattern, Tuple
+
+from ._base import DirtyEquals
+from ._utils import plain_repr
+
+__all__ = ('IsPhoneNumber',)
+
+
+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's
+    national/international formats.
+    """
+
+    _generic_pattern: Pattern[str] = re.compile(r'^\+?\d{7,15}$')
+    _unknown_country_pattern: Pattern[str] = re.compile(r'^\+\d{7,15}$')
+    _country_patterns: Dict[str, Tuple[Pattern[str], ...]] = {
+        'US': (
+            re.compile(r'^\d{10}$'),
+            re.compile(r'^\+1\d{10}$'),
+        ),
+        'GB': (
+            re.compile(r'^0\d{9,10}$'),
+            re.compile(r'^\+44\d{9,10}$'),
+        ),
+    }
+    _delimiter_re = re.compile(r'[\s\-.()]')
+
+    def __init__(self, country_code: Optional[str] = None):
+        """
+        Args:
+            country_code: An optional
+                [ISO 3166-1 alpha-2](https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) country code
+                (e.g. `'US'`, `'GB'`) used to restrict validation to that country's phone number formats.
+                If omitted, generic national/international phone number formats are accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert 12345 != IsPhoneNumber
+        ```
+        """
+        self.country_code = country_code
+        super().__init__(country_code or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        normalized = self._delimiter_re.sub('', other)
+        if not normalized:
+            return False
+
+        if self.country_code is None:
+            return bool(self._generic_pattern.fullmatch(normalized))
+
+        patterns = self._country_patterns.get(self.country_code.upper())
+        if patterns is None:
+            return bool(self._unknown_country_pattern.fullmatch(normalized))
+
+        return any(p.fullmatch(normalized) for p in patterns)
