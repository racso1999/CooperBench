+    def tick(self, now_ts: float | None = None) -> "StreamResponse | None":
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If a stream is in progress (started
+        but not yet ended) and no chunk has arrived within `idle_timeout_s` seconds, this emits a final
+        `StreamResponse` with an empty `chunk` and resets the listener's state so it isn't left stuck.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if self._last_chunk_ts is None or now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if any(f.name == "is_last_chunk" for f in dataclasses.fields(response)):
+            response.is_last_chunk = True
+
+        # Reset unconditionally (regardless of `allow_reuse`) so the listener doesn't stay stuck in a
+        # started state after a timeout.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
