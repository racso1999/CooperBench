+    def _select_tip_with_weights(self):
+        """Select a tip key from TIPS, biased by self.tip_weights.
+
+        Nonpositive or missing weights are treated as zero (missing keys default
+        to 1.0 before that check). If every weight is zero/invalid, falls back to
+        a uniform draw via self.rng.choice.
+        """
+        tip_keys = list(TIPS.keys())
+        weights = []
+        for key in tip_keys:
+            weight = self.tip_weights.get(key, 1.0)
+            try:
+                weight = float(weight)
+            except (TypeError, ValueError):
+                weight = 0.0
+            weights.append(weight if weight > 0 else 0.0)
+
+        total_weight = sum(weights)
+        if total_weight <= 0:
+            return self.rng.choice(tip_keys)
+
+        probabilities = [weight / total_weight for weight in weights]
+
+        threshold = self.rng.random()
+        cumulative = 0.0
+        for key, probability in zip(tip_keys, probabilities):
+            cumulative += probability
+            if threshold < cumulative:
+                return key
+
+        return tip_keys[-1]
+
