     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+
+    def brightness(rgb):
+        return rgb[0] * 299 + rgb[1] * 587 + rgb[2] * 114
+
+    assert colors == sorted(colors, key=brightness)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def by_green_descending(rgb_tuples):
+        return sorted(range(len(rgb_tuples)), key=lambda i: -rgb_tuples[i][1])
+
+    converted = image.quantize(100, sort_palette=by_green_descending)
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 20)
+
+    palette = converted.getpalette()
+    greens = [palette[i + 1] for i in range(0, len(palette), 3)]
+    assert greens == sorted(greens, reverse=True)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, sort_palette="not-a-real-method")
+
+
+def test_quantize_sort_palette_with_reference_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette_im:
+        palette_im = palette_im.convert("P")
+
+    unsorted = image.quantize(palette=palette_im)
+    converted = image.quantize(palette=palette_im, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    # Sorting the palette shouldn't change the resulting visual output.
+    assert converted.convert("RGB").tobytes() == unsorted.convert("RGB").tobytes()
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    assert colors == sorted(colors)
