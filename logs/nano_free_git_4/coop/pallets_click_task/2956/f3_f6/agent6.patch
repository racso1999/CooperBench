+def _batched(
+    iterable: cabc.Iterable[V], batch_size: int
+) -> cabc.Iterator[tuple[V, ...]]:
+    """Yield successive, possibly uneven, chunks of at most ``batch_size``
+    items from ``iterable``, without accumulating the whole input.
+    """
+    it = iter(iterable)
+
+    while chunk := tuple(islice(it, batch_size)):
+        yield chunk
