+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve this option's dynamic default, if it has one.
+
+        A dynamic default is a mapping of other option declarations (for
+        example ``"--protocol"``) to a mapping of that option's
+        stringified value to the default value to use for this option.
+        Returns ``None`` if this option doesn't have a dynamic default, or
+        if none of the mappings matched.
+
+        .. versionadded:: 8.2
+        """
+        if not isinstance(self.default, dict):
+            return None
+
+        result = None
+
+        for decl, mapping in self.default.items():
+            source = None
+
+            for param in ctx.command.get_params(ctx):
+                if decl in param.opts or decl in param.secondary_opts:
+                    source = param
+                    break
+
+            if source is None or source.name is None:
+                continue
+
+            key = str(ctx.params.get(source.name))
+
+            if key in mapping:
+                result = mapping[key]
+
+        return result
+
