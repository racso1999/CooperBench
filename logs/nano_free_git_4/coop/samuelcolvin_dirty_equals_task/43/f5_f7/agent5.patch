+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country.
+    """
+
+    _strip_re = re.compile(r'[\s\-.()]')
+    _generic_national_re = re.compile(r'\A\d{7,15}\Z')
+    _generic_international_re = re.compile(r'\A\+\d{8,18}\Z')
+    _country_patterns = {
+        'US': (re.compile(r'\A\d{10}\Z'), re.compile(r'\A\+1\d{10}\Z')),
+        'GB': (re.compile(r'\A0\d{10}\Z'), re.compile(r'\A\+44\d{10}\Z')),
+    }
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code used to enforce country specific formatting rules, if
+                omitted, any reasonably formatted phone number is accepted. Currently `'US'` and `'GB'` have
+                dedicated rules, other countries fall back to generic international format validation.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert 1234567890 != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(plain_repr('*') if country is None else self.country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._strip_re.sub('', other)
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(
+                self._generic_national_re.fullmatch(cleaned) or self._generic_international_re.fullmatch(cleaned)
+            )
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            return bool(self._generic_international_re.fullmatch(cleaned))
+
+        national_re, international_re = patterns
+        return bool(national_re.fullmatch(cleaned) or international_re.fullmatch(cleaned))
+
