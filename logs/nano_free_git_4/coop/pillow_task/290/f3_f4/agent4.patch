+def test_error_threshold():
+    image = hopper()
+
+    high_threshold = image.quantize(colors=256, error_threshold=10000)
+    assert_image(high_threshold, "P", high_threshold.size)
+    assert len(high_threshold.getcolors()) <= 256
+
+    low_threshold = image.quantize(colors=256, error_threshold=0.001)
+    assert_image(low_threshold, "P", low_threshold.size)
+    assert len(low_threshold.getcolors()) <= 256
+
+    # A very low threshold should require at least as many colors
+    # as a very high (easily satisfied) threshold.
+    assert len(low_threshold.getcolors()) >= len(high_threshold.getcolors())
+
+
+def test_error_threshold_uses_max_colors_when_unreachable():
+    image = hopper()
+
+    converted = image.quantize(colors=4, error_threshold=0.0001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for _, i in converted.getcolors()]
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    def brightness(color):
+        r, g, b = color
+        return r * 299 + g * 587 + b * 114
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for _, i in converted.getcolors()]
+    assert colors == sorted(colors, key=brightness)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def key(color):
+        return -sum(color)
+
+    converted = image.quantize(100, Image.FASTOCTREE, sort_palette=key)
+    assert_image(converted, "P", converted.size)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i * 3 : i * 3 + 3]) for _, i in converted.getcolors()]
+    assert colors == sorted(colors, key=key)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(100, Image.FASTOCTREE, sort_palette="unknown")
+
