+    @staticmethod
+    def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+        """Normalize raw or base64-encoded image bytes.
+
+        Detects whether the given bytes are already base64-encoded. Returns a
+        tuple of ``(encoded_image, decoded_for_guessing)`` where
+        ``encoded_image`` is guaranteed to be base64-encoded and
+        ``decoded_for_guessing`` is the raw, decoded bytes suitable for MIME
+        type detection.
+        """
+        try:
+            decoded_for_guessing = base64.b64decode(image, validate=True)
+            encoded_image = image
+        except Exception:
+            decoded_for_guessing = image
+            encoded_image = base64.b64encode(image)
+
+        return encoded_image, decoded_for_guessing
