+    def get_image_mimetype(self, image_bytes: bytes | None = None) -> str | None:
+        """Return the image mimetype, guessing and caching it if not already set.
+
+        In case the mimetype was not already set, we try to guess it using the
+        filetype library and cache the result for future accesses.
+
+        Args:
+            image_bytes: raw, non-base64-encoded bytes to guess the mimetype
+                from. If not provided, `self.image` is used, decoding it first
+                if it's already base64-encoded.
+        """
+        if not self.image_mimetype:
+            source = image_bytes
+            if source is None and self.image:
+                _, source = self.normalize_image_bytes(self.image)
+
+            if source:
+                guess = filetype.guess(source)
+                self.image_mimetype = guess.mime if guess else None
+
+        return self.image_mimetype
