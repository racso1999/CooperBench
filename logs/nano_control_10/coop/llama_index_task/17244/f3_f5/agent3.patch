+def normalize_image_bytes(image: bytes) -> tuple[bytes, bytes]:
+    """Normalize raw or base64-encoded image bytes for storage and mimetype guessing.
+
+    Args:
+        image (bytes): the image content, either raw bytes or already base64-encoded.
+
+    Returns:
+        tuple[bytes, bytes]: a tuple of (base64-encoded image, decoded bytes to use
+            for mimetype guessing).
+    """
+    try:
+        decoded_for_guessing = base64.b64decode(image, validate=True)
+        return image, decoded_for_guessing
+    except (base64.binascii.Error, ValueError):
+        return base64.b64encode(image), image
+
