+    def _get_priority_popen_kwargs(self) -> dict[str, t.Any]:
+        """Best-effort, platform-specific ``subprocess.Popen`` keyword
+        arguments to apply ``self.process_priority`` to the editor
+        process. Returns an empty dict if no priority is requested or
+        the platform does not support adjusting it.
+        """
+        if self.process_priority is None:
+            return {}
+
+        try:
+            if WIN:
+                import subprocess
+
+                priority_class = {
+                    "low": subprocess.IDLE_PRIORITY_CLASS,
+                    "below_normal": subprocess.BELOW_NORMAL_PRIORITY_CLASS,
+                    "normal": subprocess.NORMAL_PRIORITY_CLASS,
+                    "above_normal": subprocess.ABOVE_NORMAL_PRIORITY_CLASS,
+                    "high": subprocess.HIGH_PRIORITY_CLASS,
+                }[self.process_priority]
+                return {"creationflags": priority_class}
+            else:
+                nice_offset = _EDITOR_POSIX_NICE_OFFSETS[self.process_priority]
+
+                def _apply_nice_offset() -> None:
+                    try:
+                        os.nice(nice_offset)
+                    except OSError:
+                        # Not permitted (e.g. raising priority without
+                        # privileges) or not supported. Fall back to
+                        # the inherited default priority.
+                        pass
+
+                return {"preexec_fn": _apply_nice_offset}
