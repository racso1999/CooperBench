+    def resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dict-based dynamic default by inspecting the
+        current values of the options it depends on.
+
+        Each key of :attr:`default` is the declaration (e.g.
+        ``"--protocol"``) of another option on the same command, and
+        each value is a mapping of that option's stringified value to
+        the default to use for this option. When multiple dependencies
+        match, the last one in the dictionary wins.
+
+        :param ctx: Current context.
+        """
+        value = None
+
+        for source_decl, mapping in self.default.items():
+            source_param = next(
+                (
+                    param
+                    for param in ctx.command.params
+                    if isinstance(param, Option) and source_decl in param.opts
+                ),
+                None,
+            )
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)
+
+            if str(source_value) in mapping:
+                value = mapping[str(source_value)]
+
+        return value
+
