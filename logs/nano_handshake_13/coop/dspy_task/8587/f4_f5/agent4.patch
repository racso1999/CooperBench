+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Force-terminate the stream if it has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, independent of `receive()`, so that a stalled
+        upstream (which stops emitting chunks entirely) doesn't leave listeners stuck in a started state forever.
+
+        Args:
+            now_ts: The timestamp to compare against the last received chunk's timestamp. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed since the stream started
+            receiving chunks and hasn't ended yet. Otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+
+        if now_ts - last_ts < self.idle_timeout_s:
+            return None
+
+        response_field_names = {f.name for f in fields(StreamResponse)}
+        response_kwargs = {
+            "predict_name": self.predict_name,
+            "signature_field_name": self.signature_field_name,
+            "chunk": "",
+        }
+        if "is_last_chunk" in response_field_names:
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(**response_kwargs)
+
+        # Reset state unconditionally (regardless of `allow_reuse`) so the listener isn't left stuck in a
+        # started state after a timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
 
