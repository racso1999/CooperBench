@@ -11,6 +11,40 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+#: Global registry of custom Jinja2 filters, made available to every prompt
+#: template without having to be passed in explicitly. Populate it with
+#: `register_filter` and remove entries with `unregister_filter`.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom filter that will be available in all prompt templates.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be accessible in templates,
+        e.g. ``{{ text | name }}``.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a filter from the global filter registry.
+
+    Does nothing if no filter was registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
