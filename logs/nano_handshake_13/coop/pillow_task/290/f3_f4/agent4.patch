+    def _quantize_with_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes the image using as few colors as possible (up to ``colors``)
+        while keeping the mean square error against the original image at or
+        below ``error_threshold``. Falls back to ``colors`` colors if the
+        threshold cannot be reached.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        original = self.convert("RGB") if self.mode not in ("RGB", "L") else self
+
+        def quantize_to(num_colors):
+            candidate = self._new(self.im.quantize(num_colors, method, kmeans))
+            mode = candidate.im.getpalettemode()
+            candidate.palette = ImagePalette.ImagePalette(
+                mode, candidate.im.getpalette(mode, mode)
+            )
+            return candidate
+
+        def mean_square_error(candidate):
+            comparison = candidate.convert(original.mode)
+            diff = ImageChops.difference(original, comparison)
+            rms = ImageStat.Stat(diff).rms
+            return sum(value**2 for value in rms) / len(rms)
+
+        best_im = None
+        low, high = 2, colors
+        while low <= high:
+            mid = (low + high) // 2
+            candidate = quantize_to(mid)
+            if mean_square_error(candidate) <= error_threshold:
+                best_im = candidate
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_im is None:
+            best_im = quantize_to(colors)
+        return best_im
+
