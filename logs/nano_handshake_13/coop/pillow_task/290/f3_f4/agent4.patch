+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 256
+
+
+def test_quantize_error_threshold_none_uses_all_colors():
+    image = hopper()
+    converted = image.quantize(colors=4)
+    assert len(converted.getcolors()) == 4
+
+
+def test_quantize_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=4, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_high_uses_few_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
