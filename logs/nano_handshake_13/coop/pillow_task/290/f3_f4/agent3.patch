diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..da05b449d 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,47 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(sort_palette="not_a_real_method")
+
+
+def test_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 10)
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    used_colors = [color for color in colors if color != (0, 0, 0)]
+    assert used_colors == sorted(used_colors)
+
+
+def test_sort_palette_luminance():
+    image = hopper()
+    converted = image.quantize(sort_palette="luminance")
+    assert_image(converted, "P", converted.size)
+    assert_image_similar(converted.convert("RGB"), image, 10)
+
+    def luminance(color):
+        r, g, b = color
+        return 0.299 * r + 0.587 * g + 0.114 * b
+
+    palette = converted.getpalette()
+    colors = [tuple(palette[i : i + 3]) for i in range(0, len(palette), 3)]
+    used_colors = [color for color in colors if color != (0, 0, 0)]
+    assert used_colors == sorted(used_colors, key=luminance)
+
+
+def test_sort_palette_preserves_appearance():
+    image = hopper()
+    unsorted = image.quantize()
+    sorted_luminance = image.quantize(sort_palette="luminance")
+    sorted_rgb = image.quantize(sort_palette="rgb")
+
+    assert_image_similar(unsorted.convert("RGB"), sorted_luminance.convert("RGB"), 0)
+    assert_image_similar(unsorted.convert("RGB"), sorted_rgb.convert("RGB"), 0)
