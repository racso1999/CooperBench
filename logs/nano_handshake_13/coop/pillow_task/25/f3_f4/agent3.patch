@@ -752,6 +752,35 @@ class TestImage:
 
         assert not os.path.exists(temp_file)
 
+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1))
+        im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1))
+        im.save(temp_file)
+        contents_before = temp_file.read_bytes()
+
+        im2 = Image.new("RGB", (2, 2))
+        im2.save(temp_file, dry_run=True)
+
+        assert temp_file.read_bytes() == contents_before
+
+    def test_dry_run_raises_for_invalid_save(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+
+        im = Image.new("RGB", (0, 0))
+        with pytest.raises(ValueError):
+            im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
