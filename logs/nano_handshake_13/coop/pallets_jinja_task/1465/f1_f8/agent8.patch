           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
         {% endfor %}</ul>
 
+    Pass ``with_counts=True`` to also get the number of items in each
+    group, without needing ``|list|length`` in the template. Each
+    result becomes a ``(grouper, list, count)`` tuple instead.
+
+    .. sourcecode:: jinja
+
+        <ul>{% for city, items, count in users|groupby("city", with_counts=True) %}
+          <li>{{ city }} ({{ count }})</li>
+        {% endfor %}</ul>
+
+    .. versionchanged:: 3.2
+        Added the ``with_counts`` parameter.
+
     .. versionchanged:: 3.0
         Added the ``default`` parameter.
 
@@ -1210,10 +1224,20 @@ def sync_do_groupby(
         The attribute supports dot notation for nested access.
     """
     expr = make_attrgetter(environment, attribute, default=default)
-    return [
-        _GroupTuple(key, list(values))
-        for key, values in groupby(sorted(value, key=expr), expr)
-    ]
+
+    if not with_counts:
+        return [
+            _GroupTuple(key, list(values))
+            for key, values in groupby(sorted(value, key=expr), expr)
+        ]
+
+    out = []
+
+    for key, values in groupby(sorted(value, key=expr), expr):
+        values = list(values)
+        out.append((key, values, len(values)))
+
+    return out
 
 
