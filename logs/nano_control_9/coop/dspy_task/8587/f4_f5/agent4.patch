+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the listener has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system, independent of `receive()`, so that a stalled
+        upstream (which stops sending chunks entirely) can still be detected and terminated deterministically.
+
+        Args:
+            now_ts: The current timestamp to compare against the timestamp of the last received chunk. Defaults to
+                the current time if not provided.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream had started but not ended, and no chunk has been
+            received for at least `idle_timeout_s` seconds. Otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+        if now_ts - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if hasattr(response, "is_last_chunk"):
+            # `is_last_chunk` may be introduced by a separate feature; if present, mark this as the final chunk.
+            response.is_last_chunk = True
+
+        # Reset the listener state unconditionally, regardless of `allow_reuse`, so it isn't left stuck in a
+        # started state after the timeout.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        on_chunk = getattr(self, "on_chunk", None)
+        if on_chunk is not None:
+            # `on_chunk` may be supported elsewhere as a callback; invoke it for this timeout-induced chunk too.
+            on_chunk(response)
+
+        return response
+
