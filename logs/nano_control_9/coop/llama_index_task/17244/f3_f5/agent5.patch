+    def get_image_mimetype(self) -> str | None:
+        """Lazily resolve and cache the image's mimetype.
+
+        If the mimetype has already been set, the cached value is returned
+        without guessing again. Otherwise, the mimetype is guessed from the
+        (base64-encoded) image bytes and cached on the instance for future
+        accesses.
+        """
