@@ -235,6 +235,23 @@ class TestImage:
             with pytest.raises(ValueError):
                 im.save(temp_file)
 
+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+        with hopper() as im:
+            im.save(temp_file, dry_run=True)
+        assert not temp_file.exists()
+
+        # A dry run should still validate that the image can be saved
+        with Image.new("RGBA", (1, 1)) as im:
+            with pytest.raises(OSError):
+                im.save(temp_file, format="JPEG", dry_run=True)
+
+        # dry_run should also work when passed a file object
+        with hopper() as im, temp_file.open("wb"):
+            with temp_file.open("r+b") as fp:
+                im.save(fp, format="PNG", dry_run=True)
+            assert temp_file.stat().st_size == 0
+
     def test_internals(self) -> None:
         im = Image.new("L", (100, 100))
         im.readonly = 1
