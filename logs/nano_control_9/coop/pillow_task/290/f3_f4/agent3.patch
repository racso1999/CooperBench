+
+    def _sort_palette(self, sort_palette):
+        """
+        Reorders this image's palette, remapping pixel data to match, using
+        the method given by ``sort_palette``. See :py:meth:`~PIL.Image.Image.quantize`
+        for the accepted values of ``sort_palette``.
+        """
+        mode = self.palette.mode
+        mode_len = len(mode)
+        palette = self.palette.palette
+        colors = [
+            tuple(palette[i : i + mode_len])
+            for i in range(0, len(palette), mode_len)
+        ]
+
+        # Only the palette entries actually referenced by pixel data should be
+        # reordered. The remaining (unused) entries are left untouched.
+        used_indices = sorted({index for _, index in self.getcolors(maxcolors=256)})
+
+        if sort_palette == "brightness":
+
+            def sort_key(color):
+                r, g, b = (color + (0, 0, 0))[:3]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "rgb":
+
+            def sort_key(color):
+                return color[:3]
+
+        elif callable(sort_palette):
+            sort_key = sort_palette
+        else:
+            raise ValueError(
+                "sort_palette must be 'brightness', 'rgb', or a callable"
+            )
+
+        order = sorted(used_indices, key=lambda i: sort_key(colors[i]))
+
+        mapping = list(range(256))
+        new_palette_data = bytearray(palette)
+        for new_index, old_index in zip(used_indices, order):
+            mapping[old_index] = new_index
+            new_palette_data[
+                new_index * mode_len : (new_index + 1) * mode_len
+            ] = colors[old_index]
+
+        im = self.point(mapping)
+        im.putpalette(bytes(new_palette_data), mode)
         return im
 
