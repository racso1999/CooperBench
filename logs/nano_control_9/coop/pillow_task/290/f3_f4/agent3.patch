diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..787b39b89 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,59 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _get_used_palette_colors(im):
+    mode_len = len(im.palette.mode)
+    palette = im.palette.palette
+    used_indices = sorted({index for _, index in im.getcolors(maxcolors=256)})
+    return [
+        tuple(palette[i * mode_len : (i + 1) * mode_len]) for i in used_indices
+    ]
+
+
+def test_quantize_sort_palette_brightness():
+    image = hopper()
+    converted = image.quantize(8, Image.MEDIANCUT, sort_palette="brightness")
+    assert_image(converted, "P", converted.size)
+
+    def brightness(color):
+        r, g, b = color
+        return r * 299 + g * 587 + b * 114
+
+    colors = _get_used_palette_colors(converted)
+    assert colors == sorted(colors, key=brightness)
+
+    # The visual result should be unaffected by reordering the palette.
+    unsorted = image.quantize(8, Image.MEDIANCUT)
+    assert list(converted.convert("RGB").getdata()) == list(
+        unsorted.convert("RGB").getdata()
+    )
+
+
+def test_quantize_sort_palette_rgb():
+    image = hopper()
+    converted = image.quantize(8, Image.MEDIANCUT, sort_palette="rgb")
+    assert_image(converted, "P", converted.size)
+
+    colors = _get_used_palette_colors(converted)
+    assert colors == sorted(colors)
+
+
+def test_quantize_sort_palette_callable():
+    image = hopper()
+
+    def key(color):
+        return -sum(color[:3])
+
+    converted = image.quantize(8, Image.MEDIANCUT, sort_palette=key)
+    assert_image(converted, "P", converted.size)
+
+    colors = _get_used_palette_colors(converted)
+    assert colors == sorted(colors, key=key)
+
+
+def test_quantize_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(8, Image.MEDIANCUT, sort_palette="unknown")
