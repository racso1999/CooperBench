+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Performs a binary search for the smallest number of colors, up to
+        ``colors``, whose quantized result has a mean square error at or
+        below ``error_threshold``. If no such number of colors is found,
+        ``colors`` is used.
+        """
+        from . import ImageChops, ImageStat
+
+        def mean_square_error(quantized):
+            diff = ImageChops.difference(self, quantized.convert(self.mode))
+            stat = ImageStat.Stat(diff)
+            pixel_count = diff.size[0] * diff.size[1]
+            if pixel_count == 0 or not stat.sum2:
+                return 0
+            return sum(stat.sum2) / (pixel_count * len(stat.sum2))
+
+        low, high = 2, colors
+        best_im = None
+        while low <= high:
+            mid = (low + high) // 2
+            trial_im = self._new(self.im.quantize(mid, method, kmeans))
+            if mean_square_error(trial_im) <= error_threshold:
+                best_im = trial_im
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_im is None:
+            best_im = self._new(self.im.quantize(colors, method, kmeans))
+        return best_im
+
