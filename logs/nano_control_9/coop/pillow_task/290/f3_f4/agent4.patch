+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,54 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _mean_square_error(im, converted):
+    from PIL import ImageChops, ImageStat
+
+    diff = ImageChops.difference(im, converted.convert(im.mode))
+    stat = ImageStat.Stat(diff)
+    pixel_count = diff.size[0] * diff.size[1]
+    return sum(stat.sum2) / (pixel_count * len(stat.sum2))
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    threshold = 200
+    converted = image.quantize(colors=256, error_threshold=threshold)
+    assert_image(converted, "P", converted.size)
+    assert _mean_square_error(image, converted) <= threshold
+    assert len(converted.getcolors()) <= 256
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+
+    high_threshold = image.quantize(colors=256, error_threshold=10000)
+    default = image.quantize(colors=256)
+
+    assert len(high_threshold.getcolors()) <= len(default.getcolors())
+
+
+def test_quantize_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+
+    converted = image.quantize(colors=8, error_threshold=0)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 8
+
+
+def test_quantize_error_threshold_with_palette_raises():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
+
+def test_quantize_error_threshold_negative_raises():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
