+# Registry of filters that should be made available to all prompt templates,
+# without having to pass them explicitly every time.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is automatically available in every prompt
+    template, whether created with `Prompt.from_str`, `Prompt.from_file` or
+    the `prompt` decorator.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be accessible in templates
+        (e.g. `{{ text | name }}`).
+    func
+        The callable to use as the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered filter.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove. Does nothing if no filter was
+        registered under that name.
+
+    """
+    _FILTERS.pop(name, None)
+
 
