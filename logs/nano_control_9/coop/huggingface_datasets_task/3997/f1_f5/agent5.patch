+def _deep_merge_dicts(target: dict, source: dict):
+    """Recursively merge ``source`` into ``target`` in place, merging nested dicts instead of overwriting them."""
+    for key, value in source.items():
+        if key in target and isinstance(target[key], dict) and isinstance(value, dict):
+            _deep_merge_dicts(target[key], value)
+        else:
+            target[key] = value
+
