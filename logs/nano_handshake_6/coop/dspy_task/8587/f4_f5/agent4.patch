+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has been idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system (independently of `receive()`) so that a
+        stalled upstream that stops sending chunks doesn't leave the consumer waiting forever. If the stream
+        has started but not ended, and no chunk has arrived within `idle_timeout_s`, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination and resets the listener state so it isn't
+        left stuck in a started state, regardless of `allow_reuse`.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()` if not provided, this is
+                mainly for testing purposes.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if "is_last_chunk" in getattr(StreamResponse, "__dataclass_fields__", {}):
+            response.is_last_chunk = True
+
+        # Reset the listener state unconditionally so it doesn't remain stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self._last_chunk_ts = None
+
+        return response
+
 
