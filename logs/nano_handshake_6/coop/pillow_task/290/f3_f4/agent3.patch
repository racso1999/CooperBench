diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..1c024c07c 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,35 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+@pytest.mark.parametrize("sort_palette", ("luminance", "RGB"))
+def test_sort_palette(sort_palette):
+    image = hopper()
+    converted = image.quantize(32, sort_palette=sort_palette)
+    unsorted = image.quantize(32)
+
+    # Sorting the palette should not change the visible image
+    assert_image_similar(converted.convert("RGB"), unsorted.convert("RGB"), 1)
+
+    # But the palette order should differ from the unsorted quantization
+    assert converted.palette.palette != unsorted.palette.palette
+
+
+def test_sort_palette_luminance_order():
+    image = hopper()
+    converted = image.quantize(32, sort_palette="luminance")
+
+    def luminance(index):
+        r, g, b = converted.palette.palette[index * 3 : index * 3 + 3]
+        return r * 299 + g * 587 + b * 114
+
+    used_indices = sorted(count_index[1] for count_index in converted.getcolors())
+    luminances = [luminance(index) for index in used_indices]
+    assert luminances == sorted(luminances)
+
+
+def test_sort_palette_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(32, sort_palette="invalid")
