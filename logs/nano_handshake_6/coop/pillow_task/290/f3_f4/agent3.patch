+    def _sort_palette_colors(self, sort_palette):
+        channels = len(self.palette.mode)
+        palette = self.palette.palette
+        colors = [palette[i : i + channels] for i in range(0, len(palette), channels)]
+
+        if sort_palette == "luminance":
+
+            def sort_key(color):
+                r, g, b = color[0], color[1], color[2]
+                return r * 299 + g * 587 + b * 114
+
+        elif sort_palette == "RGB":
+
+            def sort_key(color):
+                return tuple(color)
+
+        else:
+            raise ValueError("sort_palette must be one of None, 'luminance' or 'RGB'")
+
+        order = sorted(range(len(colors)), key=lambda i: sort_key(colors[i]))
+        new_index_by_old_index = {old: new for new, old in enumerate(order)}
+        lut = [new_index_by_old_index.get(i, i) for i in range(256)]
