diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..dd0109499 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,28 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold_uses_fewer_colors():
+    image = hopper()
+    default = image.quantize(colors=256)
+    thresholded = image.quantize(colors=256, error_threshold=200)
+
+    assert_image(thresholded, "P", thresholded.size)
+    assert len(thresholded.getcolors()) < len(default.getcolors())
+
+
+def test_quantize_error_threshold_unreachable_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=32, error_threshold=0)
+
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) == 32
+
+
+def test_quantize_error_threshold_none_matches_default_behavior():
+    image = hopper()
+    default = image.quantize(colors=64)
+    explicit_none = image.quantize(colors=64, error_threshold=None)
+
+    assert default.tobytes() == explicit_none.tobytes()
