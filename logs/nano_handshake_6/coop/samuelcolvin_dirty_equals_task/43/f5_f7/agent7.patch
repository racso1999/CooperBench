+HASH_LENGTHS = {
+    'md5': 32,
+    'sha1': 40,
+    'sha224': 56,
+    'sha256': 64,
+    'sha384': 96,
+    'sha512': 128,
+}
+
+
+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash-like string for a given hash algorithm.
+    """
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The hash algorithm to validate against, one of `'md5'`, `'sha1'`, `'sha224'`, `'sha256'`,
+                `'sha384'` or `'sha512'` (case-insensitive).
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert hashlib.md5(b'apple').hexdigest() == IsHash('md5')
+        assert hashlib.sha1(b'apple').hexdigest() == IsHash('sha1')
+        assert hashlib.sha256(b'apple').hexdigest() == IsHash('sha256')
+        assert 'not_a_hash' != IsHash('md5')
+        ```
+        """
+        try:
+            self.length = HASH_LENGTHS[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}, must be one of {sorted(HASH_LENGTHS)}')
+        self.algorithm = algorithm
+        self.hash_regex = re.compile(f'^[0-9a-f]{{{self.length}}}$', re.IGNORECASE)
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        return isinstance(other, str) and self.hash_regex.fullmatch(other) is not None
