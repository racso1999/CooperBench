+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has been idle for longer than `idle_timeout_s` and, if so, terminate it.
+
+        This should be called periodically by the streaming system, since the listener itself has no way to
+        notice the passage of time between calls to `receive()`.
+
+        Args:
+            now_ts: The current timestamp to check against, mainly for testing purposes. Defaults to `time.time()`.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the stream timed out, `None` otherwise.
+        """
+        if self.idle_timeout_s is None or self._last_chunk_ts is None:
+            return None
+
+        if not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        if hasattr(response, "is_last_chunk"):
+            response.is_last_chunk = True
+
+        # Reset the listener state unconditionally, otherwise it would be left stuck in a started state.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
