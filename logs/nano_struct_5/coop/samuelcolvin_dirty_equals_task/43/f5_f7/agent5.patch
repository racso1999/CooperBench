+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's format.
+    """
+
+    # national/international patterns for countries with dedicated support
+    _country_patterns = {
+        'US': {
+            'national': re.compile(r'^\d{10}$'),
+            'international': re.compile(r'^\+1\d{10}$'),
+        },
+        'GB': {
+            'national': re.compile(r'^0\d{9,10}$'),
+            'international': re.compile(r'^\+44\d{9,10}$'),
+        },
+    }
+    # generic international pattern, "+" followed by 7-15 digits (country code + subscriber number)
+    _generic_international_pattern = re.compile(r'^\+\d{7,15}$')
+    # loose pattern used when no country is specified, accepts national or international looking numbers
+    _default_pattern = re.compile(r'^\+?\d{7,15}$')
+    # characters which are just formatting/delimiters and can be stripped before validation
+    _delimiters_re = re.compile(r'[\s\-.()]')
+
+    def __init__(self, country: Optional[str] = None):
+        """
+        Args:
+            country: ISO 3166-1 alpha-2 country code to validate the phone number against, if omitted, any
+                reasonably formatted phone number is accepted.
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert 123 != IsPhoneNumber
+        ```
+        """
+        self.country = country.upper() if country else None
+        super().__init__(plain_repr('*') if country is None else country)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = self._delimiters_re.sub('', other)
+        if not cleaned:
+            return False
+
+        if self.country is None:
+            return bool(self._default_pattern.fullmatch(cleaned))
+
+        patterns = self._country_patterns.get(self.country)
+        if patterns is None:
+            return bool(self._generic_international_pattern.fullmatch(cleaned))
+
+        return bool(patterns['national'].fullmatch(cleaned)) or bool(patterns['international'].fullmatch(cleaned))
+
