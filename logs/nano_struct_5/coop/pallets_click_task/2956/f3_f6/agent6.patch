+    def resolve_dynamic_default(self, ctx: Context) -> None:
+        """Resolve a dynamic default: a mapping of other options' full
+        declarations (e.g. ``"--protocol"``) to a dictionary of
+        ``{value: default}`` pairs. This is called once all parameters
+        for the command have been parsed, so that the values of the
+        options it depends on are available.
+
+        Only takes effect if this option's value source is
+        :attr:`ParameterSource.DEFAULT`, i.e. no value was given on the
+        command line, in the environment, or in a default map. If none
+        of the mappings match, the value is left as ``None``.
+
+        .. versionadded:: 8.3
+        """
+        if not isinstance(self.default, dict):
+            return
+
+        if ctx.get_parameter_source(self.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+            return
+
+        resolved = None
+
+        for decl, mapping in self.default.items():
+            source_param: Option | None = None
+
+            for param in ctx.command.params:
+                if isinstance(param, Option) and (
+                    decl in param.opts or decl in param.secondary_opts
+                ):
+                    source_param = param
+                    break
+
+            if source_param is None or source_param.name is None:
+                continue
+
+            source_value = str(ctx.params.get(source_param.name))
+
+            if source_value in mapping:
+                resolved = mapping[source_value]
+
+        if resolved is not None:
+            ctx.params[self.name] = self.type_cast_value(ctx, resolved)  # type: ignore[arg-type]
+
