+    def _sort_palette_colors(self, sort_palette):
+        """
+        Reorders this "P"-mode image's palette using ``sort_palette``,
+        remapping pixel indexes so the rendered image is unchanged.
+
+        :param sort_palette: ``"brightness"`` or ``"rgb"``. See
+           :py:meth:`~PIL.Image.Image.quantize`.
+        :returns: A new :py:class:`~PIL.Image.Image` object.
+        """
+        from . import ImagePalette
+
+        mode = self.palette.mode
+        mode_len = len(mode)
+        palette_data = self.palette.palette
+        num_colors = len(palette_data) // mode_len
+        colors = [
+            tuple(palette_data[i * mode_len : (i + 1) * mode_len])
+            for i in range(num_colors)
+        ]
+
+        if sort_palette == "brightness":
+
+            def sort_key(i):
+                r, g, b = colors[i][:3]
+                return 0.299 * r + 0.587 * g + 0.114 * b
+
+        elif sort_palette == "rgb":
+
+            def sort_key(i):
+                return colors[i]
+
+        else:
+            msg = f"Unknown sort_palette method: {sort_palette}"
+            raise ValueError(msg)
+
+        dest_map = sorted(range(num_colors), key=sort_key)
+
+        new_positions = [0] * num_colors
+        new_palette = bytearray()
+        for new_index, old_index in enumerate(dest_map):
+            new_positions[old_index] = new_index
+            new_palette += bytes(colors[old_index])
+
+        # Leverage the convert mechanism to remap pixel values: encode the
+        # old->new index mapping as a grayscale palette, convert through
+        # "L" mode so the C code rewrites the pixel bytes, then attach the
+        # reordered color palette.
+        mapping_palette = bytearray(new_positions)
+
+        m_im = self.copy()
+        m_im.mode = "P"
+        m_im.palette = ImagePalette.ImagePalette("RGB", palette=mapping_palette * 3)
+        m_im.im.putpalette("RGB;L", m_im.palette.tobytes())
+
+        m_im = m_im.convert("L")
+        m_im.putpalette(new_palette, mode)
+
+        return m_im
+
