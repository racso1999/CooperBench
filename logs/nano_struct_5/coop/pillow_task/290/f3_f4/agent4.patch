@@ -85,3 +85,23 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A high threshold should be easily satisfied, using few colors.
+    lenient = image.quantize(colors=256, error_threshold=1000)
+    assert len(lenient.getcolors()) <= 256
+
+    # A very low threshold cannot be satisfied even with the maximum
+    # number of allowed colors, so all of them should be used.
+    strict = image.quantize(colors=32, error_threshold=0.0001)
+    full = image.quantize(colors=32)
+    assert len(strict.getcolors()) == len(full.getcolors())
+
+
+def test_quantize_error_threshold_with_palette():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(palette=hopper("P"), error_threshold=10)
