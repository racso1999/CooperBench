@@ -11,6 +11,41 @@ from typing import Any, Callable, Dict, Optional, Type, cast
 import jinja2
 import pydantic
 
+# Global registry of custom filters that are made available to every
+# prompt template, in addition to the filters built into `outlines`.
+_FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is available in every prompt template
+    (via `{{ value | name }}`) without having to be passed explicitly.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable that implements the filter.
+
+    """
+    _FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered custom Jinja2 filter.
+
+    Does nothing if no filter is registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    _FILTERS.pop(name, None)
+
 
