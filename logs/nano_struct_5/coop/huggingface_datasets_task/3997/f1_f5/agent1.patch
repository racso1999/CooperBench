+def keep_features_dicts_synced(func):
+    """
+    Wrapper to keep the secondary dictionary, `_column_requires_decoding`, of the `Features` class in sync with the
+    main dictionary.
+
+    A regular dict subclass isn't enough since some `dict` methods (e.g. ``pop``, ``popitem``, ``setdefault`` and
+    ``clear``) don't go through ``__setitem__``/``__delitem__`` and would silently desync the two dictionaries.
+    Subclassing `UserDict` instead would fix this but comes with a performance cost and would be a breaking change,
+    so a decorator applied to the relevant `Features` methods is used instead.
+    """
+
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        if args:
+            self: "Features" = args[0]
+            args = args[1:]
+        else:
+            self: "Features" = kwargs.pop("self")
+        out = func(self, *args, **kwargs)
+        assert hasattr(self, "_column_requires_decoding")
+        self._column_requires_decoding = {col: require_decoding(feature) for col, feature in self.items()}
+        return out
+
+    wrapper._decorator_name_ = "_keep_dicts_synced"
+    return wrapper
+
+
