+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Second-pass resolution for options whose ``default`` is a
+        dictionary mapping other options' values to a default value.
+
+        This runs after every parameter has consumed its value from the
+        command line, environment variables, and ``default_map``, so
+        that dynamic defaults are computed from the final values of the
+        options they depend on. Only options whose value still comes
+        from :attr:`ParameterSource.DEFAULT` are eligible for resolution.
+
+        .. versionadded:: 8.3
+        """
+        for param in self.get_params(ctx):
+            if (
+                not isinstance(param, Option)
+                or param._dynamic_default is None
+                or ctx.get_parameter_source(param.name)  # type: ignore[arg-type]
+                is not ParameterSource.DEFAULT
+            ):
+                continue
+
+            resolved = param._resolve_dynamic_default(ctx)
+
+            if resolved is None:
+                continue
+
+            value = param.process_value(ctx, resolved)
+
+            if param.expose_value:
+                ctx.params[param.name] = value  # type: ignore[index]
+
