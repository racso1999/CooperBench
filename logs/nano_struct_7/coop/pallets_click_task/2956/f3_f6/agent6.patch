+    def _resolve_dynamic_default(self, ctx: Context) -> t.Any | None:
+        """Resolve a dictionary-based dynamic default by looking at the
+        current values of the referenced options in ``ctx.params``.
+
+        .. versionadded:: 8.3
+        """
+        assert self._dynamic_default is not None
+        opt_to_param = {
+            opt: param
+            for param in ctx.command.get_params(ctx)
+            for opt in (*param.opts, *param.secondary_opts)
+        }
+
+        value: t.Any | None = None
+
+        for source_opt, mapping in self._dynamic_default.items():
+            source_param = opt_to_param.get(source_opt)
+
+            if source_param is None:
+                continue
+
+            source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+            key = str(source_value)
+
+            if key in mapping:
+                value = mapping[key]
+
+        return value
+
