+def test_quantize_error_threshold():
+    image = hopper()
+
+    # A very high error threshold should be satisfied with very few colors
+    converted = image.quantize(colors=256, error_threshold=10000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) < 256
+
+    # A very low error threshold cannot be met, so the color limit is used
+    converted = image.quantize(colors=4, error_threshold=0.001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors()) <= 4
+
+
+def test_quantize_error_threshold_invalid():
+    image = hopper()
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=0)
+
+    with pytest.raises(ValueError):
+        image.quantize(error_threshold=-1)
+
+
+def test_quantize_error_threshold_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
+
