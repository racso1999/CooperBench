+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as base_im:
+        assert base_im.size == (2, 1)
+        assert base_im.getexif()[0x0112] == 8
+
+        # A callback returning a single method overrides the default mapping.
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+
+            def single_method(orientation: int) -> Image.Transpose:
+                assert orientation == 8
+                return Image.Transpose.FLIP_LEFT_RIGHT
+
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=single_method
+            )
+            assert transposed_im.size == (2, 1)
+            assert_image_equal(transposed_im, base_im.transpose(Image.Transpose.FLIP_LEFT_RIGHT))
+            assert 0x0112 not in transposed_im.getexif()
+
+        # A callback returning a sequence of methods applies them in order.
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+
+            def multiple_methods(orientation: int) -> list[Image.Transpose]:
+                return [Image.Transpose.ROTATE_90, Image.Transpose.FLIP_TOP_BOTTOM]
+
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=multiple_methods
+            )
+            expected = base_im.transpose(Image.Transpose.ROTATE_90).transpose(
+                Image.Transpose.FLIP_TOP_BOTTOM
+            )
+            assert_image_equal(transposed_im, expected)
+            assert 0x0112 not in transposed_im.getexif()
+
+        # A callback returning None applies no transformation, and the
+        # orientation tag is left untouched, matching the behavior when no
+        # method is found in the default mapping.
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            transposed_im = ImageOps.exif_transpose(
+                im, transform_callback=lambda orientation: None
+            )
+            assert transposed_im.size == (2, 1)
+            assert_image_equal(transposed_im, base_im)
+            assert 0x0112 in transposed_im.getexif()
+
+        # in_place also respects the callback.
+        with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+            ImageOps.exif_transpose(
+                im,
+                in_place=True,
+                transform_callback=lambda orientation: [
+                    Image.Transpose.ROTATE_90,
+                    Image.Transpose.FLIP_TOP_BOTTOM,
+                ],
+            )
+            expected = base_im.transpose(Image.Transpose.ROTATE_90).transpose(
+                Image.Transpose.FLIP_TOP_BOTTOM
+            )
+            assert_image_equal(im, expected)
+            assert 0x0112 not in im.getexif()
+
+
