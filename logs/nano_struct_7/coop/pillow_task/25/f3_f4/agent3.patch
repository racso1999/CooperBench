+    def test_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "red")
+        im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_dry_run_existing_file_not_written(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (10, 10), "red")
+        im.save(temp_file)
+        original_contents = temp_file.read_bytes()
+
+        other_im = Image.new("RGB", (20, 20), "blue")
+        other_im.save(temp_file, dry_run=True)
+
+        assert temp_file.read_bytes() == original_contents
+
+    def test_dry_run_fp(self) -> None:
+        im = Image.new("RGB", (10, 10), "red")
+        buf = io.BytesIO()
+        im.save(buf, format="PNG", dry_run=True)
+
+        assert buf.tell() == 0
+
+    def test_dry_run_error(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "out.jpg"
+
+        im = Image.new("RGBA", (10, 10))
+        with pytest.raises(OSError):
+            im.save(temp_file, format="JPEG", dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
