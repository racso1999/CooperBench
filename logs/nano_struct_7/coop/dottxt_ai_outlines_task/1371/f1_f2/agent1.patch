+def create_jinja_env(
+    loader: Optional[jinja2.BaseLoader] = None,
+    filters: Optional[Dict[str, Callable]] = None,
+) -> jinja2.Environment:
+    """Create a `jinja2.Environment` configured for rendering prompt templates.
+
+    This centralizes the environment settings and built-in filter
+    registration used by `Prompt.from_str` and `Prompt.from_file`, and
+    allows registering additional custom filters.
+
+    Parameters
+    ----------
+    loader
+        An optional Jinja2 loader, used for instance to load templates from
+        a file.
+    filters
+        An optional dictionary mapping filter names to callables. These are
+        registered in addition to (and may override) the built-in filters.
+
+    Returns
+    -------
+    A configured `jinja2.Environment` instance.
+
+    """
+    env = jinja2.Environment(
+        loader=loader,
+        trim_blocks=True,
+        lstrip_blocks=True,
+        keep_trailing_newline=True,
+        undefined=jinja2.StrictUndefined,
+    )
+    env.filters["name"] = get_fn_name
+    env.filters["description"] = get_fn_description
+    env.filters["source"] = get_fn_source
+    env.filters["signature"] = get_fn_signature
+    env.filters["schema"] = get_schema
+    env.filters["args"] = get_fn_args
+
+    if filters is not None:
+        env.filters.update(filters)
+
+    return env
+
