+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve dictionary-based dynamic defaults for options once all
+        other parameters (from the command line, environment variables,
+        and the default map) have been parsed.
+
+        A dynamic default maps the value of one or more other options to
+        the default that should be used, e.g.
+        ``default={"--protocol": {"http": 80, "https": 443}}``. It is only
+        applied when the option's value still comes from its own static
+        default (i.e. no value was given on the command line, environment,
+        or default map). If multiple source options are given, later
+        entries take precedence over earlier ones when more than one of
+        them matches.
+        """
+        params = self.get_params(ctx)
+
+        def find_source(opt_name: str) -> Parameter | None:
+            for candidate in params:
+                if opt_name in candidate.opts or opt_name in candidate.secondary_opts:
+                    return candidate
+
+            return None
+
+        for param in params:
+            dynamic_default = getattr(param, "_dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for opt_name, mapping in dynamic_default.items():
+                source_param = find_source(opt_name)
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)  # type: ignore[arg-type]
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                value = param.process_value(ctx, resolved)
+
+                if param.expose_value:
+                    ctx.params[param.name] = value  # type: ignore[index]
+
