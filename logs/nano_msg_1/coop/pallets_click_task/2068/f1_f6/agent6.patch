+_PROCESS_PRIORITIES = ("low", "below_normal", "normal", "above_normal", "high")
+
+
+def _priority_popen_kwargs(process_priority: str | None) -> dict[str, t.Any]:
+    """Return extra ``subprocess.Popen`` kwargs that apply the requested
+    ``process_priority``, or an empty dict if it's unset, invalid, or not
+    supported on this platform.
+    """
+    if process_priority not in _PROCESS_PRIORITIES:
+        return {}
+
+    import subprocess
+
+    if WIN:
+        priority_classes = {
+            "low": subprocess.IDLE_PRIORITY_CLASS,
+            "below_normal": subprocess.BELOW_NORMAL_PRIORITY_CLASS,
+            "normal": subprocess.NORMAL_PRIORITY_CLASS,
+            "above_normal": subprocess.ABOVE_NORMAL_PRIORITY_CLASS,
+            "high": subprocess.HIGH_PRIORITY_CLASS,
+        }
+        return {"creationflags": priority_classes[process_priority]}
+
+    if not hasattr(os, "nice"):
+        return {}
+
+    nice_values = {
+        "low": 10,
+        "below_normal": 5,
+        "normal": 0,
+        "above_normal": -5,
+        "high": -10,
+    }
+    nice_value = nice_values[process_priority]
+
+    def _set_niceness() -> None:
+        try:
+            os.nice(nice_value)
+        except OSError:
+            # Raising a negative niceness typically requires elevated
+            # privileges. Fall back to the default priority instead of
+            # failing the edit operation.
+            pass
+
+    return {"preexec_fn": _set_niceness}
+
+
