+    def test_save_backup(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        im = Image.new("RGB", (1, 1), "#f00")
+        im.save(temp_file)
+        backup_file = tmp_path / "temp.png.bak"
+        assert not os.path.exists(backup_file)
+
+        # No backup is created if the file does not already exist
+        new_file = tmp_path / "new.png"
+        im.save(new_file, backup=True)
+        assert not os.path.exists(tmp_path / "new.png.bak")
+
+        # A backup is created of the original file before it is overwritten
+        im2 = Image.new("RGB", (1, 1), "#00f")
+        im2.save(temp_file, backup=True)
+        assert os.path.exists(backup_file)
+        with Image.open(backup_file) as backup_im:
+            assert backup_im.getpixel((0, 0)) == (255, 0, 0)
+        with Image.open(temp_file) as saved_im:
+            assert saved_im.getpixel((0, 0)) == (0, 0, 255)
+
+        # The backup suffix can be customized
+        custom_backup_file = tmp_path / "temp.png.backup"
+        im.save(temp_file, backup=True, backup_suffix=".backup")
+        assert os.path.exists(custom_backup_file)
+
