diff --git a/Tests/test_image_quantize.py b/Tests/test_image_quantize.py
index bd9db362c..56f2ae849 100644
--- a/Tests/test_image_quantize.py
+++ b/Tests/test_image_quantize.py
@@ -85,3 +85,71 @@ def test_transparent_colors_equal():
     converted = im.quantize()
     converted_px = converted.load()
     assert converted_px[0, 0] == converted_px[0, 1]
+
+
+def _quantize_test_image():
+    im = Image.new("RGB", (4, 4))
+    px = im.load()
+    colors = [(255, 0, 0), (0, 255, 0), (0, 0, 255), (255, 255, 255)]
+    for y in range(4):
+        for x in range(4):
+            px[x, y] = colors[(x + y) % len(colors)]
+    return im
+
+
+def _palette_colors(im):
+    palette = im.palette.palette
+    mode_len = len(im.palette.mode)
+    return [
+        tuple(palette[i : i + mode_len])
+        for i in range(0, len(palette), mode_len)
+    ]
+
+
+def test_quantize_sort_palette_luminance():
+    im = _quantize_test_image()
+    converted = im.quantize(4, Image.FASTOCTREE, sort_palette="luminance")
+
+    assert _palette_colors(converted) == [
+        (0, 0, 255),
+        (255, 0, 0),
+        (0, 255, 0),
+        (255, 255, 255),
+    ]
+
+
+def test_quantize_sort_palette_rgb():
+    im = _quantize_test_image()
+    converted = im.quantize(4, Image.FASTOCTREE, sort_palette="rgb")
+
+    assert _palette_colors(converted) == sorted(_palette_colors(converted))
+
+
+def test_quantize_sort_palette_callable():
+    im = _quantize_test_image()
+    converted = im.quantize(4, Image.FASTOCTREE, sort_palette=lambda c: -sum(c))
+
+    assert _palette_colors(converted) == [
+        (255, 255, 255),
+        (0, 0, 255),
+        (0, 255, 0),
+        (255, 0, 0),
+    ]
+
+
+def test_quantize_sort_palette_appearance_unchanged():
+    im = _quantize_test_image()
+    unsorted = im.quantize(4, Image.FASTOCTREE)
+    sorted_luminance = im.quantize(4, Image.FASTOCTREE, sort_palette="luminance")
+    sorted_rgb = im.quantize(4, Image.FASTOCTREE, sort_palette="rgb")
+
+    assert unsorted.convert("RGB").tobytes() == sorted_luminance.convert(
+        "RGB"
+    ).tobytes()
+    assert unsorted.convert("RGB").tobytes() == sorted_rgb.convert("RGB").tobytes()
+
+
+def test_quantize_sort_palette_invalid():
+    im = _quantize_test_image()
+    with pytest.raises(ValueError):
+        im.quantize(4, Image.FASTOCTREE, sort_palette="not-a-method")
