     assert dither.tobytes() != nodither.tobytes()
 
 
+def test_quantize_error_threshold():
+    image = hopper()
+
+    high_threshold = image.quantize(256, error_threshold=100000)
+    assert len(high_threshold.getcolors()) < 256
+
+    full_colors = image.quantize(256, error_threshold=0)
+    assert len(full_colors.getcolors()) == 256
+
+
+def test_quantize_error_threshold_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    with pytest.raises(ValueError):
+        image.quantize(palette=palette, error_threshold=10)
+
+
