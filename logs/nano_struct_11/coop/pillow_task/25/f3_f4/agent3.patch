+    def test_save_dry_run(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        with hopper() as im:
+            im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
+    def test_save_dry_run_existing_file_untouched(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.png"
+
+        with hopper() as im:
+            im.save(temp_file)
+        original_contents = temp_file.read_bytes()
+
+        with hopper("1") as im:
+            im.save(temp_file, dry_run=True)
+
+        assert temp_file.read_bytes() == original_contents
+
+    def test_save_dry_run_file_object(self) -> None:
+        fp = io.BytesIO()
+
+        with hopper() as im:
+            im.save(fp, format="PNG", dry_run=True)
+
+        assert fp.tell() == 0
+
+    def test_save_dry_run_raises_on_error(self, tmp_path: Path) -> None:
+        temp_file = tmp_path / "temp.jpg"
+
+        im = Image.new("RGB", (0, 0))
+        with pytest.raises(ValueError):
+            im.save(temp_file, dry_run=True)
+
+        assert not os.path.exists(temp_file)
+
