+    def _quantize_mse(self, quantized_im):
+        """
+        Calculates the mean square error between this image and a
+        quantized version of it, used by :py:meth:`~PIL.Image.Image.quantize`
+        to evaluate the ``error_threshold`` parameter.
+        """
+        from . import ImageChops, ImageStat
+
+        original_rgb = self.convert("RGB")
+        quantized_rgb = quantized_im.convert("RGB")
+        diff = ImageChops.difference(original_rgb, quantized_rgb)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Finds the smallest number of colors, up to ``colors``, that keeps the
+        mean square error of the quantized image at or below
+        ``error_threshold``. Falls back to using ``colors`` if the threshold
+        can't be met.
+        """
+        low, high = 1, colors
+        best_im = None
+        while low <= high:
+            mid = (low + high) // 2
+            candidate_im = self._new(self.im.quantize(mid, method, kmeans))
+            error = self._quantize_mse(candidate_im)
+            if error <= error_threshold:
+                best_im = candidate_im
+                high = mid - 1
+            else:
+                low = mid + 1
+
+        if best_im is None:
+            best_im = self._new(self.im.quantize(colors, method, kmeans))
+        return best_im
+
