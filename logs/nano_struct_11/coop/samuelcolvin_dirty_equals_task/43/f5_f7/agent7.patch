+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash, e.g. an appropriately formatted string, for the given hash type.
+    """
+
+    HASH_LENGTHS = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The hash algorithm used for validation. The following algorithms are supported:
+                md5, sha1, sha224, sha256, sha384, sha512
+
+        ```py title="IsHash"
+        from dirty_equals import IsHash
+
+        assert '9e107d9d372bb6826bd81d3542a419d6' == IsHash('md5')
+        assert 'aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d' == IsHash('sha1')
+        assert 'not a valid hash' != IsHash('sha1')
+        ```
+        """
+        self.algorithm = algorithm
+        try:
+            self.hash_length = self.HASH_LENGTHS[algorithm.lower()]
+        except KeyError:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        if len(other) != self.hash_length:
+            return False
+
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+
+        return True
+
