@@ -2,6 +2,7 @@ from __future__ import annotations
 
 import collections.abc as cabc
 import enum
+import itertools
 import os
 import stat
 import sys
@@ -27,6 +28,19 @@ if t.TYPE_CHECKING:
 ParamTypeValue = t.TypeVar("ParamTypeValue")
 
 
+def _batched(
+    iterable: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Group items from ``iterable`` into tuples of up to ``batch_size``
+    items each. The final batch may be shorter if the number of items
+    is not evenly divisible by ``batch_size``.
+    """
+    iterator = iter(iterable)
+
+    while batch := tuple(itertools.islice(iterator, batch_size)):
+        yield batch
+
