+    def _reset_state(self):
+        """Reset the listener's per-stream state so it is ready to observe a new stream."""
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self.stream_start = False
+        self._last_chunk_ts = None
+
+    def tick(self, now_ts: float | None = None) -> StreamResponse | None:
+        """Check whether the stream has gone idle for longer than `idle_timeout_s` and, if so, force-terminate it.
+
+        This should be called periodically by the streaming system, independent of `receive()`, so that a stalled
+        upstream (which stops sending chunks entirely) doesn't leave the listener stuck waiting forever.
+
+        Args:
+            now_ts: The current time (as returned by `time.time()`). Defaults to the current time.
+
+        Returns:
+            A `StreamResponse` with an empty `chunk` if the idle timeout has elapsed, otherwise `None`.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        last_chunk_ts = self._last_chunk_ts if self._last_chunk_ts is not None else now_ts
+        if now_ts - last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+        # Regardless of `allow_reuse`, the listener must not be left in a started state after timing out.
+        self._reset_state()
+        return response
