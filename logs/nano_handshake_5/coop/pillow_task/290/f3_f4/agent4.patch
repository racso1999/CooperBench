+def test_error_threshold_loose_uses_fewer_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=1000)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors(256)) < 256
+
+
+def test_error_threshold_tight_uses_max_colors():
+    image = hopper()
+    converted = image.quantize(colors=256, error_threshold=0.001)
+    assert_image(converted, "P", converted.size)
+    assert len(converted.getcolors(256)) == 256
+
+
+def test_error_threshold_lower_error_uses_more_colors():
+    image = hopper()
+    loose = image.quantize(colors=256, error_threshold=500)
+    tight = image.quantize(colors=256, error_threshold=50)
+    assert len(tight.getcolors(256)) >= len(loose.getcolors(256))
+
+
+def test_error_threshold_ignored_with_palette():
+    image = hopper()
+    with Image.open("Tests/images/caption_6_33_22.png") as palette:
+        palette = palette.convert("P")
+
+    converted = image.quantize(palette=palette, error_threshold=1)
+    assert_image(converted, "P", converted.size)
+    assert converted.palette.palette == palette.palette.palette
