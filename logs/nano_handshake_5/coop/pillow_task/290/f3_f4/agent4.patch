+    def _quantize_mse(self, quantized_im):
+        """
+        Returns the mean square error between this image and a quantized
+        version of it, comparing in RGB space.
+        """
+        from . import ImageChops, ImagePalette, ImageStat
+
+        mode = quantized_im.im.getpalettemode()
+        quantized_im.palette = ImagePalette.ImagePalette(
+            mode, quantized_im.im.getpalette(mode, mode)
+        )
+
+        original_rgb = self.convert("RGB")
+        quantized_rgb = quantized_im.convert("RGB")
+
+        diff = ImageChops.difference(original_rgb, quantized_rgb)
+        stat = ImageStat.Stat(diff)
+        return sum(rms**2 for rms in stat.rms) / len(stat.rms)
+
+    def _quantize_to_error_threshold(self, colors, method, kmeans, error_threshold):
+        """
+        Quantizes using as few colors as possible, up to ``colors``, while
+        keeping the mean square error against the original image at or below
+        ``error_threshold``. Falls back to ``colors`` if the threshold cannot
+        be met.
+        """
+        max_colors = max(2, colors)
+        best_im = self._new(self.im.quantize(max_colors, method, kmeans))
+
+        if self._quantize_mse(best_im) > error_threshold:
+            # Even the maximum allowed number of colors doesn't meet the
+            # threshold, so use the maximum allowed colors.
+            return best_im
+
+        # Binary search for the smallest number of colors that still meets
+        # the error threshold.
+        low, high = 2, max_colors
+        while low < high:
+            mid = (low + high) // 2
+            candidate_im = self._new(self.im.quantize(mid, method, kmeans))
+            if self._quantize_mse(candidate_im) <= error_threshold:
+                best_im = candidate_im
+                high = mid
+            else:
+                low = mid + 1
+
+        return best_im
+
