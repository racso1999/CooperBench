+class IsHash(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid hash of a given algorithm, currently supports `md5`, `sha1`,
+    `sha224`, `sha256`, `sha384`, `sha512`.
+    """
+
+    hash_lengths = {
+        'md5': 32,
+        'sha1': 40,
+        'sha224': 56,
+        'sha256': 64,
+        'sha384': 96,
+        'sha512': 128,
+    }
+
+    def __init__(self, algorithm: Literal['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']):
+        """
+        Args:
+            algorithm: The hash algorithm to check against, must be one of `md5`, `sha1`, `sha224`, `sha256`,
+                `sha384` or `sha512`.
+
+        ```py title="IsHash"
+        import hashlib
+        from dirty_equals import IsHash
+
+        assert 'd41d8cd98f00b204e9800998ecf8427e' == IsHash('md5')
+        assert hashlib.sha256(b'hello').hexdigest() == IsHash('sha256')
+        assert 'not-a-hash' != IsHash('sha256')
+        ```
+        """
+        algorithm_lower = algorithm.lower()
+        if algorithm_lower not in self.hash_lengths:
+            raise ValueError(f'Unknown hash algorithm {algorithm!r}')
+
+        self.algorithm = algorithm_lower
+        self.length = self.hash_lengths[algorithm_lower]
+        super().__init__(algorithm)
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+        if len(other) != self.length:
+            return False
+        try:
+            int(other, 16)
+        except ValueError:
+            return False
+        return True
+
