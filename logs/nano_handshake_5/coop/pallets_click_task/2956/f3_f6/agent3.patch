diff --git a/src/click/types.py b/src/click/types.py
index 684cb3b..03f12c5 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -1125,6 +1125,16 @@ def convert_type(ty: t.Any | None, default: t.Any | None = None) -> ParamType:
     return FuncParamType(ty)
 
 
+def _batched(
+    values: cabc.Sequence[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Split ``values`` into consecutive chunks of at most ``batch_size``
+    items each.
+    """
+    for i in range(0, len(values), batch_size):
+        yield tuple(values[i : i + batch_size])
+
