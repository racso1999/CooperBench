+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve parameters whose ``default`` is a dynamic default
+        mapping (a ``dict`` of ``{option_name: {value: default}}``),
+        once every parameter has been parsed.
+
+        A dynamic default only takes effect if the parameter's value
+        was not otherwise supplied, i.e. its source is still
+        :attr:`ParameterSource.DEFAULT`. When several source options
+        are listed, later entries take precedence over earlier ones.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            if not isinstance(param.default, dict):
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for source_opt, mapping in param.default.items():
+                source_param = next(
+                    (
+                        p
+                        for p in params
+                        if source_opt in p.opts or source_opt in p.secondary_opts
+                    ),
+                    None,
+                )
+
+                if source_param is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+
+                if source_value is not None and str(source_value) in mapping:
+                    resolved = mapping[str(source_value)]
+
+            ctx.params[param.name] = resolved  # type: ignore[index]
+
