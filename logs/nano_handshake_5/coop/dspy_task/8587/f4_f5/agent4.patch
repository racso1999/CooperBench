+    def tick(self, now_ts: float | None = None):
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system (independent of chunk arrival) so that a
+        backend stall, which produces no more chunks at all, can still be detected. If the configured timeout has
+        elapsed since the last chunk was received while the stream is in progress, this emits a final
+        `StreamResponse` with an empty `chunk` to signal termination and resets the listener's state.
+
+        Args:
+            now_ts: The current timestamp to check against. Defaults to `time.time()`.
+        """
+        if self.idle_timeout_s is None:
+            return None
+
+        if not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        current_ts = now_ts if now_ts is not None else time.time()
+        if current_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response_kwargs = {}
+        if "is_last_chunk" in getattr(StreamResponse, "__dataclass_fields__", {}):
+            response_kwargs["is_last_chunk"] = True
+        response = StreamResponse(self.predict_name, self.signature_field_name, "", **response_kwargs)
+
+        # Reset the listener state unconditionally (even if `allow_reuse` is False) so that a timed-out stream
+        # doesn't leave the listener stuck thinking a stream is still in progress.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
+
