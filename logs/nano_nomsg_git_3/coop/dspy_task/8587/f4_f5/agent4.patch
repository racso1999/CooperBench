+    def tick(self, now_ts: float | None = None):
+        """Check whether the stream has gone idle for longer than `idle_timeout_s`.
+
+        This should be called periodically by the streaming system. If the field has started streaming but hasn't
+        ended, and no chunk has arrived within `idle_timeout_s`, it emits a final empty-chunk `StreamResponse` to
+        signal termination and resets the listener's state so it doesn't stay stuck in a started state.
+        """
+        if self.idle_timeout_s is None or not self.stream_start or self.stream_end or self._last_chunk_ts is None:
+            return None
+
+        now_ts = now_ts if now_ts is not None else time.time()
+        if now_ts - self._last_chunk_ts < self.idle_timeout_s:
+            return None
+
+        response = StreamResponse(self.predict_name, self.signature_field_name, "")
+
+        # Reset the state unconditionally so the listener isn't left stuck in a started state, regardless of
+        # `allow_reuse`.
+        self.stream_start = False
+        self.stream_end = False
+        self.cache_hit = False
+        self.field_start_queue = []
+        self.field_end_queue = Queue()
+        self._last_chunk_ts = None
+
+        return response
