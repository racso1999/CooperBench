-    def quantize(self, colors=256, method=None, kmeans=0, palette=None, dither=1):
+    def _quantize_mse(self, quantized_im):
+        """
+        Computes the mean square error between this image and a quantized
+        version of it, across all bands.
+        """
+        from . import ImageChops
+
+        comparable = quantized_im.convert(self.mode)
+        diff = ImageChops.difference(self, comparable)
+        histogram = diff.histogram()
+
+        bands = len(self.getbands())
+        bins_per_band = len(histogram) // bands
+        num_values = self.size[0] * self.size[1] * bands
+
+        squared_error = 0
+        for band in range(bands):
+            band_histogram = histogram[
+                band * bins_per_band : (band + 1) * bins_per_band
+            ]
+            squared_error += sum(
+                value * value * count for value, count in enumerate(band_histogram)
+            )
+        return squared_error / num_values
+
+    def quantize(
+        self,
+        colors=256,
+        method=None,
+        kmeans=0,
+        palette=None,
+        dither=1,
+        error_threshold=None,
+    ):
         """
         Convert the image to 'P' mode with the specified number
         of colors.
@@ -1073,6 +1106,13 @@ class Image:
