@@ -470,6 +470,67 @@ def test_exif_transpose_in_place() -> None:
         assert_image_equal(im, expected)
 
 
+def test_exif_transpose_transform_callback() -> None:
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        assert im.size == (2, 1)
+        assert im.getexif()[0x0112] == 8
+        expected = im.transpose(Image.Transpose.FLIP_LEFT_RIGHT)
+
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: Image.Transpose.FLIP_LEFT_RIGHT
+        )
+        assert 0x0112 not in transposed_im.getexif()
+        assert_image_equal(transposed_im, expected)
+
+    # A sequence of methods
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        expected = im.rotate(90, expand=True).rotate(90, expand=True)
+
+        transposed_im = ImageOps.exif_transpose(
+            im,
+            transform_callback=lambda orientation: (
+                Image.Transpose.ROTATE_90,
+                Image.Transpose.ROTATE_90,
+            ),
+        )
+        assert 0x0112 not in transposed_im.getexif()
+        assert_image_equal(transposed_im, expected)
+
+    # Returning None should mean no transposition is applied,
+    # and the orientation tag is left as-is, consistent with an
+    # unrecognized orientation value
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        transposed_im = ImageOps.exif_transpose(
+            im, transform_callback=lambda orientation: None
+        )
+        assert transposed_im.size == im.size
+        assert transposed_im.getexif()[0x0112] == 8
+
+    # The callback receives the orientation value
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        seen_orientations = []
+
+        def callback(orientation: int) -> Image.Transpose:
+            seen_orientations.append(orientation)
+            return Image.Transpose.FLIP_LEFT_RIGHT
+
+        ImageOps.exif_transpose(im, transform_callback=callback)
+        assert seen_orientations == [8]
+
+    # in_place with a callback
+    with Image.open("Tests/images/orientation_rectangle.jpg") as im:
+        expected = im.rotate(90, expand=True)
+
+        ImageOps.exif_transpose(
+            im,
+            in_place=True,
+            transform_callback=lambda orientation: Image.Transpose.ROTATE_90,
+        )
+        assert im.size == (1, 2)
+        assert 0x0112 not in im.getexif()
+        assert_image_equal(im, expected)
+
+
