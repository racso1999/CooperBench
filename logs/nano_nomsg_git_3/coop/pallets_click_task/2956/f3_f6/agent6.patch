+    def _resolve_dynamic_defaults(self, ctx: Context) -> None:
+        """Resolve ``dict``-based dynamic defaults now that every
+        parameter has an initial value in ``ctx.params``.
+
+        A dynamic default maps the string form of another option's
+        declaration (e.g. ``"--protocol"``) to a ``{value: default}``
+        mapping. It only takes effect if the target parameter's value
+        still comes from :attr:`ParameterSource.DEFAULT`. Later entries
+        take precedence when multiple source options are given.
+        """
+        params = self.get_params(ctx)
+
+        for param in params:
+            dynamic_default = getattr(param, "dynamic_default", None)
+
+            if not dynamic_default:
+                continue
+
+            if ctx.get_parameter_source(param.name) is not ParameterSource.DEFAULT:  # type: ignore[arg-type]
+                continue
+
+            resolved = None
+
+            for opt, mapping in dynamic_default.items():
+                source_param = next(
+                    (p for p in params if opt in p.opts or opt in p.secondary_opts),
+                    None,
+                )
+
+                if source_param is None or source_param.name is None:
+                    continue
+
+                source_value = ctx.params.get(source_param.name)
+                key = str(source_value)
+
+                if key in mapping:
+                    resolved = mapping[key]
+
+            if resolved is not None:
+                if param.callback is not None:
+                    resolved = param.callback(ctx, param, resolved)
+
+                ctx.params[param.name] = resolved  # type: ignore[index]
+
