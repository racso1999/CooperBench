index 684cb3b..bd78c4b 100644
--- a/src/click/types.py
+++ b/src/click/types.py
@@ -2,6 +2,7 @@ from __future__ import annotations
 
 import collections.abc as cabc
 import enum
+import itertools
 import os
 import stat
 import sys
@@ -1125,6 +1126,23 @@ def convert_type(ty: t.Any | None, default: t.Any | None = None) -> ParamType:
     return FuncParamType(ty)
 
 
+def _batch_iterable(
+    iterable: cabc.Iterable[t.Any], batch_size: int
+) -> cabc.Iterator[tuple[t.Any, ...]]:
+    """Yield successive batches of up to ``batch_size`` items from
+    ``iterable``.
+    """
+    it = iter(iterable)
+
+    while True:
+        batch = tuple(itertools.islice(it, batch_size))
+
+        if not batch:
+            return
+
+        yield batch
+
+
