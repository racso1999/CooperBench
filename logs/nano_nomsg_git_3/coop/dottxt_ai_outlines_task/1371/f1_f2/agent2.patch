+# Registry of filters that are made available to every prompt template,
+# without having to pass them explicitly. See `register_filter` and
+# `unregister_filter`.
+FILTERS: Dict[str, Callable] = {}
+
+
+def register_filter(name: str, func: Callable) -> None:
+    """Register a custom Jinja2 filter globally.
+
+    Once registered, the filter is available in every prompt template
+    (built with `outlines.prompt`, `Prompt.from_str` or `Prompt.from_file`)
+    under the given name, e.g. `{{ text | name }}`.
+
+    Parameters
+    ----------
+    name
+        The name under which the filter will be available in templates.
+    func
+        The callable implementing the filter.
+
+    """
+    FILTERS[name] = func
+
+
+def unregister_filter(name: str) -> None:
+    """Remove a globally registered custom Jinja2 filter.
+
+    Does nothing if no filter was registered under `name`.
+
+    Parameters
+    ----------
+    name
+        The name of the filter to remove.
+
+    """
+    FILTERS.pop(name, None)
+
 
