+class IsPhoneNumber(DirtyEquals[str]):
+    """
+    A class that checks if a value is a valid phone number, optionally restricted to a specific country's format.
+    """
+
+    # (national format, international format) regexes, matched against the number with all whitespace and
+    # common delimiters (`-`, `.`, `()`) stripped out.
+    _country_patterns: Dict[str, Tuple[str, str]] = {
+        'US': (r'\d{10}', r'\+1\d{10}'),
+        'GB': (r'0\d{9,10}', r'\+44\d{9,10}'),
+    }
+
+    def __init__(self, country_code: Optional[str] = None):
+        """
+        Args:
+            country_code: ISO 3166-1 alpha-2 country code, if provided, only phone numbers valid for that country
+                (in national or international format) are accepted. If omitted, a generic international/national
+                format is accepted. Countries without dedicated rules fall back to generic international
+                validation (a `+` followed by 7 to 15 digits).
+
+        ```py title="IsPhoneNumber"
+        from dirty_equals import IsPhoneNumber
+
+        assert '+1-555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber
+        assert '555-123-4567' == IsPhoneNumber('US')
+        assert '+1-555-123-4567' == IsPhoneNumber('US')
+        assert '020 7946 0958' == IsPhoneNumber('GB')
+        assert '+44 20 7946 0958' == IsPhoneNumber('GB')
+        assert '555-123-4567' != IsPhoneNumber('GB')
+        assert '020 7946 0958' != IsPhoneNumber('US')
+        assert 123 != IsPhoneNumber
+        ```
+        """
+        self.country_code = country_code
+        super().__init__(self.country_code or plain_repr('*'))
+
+    def equals(self, other: Any) -> bool:
+        if not isinstance(other, str):
+            return False
+
+        cleaned = re.sub(r'[\s\-.()]', '', other)
+        if not cleaned:
+            return False
+
+        if self.country_code is None:
+            return bool(re.fullmatch(r'\+?\d{7,15}', cleaned))
+
+        national_pattern, international_pattern = self._country_patterns.get(
+            self.country_code.upper(), (None, r'\+\d{7,15}')
+        )
+        if national_pattern is not None and re.fullmatch(national_pattern, cleaned):
+            return True
+        return bool(re.fullmatch(international_pattern, cleaned))
+
